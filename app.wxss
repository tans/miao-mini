/* 创意喵全局样式 - 引入weui基础样式库 */
@import 'styles/weui.wxss';

/* WeUI 主题色覆盖 - 使用weui默认颜色变量 */
page {
  --weui-THEME-color: #EF8802;
  --weui-BRAND-color: #EF8802;
}

/* 统一Primary按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, #ff9a1f 0%, #ef6c00 100%);
  color: #fff;
  border: none;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  line-height: 1.2;
}

.btn-primary:not(.btn-disabled):active {
  background: linear-gradient(135deg, #e88a10 0%, #d66000 100%);
}

.btn-primary.btn-disabled {
  background: #ccc;
  color: #fff;
}

/* 表单样式覆盖 */
.form-input,
.form-textarea {
  border-color: #e6e6e6;
}

.form-input:focus,
.form-textarea:focus {
  border-color: #EF8802;
  box-shadow: 0 0 0 2px rgba(239, 136, 2, 0.1);
}

/* 标签 */
.tag.video {
  background: #fff3e0;
  color: #EF8802;
}

/* 状态标签 */
.task-status.open,
.task-status.online,
.task-status.pending {
  background: #fff3e0;
  color: #EF8802;
}

.task-status.in-progress,
.task-status.submitted {
  background: #fff3e0;
  color: #ff9800;
}

.task-status.completed,
.task-status.passed {
  background: #e3f2fd;
  color: #2196f3;
}

.task-status.closed,
.task-status.cancelled {
  background: #f5f5f5;
  color: #999;
}

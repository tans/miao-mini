/* pages/video-proposals/index.wxss */
.proposals-container {
  padding-bottom: 20px;
}

.filter-tabs {
  display: flex;
  background: #fff;
  padding: 12px 16px;
  gap: 8px;
}

.filter-btn {
  padding: 6px 16px;
  border-radius: 16px;
  font-size: 13px;
  color: #666;
  background: #f0f0f0;
}

.filter-btn.active {
  background: #FF2442;
  color: #fff;
}

.proposal-card {
  margin: 8px 16px;
}

.task-label {
  font-size: 13px;
  color: #999;
  margin-bottom: 8px;
}

.proposal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.creator-info {
  display: flex;
  align-items: center;
  gap: 10px;
}

.avatar {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: #FF2442;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  font-weight: 600;
}

.creator-name {
  font-size: 14px;
  font-weight: 600;
  color: #333;
  display: block;
}

.submit-time {
  font-size: 12px;
  color: #999;
  display: block;
}

.proposal-status {
  font-size: 12px;
  padding: 2px 8px;
  border-radius: 4px;
}

.proposal-status.pending {
  background: #FFF3E0;
  color: #FF9800;
}

.proposal-status.completed {
  background: #E3F2FD;
  color: #2196F3;
}

.proposal-content {
  color: #666;
  font-size: 14px;
  display: block;
  margin: 12px 0;
}

.proposal-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.proposal-price {
  font-weight: 700;
  color: #FF2442;
  font-size: 16px;
}

.proposal-actions {
  display: flex;
  gap: 8px;
}

.btn {
  display: inline-block;
  padding: 8px 16px;
  border-radius: 6px;
  font-size: 13px;
  font-weight: 600;
  text-align: center;
  border: none;
}

.btn-primary {
  background: #FF2442;
  color: #fff;
}

.btn-secondary {
  background: #f0f0f0;
  color: #666;
}

.empty-state {
  text-align: center;
  padding: 80px 20px;
}

.empty-icon {
  font-size: 48px;
  display: block;
  margin-bottom: 16px;
}

.empty-desc {
  color: #999;
  font-size: 14px;
}

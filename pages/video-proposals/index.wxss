/* pages/video-proposals/index.wxss */
.proposals-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 20px;
}

.filter-tabs {
  display: flex;
  background: #fff;
  padding: 12px 16px;
  gap: 8px;
  position: sticky;
  top: 0;
  z-index: 10;
}

.filter-btn {
  padding: 6px 16px;
  border-radius: 16px;
  font-size: 13px;
  color: #999;
  background: #f0f0f0;
  transition: all 0.2s;
}

.filter-btn.active {
  background: #EF8802;
  color: #fff;
}

.proposal-card {
  background: #fff;
  border-radius: 8px;
  padding: 16px;
  margin: 8px 12px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.08);
}

.task-label {
  font-size: 12px;
  color: #999;
  margin-bottom: 10px;
  display: block;
}

.proposal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.creator-info {
  display: flex;
  align-items: center;
  gap: 10px;
}

.avatar {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: #EF8802;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  font-weight: 600;
}

.creator-name {
  font-size: 14px;
  font-weight: 600;
  color: #333;
  display: block;
}

.submit-time {
  font-size: 12px;
  color: #999;
  display: block;
  margin-top: 2px;
}

.proposal-status {
  font-size: 12px;
  padding: 2px 8px;
  border-radius: 4px;
}

.proposal-status.pending {
  color: #FF9800;
  border: 1px solid #FF9800;
  background: transparent;
}

.proposal-status.completed {
  color: #2196F3;
  border: 1px solid #2196F3;
  background: transparent;
}

.proposal-content {
  color: #666;
  font-size: 14px;
  display: block;
  margin-bottom: 12px;
  line-height: 1.6;
}

.proposal-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 12px;
  border-top: 1px solid #f0f0f0;
}

.proposal-price {
  font-weight: 700;
  color: #EF8802;
  font-size: 16px;
}

.proposal-actions {
  display: flex;
  gap: 8px;
}

.btn {
  display: inline-block;
  padding: 8px 16px;
  border-radius: 6px;
  font-size: 13px;
  font-weight: 600;
  text-align: center;
  border: none;
}

.btn-primary {
  background: #EF8802;
  color: #fff;
}

.btn-primary:not(.btn-disabled):active {
  background: #D66E00;
}

.btn-secondary {
  background: #f0f0f0;
  color: #666;
}

.empty-state {
  text-align: center;
  padding: 80px 20px;
}

.empty-icon {
  font-size: 48px;
  display: block;
  margin-bottom: 16px;
}

.empty-desc {
  color: #999;
  font-size: 14px;
}

<!--pages/video-proposals/index.wxml-->
<view class="proposals-container">
  <!-- 过滤器 -->
  <view class="filter-tabs">
    <view
      wx:for="{{filters}}"
      wx:key="key"
      class="filter-btn {{activeFilter === item.key ? 'active' : ''}}"
      data-filter="{{item.key}}"
      bindtap="switchFilter"
    >{{item.label}}</view>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{filteredClaims.length === 0}}" class="empty-state">
    <text class="empty-icon">📭</text>
    <text class="empty-desc">暂无提案</text>
  </view>

  <!-- 提案列表 - 使用 WeUI Panel 风格 -->
  <view class="proposals-list" wx:if="{{filteredClaims.length > 0}}">
    <view class="weui-panel" wx:for="{{filteredClaims}}" wx:key="id" wx:for-index="claimIndex">
      <!-- Panel Header -->
      <view class="weui-panel__hd">
        <text class="task-title">{{item.task_title || '任务'}}</text>
        <view class="status-badge status-{{item.statusClass}}">
          <text>{{item.statusText}}</text>
        </view>
      </view>

      <!-- Panel Body -->
      <view class="weui-panel__bd">
        <view class="weui-media-box weui-media-box_text">
          <!-- 创作者信息 -->
          <view class="info-row creator-row">
            <view class="creator-info">
              <view class="avatar">{{item.creatorInitial}}</view>
              <view class="creator-details">
                <text class="creator-name">{{item.creatorName}}</text>
                <text class="submit-time">{{item.displayDate || '未提交时间'}}</text>
              </view>
            </view>
            <text class="proposal-price">¥{{item.displayPrice}}</text>
          </view>

          <view class="proposal-preview">
            <view class="preview-row">
              <text class="preview-label">状态</text>
              <text class="preview-value preview-status">{{item.statusText}}</text>
            </view>
            <view class="preview-row">
              <text class="preview-label">提交时间</text>
              <text class="preview-value">{{item.displayDate || '--'}}</text>
            </view>
            <view class="preview-row">
              <text class="preview-label">提案报价</text>
              <text class="preview-value preview-price">¥{{item.displayPrice}}</text>
            </view>
          </view>

          <view wx:if="{{item.hasContent}}" class="proposal-content">
            <text class="content-label">提案内容</text>
            <text class="content-text">{{item.contentText}}</text>
          </view>

          <view wx:if="{{item.hasMaterials}}" class="proposal-content">
            <view class="content-header">
              <text class="content-label">作品素材</text>
              <text class="content-meta">图片 {{item.imageCount}} · 视频 {{item.videoCount}}</text>
            </view>

            <scroll-view
              wx:if="{{item.previewImages.length > 0}}"
              class="material-scroll"
              scroll-x
              enable-flex
            >
              <view class="material-row">
                <image
                  wx:for="{{item.previewImages}}"
                  wx:key="*this"
                  wx:for-item="imageUrl"
                  class="material-thumb"
                  src="{{imageUrl}}"
                  mode="aspectFill"
                  data-current="{{imageUrl}}"
                  data-claim-index="{{claimIndex}}"
                  bindtap="previewImages"
                />
              </view>
            </scroll-view>

            <view wx:if="{{item.previewVideos.length > 0}}" class="video-list">
              <video
                wx:for="{{item.previewVideos}}"
                wx:key="url"
                wx:for-item="videoItem"
                class="proposal-video"
                src="{{videoItem.url}}"
                poster="{{videoItem.poster}}"
                controls
                enable-play-gesture="{{true}}"
                show-center-play-btn="{{true}}"
              />
            </view>
          </view>

          <view wx:if="{{item.videoLink}}" class="proposal-content">
            <view class="content-header">
              <text class="content-label">视频链接</text>
              <text class="link-action" data-url="{{item.videoLink}}" bindtap="copyVideoLink">复制</text>
            </view>
            <text class="content-text">{{item.videoLink}}</text>
          </view>
        </view>
      </view>

      <!-- Panel Footer - 操作按钮 -->
      <view class="weui-panel__ft" wx:if="{{item.canReview}}">
        <view class="action-group">
          <button class="weui-btn weui-btn_mini weui-btn_default" data-claim-id="{{item.id}}" data-result="2" bindtap="reviewClaim">拒绝</button>
          <button class="weui-btn weui-btn_mini weui-btn_primary" data-claim-id="{{item.id}}" data-result="1" bindtap="reviewClaim">采纳</button>
        </view>
      </view>
    </view>
  </view>
</view>

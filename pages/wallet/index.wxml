<view class="wallet-container">
  <!-- 顶部状态栏 -->
  <view class="status-bar">
    <text class="status-time">9:41</text>
    <view class="status-icons">
      <view class="signal-icon"></view>
      <view class="wifi-icon"></view>
      <view class="battery-icon"></view>
    </view>
  </view>

  <!-- 标题栏 -->
  <view class="page-header">
    <view class="back-btn" bindtap="goBack">
      <image src="/assets/icons/back.png" class="back-icon" />
    </view>
    <text class="page-title">我的钱包</text>
    <view class="message-btn">
      <image src="/assets/icons/message.png" class="message-icon" />
    </view>
  </view>

  <!-- 余额区域 -->
  <view class="balance-section">
    <view class="balance-bg">
      <view class="balance-main">
        <text class="balance-label">总余额(元)</text>
        <view class="balance-amount-row">
          <text class="balance-yuan">¥</text>
          <text class="balance-value">{{balanceDisplay}}</text>
        </view>
      </view>
      <view class="balance-sub">
        <view class="balance-sub-item">
          <text class="sub-label">待解冻金额(元)</text>
          <text class="sub-value">{{frozenAmount}}</text>
        </view>
        <view class="balance-divider"></view>
        <view class="balance-sub-item">
          <text class="sub-label">可提现金额(元)</text>
          <text class="sub-value">{{withdrawableAmount}}</text>
        </view>
      </view>
    </view>
    <view class="balance-actions">
      <view class="action-btn" bindtap="goRecharge">
        <text>充值</text>
      </view>
      <view class="action-btn action-btn-outline" bindtap="goWithdraw">
        <text>提现</text>
      </view>
    </view>
  </view>

  <!-- 交易记录标签 -->
  <view class="tabs-section">
    <view class="tab-group">
      <text class="tab-item {{currentTab === 'all' ? 'active' : ''}}" data-tab="all" bindtap="switchTab">全部</text>
      <text class="tab-item {{currentTab === 'income' ? 'active' : ''}}" data-tab="income" bindtap="switchTab">收入</text>
      <text class="tab-item {{currentTab === 'expense' ? 'active' : ''}}" data-tab="expense" bindtap="switchTab">支出</text>
    </view>
    <view class="tab-indicator" style="left: {{tabIndicatorLeft}}"></view>
  </view>

  <!-- 交易记录列表 -->
  <view class="transactions-section">
    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{filteredTransactions.length === 0}}">
      <text class="empty-text">暂无交易记录</text>
    </view>

    <!-- 记录列表 -->
    <view class="transaction-list" wx:if="{{filteredTransactions.length > 0}}">
      <view class="transaction-item" wx:for="{{filteredTransactions}}" wx:key="id">
        <view class="trans-info">
          <text class="trans-type">{{item.type_text || '其他'}}</text>
          <text class="trans-time">{{item.created_at}}</text>
        </view>
        <view class="trans-amount-group">
          <view class="trans-amount-row">
            <text class="trans-sign {{item.amount >= 0 ? 'income' : 'expense'}}">{{item.amount >= 0 ? '+' : '-'}}</text>
            <text class="trans-value {{item.amount >= 0 ? 'income' : 'expense'}}">{{item.amountDisplay}}</text>
            <text class="trans-unit {{item.amount >= 0 ? 'income' : 'expense'}}">元</text>
          </view>
          <text class="trans-fee" wx:if="{{item.fee > 0}}">{{item.type_text}}手续费：{{item.fee}}元</text>
        </view>
      </view>
    </view>
  </view>
</view>
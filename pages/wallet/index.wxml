<view class="wallet-container">
  <!-- 余额区域 -->
  <view class="balance-section">
    <view class="balance-bg">
      <view class="balance-main">
        <text class="balance-label">总余额(元)</text>
        <view class="balance-amount-row">
          <text class="balance-yuan">¥</text>
          <text class="balance-value">{{balanceDisplay}}</text>
        </view>
      </view>
      <!-- <view class="balance-deco"></view> -->
    </view>
    <view class="balance-panel">
      <view class="balance-sub">
        <view class="balance-sub-item">
          <text class="sub-label">待解冻金额(元)</text>
          <text class="sub-value">{{frozenAmount}}</text>
        </view>
        <view class="balance-sub-item">
          <text class="sub-label">可提现金额(元)</text>
          <text class="sub-value">{{withdrawableAmount}}</text>
        </view>
      </view>
      <view class="balance-actions">
        <button class="action-btn action-btn-primary" bindtap="goRecharge" hover-class="none">充值</button>
        <button class="action-btn action-btn-outline" bindtap="goWithdraw" hover-class="none">提现</button>
      </view>
    </view>
  </view>

  <!-- 交易记录标签 -->
  <view class="tabs-section">
    <view class="tab-group">
      <view class="tab-item {{currentTab === 'all' ? 'active' : ''}}" data-tab="all" bindtap="switchTab">全部</view>
      <view class="tab-item {{currentTab === 'income' ? 'active' : ''}}" data-tab="income" bindtap="switchTab">收入</view>
      <view class="tab-item {{currentTab === 'expense' ? 'active' : ''}}" data-tab="expense" bindtap="switchTab">支出</view>
    </view>
  </view>

  <!-- 交易记录列表 -->
  <view class="transactions-section">
    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{filteredTransactions.length === 0}}">
      <text class="empty-text">暂无交易记录</text>
    </view>

    <!-- 记录列表 -->
    <view class="transaction-list" wx:if="{{filteredTransactions.length > 0}}">
      <view class="transaction-item" wx:for="{{filteredTransactions}}" wx:key="id">
        <view class="trans-info">
          <text class="trans-type">{{item.type_text || '其他'}}</text>
          <text class="trans-time">{{item.createdAtText}}</text>
        </view>
        <view class="trans-amount-group">
          <view class="trans-amount-row">
            <text class="trans-sign {{item.amount >= 0 ? 'income' : 'expense'}}">{{item.amount >= 0 ? '+' : '-'}}</text>
            <text class="trans-value {{item.amount >= 0 ? 'income' : 'expense'}}">{{item.amountDisplay}}</text>
            <text class="trans-unit {{item.amount >= 0 ? 'income' : 'expense'}}">元</text>
          </view>
          <text class="trans-fee" wx:if="{{item.fee > 0}}">{{item.fee_label}}：{{item.feeDisplay}}元</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 充值弹窗 -->
  <view wx:if="{{showRechargeModal}}" class="modal-mask" bindtap="closeRechargeModal"></view>
  <view wx:if="{{showRechargeModal}}" class="modal-container">
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">充值</text>
        <view class="modal-close" bindtap="closeRechargeModal">×</view>
      </view>
      <view class="modal-body">
        <input class="modal-input" type="number" placeholder="请输入金额" value="{{rechargeAmount}}" bindinput="onRechargeInput" />
        <text class="modal-tip">充值手续费为充值金额的<text style="color:#EF8802">10%</text>，实际到账金额将自动扣除手续费。</text>
      </view>
      <view class="modal-submit" bindtap="submitRecharge">确认充值</view>
    </view>
  </view>

  <!-- 充值成功弹窗 -->
  <view wx:if="{{showRechargeSuccessModal}}" class="modal-mask" bindtap="closeRechargeSuccessModal"></view>
  <view wx:if="{{showRechargeSuccessModal}}" class="modal-container">
    <view class="modal-content success-content">
      <text class="success-title">充值成功</text>
      <image class="success-icon" src="./images/success.png" />
      <!-- <image class="success-icon" src="/images/images/error.png" /> -->
      <text class="success-desc">充值已到账，您的当前余额是：<text class="success-amount">{{balanceDisplay}}</text></text>
      <view class="success-btn" bindtap="closeRechargeSuccessModal">我知道了</view>
    </view>
  </view>

  <!-- 提现弹窗 -->
  <view wx:if="{{showWithdrawModal}}" class="modal-mask" bindtap="closeWithdrawModal"></view>
  <view wx:if="{{showWithdrawModal}}" class="modal-container">
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">提现</text>
        <view class="modal-close" bindtap="closeWithdrawModal">×</view>
      </view>
      <view class="modal-body">
        <input class="modal-input" type="number" placeholder="请输入金额" value="{{withdrawAmount}}" bindinput="onWithdrawInput" />
        <text class="modal-tip">提现手续费为提现金额的<text style="color:#EF8802">10%</text>，实际到账金额将自动扣除手续费。</text>
      </view>
      <view class="modal-submit" bindtap="submitWithdraw">确认提现</view>
    </view>
  </view>

  <!-- 提现成功弹窗 -->
  <view wx:if="{{showWithdrawSuccessModal}}" class="modal-mask" bindtap="closeWithdrawSuccessModal"></view>
  <view wx:if="{{showWithdrawSuccessModal}}" class="modal-container">
    <view class="modal-content success-content">
      <text class="success-title">提现成功</text>
      <image class="success-icon" src="./images/success.png" />
      <text class="success-desc">
        本次提现¥{{withdrawResult.withdraw_amount || withdrawAmount}}，手续费¥{{withdrawResult.commission || '0.00'}}，实际到账¥{{withdrawResult.actual_amount || '0.00'}}。
      </text>
      <view class="success-btn" bindtap="closeWithdrawSuccessModal">我知道了</view>
    </view>
  </view>
</view>

.withdraw-container {
  min-height: 100vh;
  background: #fafafa;
}

/* 顶部导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 32rpx;
  background: #fff;
}

.nav-left {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
}

.nav-back {
  width: 40rpx;
  height: 40rpx;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
}

.nav-right {
  width: 40rpx;
}

/* 可提现余额 */
.balance-section {
  padding: 32rpx;
}

.balance-bg {
  background: linear-gradient(135deg, #ff9a1f 0%, #ef6c00 100%);
  border-radius: 16rpx;
  padding: 40rpx 32rpx;
}

.balance-main {
  text-align: center;
}

.balance-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.balance-amount-row {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 8rpx;
  margin-top: 12rpx;
}

.balance-yuan {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.balance-value {
  font-size: 64rpx;
  font-weight: 700;
  color: #fff;
  font-family: 'home-din-pro-700-bold';
  line-height: 1;
}

/* 实名认证提示 */
.verify-tip {
  display: flex;
  align-items: center;
  margin: 0 32rpx 24rpx;
  padding: 20rpx 24rpx;
  background: #fff7e6;
  border-radius: 12rpx;
}

.tip-icon {
  width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  background: #ff9a1f;
  color: #fff;
  border-radius: 50%;
  font-size: 24rpx;
  font-weight: 700;
  margin-right: 16rpx;
}

.tip-text {
  font-size: 26rpx;
  color: #666;
}

/* 提现金额输入 */
.amount-section {
  background: #fff;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 24rpx;
}

.input-wrapper {
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #eee;
  padding-bottom: 16rpx;
}

.input-yuan {
  font-size: 48rpx;
  font-weight: 700;
  color: #333;
  font-family: 'home-din-pro-700-bold';
  margin-right: 16rpx;
}

.input-field {
  flex: 1;
  font-size: 48rpx;
  font-weight: 700;
  color: #333;
  font-family: 'home-din-pro-700-bold';
  height: 64rpx;
  line-height: 64rpx;
}

.all-amount-btn {
  display: flex;
  justify-content: flex-end;
  margin-top: 24rpx;
}

.all-amount-text {
  font-size: 26rpx;
  color: #ef8802;
}

/* 错误提示 */
.error-tip {
  padding: 16rpx 32rpx;
}

.error-text {
  font-size: 26rpx;
  color: #f5222d;
}

/* 确认提现按钮 */
.submit-section {
  padding: 0 32rpx;
}

.submit-btn {
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #ff9a1f 0%, #ef6c00 100%);
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  text-align: center;
}

.submit-btn.loading {
  opacity: 0.6;
}

.submit-btn[disabled] {
  opacity: 0.6;
}

/* 注意事项 */
.notice-section {
  padding: 32rpx;
  margin-top: 24rpx;
}

.notice-title {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.notice-item {
  font-size: 24rpx;
  color: #999;
  line-height: 1.6;
  margin-bottom: 8rpx;
}

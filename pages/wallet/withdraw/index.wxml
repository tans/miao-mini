<view class="withdraw-container">
  <!-- 可提现余额 -->
  <view class="balance-section">
    <view class="balance-bg">
      <view class="balance-main">
        <text class="balance-label">可提现金额(元)</text>
        <text class="balance-value">¥{{withdrawableAmount}}</text>
      </view>
    </view>
  </view>

  <!-- 实名认证提示 -->
  <view class="verify-tip" wx:if="{{!realNameVerified}}">
    <text class="tip-icon">!</text>
    <text class="tip-text">首次提现需要先完成实名认证</text>
  </view>

  <!-- 提现金额输入 -->
  <view class="amount-section">
    <view class="section-title">提现金额</view>
    <view class="input-wrapper">
      <text class="input-yuan">¥</text>
      <input
        type="digit"
        class="input-field"
        placeholder="请输入提现金额"
        value="{{amount}}"
        bindinput="onAmountInput"
      />
    </view>
    <view class="all-amount-btn" bindtap="handleAllAmount">
      <text class="all-amount-text">全部提现</text>
    </view>
  </view>

  <!-- 错误提示 -->
  <view class="error-tip" wx:if="{{error}}">
    <text class="error-text">{{error}}</text>
  </view>

  <!-- 确认提现按钮 -->
  <view class="submit-section">
    <button class="submit-btn {{loading ? 'loading' : ''}}" bindtap="handleWithdraw" disabled="{{loading}}">
      <text wx:if="{{!loading}}">确认提现</text>
      <text wx:if="{{loading}}">提交中...</text>
    </button>
  </view>

  <!-- 注意事项 -->
  <view class="notice-section">
    <view class="notice-title">提现说明</view>
    <view class="notice-item">• 提现将扣除对应等级佣金比例</view>
    <view class="notice-item">• 提现申请提交后，T+1到账</view>
    <view class="notice-item">• 如有疑问请联系客服</view>
  </view>
</view>

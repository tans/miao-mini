.balance-panel {
  margin-top: 32rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
}

.balance-sub {
  display: flex;
  gap: 16rpx;
  justify-content: space-between;
}

.balance-sub-item {
  min-height: 96rpx;
  padding: 8rpx 0;
  gap: 10rpx;
  background: transparent;
  border-radius: 0;
  display: flex;
  flex-direction: column;
}

.sub-label {
  font-size: 22rpx;
  color: #9aa1b1;
  text-align: left;
  line-height: 1.2;
}

.sub-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
}

.balance-actions {
  display: flex;
  gap: 24rpx;
  padding: 20rpx 0 0;
}

.action-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 0;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.action-btn::after {
  border: none;
}

.action-btn-primary {
  color: #fff;
  background: #ff9f2f;
  box-shadow: none;
}

.action-btn-outline {
  color: #ef8802;
  background: #f4ede2;
  border: none;
  box-shadow: none;
}

/* 交易记录标签 */
.tabs-section {
  position: relative;
  background: #fff;
  padding: 0 32rpx;
  margin-top: 24rpx;
  border-radius: 16rpx 16rpx 0 0;
  width: 100%;
}

.tab-group {
  display: flex;
  gap: 48rpx;
  padding: 24rpx 0;
}

.tab-item {
  font-size: 28rpx;
  color: #999;
  font-weight: 500;
  padding-bottom: 8rpx;
}

.tab-item.active {
  color: #ef8802;
  font-weight: 700;
}

.tab-indicator {
  position: absolute;
  bottom: 0;
  width: 64rpx;
  height: 4rpx;
  background: #ef8802;
  border-radius: 2rpx;
  transition: left 0.3s ease;
}

/* 交易记录列表 */
.transactions-section {
  padding: 40rpx 24rpx;
  background: #FAFAFA;
  border-radius: 0 0 16rpx 16rpx;
  width: 100%;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.transaction-list {
  background: transparent;
  border-radius: 0;
  overflow: visible;
}

.transaction-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: none;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.trans-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.trans-type {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.trans-time {
  font-size: 24rpx;
  color: #8C8C98;
}

.trans-amount-group {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.trans-amount-row {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.trans-sign {
  font-size: 28rpx;
  font-weight: 600;
}

.trans-value {
  font-size: 32rpx;
  font-weight: 700;
}

.trans-unit {
  font-size: 22rpx;
}

.trans-sign.income, .trans-value.income, .trans-unit.income {
  color: #35B86B;
}

.trans-sign.expense, .trans-value.expense, .trans-unit.expense {
  color: #EF4444;
}

.trans-fee {
  font-size: 24rpx;
  color: #8C8C98;
}

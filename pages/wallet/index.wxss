.wallet-container {
  min-height: 100vh;
  background: #f3f3f3;
  box-sizing: border-box;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: center;
}

/* 顶部导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 32rpx;
  background: #fff;
}

.nav-left {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
}

.nav-back {
  width: 40rpx;
  height: 40rpx;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
}

.nav-right {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.nav-icon {
  width: 34rpx;
  height: 34rpx;
}

/* 余额区域 */
.balance-section {
  border-radius: 16rpx;
  overflow: hidden;
  width: 702rpx;
}

.balance-bg {
  background: url('https://public.jisuhudong.com/minapp/钱包背景图.png') no-repeat center center;
  background-size: 100% 100%;
  border-radius: 16rpx;
  position: relative;
  width: 702rpx;
  height: 240rpx;
  overflow: hidden;
}

.balance-main {
  text-align: left;
  position: relative;
  z-index: 1;
  margin: 48rpx 40rpx;
}

.balance-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255);
}

.balance-amount-row {
  display: flex;
  align-items: baseline;
  justify-content: flex-start;
  margin-top: 20rpx;
}

.balance-yuan {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
}

.balance-value {
  font-size: 64rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1;
}


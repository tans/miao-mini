.wallet-container {
  min-height: 100vh;
  background: #fafafa;
}

/* 顶部导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 32rpx;
  background: #fff;
}

.nav-left {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
}

.nav-back {
  width: 40rpx;
  height: 40rpx;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
}

.nav-right {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.nav-icon {
  width: 34rpx;
  height: 34rpx;
}

/* 余额区域 */
.balance-section {
  background: #fff;
  padding-bottom: 32rpx;
}

.balance-bg {
  background: linear-gradient(135deg, #ff9a1f 0%, #ef6c00 100%);
  padding: 40rpx 32rpx 32rpx;
}

.balance-main {
  text-align: center;
  margin-bottom: 24rpx;
}

.balance-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.balance-amount-row {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 8rpx;
  margin-top: 12rpx;
}

.balance-yuan {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.balance-value {
  font-size: 64rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1;
}

.balance-sub {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.balance-sub-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 116rpx;
  padding: 20rpx 12rpx;
  gap: 10rpx;
  background: rgba(255, 255, 255, 0.16);
  border-radius: 16rpx;
}

.sub-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  text-align: center;
  line-height: 1.2;
}

.sub-value {
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
}

.balance-sub-item-highlight {
  background: rgba(255, 255, 255, 0.22);
  border: 1rpx solid rgba(255, 255, 255, 0.22);
}

.balance-actions {
  display: flex;
  gap: 24rpx;
  padding: 32rpx 32rpx 0;
}

.action-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  background: #fff;
  border-radius: 40rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #ef6c00;
}

.action-btn-outline {
  background: transparent;
  border: 2rpx solid #ef6c00;
  color: #ef6c00;
}

/* 交易记录标签 */
.tabs-section {
  position: relative;
  background: #fff;
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.tab-group {
  display: flex;
  gap: 48rpx;
  padding: 24rpx 0;
}

.tab-item {
  font-size: 28rpx;
  color: #999;
  font-weight: 500;
  padding-bottom: 8rpx;
}

.tab-item.active {
  color: #333;
  font-weight: 700;
}

.tab-indicator {
  position: absolute;
  bottom: 0;
  width: 64rpx;
  height: 4rpx;
  background: linear-gradient(135deg, #ff9a1f 0%, #ef6c00 100%);
  border-radius: 2rpx;
  transition: left 0.3s ease;
}

/* 交易记录列表 */
.transactions-section {
  padding: 0 32rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.transaction-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.transaction-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.transaction-item:last-child {
  border-bottom: none;
}

.trans-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.trans-type {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.trans-time {
  font-size: 22rpx;
  color: #999;
}

.trans-amount-group {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.trans-amount-row {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.trans-sign {
  font-size: 28rpx;
  font-weight: 600;
}

.trans-value {
  font-size: 32rpx;
  font-weight: 700;
}

.trans-unit {
  font-size: 22rpx;
}

.trans-sign.income, .trans-value.income, .trans-unit.income {
  color: #52c41a;
}

.trans-sign.expense, .trans-value.expense, .trans-unit.expense {
  color: #333;
}

.trans-fee {
  font-size: 20rpx;
  color: #999;
}

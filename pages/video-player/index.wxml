<view class="preview-container">
  <view class="content-wrap">
    <view wx:if="{{loading}}" class="loading-wrap">
      <text>加载中...</text>
    </view>

    <block wx:elif="{{videoUrl}}">
      <view class="player-shell">
        <video
          id="videoPlayer"
          class="video-player"
          src="{{videoUrl}}"
          autoplay
          object-fit="contain"
          controls="{{false}}"
          show-play-btn="{{false}}"
          show-center-play-btn="{{false}}"
          show-fullscreen-btn="{{false}}"
          show-mute-btn="{{false}}"
          picture-in-picture-mode="{{[]}}"
          enable-progress-gesture="{{false}}"
          vslide-gesture="{{false}}"
          page-gesture="{{false}}"
          bindplay="onVideoPlay"
          bindpause="onVideoPause"
          bindended="onVideoEnded"
          bindtimeupdate="onTimeUpdate"
          bindloadedmetadata="onLoadedMetadata"
          bind:error="onVideoError"
        />
        <view class="control-bar">
          <text class="control-btn" bindtap="togglePlay">{{playing ? '暂停' : '播放'}}</text>
          <slider
            class="progress-slider"
            min="0"
            max="{{duration || 0}}"
            value="{{currentTime}}"
            activeColor="#ffffff"
            backgroundColor="rgba(255,255,255,0.25)"
            block-color="#ffffff"
            block-size="14"
            bindchanging="onSeekChanging"
            bindchange="onSeekChange"
          />
          <text class="time-text">{{currentTimeText}} / {{durationText}}</text>
        </view>
      </view>
    </block>

    <block wx:elif="{{processStatusText}}">
      <view class="empty-wrap">
        <text>{{processStatusText}}</text>
      </view>
    </block>

    <view wx:else class="empty-wrap">
      <text>暂无视频内容</text>
    </view>
  </view>
</view>

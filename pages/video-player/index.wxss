.preview-container {
  min-height: 100vh;
  width: 100%;
  background: #000;
  overflow: hidden;
}

.content-wrap {
  min-height: 100vh;
  width: 100%;
  display: block;
}

.player-shell {
  width: 100%;
  height: 100vh;
  background: #000;
  overflow: hidden;
}

.loading-wrap,
.empty-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  width: 100%;
  color: #999;
  font-size: 28rpx;
  background: #000;
}

.video-player {
  width: 100%;
  height: 100%;
  max-width: 100%;
  max-height: 100%;
  background: #000;
  display: block;
  object-fit: contain;
}

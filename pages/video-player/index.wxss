.preview-container {
  min-height: 100vh;
  background: #000;
  overflow: hidden;
}

.content-wrap {
  min-height: 100vh;
  display: block;
}

.player-shell {
  position: relative;
  width: 100vw;
  height: 100vh;
  background: #000;
  overflow: hidden;
}

.loading-wrap,
.empty-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  color: #999;
  font-size: 28rpx;
  background: #000;
}

.video-player {
  width: 100%;
  height: 100%;
  object-fit: cover;
  background: #000;
  display: block;
}

.control-bar {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 24rpx 28rpx;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.84), rgba(0, 0, 0, 0));
}

.control-btn {
  color: #fff;
  font-size: 26rpx;
  min-width: 56rpx;
}

.progress-slider {
  flex: 1;
  margin: 0;
}

.time-text {
  color: rgba(255,255,255,0.8);
  font-size: 22rpx;
  white-space: nowrap;
}

.image-list {
  padding: 20rpx;
}

.image-item {
  margin-bottom: 20rpx;
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
}

.preview-image {
  width: 100%;
  display: block;
}

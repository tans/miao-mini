.preview-container {
  min-height: 100vh;
  background: #000;
  overflow: hidden;
}

.content-wrap {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-wrap,
.empty-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  color: #999;
  font-size: 28rpx;
  background: #000;
}

.video-player {
  width: 100vw;
  height: 133.33vw;
  max-height: calc(100vh - 140rpx);
  min-height: 1000rpx;
  background: #000;
  display: block;
}

.image-list {
  padding: 20rpx;
}

.image-item {
  margin-bottom: 20rpx;
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
}

.preview-image {
  width: 100%;
  display: block;
}

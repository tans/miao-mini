.transactions-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 12px;
}

.transaction-list {
  background: #fff;
  border-radius: 8px;
  overflow: hidden;
}

.transaction-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px;
  border-bottom: 1px solid #f0f0f0;
}

.transaction-item:last-child {
  border-bottom: none;
}

.trans-left {
  display: flex;
  flex-direction: column;
}

.trans-type {
  font-size: 15px;
  color: #333;
  margin-bottom: 4px;
}

.trans-time {
  font-size: 12px;
  color: #999;
}

.trans-amount {
  font-size: 16px;
  font-weight: 600;
}

.trans-amount.income { color: #52c41a; }
.trans-amount.expense { color: #FF2442; }

.empty-state {
  text-align: center;
  padding: 60px 0;
  color: #999;
  font-size: 14px;
}

.loading-more {
  text-align: center;
  padding: 20px;
  color: #999;
  font-size: 14px;
}
<!--pages/register/index.wxml-->
<view class="register-container">
  <view class="register-header">
    <view class="logo">🐱</view>
    <view class="title">注册账号</view>
  </view>

  <view class="card register-form">
    <view class="form-group">
      <text class="form-label">用户名</text>
      <input
        class="form-input"
        type="text"
        placeholder="3-50位字母或数字"
        value="{{username}}"
        bindinput="onUsernameInput"
      />
    </view>
    <view class="form-group">
      <text class="form-label">手机号</text>
      <input
        class="form-input"
        type="tel"
        placeholder="输入手机号"
        value="{{phone}}"
        bindinput="onPhoneInput"
      />
    </view>
    <view class="form-group">
      <text class="form-label">密码</text>
      <input
        class="form-input"
        type="password"
        placeholder="至少6位密码"
        value="{{password}}"
        bindinput="onPasswordInput"
      />
    </view>
    <view class="form-group">
      <text class="form-label">注册身份</text>
      <view class="role-group">
        <view
          class="role-btn {{role === 'creator' ? 'active' : ''}}"
          data-role="creator"
          bindtap="selectRole"
        >
          <text class="role-icon">🎬</text>
          <text class="role-name">创作者</text>
          <text class="role-desc">接单赚取收益</text>
        </view>
        <view
          class="role-btn {{role === 'business' ? 'active' : ''}}"
          data-role="business"
          bindtap="selectRole"
        >
          <text class="role-icon">🏪</text>
          <text class="role-name">商家</text>
          <text class="role-desc">发布任务推广</text>
        </view>
      </view>
    </view>
    <button class="btn btn-primary btn-block" bindtap="handleRegister">注册</button>
  </view>

  <view class="login-link">
    <text>已有账号？</text>
    <text class="link" bindtap="goLogin">立即登录</text>
  </view>
</view>

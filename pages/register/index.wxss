/* pages/register/index.wxss */
.register-container {
  padding: 20px 16px;
}

.register-header {
  text-align: center;
  margin-bottom: 32px;
  padding-top: 40px;
}

.logo {
  font-size: 64px;
  margin-bottom: 8px;
}

.title {
  font-size: 22px;
  font-weight: 700;
  color: #333;
}

.register-form {
  padding: 24px;
}

.form-group {
  margin-bottom: 16px;
}

.form-label {
  display: block;
  font-size: 13px;
  color: #666;
  margin-bottom: 6px;
}

.form-input {
  width: 100%;
  padding: 10px 12px;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  font-size: 14px;
  box-sizing: border-box;
}

.btn-block {
  margin-top: 8px;
}

.btn-primary {
  background: #FF6B6B;
  color: #fff;
}

.login-link {
  text-align: center;
  margin-top: 20px;
  font-size: 14px;
  color: #999;
}

.link {
  color: #FF6B6B;
  font-weight: 600;
  margin-left: 4px;
}

.role-group {
  display: flex;
  gap: 12px;
}

.role-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16px 12px;
  border: 2px solid #e0e0e0;
  border-radius: 12px;
  background: #fff;
}

.role-btn.active {
  border-color: #FF6B6B;
  background: #FFF8F8;
}

.role-icon {
  font-size: 28px;
  margin-bottom: 6px;
}

.role-name {
  font-size: 15px;
  font-weight: 600;
  color: #333;
}

.role-desc {
  font-size: 12px;
  color: #999;
  margin-top: 2px;
}

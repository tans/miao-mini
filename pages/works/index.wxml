    <view class="sort-tabs">
      <text class="tab {{sort === 'latest' ? 'active' : ''}}" data-sort="latest" bindtap="switchSort">йЏ€в‚¬йЏ‚?</text>
      <text class="tab {{sort === 'likes' ? 'active' : ''}}" data-sort="likes" bindtap="switchSort">йЏ€в‚¬жѕ¶ж°±еЃЈз’§?</text>

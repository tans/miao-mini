<view class="works-container">
  <view class="works-header">
    <text class="works-title">鐏垫劅</text>
    <view class="sort-tabs">
      <text class="tab {{sort === 'latest' ? 'active' : ''}}" data-sort="latest" bindtap="switchSort">鏈€鏂?</text>
      <text class="tab {{sort === 'likes' ? 'active' : ''}}" data-sort="likes" bindtap="switchSort">鏈€澶氱偣璧?</text>
      <text class="tab {{sort === 'views' ? 'active' : ''}}" data-sort="views" bindtap="switchSort">鏈€澶氭祻瑙?</text>
    </view>
  </view>

  <mp-msg type="info" title="鏆傛棤鐏垫劅" wx:if="{{!loading && works.length === 0}}" />

  <view class="works-grid" wx:if="{{works.length > 0}}">
    <view class="work-card" wx:for="{{works}}" wx:key="id" bindtap="goWorkDetail" data-id="{{item.id}}">
      <view class="work-cover-wrap">
        <video wx:if="{{item.cover_type === 'video'}}" class="work-cover" src="{{item.cover_url || item.image}}" objectFit="cover" controls="{{false}}" muted></video>
        <image wx:else class="work-cover" src="{{item.cover_url || item.image}}" mode="aspectFill"/>
      </view>
      <view class="work-info">
        <text class="work-title">{{item.task_title || item.title}}</text>
        <view class="work-author">
          <image class="author-avatar" src="{{item.creator_avatar || '/assets/icons/avatar-default.jpg'}}"/>
          <text class="author-name">{{item.creator_name || '鍒涗綔鑰?'}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="loading-more" wx:if="{{loading}}">
    <mp-loading type="circle"></mp-loading>
    <text>鍔犺浇涓?..</text>
  </view>
</view>


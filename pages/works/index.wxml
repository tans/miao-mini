  <mp-msg type="info" title="йЏ†е‚›жЈ¤йђЏећ«еЉ…" wx:if="{{!loading && works.length === 0}}" />

  <view class="works-grid" wx:if="{{works.length > 0}}">
    <view class="work-card" wx:for="{{works}}" wx:key="id" bindtap="goWorkDetail" data-id="{{item.id}}">
      <view class="work-cover-wrap">
        <video wx:if="{{item.cover_type === 'video'}}" class="work-cover" src="{{item.cover_url || item.image}}" objectFit="cover" controls="{{false}}" muted></video>

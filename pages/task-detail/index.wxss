/* pages/task-detail/index.wxss */
.task-detail-container {
  min-height: 100vh;
  background: #fafafa;
  padding-bottom: 120rpx;
}

/* 标签切换 */
.tab-switch {
  display: flex;
  position: relative;
  padding: 0 48rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.tab-item {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #8c8c98;
}

.tab-item.active {
  color: #333;
}

.tab-indicator {
  position: absolute;
  bottom: 0;
  width: 104rpx;
  height: 6rpx;
  background: #ff9f2f;
  border-radius: 3rpx;
  transition: left 0.3s ease;
}

/* 标签内容 */
.tab-content {
  padding: 24rpx;
}

/* 视频占位 */
.video-placeholder {
  height: 420rpx;
  background: linear-gradient(160deg, #f1f3f8, #dde4ef);
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
}

.play-btn {
  width: 100rpx;
  height: 100rpx;
  background: rgba(255, 159, 47, 0.9);
  border-radius: 50%;
  position: relative;
}

.play-btn::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-40%, -50%);
  border-top: 20rpx solid transparent;
  border-bottom: 20rpx solid transparent;
  border-left: 32rpx solid #fff;
}

.video-hint {
  font-size: 26rpx;
  color: #666;
}

/* 任务ID卡片 */
.task-id-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(17, 17, 17, 0.04);
}

.id-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.id-label {
  font-size: 24rpx;
  color: #8c8c98;
}

.id-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.copy-btn {
  padding: 12rpx 32rpx;
  background: #ff9f2f;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 900;
  color: #fff;
}

/* 详情卡片 */
.detail-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(17, 17, 17, 0.04);
}

.detail-title {
  font-size: 32rpx;
  font-weight: 900;
  color: #333;
  margin-bottom: 24rpx;
}

/* 奖励行 */
.reward-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.reward-item {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.reward-label {
  font-size: 24rpx;
  color: #000;
}

.reward-value {
  font-size: 32rpx;
  font-weight: 900;
  color: #de872c;
}

.reward-unit {
  font-size: 24rpx;
  color: #000;
}

.reward-plus {
  font-size: 32rpx;
  color: #de872c;
}

/* 标签行 */
.tags-row {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.tag-group {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.tag-label {
  font-size: 24rpx;
  color: #8c8c98;
}

.tag-content {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 12rpx 16rpx;
}

.tag-value {
  font-size: 24rpx;
  font-weight: 900;
  color: #333;
}

/* 描述 */
.desc-section {
  padding: 24rpx 0;
  border-top: 1rpx solid #f0f0f0;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 24rpx;
}

.desc-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.7;
}

/* 规格行 */
.spec-row {
  display: flex;
  margin-bottom: 16rpx;
}

.spec-item {
  display: flex;
  gap: 12rpx;
}

.spec-label {
  font-size: 26rpx;
  color: #8c8c98;
}

.spec-value {
  font-size: 26rpx;
  color: #333;
}

/* 限制 */
.restriction-section {
  padding: 24rpx 0;
}

.restriction-text {
  font-size: 24rpx;
  color: #ef4444;
  line-height: 1.6;
}

/* 素材卡片 */
.material-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(17, 17, 17, 0.04);
}

.card-header {
  margin-bottom: 24rpx;
}

.header-title {
  font-size: 30rpx;
  font-weight: 900;
  color: #333;
}

.material-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.material-item {
  aspect-ratio: 1;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f5f5f5;
}

.material-thumb {
  width: 100%;
  height: 100%;
}

/* 即梦卡片 */
.jimeng-card {
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  margin-bottom: 24rpx;
}

.jimeng-content {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.jimeng-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.jimeng-name {
  font-size: 28rpx;
  font-weight: 900;
  color: #333;
}

.jimeng-desc {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

.jimeng-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  background: #fff;
}

.jimeng-link-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 16rpx;
}

.link-text {
  font-size: 22rpx;
  color: #2563eb;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.link-count {
  font-size: 22rpx;
  color: #8c8c98;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.jimeng-tutorial {
  font-size: 24rpx;
  color: #8c8c98;
  text-align: center;
  padding: 16rpx 0;
  border-top: 1rpx dashed #d4a574;
  margin-bottom: 16rpx;
}

.update-link-btn {
  text-align: center;
  padding: 16rpx;
  background: #fff;
  border-radius: 24rpx;
  font-size: 26rpx;
  font-weight: 900;
  color: #333;
}

/* 底部操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.08);
  display: flex;
  justify-content: center;
}

.claim-btn, .submit-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #ff9f2f 0%, #ef6c00 100%);
  border-radius: 44rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 900;
  color: #fff;
}

.claim-btn::after, .submit-btn::after {
  border: none;
}

.status-indicator {
  width: 100%;
  height: 88rpx;
  background: #f5f5f5;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.status-indicator.success {
  background: #d1fae5;
  color: #059669;
}

<!--pages/task-detail/index.wxml-->
<!-- Skeleton 加载状态 -->
<view class="skeleton-container" wx:if="{{loading}}">
  <view class="skeleton-header"></view>
  <view class="skeleton-section"></view>
  <view class="skeleton-section"></view>
  <view class="skeleton-section"></view>
</view>

<!-- 内容区域 -->
<view class="detail-container" wx:if="{{!loading && task}}">
  <!-- 任务头部 -->
  <view class="task-header-card">
    <view class="detail-title">{{task.title}}</view>
    <view class="detail-meta">
      <text>👤 {{task.business_name || '商家'}}</text>
      <text>📅 {{task.deadline ? task.deadline.substring(0, 10) : '不限'}}</text>
      <text class="task-status {{getStatusClass(task.status)}}">{{getStatusText(task.status)}}</text>
    </view>
  </view>

  <!-- 任务描述 -->
  <mp-cells title="任务描述">
    <mp-cell>
      <text class="detail-text">{{task.description || '暂无描述'}}</text>
    </mp-cell>
  </mp-cells>

  <!-- 预算 -->
  <mp-cells title="奖励说明">
    <mp-cell>
      <view class="budget-info">
        <view class="budget-row budget-row_highlight">
          <text class="budget-label">基础奖励</text>
          <text class="budget-value budget-highlight">¥{{task.unit_price}}/人 × {{task.total_count || 0}}人</text>
        </view>
        <view class="budget-row budget-row_highlight" wx:if="{{task.award_price > 0}}">
          <text class="budget-label">入围奖励</text>
          <text class="budget-value budget-highlight">¥{{task.award_price}}/人 × {{task.award_count || 0}}人</text>
        </view>
        <view class="budget-row budget-row_minor">
          <text class="budget-label">预计总费用</text>
          <text class="budget-value budget-total">¥{{task.total_budget || 0}}</text>
        </view>
        <view class="budget-row budget-row_minor" wx:if="{{task.paid_amount > 0}}">
          <text class="budget-label">已支付</text>
          <text class="budget-value paid">¥{{task.paid_amount || 0}}</text>
        </view>
      </view>
    </mp-cell>
  </mp-cells>

  <!-- 标签 -->
  <mp-cells title="标签" wx:if="{{task.industries.length > 0}}">
    <mp-cell>
      <view class="task-tags">
        <text wx:for="{{task.industries}}" wx:key="index" class="tag video">{{item}}</text>
      </view>
    </mp-cell>
  </mp-cells>

  <!-- 视频要求 -->
  <mp-cells title="视频要求" wx:if="{{task.video_duration}}">
    <mp-cell>
      <text class="detail-text">
        {{task.video_duration}}{{task.video_aspect ? ' | 尺寸: ' + task.video_aspect : ''}}{{task.video_resolution ? ' | 分辨率: ' + task.video_resolution : ''}}
      </text>
    </mp-cell>
  </mp-cells>

  <!-- 素材 -->
  <mp-cells title="任务素材" wx:if="{{materials.length > 0}}">
    <mp-cell wx:for="{{materials}}" wx:key="id">
      <view class="material-item">
        <image wx:if="{{item.file_type === 'image'}}" class="material-thumb" src="{{item.file_path}}" mode="aspectFill" bindtap="previewMaterial" data-url="{{item.file_path}}"/>
        <video wx:if="{{item.file_type === 'video'}}" class="material-video" src="{{item.file_path}}" controls/>
        <view class="material-info">
          <button class="weui-btn weui-btn_mini weui-btn_default material-download" data-url="{{item.file_path}}" data-name="{{item.file_name}}" bindtap="downloadMaterial">下载素材</button>
        </view>
      </view>
    </mp-cell>
  </mp-cells>

  <!-- 收到的提案 -->
  <view class="review-section" wx:if="{{isMyTask}}">
    <view class="section-header">
      <text class="section-title">收到的提案</text>
      <button class="btn-review" bindtap="goReviewProposals">审核投稿</button>
    </view>
  </view>
  <mp-cells title="提案列表" wx:if="{{isMyTask}}">
    <block wx:if="{{claims.length === 0}}">
      <mp-cell>
        <view class="empty-state">
          <text class="empty-desc">暂无提案</text>
        </view>
      </mp-cell>
    </block>
    <block wx:else>
      <mp-cell wx:for="{{claims}}" wx:key="id">
        <view class="proposal-card">
          <view class="proposal-header">
            <view class="creator-info">
              <view class="avatar-sm">{{item.creator_name ? item.creator_name[0] : '创'}}</view>
              <view>
                <text class="creator-name">{{item.creator_name || '匿名创作者'}}</text>
                <text class="proposal-status task-status {{item.status === 2 ? 'completed' : 'pending'}}">
                  {{getClaimStatusText(item.status)}}
                </text>
              </view>
            </view>
          </view>
          <text class="proposal-content">{{item.content || '暂无说明'}}</text>
          <view class="proposal-actions" wx:if="{{item.status === 2}}">
            <button class="weui-btn weui-btn_mini weui-btn_default" data-claim-id="{{item.id}}" data-result="0" bindtap="reviewClaim">拒绝</button>
            <button class="weui-btn weui-btn_mini weui-btn_primary" data-claim-id="{{item.id}}" data-result="1" bindtap="reviewClaim">采纳</button>
          </view>
        </view>
      </mp-cell>
    </block>
  </mp-cells>

  <!-- 接单按钮 -->
  <view class="action-bar" wx:if="{{canClaim || claimReason || hasClaimed}}">
    <!-- 已认领该任务，根据状态显示不同按钮 -->
    <button class="weui-btn weui-btn_primary weui-btn_block" bindtap="goSubmitWork" wx:if="{{hasClaimed && claimStatus === 1}}">提交作品</button>
    <button class="weui-btn weui-btn_default weui-btn_block" wx:if="{{hasClaimed && claimStatus === 2}}" disabled>待验收</button>
    <view class="weui-btn weui-btn_default weui-btn_block" wx:if="{{hasClaimed && claimStatus === 3}}">已完成</view>
    <view class="weui-btn weui-btn_default weui-btn_block" wx:if="{{hasClaimed && (claimStatus === 4 || claimStatus === 5)}}">已失效</view>
    <!-- 未认领，显示接单按钮或原因 -->
    <button class="weui-btn weui-btn_primary weui-btn_block" bindtap="claimTask" wx:if="{{!hasClaimed && canClaim}}">立即接单</button>
    <view class="claim-reason" wx:if="{{!canClaim && !hasClaimed && claimReason}}">{{claimReason}}</view>
  </view>
</view>

<!-- 空状态 - 仅在非加载且无任务时显示 -->
<mp-msg type="warn" title="暂无任务信息" wx:if="{{!loading && !task}}" />

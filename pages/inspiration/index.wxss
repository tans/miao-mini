.inspiration-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 32rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.nav-left, .nav-right {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
}

.nav-back {
  width: 40rpx;
  height: 40rpx;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 900;
  color: #333;
}

/* 分类标签 */
.category-section {
  background: #fff;
  padding: 16rpx 0;
}

.category-scroll {
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

.category-group {
  display: flex;
  gap: 32rpx;
  padding: 0 32rpx;
  white-space: nowrap;
}

.category-item {
  font-size: 28rpx;
  color: #666;
  padding-bottom: 8rpx;
  position: relative;
}

.category-item.active {
  color: #ef8802;
  font-weight: 700;
}

.category-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: #ef8802;
  border-radius: 2rpx;
}

/* 排序选项 */
.sort-section {
  background: #fff;
  padding: 0 32rpx 16rpx;
}

.sort-group {
  display: flex;
  gap: 16rpx;
}

.sort-item {
  padding: 12rpx 24rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #666;
}

.sort-item.active {
  background: #333;
  color: #fff;
}

/* 内容区域 */
.content-scroll {
  height: calc(100vh - 380rpx);
  padding: 24rpx;
}

/* 瀑布流网格 */
.masonry-grid {
  display: flex;
  gap: 24rpx;
}

.masonry-column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* 灵感卡片 */
.inspiration-card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(20, 42, 31, 0.08);
}

.card-image-wrap {
  position: relative;
  width: 100%;
}

.card-image {
  width: 100%;
  display: block;
}

.like-btn {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  background: rgba(0, 0, 0, 0.4);
  border-radius: 24rpx;
}

.like-icon {
  font-size: 28rpx;
  line-height: 1;
  color: #fff;
}

.like-count {
  font-size: 22rpx;
  color: #fff;
}

.card-info {
  padding: 20rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  line-height: 1.4;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.card-author {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.author-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
}

.author-name {
  font-size: 22rpx;
  color: #8c8c98;
}

/* 底部TabBar */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 96rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: space-around;
  border-top: 1rpx solid #f0f0f0;
  padding-bottom: env(safe-area-inset-bottom);
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.tab-icon {
  font-size: 48rpx;
  line-height: 1;
}

.tab-text {
  font-size: 20rpx;
  color: #999;
}

.tab-text.active {
  color: #ef8802;
}
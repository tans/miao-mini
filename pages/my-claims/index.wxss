.claims-container {
  min-height: 100vh;
  background: #f5f5f5;
}

.tabs {
  background: #fff;
  display: flex;
  padding: 12px 16px;
  gap: 20px;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab {
  font-size: 14px;
  color: #999;
  padding-bottom: 4px;
}

.tab.active {
  color: #EF8802;
  font-weight: 500;
  border-bottom: 2px solid #EF8802;
}

.claim-task-title {
  font-size: 15px;
  font-weight: 500;
  color: #333;
  position: relative;
  z-index: 1;
}

.title-row {
  display: flex;
  align-items: center;
  gap: 8px;
  position: relative;
  z-index: 1;
}

.watermark-badge {
  font-size: 10px;
  padding: 1px 6px;
  border-radius: 2px;
  border: 1px solid;
}

.watermark-1 {
  color: #ff4d4f;
  border-color: #ff4d4f;
  opacity: 0.6;
}

.watermark-2 {
  color: #1890ff;
  border-color: #1890ff;
  opacity: 0.6;
}

.watermark-3 {
  color: #999;
  border-color: #999;
  opacity: 0.6;
}

.claim-body {
  display: flex;
  gap: 12px;
}

.claim-price {
  font-size: 16px;
  font-weight: 600;
  color: #EF8802;
}

.claim-time {
  font-size: 12px;
  color: #999;
  display: none;
}

.claim-status {
  font-size: 12px;
  padding: 2px 8px;
  border-radius: 10px;
  display: none;
}

.claim-status-with-action {
  display: flex;
  align-items: center;
  gap: 8px;
}

.modify-link {
  font-size: 12px;
  color: #576b95;
  text-decoration: underline;
}

.claim-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.claim-btns {
  display: flex;
  gap: 8px;
}

.status-0 { background: #fff7e6; color: #fa8c16; }
.status-1 { background: #fff3e0; color: #EF8802; }
.status-2 { background: #e3f2fd; color: #2196f3; }

.empty-state {
  text-align: center;
  padding: 60px 0;
  color: #999;
  font-size: 14px;
}

.dialog-content {
  padding: 12px 0;
}

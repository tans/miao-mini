.claims-container {
  min-height: 100vh;
  background: #f5f5f5;
}

.tabs {
  background: #fff;
  display: flex;
  padding: 12px 16px;
  gap: 20px;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab {
  font-size: 14px;
  color: #999;
  padding-bottom: 4px;
}

.tab.active {
  color: #07c160;
  font-weight: 500;
  border-bottom: 2px solid #07c160;
}

.claim-task-title {
  font-size: 15px;
  font-weight: 500;
  color: #333;
  display: block;
  margin-bottom: 4px;
}

.claim-body {
  display: flex;
  gap: 12px;
}

.claim-price {
  font-size: 16px;
  font-weight: 600;
  color: #07c160;
}

.claim-time {
  font-size: 12px;
  color: #999;
}

.claim-status {
  font-size: 12px;
  padding: 2px 8px;
  border-radius: 10px;
}

.claim-status-with-action {
  display: flex;
  align-items: center;
  gap: 8px;
}

.modify-link {
  font-size: 12px;
  color: #576b95;
  text-decoration: underline;
}

.claim-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.claim-btns {
  display: flex;
  gap: 8px;
}

.claim-item-wrapper {
  position: relative;
  display: flex;
  align-items: center;
  gap: 8px;
}

.watermark-bg {
  position: absolute;
  left: -24px;
  top: 50%;
  transform: translateY(-50%) rotate(-15deg);
  font-size: 10px;
  padding: 1px 4px;
  border-radius: 2px;
  white-space: nowrap;
  z-index: 0;
}

.watermark-red {
  color: #ff4d4f;
  border: 1px solid #ff4d4f;
  opacity: 0.8;
}

.watermark-blue {
  color: #1890ff;
  border: 1px solid #1890ff;
  opacity: 0.8;
}

.watermark-gray {
  color: #999;
  border: 1px solid #999;
  opacity: 0.8;
}

.status-0 { background: #fff7e6; color: #fa8c16; }
.status-1 { background: #e6fff7; color: #07c160; }
.status-2 { background: #e3f2fd; color: #2196f3; }

.empty-state {
  text-align: center;
  padding: 60px 0;
  color: #999;
  font-size: 14px;
}

.dialog-content {
  padding: 12px 0;
}

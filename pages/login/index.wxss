/* pages/login/index.wxss */
.login-container {
  padding: 20px 16px;
}

.login-header {
  text-align: center;
  margin-bottom: 32px;
  padding-top: 40px;
}

.logo {
  font-size: 64px;
  margin-bottom: 8px;
}

.title {
  font-size: 24px;
  font-weight: 700;
  color: #333;
}

.subtitle {
  font-size: 13px;
  color: #999;
  margin-top: 4px;
}

.login-form {
  padding: 24px;
}

.form-group {
  margin-bottom: 16px;
}

.form-label {
  display: block;
  font-size: 13px;
  color: #666;
  margin-bottom: 6px;
}

.form-input {
  width: 100%;
  padding: 10px 12px;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  font-size: 14px;
  box-sizing: border-box;
}

.btn-block {
  margin-top: 8px;
}

.btn-primary {
  background: #FF2442;
  color: #fff;
}

.register-link {
  text-align: center;
  margin-top: 20px;
  font-size: 14px;
  color: #999;
}

.link {
  color: #FF2442;
  font-weight: 600;
  margin-left: 4px;
}

/* pages/home/index.wxss */
.home-container {
  padding-bottom: 20px;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 排序栏 */
.sort-bar {
  display: flex;
  background: #fff;
  padding: 0 16px;
  border-bottom: 1px solid #f0f0f0;
}

.sort-item {
  padding: 12px 14px;
  font-size: 14px;
  color: #666;
  position: relative;
  white-space: nowrap;
}

.sort-item.active {
  color: #07c160;
  font-weight: 600;
}

.sort-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 14px;
  right: 14px;
  height: 2px;
  background: #07c160;
  border-radius: 2px;
}

/* 行业标签栏 */
.industry-bar {
  background: #fff;
  white-space: nowrap;
  margin-bottom: 4px;
}

.industry-inner {
  display: flex;
  padding: 10px 12px;
  gap: 8px;
}

.industry-tag {
  display: inline-block;
  padding: 4px 12px;
  border-radius: 20px;
  font-size: 13px;
  background: #f5f5f5;
  color: #666;
  white-space: nowrap;
  flex-shrink: 0;
}

.industry-tag.active {
  background: rgba(7, 193, 96, 0.1);
  color: #07c160;
  font-weight: 600;
}

/* 标题栏 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 16px 6px;
}

.section-title {
  font-size: 15px;
  font-weight: 700;
  color: #333;
}

.section-count {
  font-size: 13px;
  color: #999;
}

/* 两列任务网格 */
.task-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 8px;
  gap: 8px;
}

.task-card-grid {
  width: calc(50% - 4px);
  background: #fff;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 1px 4px rgba(0,0,0,0.06);
}

/* 缩略图 - 长比例 */
.card-thumb-wrap {
  width: 100%;
  height: 240rpx;
  background: #f0f0f0;
  overflow: hidden;
}

.card-thumb {
  width: 100%;
  height: 100%;
}

.card-thumb-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f5f5f5 0%, #e8e8e8 100%);
}

.placeholder-icon {
  font-size: 36rpx;
}

/* 卡片内容 */
.card-body {
  padding: 10rpx 12rpx 12rpx;
}

.card-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #222;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  line-height: 1.4;
  margin-bottom: 6rpx;
}

.card-tags {
  display: flex;
  align-items: center;
  gap: 4rpx;
  margin-bottom: 8rpx;
}

.card-tag {
  background: #e8f5e9;
  color: #07c160;
  font-size: 20rpx;
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
}

.card-tag-more {
  font-size: 20rpx;
  color: #999;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-price {
  font-size: 28rpx;
  font-weight: 700;
  color: #07c160;
}

.card-remain {
  font-size: 20rpx;
  color: #999;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 16px;
}


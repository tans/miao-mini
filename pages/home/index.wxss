/* pages/home/index.wxss */
.home-container {
  padding-bottom: 20px;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 排序栏 */
.sort-bar {
  display: flex;
  background: #fff;
  padding: 0 16px;
  border-bottom: 1px solid #f0f0f0;
}

.sort-item {
  padding: 12px 14px;
  font-size: 14px;
  color: #666;
  position: relative;
  white-space: nowrap;
}

.sort-item.active {
  color: #EF8802;
  font-weight: 600;
}

.sort-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 14px;
  right: 14px;
  height: 2px;
  background: #EF8802;
  border-radius: 2px;
}

/* 行业标签栏 */
.industry-bar {
  background: #fff;
  white-space: nowrap;
  margin-bottom: 4px;
}

.industry-inner {
  display: flex;
  padding: 10px 12px;
  gap: 8px;
}

.industry-tag {
  display: inline-block;
  padding: 4px 12px;
  border-radius: 20px;
  font-size: 13px;
  background: #f5f5f5;
  color: #666;
  white-space: nowrap;
  flex-shrink: 0;
}

.industry-tag.active {
  background: rgba(239, 136, 2, 0.1);
  color: #EF8802;
  font-weight: 600;
}

/* 标题栏 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 16px 6px;
}

.section-title {
  font-size: 15px;
  font-weight: 700;
  color: #333;
}

.section-count {
  font-size: 13px;
  color: #999;
}

/* 两列任务网格 */
.task-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 8px;
  gap: 8px;
}

.task-card-grid {
  width: calc(50% - 4px);
  background: #fff;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 1px 4px rgba(0,0,0,0.06);
}

/* 缩略图 - 竖屏比例 */
.card-thumb-wrap {
  width: 100%;
  padding-top: 133%; /* 3:4 竖屏比例 */
  height: 0;
  background: #f0f0f0;
  overflow: hidden;
  position: relative;
}

.card-thumb {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.card-thumb-fallback {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  gap: 10rpx;
  padding: 22rpx 20rpx;
  color: #fff;
}

.fallback-badge {
  align-self: flex-start;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  font-size: 20rpx;
  line-height: 1;
}

.fallback-summary {
  font-size: 30rpx;
  line-height: 1.45;
  font-weight: 700;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
}

.fallback-title {
  font-size: 20rpx;
  line-height: 1.4;
  opacity: 0.85;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* 截止时间倒计时标签 */
.card-countdown {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
}

/* 卡片内容 */
.card-body {
  padding: 10rpx 12rpx 12rpx;
}

.card-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #222;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  line-height: 1.4;
  margin-bottom: 6rpx;
}

/* 行业类别和视频风格一行，两端对齐 */
.card-tags-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 6rpx;
}

.card-tags-left {
  display: flex;
  align-items: center;
  gap: 4rpx;
  flex-wrap: wrap;
  flex: 1;
  min-width: 0;
}

.card-tags-right {
  display: flex;
  align-items: center;
  gap: 4rpx;
  flex-wrap: wrap;
  flex-shrink: 0;
}

.card-tag {
  background: #FFFBF3;
  color: #EF8802;
  font-size: 20rpx;
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
}

.card-style-tag {
  background: #fff3e0;
  color: #e65100;
  font-size: 18rpx;
  padding: 2rpx 6rpx;
  border-radius: 4rpx;
}

/* 报名信息 */
.card-enroll {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.enroll-count {
  font-size: 20rpx;
  color: #666;
}

.enroll-sep {
  font-size: 20rpx;
  color: #ddd;
}

.remain-count {
  font-size: 20rpx;
  color: #999;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-price {
  font-size: 28rpx;
  font-weight: 700;
  color: #EF8802;
}

.card-price-wrap {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.card-award {
  font-size: 20rpx;
  font-weight: 500;
  color: #52c41a;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 16px;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80px 20px;
}

.empty-icon {
  font-size: 48px;
  display: block;
  margin-bottom: 16px;
}

.empty-desc {
  color: #999;
  font-size: 14px;
}

/* 发布任务悬浮按钮 */
.fab-container {
  position: fixed;
  bottom: 30px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 100;
}

.fab {
  background: #EF8802;
  color: #fff;
  border: none;
  border-radius: 24px;
  padding: 10px 20px;
  font-size: 14px;
  font-weight: 600;
  box-shadow: 0 4px 12px rgba(239, 136, 2, 0.4);
}

.cover-theme-0 {
  background: linear-gradient(145deg, #ff7a59, #ffb347);
}

.cover-theme-1 {
  background: linear-gradient(145deg, #5b86e5, #36d1dc);
}

.cover-theme-2 {
  background: linear-gradient(145deg, #8e54e9, #4776e6);
}

.cover-theme-3 {
  background: linear-gradient(145deg, #11998e, #38ef7d);
}

.cover-theme-4 {
  background: linear-gradient(145deg, #ee0979, #ff6a00);
}

.cover-theme-5 {
  background: linear-gradient(145deg, #4568dc, #b06ab3);
}

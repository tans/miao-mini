/* pages/home/index.wxss */
.home-container {
  background: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 180rpx;
}

/* 顶部渐变区域 */
.header-gradient {
  background: linear-gradient(66deg, #FF7C09 0%, #FFAF55 32%, #FFCD42 72%, #FFE177 100%);
  padding: 16rpx 32rpx 32rpx;
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.header-title-wrap {
  flex: 1;
}

.header-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: rgba(0,0,0,1);
  line-height: 48rpx;
}

.header-subtitle {
  display: block;
  font-size: 24rpx;
  font-weight: 500;
  color: rgba(0,0,0,1);
  line-height: 36rpx;
  margin-top: 8rpx;
}

.header-actions {
  position: relative;
}

.msg-icon {
  width: 48rpx;
  height: 48rpx;
}

.msg-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  background: #FA5148;
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
  width: 32rpx;
  height: 32rpx;
  border-radius: 16rpx;
  text-align: center;
  line-height: 32rpx;
}

/* Banner轮播 */
.banner-scroll {
  white-space: nowrap;
}

.banner-list {
  display: flex;
  gap: 24rpx;
}

.banner-item {
  width: 560rpx;
  height: 320rpx;
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
  flex-shrink: 0;
  background: linear-gradient(135deg, #5b86e5, #36d1dc);
}

.banner-img {
  width: 100%;
  height: 100%;
}

.banner-tag {
  position: absolute;
  bottom: 24rpx;
  left: 28rpx;
  background: rgba(55,55,55,0.9);
  border-radius: 8rpx;
  padding: 8rpx 16rpx;
  font-size: 18rpx;
  font-weight: 700;
  color: #fff;
}

/* 分类标签栏 */
.category-bar {
  background: #fff;
  white-space: nowrap;
  margin-top: -16rpx;
}

.category-inner {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  gap: 24rpx;
}

.category-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #EF8802;
  flex-shrink: 0;
}

.category-tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #666;
  white-space: nowrap;
  flex-shrink: 0;
}

.category-tag.active {
  background: #EF8802;
  color: #fff;
}

/* 排序栏 */
.sort-bar {
  display: flex;
  background: #fff;
  padding: 0 32rpx;
  margin-bottom: 16rpx;
}

.sort-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 26rpx;
  color: #666;
  position: relative;
}

.sort-item.active {
  color: #EF8802;
  font-weight: 600;
}

.sort-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: #EF8802;
  border-radius: 2rpx;
}

/* 任务列表 */
.task-list {
  padding: 0 24rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.task-card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(20,42,31,0.08);
}

/* 卡片内容区 */
.task-card-body {
  padding: 28rpx;
}

/* 标题行 */
.task-title-row {
  margin-bottom: 8rpx;
}

.task-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
  line-height: 1.4;
}

/* 价格行 */
.task-price-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 20rpx;
}

.task-price {
  font-size: 44rpx;
  font-weight: 700;
  color: #ef4444;
  font-family: D-DIN-PRO-Bold;
}

.task-price-unit {
  font-size: 24rpx;
  font-weight: 500;
  color: #ef4444;
  margin-left: 4rpx;
}

/* 标签区域 */
.task-tags {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
}

.badge {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.badge-reward {
  background: #FFF0EA;
  color: #ef4444;
}

.badge-brand {
  background: #F0F7FF;
  color: #3388FF;
}

.badge-trusted {
  background: #E9FFEE;
  color: #34A853;
}

.badge-icon {
  width: 24rpx;
  height: 24rpx;
}

/* 行业标签 */
.industry-tags {
  display: flex;
  gap: 8rpx;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
}

.industry-tag {
  background: #FFFBF3;
  color: #EF8802;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.style-tag {
  background: #fff3e0;
  color: #e65100;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

/* 报名进度 */
.task-progress {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.progress-label {
  font-size: 24rpx;
  color: #999;
}

.progress-info {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.progress-text {
  font-size: 24rpx;
  color: #666;
}

.progress-num {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
}

/* 底部操作区 */
.task-action {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.task-deadline {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.clock-icon {
  width: 28rpx;
  height: 28rpx;
}

.deadline-text {
  font-size: 24rpx;
  color: #999;
}

.btn-apply {
  background: #EF8802;
  color: #fff;
  padding: 14rpx 32rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 32rpx;
}

/* 发布任务悬浮按钮 */
.fab-container {
  position: fixed;
  bottom: 140rpx;
  right: 32rpx;
  z-index: 100;
}

.fab {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #EF8802;
  color: #fff;
  border: none;
  border-radius: 40rpx;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 32rpx rgba(239,136,2,0.4);
}

.fab-icon {
  width: 32rpx;
  height: 32rpx;
}
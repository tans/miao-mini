/* pages/home/index.wxss */
.home-container {
  background: #ffffff;
  min-height: 100vh;
  padding-bottom: 180rpx;
  
}

/* 顶部导航 */
.block_1{
  display: flex;
  padding: 30rpx 32rpx 24rpx 32rpx;
  align-items: center;
}
.block_1>image{
  width: 96rpx;
  height: 96rpx;
  margin-right: 16rpx;
}
.block_1 text{
  display: block;
}
.block_1 .text_1{
  font-family: PingFang SC, PingFang SC;
  font-weight: bold;
  font-size: 32rpx;
  color: #000000;
  line-height: 48rpx;
}
.block_1 .text_2{
  font-family: PingFang SC, PingFang SC;
  font-weight: 500;
  font-size: 24rpx;
  color: #000000;
  line-height: 36rpx;
}
.notice-container{
  width: 266.67rpx;
  height: 160rpx;
}
.notice-container image{
  width: 100%;
  height: 100%;
}
/* 顶部渐变区域 */
.header-gradient {
  padding-left: 24rpx;
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.header-title-wrap {
  flex: 1;
}

.header-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: rgba(0,0,0,1);
  line-height: 48rpx;
}

.header-subtitle {
  display: block;
  font-size: 24rpx;
  font-weight: 500;
  color: rgba(0,0,0,1);
  line-height: 36rpx;
  margin-top: 8rpx;
}
.header-desc-container{
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-top: 12rpx;
}
.header-desc-item{
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}
.header-desc-item image{
  width: 24rpx;
  height: 24rpx;
}

.header-actions {
  position: relative;
}

.msg-icon {
  width: 48rpx;
  height: 48rpx;
}

.msg-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  background: #FA5148;
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
  width: 32rpx;
  height: 32rpx;
  border-radius: 16rpx;
  text-align: center;
  line-height: 32rpx;
}

/* Banner轮播 */
.banner-scroll {
  white-space: nowrap;
}

.banner-list {
  display: flex;
  gap: 16rpx;
}

.banner-item {
  overflow: hidden;
  position: relative;
  flex-shrink: 0;
  width: 328rpx;
  height: 176rpx;
  border-radius: 16rpx 16rpx 16rpx 16rpx;

}

.banner-img {
  width: 100%;
  height: 100%;
}

.banner-tag {
  position: absolute;
  bottom: 24rpx;
  left: 28rpx;
  background: rgba(55,55,55,0.9);
  border-radius: 8rpx;
  padding: 8rpx 16rpx;
  font-size: 18rpx;
  font-weight: 700;
  color: #fff;
}

/* 分类标签栏 */
.category-bar {
  position: relative;
  z-index: 1;
  background: #fff;
  white-space: nowrap;
  border-radius: 24rpx 24rpx 0 0;
}

.category-inner {
  display: flex;
  align-items: center;
  padding: 0 16rpx 24rpx 16rpx;
}

.category-label {
  font-size: 32rpx;
  font-weight: 600;
  color: #EF8802;
  flex-shrink: 0;
  padding-right: 8rpx;
}

.category-tag {
  display: inline-block;
  padding: 16rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  color: #1D2129;
  white-space: nowrap;
  flex-shrink: 0;
  transition: all 0.2s ease;
  position: relative;
}

.category-tag.active {
  /* background: linear-gradient(135deg, #ff9a1f 0%, #ef6c00 100%); */
  color: #EF8802;
  /* font-weight: 600; */
}
.category-tag.active::after {
  content: '';
  position: absolute;
  bottom: 0rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: #EF8802;
  border-radius: 6rpx;

}
/* 排序栏 */
.sort-bar {
  display: flex;
  /* background: linear-gradient( 180deg, #FFFFFF 0%, #F1F1F1 100%); */
  padding: 0 32rpx 32rpx 20rpx;
}

.sort-item {
  text-align: center;
  padding: 8rpx 24rpx;
  font-size: 24rpx;
  color: #1D2129;
  position: relative;
  background: #ECEEF4;
  border-radius: 8rpx 8rpx 8rpx 8rpx;
  margin-right: 16rpx;
}

.sort-item.active {
  color: #FFFFFF;
  background: #000000;
}

/* 任务列表 */
.task-list {
  padding: 0 24rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.task-card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  /* border: 1px solid #ECEEF4; */
  box-shadow: 0 2rpx 24rpx rgba(101, 55, 1, 0.1);
}

/* 卡片内容区 */
.task-card-body {
  padding: 32rpx 32rpx 32rpx 32rpx;
}

/* 标题行 */
.task-title-container{
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.task-title-row {
  width: 60%;
  display: block;
}

.task-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
  line-height: 2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  width: 100%;
  display: block;
}

/* 价格行 */
.task-price-row {
  display: flex;
  align-items: baseline;
}

.task-price {
  font-size: 44rpx;
  font-weight: 700;
  color: #ef4444;
}

.task-price-unit {
  font-size: 32rpx;
  font-weight: 500;
  color: #ef4444;
  margin-left: 4rpx;
}

/* 标签区域 */
.task-tags {
  display: flex;
  gap: 10rpx;
  margin-bottom: 18rpx;
  flex-wrap: wrap;
}

.badge {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 12rpx;
  border-radius: 6rpx;
  font-size: 20rpx;
  line-height: 1.4;
}

.badge-reward {
  background: #FFF0EA;
  color: #ef4444;
  border: 2rpx solid #FFD8D2;
}

.badge-reward .home-price-num,
.task-price .home-price-num {
  font-family: 'home-din-pro-700-bold';
  font-weight: 700;
}

.badge-brand {
  background: #F0F7FF;
  color: #616878;
  border: 2rpx solid #A9D2FF;
}

.badge-trusted {
  background: #E9FFEE;
  color: #616878;
  border: 2rpx solid #BEF4C8;
}

.badge-icon {
  width: 24rpx;
  height: 24rpx;
}

/* 行业标签 */
.industry-tags {
  display: flex;
  gap: 8rpx;
  margin-bottom: 24rpx;
  flex-wrap: wrap;
}

.industry-tag {
  background: #F5F5F5;
  color: #878FA1;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.style-tag {
  background: #F5F5F5;
  color: #878FA1;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

/* 报名进度 */
.task-progress {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.progress-label {
  font-size: 24rpx;
  color: #64748B;
}

.progress-info {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.progress-text {
  font-size: 24rpx;
  color: #000000;
}

.progress-num {
  font-size: 24rpx;
  color: #DE872C;
}
.progress-bar-body {
  width: 100%;
  margin-top: 10rpx;
}
.progress-bar {
  width: 100%;
  border-radius: 4px;
}
.progress-bar /deep/ .progress__bar {
  background-color: #1677ff;
  border-radius: 4px;
}

/* 底部操作区 */
.task-action {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 30rpx;
}

.task-deadline {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.clock-icon {
  width: 28rpx;
  height: 28rpx;
}

.deadline-text {
  font-size: 24rpx;
  color: #999;
}

.btn-primary {
  background: #F99935;
  color: #fff;
  border-radius: 100rpx;
  font-size: 24rpx;
  padding: 10rpx 32rpx;
  background: #F99935;
  border-radius: 19998rpx 19998rpx 19998rpx 19998rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 400;
}

.btn-primary-disabled {
  background: #D9DEE7;
  color: #7B8794;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
  display: flex;
  flex-wrap: wrap;
  flex-direction: column; 
  justify-content: center;
  align-items: center;
}
.empty-state image,text {
  display: block;
}
.empty-state text {
  font-family: PingFang SC, PingFang SC;
  font-weight: 500;
  font-size: 24rpx;
  color: #878FA1;
  line-height: 36rpx;
  margin-top: 16rpx;
}
/* 加载更多 */
.load-more {
  text-align: center;
  padding: 32rpx;
}

/* 发布任务悬浮按钮 */
.fab-container {
  position: fixed;
  bottom: 50rpx;
  left: 50%;
  transform: translateX(-50%);
  z-index: 100;
}

.fab {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 240rpx;
  height: 72rpx;
  box-shadow: 0rpx 20rpx 52rpx 0rpx rgba(20,42,31,0.08);
  border-radius: 0rpx 0rpx 0rpx 0rpx;
  gap: 8rpx;
  background: linear-gradient( 0deg, #F97F00 0%, #FFA84C 100%);
  color: #fff;
  font-size: 26rpx;
  border-radius: 19998rpx 19998rpx 19998rpx 19998rpx;
}

.fab-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 4rpx;
}

.shared-bg-container {
  position: relative;
  width: 100%;
  background: linear-gradient( 180deg, #FFF4EA 0%, #FFFFFF 100%);
  padding-bottom: 24rpx;
}

.shared-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}
.shared-bg image {
  width: 750rpx;
  height: 242rpx;
}

.shared-bg-container /deep/ custom-nav {
  position: relative;
  z-index: 1;
  background: transparent !important;
}

.block_1 {
  position: relative;
  z-index: 1;
}

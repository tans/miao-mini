/* pages/home/index.wxss */
.home-container {
  padding-bottom: 20px;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 排序栏 */
.sort-bar {
  display: flex;
  background: #fff;
  padding: 0 16px;
  border-bottom: 1px solid #f0f0f0;
}

.sort-item {
  padding: 12px 14px;
  font-size: 14px;
  color: #666;
  position: relative;
  white-space: nowrap;
}

.sort-item.active {
  color: #FF2442;
  font-weight: 600;
}

.sort-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 14px;
  right: 14px;
  height: 2px;
  background: #FF2442;
  border-radius: 2px;
}

/* 行业标签栏 */
.industry-bar {
  background: #fff;
  white-space: nowrap;
  margin-bottom: 4px;
}

.industry-inner {
  display: flex;
  padding: 10px 12px;
  gap: 8px;
}

.industry-tag {
  display: inline-block;
  padding: 4px 12px;
  border-radius: 20px;
  font-size: 13px;
  background: #f5f5f5;
  color: #666;
  white-space: nowrap;
  flex-shrink: 0;
}

.industry-tag.active {
  background: rgba(255, 36, 66, 0.1);
  color: #FF2442;
  font-weight: 600;
}

/* 标题栏 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 16px 6px;
}

.section-title {
  font-size: 15px;
  font-weight: 700;
  color: #333;
}

.section-count {
  font-size: 13px;
  color: #999;
}

/* 任务卡片 */
.task-card {
  margin: 8px 12px;
}

.task-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 8px;
}

.task-title {
  font-size: 15px;
  font-weight: 600;
  color: #333;
  flex: 1;
  margin-right: 12px;
  line-height: 1.4;
}

.task-budget {
  font-weight: 700;
  color: #FF2442;
  font-size: 16px;
  flex-shrink: 0;
}

.task-tags {
  margin-bottom: 8px;
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.tag {
  display: inline-block;
  padding: 2px 8px;
  background: #FFF0F0;
  color: #FF2442;
  border-radius: 4px;
  font-size: 12px;
}

.task-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 12px;
  color: #999;
  margin-top: 4px;
}

.task-remain {
  color: #999;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 16px;
}

.btn-load {
  display: inline-block;
  padding: 8px 32px;
  border-radius: 20px;
  font-size: 13px;
  color: #666;
  background: #fff;
  border: 1px solid #e0e0e0;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80px 20px;
}

.empty-icon {
  font-size: 48px;
  display: block;
  margin-bottom: 16px;
}

.empty-desc {
  color: #999;
  font-size: 14px;
}

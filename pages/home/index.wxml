<!-- pages/home/index.wxml -->
<!-- 共用背景图容器 -->
<view class="home-container">
<view class="shared-bg-container">
  <!-- 顶部背景图 -->
  <!-- <view class="shared-bg">
    <image src="../../images/home/nav-bg.png"/>
  </view> -->
  <custom-nav title="首页"/>
  <!-- 顶部内容 -->
  <view class="block_1">
    <!-- <image src="../../images/home/msg-icon.png" class="banner-img" /> -->
    <view class="title-container">
      <text lines="1" class="text_1">创意喵｜AI视频众包撮合平台</text>
      <view class="header-desc-container">
        <view class="header-desc-item">
          <image src="../../images/home/header-icon1.png"/>
          <text lines="1" decode="true" class="text_2">双向信用管控</text>
        </view>
        <view class="header-desc-item">
          <image src="../../images/home/header-icon2.png"/>
          <text lines="1" decode="true" class="text_2">100%资金托管</text>
        </view>
      </view>
      
    </view>
    <view class="notice-container">
      <image src="../../images/home/IP.png" class="banner-img" />
    </view>
  </view>
  <view class="header-gradient">
    <!-- Banner轮播 -->
    <scroll-view class="banner-scroll" scroll-x>
      <view class="banner-list">
        <view class="banner-item">
          <image src="../../images/home/1.png" class="banner-img" />
          <!-- <view class="banner-tag">学会这招，收益稳稳到账</view> -->
        </view>
        <view class="banner-item">
          <image src="../../images/home/2.png" class="banner-img" />
          <!-- <view class="banner-tag">学会这招，收益稳稳到账</view> -->
        </view>
        <view class="banner-item">
          <image src="../../images/home/3.png" class="banner-img" />
          <!-- <view class="banner-tag">学会这招，收益稳稳到账</view> -->
        </view>
      </view>
    </scroll-view>
  </view>
</view>


  <!-- 分类标签栏 (在排序栏上方) -->
  <scroll-view class="category-bar" scroll-x>
    <view class="category-inner">
      <!-- <text class="category-label">推荐</text> -->
      <view
        wx:for="{{industryTags}}" wx:key="index"
        class="category-tag {{activeIndustry === item ? 'active' : ''}}"
        bindtap="setIndustry" data-industry="{{item}}"
      >{{item}}</view>
    </view>
  </scroll-view>

  <!-- 排序栏 -->
  <view class="sort-bar">
    <view
      class="sort-item {{sort === 'created_at' ? 'active' : ''}}"
      bindtap="setSort" data-sort="created_at"
    >按时间</view>
    <view
      class="sort-item {{sort === 'price_desc' ? 'active' : ''}}"
      bindtap="setSort" data-sort="price_desc"
    >从高到低</view>
    <view
      class="sort-item {{sort === 'price_asc' ? 'active' : ''}}"
      bindtap="setSort" data-sort="price_asc"
    >从低到高</view>
  </view>

  <!-- 任务列表 -->
  <view class="task-list" wx:if="{{displayTasks.length > 0}}">
    <view
      wx:for="{{displayTasks}}" wx:key="id"
      class="task-card"
      bindtap="goTaskDetail" data-id="{{item.id}}"
    >
      <view class="task-card-body">
        <!-- 标题和价格 -->
         <view class="task-title-container">
            <view class="task-title-row">
              <text class="task-title">{{item.title}}</text>
            </view>
            <view class="task-price-row"  >
              <view class="task-price">{{item.award_price + item.unit_price}}</view>
              <view class="task-price-unit" style="font-size: 38rpx;">元</view>
              <text class="task-price-unit">/条</text>
            </view>
         </view>
        <!-- 标签区域 -->
        <view class="task-tags">
          <view class="badge badge-reward" wx:if="{{item.unit_price > 0}}">
            <image src="../../images/home/badge-reward.png" class="badge-icon" />
            <view>基础:¥ {{item.unit_price}}</view>
          </view>
          <view class="badge badge-brand">
            <image src="../../images/home/badge-brand.png" class="badge-icon" />
            <text>品牌名企</text>
          </view>
          <view class="badge badge-trusted">
            <image src="../../images/home/badge-trusted.png" class="badge-icon" />
            <text>资金已托管</text>
          </view>
        </view>

        <!-- 行业标签 -->
        <view class="industry-tags">
          <text class="industry-tag" wx:for="{{item.industryArray}}" wx:key="index" wx:for-item="tag">{{tag}}</text>
          <text class="style-tag" wx:if="{{item.styleArray.length > 0}}">{{item.styleArray[0]}}</text>
        </view>

        <!-- 报名进度 -->
        <view class="task-progress">
          <text class="progress-label">报名进度</text>
          <view class="progress-info">
            <text class="progress-text">已报名</text>
            <text class="progress-num">{{item.enrolled_count}}</text>
            <text class="progress-text">/{{item.total_count || 10}}人</text>
          </view>
          
        </view>
        <view class="progress-bar-body">
          <progress class="progress-bar" percent="{{(item.enrolled_count / (item.total_count || 10))*100}}" stroke-width="4" activeColor="#F99935" backgroundColor="#F2EEEB" border-radius="16"/>
        </view>
        <!-- 底部操作区 -->
        <view class="task-action">
          <view class="task-deadline">
            <image src="../../images/home/icon-clock.png" class="clock-icon" />
            <text class="deadline-text" wx:if="{{item.countdown}}">{{item.countdown}}后截止投稿</text>
            <text class="deadline-text" wx:else>截止时间未知</text>
          </view>
          <view class="btn-primary {{item.isFull ? 'btn-primary-disabled' : ''}}" bindtap="applyTask" data-id="{{item.id}}">{{item.isFull ? '已经满人' : '立即报名'}}</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{displayTasks.length === 0 && !loading}}">
    <!-- <mp-msg type="info" title="暂无相关任务" /> -->
    <image src="../../images/home/empty.png" class="clock-icon" style="width:300rpx;height:300rpx;"/>
    <text>暂无任务哦</text>
  </view>

  <!-- 加载更多 -->
  <view wx:if="{{hasMore && activeIndustry === '' && displayTasks.length > 0}}" class="load-more">
    <button class="weui-btn weui-btn_default" bindtap="loadMore" disabled="{{loading}}">
      {{loading ? '加载中...' : '加载更多'}}
    </button>
  </view>

  <!-- 发布任务悬浮按钮 -->
  <view class="fab-container">
    <view class="fab" bindtap="goCreateTask">
      <image src="../../images/home/fab-icon.png" class="fab-icon" />
      <text>发布任务</text>
    </view>
  </view>
</view>

<!--pages/home/index.wxml-->
<view class="home-container">

  <!-- 排序栏 -->
  <view class="sort-bar">
    <view
      class="sort-item {{sort === 'created_at' ? 'active' : ''}}"
      bindtap="setSort" data-sort="created_at"
    >最新</view>
    <view
      class="sort-item {{sort === 'price_desc' ? 'active' : ''}}"
      bindtap="setSort" data-sort="price_desc"
    >价格最高</view>
    <view
      class="sort-item {{sort === 'price_asc' ? 'active' : ''}}"
      bindtap="setSort" data-sort="price_asc"
    >价格最低</view>
  </view>

  <!-- 行业筛选标签 -->
  <scroll-view class="industry-bar" scroll-x wx:if="{{industryTags.length > 0}}">
    <view class="industry-inner">
      <view
        class="industry-tag {{activeIndustry === '' ? 'active' : ''}}"
        bindtap="setIndustry" data-industry=""
      >全部</view>
      <view
        wx:for="{{industryTags}}" wx:key="index"
        class="industry-tag {{activeIndustry === item ? 'active' : ''}}"
        bindtap="setIndustry" data-industry="{{item}}"
      >{{item}}</view>
    </view>
  </scroll-view>

  <!-- 任务数量 -->
  <view class="section-header">
    <text class="section-title">{{activeIndustry ? activeIndustry : '全部任务'}}</text>
    <text class="section-count">{{displayTasks.length}}{{hasMore && activeIndustry === '' ? '+' : ''}}个</text>
  </view>

  <!-- 空状态 -->
  <mp-msg type="info" title="暂无相关任务" wx:if="{{displayTasks.length === 0 && !loading}}" />

  <!-- 两列任务网格 -->
  <view class="task-grid" wx:if="{{displayTasks.length > 0}}">
    <view
      wx:for="{{displayTasks}}" wx:key="id"
      class="task-card-grid"
      bindtap="goTaskDetail" data-id="{{item.id}}"
    >
      <view class="card-thumb-wrap">
        <image
          wx:if="{{item.cover}}"
          class="card-thumb"
          src="{{item.cover}}"
          mode="aspectFill"
          lazy-load
        />
        <view wx:else class="card-thumb-placeholder">
          <text class="placeholder-icon">🎬</text>
        </view>
        <!-- 截止时间倒计时标签 -->
        <view class="card-countdown" wx:if="{{item.countdown}}">{{item.countdown}}</view>
      </view>
      <view class="card-body">
        <text class="card-title">{{item.title}}</text>
        <!-- 行业标签 -->
        <view class="card-tags" wx:if="{{item.industryArray.length > 0}}">
          <text class="card-tag">{{item.industryArray[0]}}</text>
          <text wx:if="{{item.industryArray.length > 1}}" class="card-tag-more">+{{item.industryArray.length - 1}}</text>
        </view>
        <!-- 风格标签 -->
        <view class="card-style-tags" wx:if="{{item.styleArray.length > 0}}">
          <text class="card-style-tag" wx:for="{{item.styleArray}}" wx:key="index" wx:for-item="style">{{style}}</text>
        </view>
        <!-- 报名信息 -->
        <view class="card-enroll">
          <text class="enroll-count">已报名{{item.enrolled_count}}人</text>
          <text class="enroll-sep">|</text>
          <text class="remain-count">剩{{item.remaining_count}}名</text>
        </view>
        <!-- 价格 -->
        <view class="card-footer">
          <text class="card-price">¥{{item.unit_price}}</text>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{hasMore && activeIndustry === '' && displayTasks.length > 0}}" class="load-more">
    <button class="weui-btn weui-btn_default" bindtap="loadMore" disabled="{{loading}}">
      {{loading ? '加载中...' : '加载更多'}}
    </button>
  </view>

  <!-- 发布任务按钮 -->
  <view class="fab-container">
    <button class="fab" bindtap="goCreateTask">+ 发布任务</button>
  </view>

</view>
/* pages/my-tasks/index.wxss */
.my-tasks-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 20rpx;
}

/* 顶部栏 */
.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  background: #fff;
  border-bottom: 1rpx solid #e5e5e5;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #ddd;
}

.username {
  font-size: 28rpx;
  color: #333;
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.balance-box {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.balance-label {
  font-size: 24rpx;
  color: #999;
}

.balance-amount {
  font-size: 32rpx;
  font-weight: 700;
  color: #EF8802;
}

/* 标题栏 */
.section-header {
  padding: 24rpx 32rpx;
  background: #fff;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #e5e5e5;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.btn-publish {
  background: #EF8802;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  font-weight: 600;
}

/* 任务列表 */
.tasks-list {
  padding: 24rpx;
}

/* WeUI Panel 风格 */
.weui-panel {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.weui-panel__hd {
  padding: 24rpx 24rpx 16rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.task-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.task-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  flex: 1;
  margin-right: 16rpx;
}

/* 状态徽章 */
.status-badge {
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  white-space: nowrap;
}

.status-badge.status-1 {
  background: #FFF2E8;
  color: #EF8802;
}

.status-badge.status-2 {
  background: #E8F4FF;
  color: #1890ff;
}

.status-badge.status-3 {
  background: #E8F5E9;
  color: #52c41a;
}

.status-badge.status-4 {
  background: #FFEBEE;
  color: #f44336;
}

.status-badge.status-5 {
  background: #F5F5F5;
  color: #999;
}

/* Panel Body */
.weui-panel__bd {
  padding: 20rpx 24rpx;
}

.weui-media-box {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.thumb-row {
  margin-bottom: 8rpx;
}

.task-thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  background: #f0f0f0;
}

.info-row {
  display: flex;
  gap: 32rpx;
}

.info-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.info-item .label {
  font-size: 24rpx;
  color: #999;
}

.info-item .value {
  font-size: 26rpx;
  color: #666;
}

.info-item .value.price {
  font-size: 32rpx;
  font-weight: 600;
  color: #EF8802;
}

.info-item .value.success {
  color: #52c41a;
}

/* Panel Footer */
.weui-panel__ft {
  padding: 16rpx 24rpx 20rpx;
  border-top: 1rpx solid #f5f5f5;
  display: flex;
  justify-content: flex-end;
}

.action-group {
  display: flex;
  align-items: center;
}

.action-group.dual {
  width: 100%;
  justify-content: center;
  gap: 24rpx;
}

.action-link {
  font-size: 26rpx;
  color: #576b95;
}

.action-link.primary {
  color: #EF8802;
  font-weight: 600;
}

.action-divider {
  color: #ddd;
  font-size: 26rpx;
}

/* 空状态 */
.empty-state {
  padding: 120rpx 0;
}
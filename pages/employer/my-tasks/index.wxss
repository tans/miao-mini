/* pages/employer/my-tasks/index.wxss */
.my-tasks-container {
  min-height: 100vh;
  background: #fafafa;
  padding-bottom: 20rpx;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 32rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.nav-left, .nav-right {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
}

.nav-back {
  width: 40rpx;
  height: 40rpx;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 900;
  color: #333;
}

/* 筛选标签 */
.filter-tabs {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  background: #fff;
}

.filter-tab {
  padding: 16rpx 32rpx;
  border-radius: 36rpx;
  font-size: 26rpx;
  font-weight: 900;
  color: #8c8c98;
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(17, 17, 17, 0.04);
}

.filter-tab.active {
  background: #ff9f2f;
  color: #fff;
}

/* 任务列表 */
.tasks-list {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* 任务卡片 */
.task-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(17, 17, 17, 0.04);
}

.card-main {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.card-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.task-title {
  font-size: 32rpx;
  font-weight: 900;
  color: #333;
  max-width: 320rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.publish-time {
  font-size: 24rpx;
  color: #8c8c98;
}

.progress-label {
  font-size: 24rpx;
  color: #647489;
}

.card-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 16rpx;
}

.status-tag {
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 900;
}

.status-tag.status-active {
  background: #fff4ea;
  color: #ef8802;
}

.status-tag.status-ended {
  background: #f5f5f5;
  color: #8f96a8;
}

.submission-info {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.info-label {
  font-size: 24rpx;
  color: #000;
}

.info-count {
  font-size: 24rpx;
  color: #de872c;
  font-weight: 500;
}

.info-total {
  font-size: 24rpx;
  color: #000;
}

/* 进度条 */
.progress-bar {
  height: 16rpx;
  background: #000;
  border-radius: 16rpx;
  margin-top: 16rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #ff9f2f 0%, #ef6c00 100%);
  border-radius: 16rpx;
  transition: width 0.3s ease;
}

/* 卡片底部 */
.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 32rpx;
}

.pending-notice {
  font-size: 24rpx;
  color: #ef4444;
  flex: 1;
}

.action-btn {
  padding: 16rpx 40rpx;
  border-radius: 36rpx;
  font-size: 26rpx;
  font-weight: 900;
  text-align: center;
}

.action-btn.btn-review {
  background: linear-gradient(135deg, #ff9a1f 0%, #ef6c00 100%);
  color: #fff;
  margin-left: auto;
}

.action-btn.btn-result {
  background: #fff;
  color: #333;
  border: 1px solid #ececef;
  margin-left: auto;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 32rpx;
}

.empty-btn {
  padding: 16rpx 48rpx;
  background: linear-gradient(135deg, #ff9a1f 0%, #ef6c00 100%);
  color: #fff;
  border-radius: 36rpx;
  font-size: 28rpx;
  font-weight: 600;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
  gap: 16rpx;
}

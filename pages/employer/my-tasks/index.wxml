<view class="my-tasks-container">
  <!-- 顶部导航栏 -->
  <view class="nav-bar">
    <view class="nav-left" bindtap="goBack">
      <image class="nav-back" src="/assets/icons/back.png" />
    </view>
    <text class="nav-title">任务管理</text>
    <view class="nav-right"></view>
  </view>

  <!-- 筛选标签 -->
  <view class="filter-tabs">
    <view class="filter-tab {{currentFilter === 'all' ? 'active' : ''}}" data-filter="all" bindtap="switchFilter">
      <text>全部</text>
    </view>
    <view class="filter-tab {{currentFilter === 'active' ? 'active' : ''}}" data-filter="active" bindtap="switchFilter">
      <text>征稿中</text>
    </view>
    <view class="filter-tab {{currentFilter === 'ended' ? 'active' : ''}}" data-filter="ended" bindtap="switchFilter">
      <text>已结束</text>
    </view>
  </view>

  <!-- 任务列表 -->
  <view class="tasks-list" wx:if="{{filteredTasks.length > 0}}">
    <view class="task-card {{item.status === 'active' ? 'card-active' : 'card-ended'}}" wx:for="{{filteredTasks}}" wx:key="id">
      <!-- 卡片主体 -->
      <view class="card-main">
        <view class="card-left">
          <text class="task-title">{{item.title || '任务' + item.id}}</text>
          <text class="publish-time">发布时间 {{item.created_at}}</text>
          <text class="progress-label">投稿进度</text>
        </view>
        <view class="card-right">
          <view class="status-tag {{item.status === 'active' ? 'status-active' : 'status-ended'}}">
            <text>{{item.status === 'active' ? '征稿中' : '已结束'}}</text>
          </view>
          <view class="submission-info">
            <text class="info-label">已投稿</text>
            <text class="info-count">{{item.submission_count || 0}}</text>
            <text class="info-total">/{{item.max_submissions || 10}}条</text>
          </view>
        </view>
      </view>

      <!-- 进度条 -->
      <view class="progress-bar">
        <view class="progress-fill" style="width: {{(item.submission_count || 0) / (item.max_submissions || 10) * 100}}%"></view>
      </view>

      <!-- 底部操作 -->
      <view class="card-footer">
        <text class="pending-notice" wx:if="{{item.pending_review_count > 0}}">您有{{item.pending_review_count}}条视频未审核，请尽快处理</text>
        <view class="action-btn {{item.pending_review_count > 0 ? 'btn-review' : (item.status === 'active' ? 'btn-review' : 'btn-result')}}" bindtap="{{item.pending_review_count > 0 || item.status === 'active' ? 'goReviewTask' : 'goTaskResult'}}" data-id="{{item.id}}">
          <text>{{item.pending_review_count > 0 || item.status === 'active' ? '去审核' : '查看结果'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{filteredTasks.length === 0 && !loading}}">
    <view class="empty-icon">📋</view>
    <text class="empty-text">暂无任务</text>
    <view class="empty-btn" bindtap="goCreateTask">发布任务</view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-state" wx:if="{{loading}}">
    <mp-loading type="circle"></mp-loading>
    <text>加载中...</text>
  </view>
</view>

.create-container {
  min-height: 100vh;
  background: #fafafa;
  display: flex;
  flex-direction: column;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 32rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.nav-left, .nav-right {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
}

.nav-back {
  width: 40rpx;
  height: 40rpx;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
}

/* 表单滚动区域 */
.form-scroll {
  flex: 1;
}

/* 流程图 */
.flow-section {
  background: #fff;
  margin: 32rpx 24rpx;
  border-radius: 16rpx;
  box-shadow: 0px 10rpx 26rpx rgba(20,42,31,0.08);
  padding-bottom: 24rpx;
}

.flow-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 24rpx;
}

.flow-header-left {
  display: flex;
  align-items: center;
}

.flow-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 8rpx;
}

.flow-headline {
  font-size: 28rpx;
  font-weight: 900;
  color: #333;
}

.flow-headline-highlight {
  font-size: 28rpx;
  font-weight: 900;
  color: #ef8802;
  margin-left: 8rpx;
}

.flow-hint {
  font-size: 24rpx;
  font-weight: 500;
  color: #ef8802;
  margin-left: 206rpx;
}

.flow-body {
  display: flex;
  align-items: flex-start;
  justify-content: flex-start;
  padding-left: 56rpx;
  margin-bottom: 34rpx;
}

.flow-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 106rpx;
}

.flow-icon-wrapper {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.flow-step-icon {
  width: 100%;
  height: 100%;
}

.flow-step-text {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 24rpx;
}

.flow-step-title {
  font-size: 24rpx;
  color: #333;
  white-space: nowrap;
  text-align: center;
}

.flow-step-sub {
  font-size: 20rpx;
  color: #666;
  white-space: nowrap;
  text-align: center;
}

.flow-arrow {
  width: 68rpx;
  height: 20rpx;
  flex-shrink: 0;
  margin: 20rpx 0 0 -12rpx;
}

/* 表单卡片 */
.form-card {
  background: #fff;
  margin: 0 24rpx 32rpx 24rpx;
  padding: 32rpx;
  border-radius: 16rpx;
  box-shadow: 0rpx 4rpx 16rpx 0rpx rgba(17,17,17,0.04);
}

.card-with-shadow {
  box-shadow: 0rpx 4rpx 16rpx 0rpx rgba(17,17,17,0.04);
}

.card-title {
  font-size: 32rpx;
  color: #333333;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #ECECEF;
  margin-bottom: 48rpx;
  font-weight: 800;
}

/* 任务标题 */
.title-field {
  margin-bottom: 48rpx;
}

.title-label,.desc-label{
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #333333;
  line-height: 44rpx;
  margin-bottom: 20rpx;
}

.title-input {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  background: #ffffff;
  border: 2rpx solid #ECECEF;
  border-radius: 16rpx;
  box-sizing: border-box;
  padding: 0 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.get-hover:hover {
  border: 2rpx solid #EF8802;
}

/* 表单字段 */
.form-field {
  margin-bottom: 48rpx;
  padding: 22rpx 32rpx;
  border-radius: 16rpx 16rpx 16rpx 16rpx;
  display: flex;
  border: 2rpx solid #ECECEF;
}

.field-label-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  width: 190rpx
}

.field-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.field-hint {
  font-size: 24rpx;
  color: #878ba1;
}

/* 标签横向滚动 */
.tag-scroll {
  white-space: nowrap;
}

.tag-group {
  gap: 16rpx;
  padding: 4rpx 0;
  display: flex;
  flex-wrap: wrap;
  flex: 1;
  align-items: center;
  justify-content: flex-end;
}
.tags-group{
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 24rpx;
}
.tags-item{
  width: 202rpx;
  height: 64rpx;
  background: #F5F5F7;
  border-radius: 4rpx 4rpx 4rpx 4rpx;
  font-size: 28rpx;
  color: #333;
  display: flex;
  align-items: center;
  justify-content: center;
}
.tag-group-content{
  flex: 1;
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx;
  justify-content: flex-end;
}
.tag {
  width: 180rpx;
  height: 72rpx;
  background: #F5F5F7;
  border-radius: 4rpx 4rpx 4rpx 4rpx;
  font-size: 28rpx;
  color: #333;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.show-tag{
  background: #000000;
  border-radius: 8rpx 8rpx 8rpx 8rpx;
  padding: 4rpx 16rpx;
  color: #FFFFFF;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tags-item.active {
  background: #FEF4E6;
  color: #EF8802;
}
.tag-btn-group{
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.reset-btn {
  width: 316rpx;
  height: 72rpx;
  background: rgba(239,136,2,0.1);
  border-radius: 19998rpx 19998rpx 19998rpx 19998rpx; 
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #EF8802;
}
.confirm-btn {
  width: 316rpx;
  height: 72rpx;
  background: #FF9F2F;
  border-radius: 19998rpx 19998rpx 19998rpx 19998rpx; 
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #fff;
}

/* 任务描述 */
.desc-field {
  margin-bottom: 24rpx;
  background: #F5F5F7;
  padding: 32rpx;
}

/* .desc-label {
  font-size: 44rpx;
  font-weight: 700;
  color: #333333;
  line-height: 56rpx;
  margin-bottom: 20rpx;
  display: block;
} */

.desc-area {
  background: transparent;
  border-radius: 0;
  position: relative;
  display: block;
}

.desc-textarea {
  width: 100%;
  min-height: 216rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #333333;
  line-height: 44rpx;
  box-sizing: border-box;
  background: #FFFFFF;
  border: 2rpx solid #e5e6eb;
  border-radius: 16rpx;
  display: block;
  overflow: hidden;
}
.desc-textarea-box{
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 15rpx;
}
.desc-textarea-box .desc-textarea-box-text{
  font-size: 24rpx;
  color: #8C8C98;
}

.ai-write-btn {
  padding: 18rpx 32rpx;
  background: linear-gradient( 180deg, #F97F00 0%, #FFA84C 100%);
  border-radius: 19998rpx 19998rpx 19998rpx 19998rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.ai-write-btn-disabled {
  opacity: 0.65;
}

.ai-icon {
  width: 28rpx;
  height: 28rpx;
}

.ai-write-btn text {
  font-size: 24rpx;
  font-weight: 600;
  color: #fff;
}

/* 图片参考 */
.upload-icon-wrapper {
  position: relative;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dashed-border {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border: 2rpx dashed #d5d8df;
  border-radius: 12rpx;
}
.plus-icon {
  font-size: 56rpx;
  font-weight: 300;
  color: #a5acbb;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}
.upload-icon {
  width: 40rpx;
  height: 40rpx;
  z-index: 1;
}
.image-reference {
  margin-top: 48rpx;
}

.image-reference-label-row {
  width: 100%;
  align-items: baseline;
  margin-bottom: 16rpx;
}

.image-reference-label {
  margin-bottom: 0;
}

.ref-images-box {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.ref-image-item {
  position: relative;
  width: 120rpx;
  height: 120rpx;
}

.ref-image-item .ref-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
}

.ref-image-item .ref-material-video {
  display: block;
  background: #000;
}

.ref-image-remove {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ref-image-remove .remove-icon {
  width: 24rpx;
  height: 24rpx;
}

.ref-upload {
  width: 120rpx;
  height: 120rpx;
  background: #fff;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-icon {
  width: 40rpx;
  height: 40rpx;
}

/* 平台禁忌 */
.forbidden-notice {
  background: rgba(239,68,68,0.08);
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
}

.forbidden-notice text {
  font-size: 24rpx;
  color: #ef4444;
  line-height: 36rpx;
}

/* 开关框 */
.switch-box {
  border-radius: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 34rpx;
  border-radius: 16rpx 16rpx 16rpx 16rpx;
  border: 2rpx solid #ECECEF;
}

.switch-info {
  flex: 1;
}

.switch-title {
  font-size: 28rpx;
  font-weight: 900;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.switch-desc {
  font-size: 24rpx;
  color: #878ba1;
  display: block;
}

.switch-icon {
  width: 96rpx;
  height: 56rpx;
}

/* 即梦合拍 */
.jimeng-box {
  border-radius: 16rpx 16rpx 16rpx 16rpx;
  border: 2rpx solid #ECECEF;
  border-radius: 16rpx;
  padding: 32rpx;
}

.jimeng-content {
  margin-top: 24rpx;
}

.jimeng-input-box {
  background: #fff;
  border-radius: 8rpx 8rpx 8rpx 8rpx;
  display: flex;
  flex-direction: column;
  height: 206rpx;
  margin-bottom: 24rpx;
  padding: 24rpx;
  border-radius: 8rpx 8rpx 8rpx 8rpx;
  border: 2rpx solid #ECECEF;
}

.jimeng-input {
  flex: 1;
  width: 100%;
  font-size: 28rpx;
  color: #c9cdd4;
  line-height: 44rpx;
}

.char-count {
  font-size: 24rpx;
  color: #8690a4;
  text-align: right;
  padding: 0 24rpx 18rpx;
}

.jimeng-tutorial {
  background: linear-gradient(62deg, #ffbf70 0%, #ff9f2f 100%);
  border-radius: 16rpx;
  height: 328rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.video-box{
  width: 574rpx;
  height: 328rpx;
}

.tutorial-icon-wrapper {
  width: 50rpx;
  height: 52rpx;
  background: rgba(0,0,0,0.55);
  border-radius: 19998rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tutorial-icon {
  width: 20rpx;
  height: 20rpx;
}

.jimeng-tutorial text {
  font-size: 24rpx;
  font-weight: 900;
  color: #fff;
  margin-top: 120rpx;
}

.jimeng-course {
  font-size: 24rpx;
  color: #1979F7;
  margin-top: 16rpx;
  display: flex;
  align-items: center;
}

.jimeng-tips {
  background: #fff;
  padding-top: 16rpx;
  border-radius: 8rpx;
}

.tips-main {
  font-size: 24rpx;
  color: #8c8c98;
}

.tips-highlight {
  font-size: 24rpx;
  color: #ef8802;
}

.tips-sub {
  font-size: 24rpx;
  color: #8c8c98;
}

/* 视频规格 */
.spec-box {
  display: flex;
  gap: 24rpx;
}

.spec-item {
  flex: 1;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

picker.spec-item {
  cursor: pointer;
}

.spec-value {
  font-size: 25rpx;
  font-weight: 900;
  color: #333;
  margin-right: 16rpx;
}

.spec-unit {
  font-size: 20rpx;
  color: #666;
}

/* 选择框 */
.picker-box {
  background: #f5f5f7;
  border-radius: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 90rpx;
  padding: 0 32rpx;
  margin: 32rpx 0 0 0;
}

.picker-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.picker-row {
  display: flex;
  align-items: center;
}
.picker-row-box{
  margin-top: 0;
  display: flex;
  justify-content: space-between;
  width: 580rpx;
}

.picker-value {
  font-size: 28rpx;
  color: #878FA1;
}

.picker-arrow {
  width: 28rpx;
  height: 28rpx;
}

.picker-box-disabled {
  opacity: 1;
}

.picker-row-disabled {
  flex-direction: column;
  align-items: flex-end;
}

.picker-hint {
  font-size: 24rpx;
  color: #8C8C98;
}

/* 输入框 */
.input-box {
  border-radius: 16rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  height: 90rpx;
  margin: 16rpx 0 0 0;
  border-radius: 16rpx 16rpx 16rpx 16rpx;
  border: 2rpx solid #ECECEF;
}

.input-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-right: auto;
  padding-left: 32rpx;
}

.input-row {
  display: flex;
  align-items: center;
}

.price-input {
  font-size: 28rpx;
  color: #333;
  text-align: center;
  min-width: 80rpx;
}

.input-unit {
  font-size: 24rpx;
  color: #878ba1;
  padding-right: 32rpx;
  margin-left: 8rpx;
}

/* 提示 */
.tips-notice {
  padding: 8rpx 0;
  font-size: 24rpx;
  color: #8c8c98;
}

/* 预算框 */
.budget-box {
  background: #eef5ff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin: 48rpx 0 0 0;
}

.budget-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}

.budget-label {
  font-size: 28rpx;
  color: #333;
}

.budget-value {
  font-size: 28rpx;
  font-weight: 800;
  color: #333;
}

.budget-value-strikethrough {
  color: #9ca3af;
  text-decoration: line-through;
}

.budget-divider {
  height: 1rpx;
  border: 1px solid #ececef;
  margin: 16rpx 0;
}

.budget-total-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}

.budget-total-label {
  font-size: 30rpx;
  font-weight: 900;
  color: #333;
}

.budget-total-value {
  font-size: 28rpx;
  font-weight: 900;
  color: #ef4444;
}

.budget-discount-value {
  font-size: 28rpx;
  font-weight: 900;
  color: #10b981;
}

.budget-warning {
  margin-top: 16rpx;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  background: #fff4f4;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.budget-warning-text {
  font-size: 24rpx;
  color: #dc2626;
}

.budget-warning-action {
  flex-shrink: 0;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: #ef4444;
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
}

.budget-tips {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #8c8c98;
  line-height: 36rpx;
}

/* 提交区域 */
.submit-section {
  padding: 26rpx 32rpx;
  position: relative;
  background-color: #fff;
  border-top: 2rpx solid #ECECEF;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: #FF9F2F;
  border: none;
  border-radius: 48rpx;
  color: #fff;
  font-size: 30rpx;
  font-weight: 900;
  text-align: center;
}

.submit-btn-disabled {
  background: #d9d9d9;
  color: #8c8c8c;
}

.submit-btn::after {
  border: none;
}

.submit-indicator {
  width: 264rpx;
  height: 10rpx;
  background: rgba(17,17,17,0.92);
  border-radius: 1998rpx;
  margin: 24rpx auto 0;
}

/* 模态框样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
}

.industry-modal {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 16rpx 16rpx 0 0;
  z-index: 1000;
  padding-bottom: env(safe-area-inset-bottom);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
}

.modal-confirm {
  font-size: 28rpx;
  color: #07C160;
}

.modal-content {
  max-height: 60vh;
  padding: 0 30rpx;
}

.modal-item {
  display: flex;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.modal-item-text {
  margin-left: 20rpx;
  font-size: 28rpx;
}

.add-tag {
  background-color: #f5f5f5;
  color: #999;
}
.flex{
  display: flex;
}

/* 覆盖半屏对话框底部样式 */
.weui-half-screen-dialog__ft {
  padding: 10px 0 20px 0;
}

/* 发帖提醒 */
.post-reminder-card {
  padding-bottom: 28rpx;
}

.post-reminder-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.post-reminder-icon {
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.post-reminder-icon-inner {
  font-size: 22rpx;
  font-weight: 800;
  color: #fff;
  line-height: 1;
}

.post-reminder-title-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  line-height: 1.35;
}

.post-reminder-title-brand {
  font-size: 26rpx;
  font-weight: 800;
  color: #ef8802;
}

.post-reminder-title-rest {
  font-size: 26rpx;
  font-weight: 800;
  color: #333;
}

.post-reminder-list {
  padding-top: 4rpx;
}

.post-reminder-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.post-reminder-item:last-child {
  margin-bottom: 0;
}

.post-reminder-bullet {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #8C8C98;
  margin-right: 14rpx;
  margin-top: 14rpx;
  flex-shrink: 0;
}

.post-reminder-text {
  flex: 1;
  font-size: 24rpx;
  color: #8C8C98;
  line-height: 48rpx;
  font-weight: 400;
}
.action-text{
  font-size: 24rpx;
  color: #8C8C98;
  margin-bottom: 8rpx;
  text-align: center;
}

.agreement-link {
  color: #ef8802;
}

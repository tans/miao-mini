.create-container {
  min-height: 100vh;
  background: #fafafa;
}

/* 顶部状态栏 */
.status-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 32rpx;
  background: #fff;
}

.status-time {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.status-icons {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.signal-icon, .wifi-icon, .battery-icon {
  width: 32rpx;
  height: 22rpx;
  background: #333;
  border-radius: 4rpx;
}

.battery-icon {
  width: 48rpx;
  height: 24rpx;
}

/* 标题栏 */
.page-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  width: 40rpx;
  height: 40rpx;
}

.page-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
}

.message-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.message-icon {
  width: 42rpx;
  height: 38rpx;
}

/* 表单滚动区域 */
.form-scroll {
  height: calc(100vh - 132rpx);
}

/* 流程图 */
.flow-section {
  background: #fff;
  padding: 24rpx 32rpx;
  margin-bottom: 24rpx;
}

.flow-item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.flow-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  flex: 1;
}

.flow-dot {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #fff;
}

.flow-dot-1 {
  background: linear-gradient(145deg, #ff7a59, #ffb347);
}

.flow-dot-2 {
  background: linear-gradient(145deg, #5b86e5, #36d1dc);
}

.flow-dot-3 {
  background: linear-gradient(145deg, #8e54e9, #4776e6);
}

.flow-dot-4 {
  background: linear-gradient(145deg, #11998e, #38ef7d);
}

.flow-label {
  font-size: 20rpx;
  color: #666;
  text-align: center;
  max-width: 96rpx;
  line-height: 1.3;
}

.flow-arrow {
  width: 40rpx;
  height: 2rpx;
  background: #eee;
  margin-top: 27rpx;
  flex-shrink: 0;
}

.flow-hint {
  text-align: center;
  font-size: 22rpx;
  color: #ff9f2f;
  margin-top: 24rpx;
}

/* 表单卡片 */
.form-card {
  background: #fff;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 32rpx;
}

/* 表单字段 */
.form-field {
  margin-bottom: 32rpx;
}

.field-label {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 16rpx;
}

.field-label-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.field-hint {
  font-size: 22rpx;
  color: #999;
}

.field-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

/* 标签组 */
.tag-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag {
  padding: 12rpx 24rpx;
  background: #f5f5f5;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #666;
}

.tag.active {
  background: #ff9f2f;
  color: #fff;
}

/* 描述区域 */
.desc-area {
  position: relative;
}

.desc-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  box-sizing: border-box;
}

.ai-write-btn {
  position: absolute;
  bottom: 16rpx;
  right: 16rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: linear-gradient(135deg, #ff9a1f 0%, #ef6c00 100%);
  border-radius: 24rpx;
  color: #fff;
  font-size: 22rpx;
}

.ai-icon {
  font-size: 28rpx;
  color: #fff;
  line-height: 1;
}

/* 平台禁忌 */
.forbidden-notice {
  padding: 16rpx 20rpx;
  background: #fff4e8;
  border-radius: 8rpx;
  margin-top: 24rpx;
}

.forbidden-notice text {
  font-size: 22rpx;
  color: #ef8802;
  line-height: 1.5;
}

/* 开关行 */
.switch-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
}

.switch-info {
  flex: 1;
}

.switch-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: block;
  margin-bottom: 8rpx;
}

.switch-desc {
  font-size: 22rpx;
  color: #999;
  display: block;
}

.privacy-switch, .jimeng-switch {
  transform: scale(0.8);
}

/* 即梦内容 */
.jimeng-content {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.jimeng-input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.jimeng-input {
  flex: 1;
  height: 80rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.char-count {
  font-size: 22rpx;
  color: #999;
  flex-shrink: 0;
}

.jimeng-tutorial {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 0;
  margin-top: 16rpx;
}

.tutorial-icon {
  font-size: 28rpx;
  line-height: 1;
}

.jimeng-tutorial text {
  font-size: 24rpx;
  color: #ff9f2f;
}

.jimeng-tips {
  background: #f5f5f5;
  padding: 16rpx 20rpx;
  border-radius: 8rpx;
}

.tips-main {
  font-size: 22rpx;
  color: #333;
}

.tips-sub {
  font-size: 22rpx;
  color: #999;
}

/* 视频规格 */
.spec-row {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 24rpx 0;
}

.spec-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.spec-value {
  font-size: 32rpx;
  color: #333;
  font-weight: 700;
}

.spec-unit {
  font-size: 22rpx;
  color: #999;
}

.spec-divider {
  width: 1rpx;
  height: 48rpx;
  background: #e0e0e0;
}

/* 奖金字段 */
.award-input-row, .count-input-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.award-input, .count-input {
  width: 160rpx;
  height: 80rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  text-align: center;
  box-sizing: border-box;
}

.award-unit {
  font-size: 26rpx;
  color: #666;
}

/* 提示 */
.tips-notice {
  padding: 16rpx 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  margin-top: 24rpx;
}

.tips-notice text {
  font-size: 22rpx;
  color: #666;
  line-height: 1.5;
}

/* 预算框 */
.budget-box {
  background: #fafafa;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-top: 24rpx;
}

.budget-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}

.budget-label {
  font-size: 24rpx;
  color: #666;
}

.budget-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.budget-divider {
  height: 1rpx;
  background: #e0e0e0;
  margin: 16rpx 0;
}

.budget-total-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}

.budget-total-label {
  font-size: 26rpx;
  color: #333;
  font-weight: 700;
}

.budget-total-value {
  font-size: 36rpx;
  color: #ff9f2f;
  font-weight: 700;
}

.budget-tips {
  margin-top: 16rpx;
}

.budget-tips text {
  font-size: 20rpx;
  color: #999;
  line-height: 1.5;
}

/* 提交区域 */
.submit-section {
  padding: 32rpx;
  margin-bottom: 40rpx;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #ff9a1f 0%, #ef6c00 100%);
  border: none;
  border-radius: 48rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
}

.submit-btn::after {
  border: none;
}

/* picker样式 */
.field-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 80rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.field-picker text {
  font-size: 28rpx;
  color: #333;
}

.picker-arrow {
  font-size: 36rpx;
  color: #999;
  line-height: 1;
}
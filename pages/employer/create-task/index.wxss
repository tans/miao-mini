/* pages/create-task/index.wxss */
.create-container {
  min-height: 100vh;
  background: #f5f5f5;
}

.chip-group {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.chip {
  padding: 6px 14px;
  background: #f0f0f0;
  border-radius: 16px;
  font-size: 13px;
  color: #666;
}

.chip.active {
  background: #EF8802;
  color: #fff;
}

/* 素材上传 */
.materials-section {
  background: #fff;
  padding: 16px;
  margin-top: 12px;
}

.section-title {
  font-size: 15px;
  font-weight: 500;
  color: #333;
  margin-bottom: 4px;
}

.required {
  color: #e64340;
}

.section-hint {
  font-size: 12px;
  color: #999;
  margin-bottom: 12px;
}

.materials-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.material-item {
  position: relative;
  width: 96rpx;
  height: 96rpx;
  border-radius: 8rpx;
  overflow: hidden;
  background: #f5f5f5;
}

.material-thumb {
  width: 100%;
  height: 100%;
}

.material-video-thumb {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #222;
}

.material-video-icon {
  color: #fff;
  font-size: 24rpx;
}

.material-video-name {
  color: #ccc;
  font-size: 18rpx;
  margin-top: 4rpx;
  max-width: 80rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.material-delete {
  position: absolute;
  top: 2rpx;
  right: 2rpx;
  width: 32rpx;
  height: 32rpx;
  background: rgba(0,0,0,0.55);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 20rpx;
  line-height: 32rpx;
  text-align: center;
}

.material-add {
  width: 96rpx;
  height: 96rpx;
  border-radius: 8rpx;
  border: 1rpx dashed #ccc;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fafafa;
}

.material-add-icon {
  font-size: 36rpx;
  color: #bbb;
  line-height: 1;
}

.material-add-label {
  font-size: 20rpx;
  color: #bbb;
  margin-top: 4rpx;
}

.uploading-tip {
  margin-top: 8px;
  font-size: 12px;
  color: #999;
  display: flex;
  align-items: center;
  gap: 8px;
}

.submit-section {
  padding: 16px;
}

.weui-btn {
  width: 100%;
}

/* 预算预览 */
.budget-preview {
  background: #fff;
  padding: 16px;
  margin: 12px 0;
  border-radius: 8px;
}

.budget-title {
  font-size: 15px;
  font-weight: 500;
  color: #333;
  margin-bottom: 12px;
  padding-bottom: 8px;
  border-bottom: 1rpx solid #eee;
}

.budget-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 6px 0;
}

.budget-label {
  font-size: 13px;
  color: #666;
}

.budget-value {
  font-size: 14px;
  color: #333;
  font-weight: 500;
}

.budget-total {
  margin-top: 8px;
  padding-top: 8px;
  border-top: 1rpx solid #eee;
}

.budget-total .budget-label {
  font-weight: 600;
  color: #333;
}

.budget-total .total {
  font-size: 18px;
  color: #EF8802;
  font-weight: 600;
}

.budget-hint {
  margin-top: 12px;
  font-size: 12px;
  color: #999;
  background: #f5f5f5;
  padding: 8px;
  border-radius: 4px;
}

/* 奖励设置label字体缩小 */
.award-label {
  font-size: 14px;
  color: #333;
}

.picker-value {
  color: #333;
}

/* 即梦合拍 */
.jimeng-section {
  background: #fff;
  padding: 16px;
  margin-top: 12px;
}

.jimeng-section .section-title {
  font-size: 15px;
  font-weight: 500;
  color: #333;
  margin-bottom: 4px;
}

.jimeng-section .section-hint {
  font-size: 12px;
  color: #999;
  margin-bottom: 12px;
}

.jimeng-input-area {
  background: #fff;
  border-radius: 8px;
  overflow: hidden;
}

.jimeng-textarea {
  width: 100%;
  min-height: 80px;
  padding: 12px;
  font-size: 14px;
  line-height: 1.6;
  border: 1rpx solid #eee;
  border-radius: 8px;
  box-sizing: border-box;
}

.jimeng-preview {
  padding: 12px;
  background: #f9f9f9;
  border-top: 1rpx dashed #eee;
}

.preview-row {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 6px;
}

.preview-row:last-child {
  margin-bottom: 0;
}

.preview-label {
  font-size: 13px;
  color: #666;
  flex-shrink: 0;
}

.preview-value {
  font-size: 13px;
  color: #2563eb;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.optional {
  color: #999;
  font-weight: 400;
}

.jimeng-label {
  font-size: 14px;
  color: #333;
}

<view class="create-container">
  <!-- 顶部状态栏 -->
  <view class="status-bar">
    <text class="status-time">9:41</text>
    <view class="status-icons">
      <view class="signal-icon"></view>
      <view class="wifi-icon"></view>
      <view class="battery-icon"></view>
    </view>
  </view>

  <!-- 标题栏 -->
  <view class="page-header">
    <view class="back-btn" bindtap="goBack">
      <image src="/assets/icons/back.png" class="back-icon" />
    </view>
    <text class="page-title">发布任务</text>
    <view class="message-btn">
      <image src="/assets/icons/message.png" class="message-icon" />
    </view>
  </view>

  <scroll-view scroll-y="true" class="form-scroll">
    <!-- 流程图 -->
    <view class="flow-section">
      <view class="flow-item">
        <view class="flow-step">
          <view class="flow-dot flow-dot-1">发</view>
          <text class="flow-label">发布任务托管奖金</text>
        </view>
        <view class="flow-arrow"></view>
        <view class="flow-step">
          <view class="flow-dot flow-dot-2">创</view>
          <text class="flow-label">创作者报名提交视频</text>
        </view>
        <view class="flow-arrow"></view>
        <view class="flow-step">
          <view class="flow-dot flow-dot-3">审</view>
          <text class="flow-label">商家审核验收视频</text>
        </view>
        <view class="flow-arrow"></view>
        <view class="flow-step">
          <view class="flow-dot flow-dot-4">结</view>
          <text class="flow-label">任务结束解冻剩余资金</text>
        </view>
      </view>
      <view class="flow-hint">详细教程</view>
    </view>

    <!-- 基础信息 -->
    <view class="form-card">
      <view class="card-title">基础信息</view>

      <!-- 任务标题 -->
      <view class="form-field">
        <view class="field-label">任务标题</view>
        <input class="field-input" placeholder="请输入任务标题" value="{{title}}" bindinput="onTitleInput"/>
      </view>

      <!-- 行业 -->
      <view class="form-field">
        <view class="field-label-row">
          <text class="field-label">行业</text>
          <text class="field-hint">（可多选）</text>
        </view>
        <view class="tag-group">
          <text wx:for="{{industryOptions}}" wx:key="id" class="tag {{selectedIndustries.includes(item.id) ? 'active' : ''}}" data-id="{{item.id}}" bindtap="toggleIndustry">{{item.name}}</text>
        </view>
      </view>

      <!-- 风格 -->
      <view class="form-field">
        <view class="field-label-row">
          <text class="field-label">风格</text>
          <text class="field-hint">（可多选）</text>
        </view>
        <view class="tag-group">
          <text wx:for="{{styleOptions}}" wx:key="index" class="tag {{selectedStyles.includes(item) ? 'active' : ''}}" data-style="{{item}}" bindtap="toggleStyle">{{item}}</text>
        </view>
      </view>

      <!-- 任务描述 -->
      <view class="form-field">
        <view class="field-label">任务描述</view>
        <view class="desc-area">
          <textarea class="desc-textarea" placeholder="请输入不少于10个字的描述" value="{{description}}" bindinput="onDescInput" maxlength="500"/>
          <view class="ai-write-btn" bindtap="aiWriteDesc">
            <text class="ai-icon">✎</text>
            <text>AI帮写</text>
          </view>
        </view>
      </view>

      <!-- 平台禁忌 -->
      <view class="forbidden-notice">
        <text>平台禁忌：敏感词、低俗内容、侵权内容、政治敏感、广告夸大。</text>
      </view>
    </view>

    <!-- 隐私保护 -->
    <view class="form-card">
      <view class="card-title">隐私保护</view>
      <view class="switch-row">
        <view class="switch-info">
          <text class="switch-title">开启稿件隐私保护</text>
          <text class="switch-desc">开启后，创作者的投稿仅商家可见</text>
        </view>
        <switch class="privacy-switch" checked="{{privacyProtected}}" bindchange="togglePrivacy"/>
      </view>
    </view>

    <!-- 即梦合拍 -->
    <view class="form-card">
      <view class="card-title">即梦合拍</view>
      <view class="switch-row">
        <view class="switch-info">
          <text class="switch-title">即梦合拍设置</text>
          <text class="switch-desc">商家提供数字人模型给创作者用于合成视频</text>
        </view>
        <switch class="jimeng-switch" checked="{{jimengEnabled}}" bindchange="toggleJimeng"/>
      </view>
      <view wx:if="{{jimengEnabled}}" class="jimeng-content">
        <view class="jimeng-input-row">
          <input class="jimeng-input" placeholder="请输入邀请链接" value="{{jimeng_link}}" bindinput="onJimengLinkInput" maxlength="50"/>
          <text class="char-count">{{jimeng_link.length}}/50</text>
        </view>
        <view class="jimeng-tutorial" bindtap="showJimengTutorial">
          <text class="tutorial-icon">📖</text>
          <text>查看即梦合拍教程</text>
        </view>
        <view class="jimeng-tips">
          <text class="tips-main">tips：即梦合拍邀请链接仅48小时有效</text>
          <text class="tips-sub">，请在我的-任务管理-任务详情中更新链接。</text>
        </view>
      </view>
    </view>

    <!-- 视频规格 -->
    <view class="form-card">
      <view class="card-title">视频规格</view>
      <view class="spec-row">
        <view class="spec-item">
          <text class="spec-value">30</text>
          <text class="spec-unit">秒内</text>
        </view>
        <view class="spec-divider"></view>
        <view class="spec-item">
          <text class="spec-value">9:16</text>
          <text class="spec-unit">竖版</text>
        </view>
        <view class="spec-divider"></view>
        <view class="spec-item">
          <text class="spec-value">1080P</text>
          <text class="spec-unit">高清</text>
        </view>
      </view>
    </view>

    <!-- 时间与奖金 -->
    <view class="form-card">
      <view class="card-title">时间与奖金</view>

      <!-- 投稿截止时间 -->
      <view class="form-field">
        <view class="field-label">投稿截止时间</view>
        <picker mode="date" value="{{deadline}}" start="{{minDeadline}}" end="{{maxDeadline}}" bindchange="onDeadlineChange">
          <view class="field-picker">
            <text>{{deadline || '默认7天后'}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>

      <!-- 参与奖 -->
      <view class="form-field">
        <view class="field-label">参与奖</view>
        <view class="award-input-row">
          <input type="number" class="award-input" placeholder="2" value="{{unit_price}}" bindinput="onUnitPriceInput"/>
          <text class="award-unit">元/条</text>
        </view>
      </view>

      <!-- 采纳奖 -->
      <view class="form-field">
        <view class="field-label">采纳奖</view>
        <view class="award-input-row">
          <input type="number" class="award-input" placeholder="≥8元" value="{{award_price}}" bindinput="onAwardPriceInput"/>
          <text class="award-unit">元/条</text>
        </view>
      </view>

      <!-- 报名人数上限 -->
      <view class="form-field">
        <view class="field-label">报名人数上限</view>
        <view class="count-input-row">
          <input type="number" class="count-input" placeholder="10" value="{{total_count}}" bindinput="onTotalCountInput"/>
          <text class="award-unit">人</text>
        </view>
      </view>

      <view class="tips-notice">tips：请按需设置报名人数，若活动采纳率过低，可能会隐形您的信誉。</view>

      <!-- 预算预览 -->
      <view class="budget-box">
        <view class="budget-row">
          <text class="budget-label">参与奖励总额</text>
          <text class="budget-value">¥{{baseTotal}}</text>
        </view>
        <view class="budget-row">
          <text class="budget-label">采纳奖励总额</text>
          <text class="budget-value">¥{{awardTotal}}</text>
        </view>
        <view class="budget-row">
          <text class="budget-label">平台服务费</text>
          <text class="budget-value">¥{{platformFee}}</text>
        </view>
        <view class="budget-divider"></view>
        <view class="budget-total-row">
          <text class="budget-total-label">需预支付总金额</text>
          <text class="budget-total-value">¥{{totalBudget}}</text>
        </view>
        <view class="budget-tips">tips：活动金额按报名人数上限全额冻结，审核完全部稿件48小时后，剩余活动金即可解冻。</view>
      </view>
    </view>

    <!-- 提交按钮 -->
    <view class="submit-section">
      <button class="submit-btn" bindtap="handleSubmit">托管奖金并发布</button>
    </view>
  </scroll-view>
</view>
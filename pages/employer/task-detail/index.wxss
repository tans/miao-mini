.page {
  min-height: 100vh;
  background: #f5f5f5;
}

.header {
  background: #fff;
  padding: 28rpx 24rpx 0;
  box-shadow: 0 10rpx 26rpx rgba(20, 42, 31, 0.06);
}

.header-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 72rpx;
}

.back-btn {
  width: 40rpx;
  height: 40rpx;
  position: relative;
}

.back-btn::before {
  content: '';
  position: absolute;
  left: 10rpx;
  top: 11rpx;
  width: 16rpx;
  height: 16rpx;
  border-left: 3rpx solid #222;
  border-bottom: 3rpx solid #222;
  transform: rotate(45deg);
}

.page-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
}

.header-action {
  min-width: 112rpx;
  height: 48rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #f5f5f7;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #555562;
}

.tab-switch {
  position: relative;
  display: flex;
  margin-top: 14rpx;
}

.tab-item {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #1d2129;
}

.tab-item.active {
  color: #ef8802;
  font-weight: 500;
}

.tab-indicator {
  position: absolute;
  bottom: 0;
  width: 128rpx;
  height: 4rpx;
  background: #ef8802;
  border-radius: 4rpx;
  transition: left 0.3s ease;
}

.content {
  padding: 32rpx 24rpx 40rpx;
}

.tab-content {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.proposal-review-card,
.video-card,
.merchant-card,
.task-id-card,
.detail-card,
.material-card,
.jimeng-card,
.safety-card {
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 10rpx 26rpx rgba(20, 42, 31, 0.08);
}

.proposal-review-card {
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.proposal-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.proposal-title {
  font-size: 28rpx;
  font-weight: 900;
  color: #333;
}

.proposal-count {
  font-size: 24rpx;
  color: #8c8c98;
}

.proposal-arrow {
  width: 22rpx;
  height: 22rpx;
  border-right: 3rpx solid #8c8c98;
  border-top: 3rpx solid #8c8c98;
  transform: rotate(45deg);
}

.video-card,
.merchant-card,
.task-id-card,
.detail-card,
.material-card,
.jimeng-card,
.safety-card {
  padding: 32rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.header-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.header-hint {
  flex: 1;
  text-align: right;
  font-size: 22rpx;
  color: #8c8c98;
}

.header-link {
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  background: #f5f5f7;
  font-size: 22rpx;
  color: #555562;
}

.video-container {
  border-radius: 16rpx;
  overflow: hidden;
}

.video-player {
  width: 100%;
  height: 420rpx;
  background: #000;
}

.video-placeholder {
  height: 420rpx;
  border-radius: 16rpx;
  background: linear-gradient(160deg, #eef2f7, #dde4ef);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
}

.play-btn {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(255, 159, 47, 0.92);
  position: relative;
}

.play-btn::after {
  content: '';
  position: absolute;
  left: 42rpx;
  top: 30rpx;
  border-top: 20rpx solid transparent;
  border-bottom: 20rpx solid transparent;
  border-left: 32rpx solid #fff;
}

.video-hint {
  font-size: 26rpx;
  color: #666;
}

.merchant-main {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.merchant-avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 16rpx;
  background: #f5f5f7;
}

.merchant-avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 700;
  color: #ef8802;
}

.merchant-info {
  flex: 1;
}

.merchant-name {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 12rpx;
}

.merchant-badges {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
}

.badge-brand {
  background: #f0f7ff;
}

.badge-trusted {
  background: #e9ffef;
}

.badge-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #ef8802;
}

.badge-text {
  color: #616878;
}

.merchant-stats {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #ececef;
}

.stat-item {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #555562;
}

.stat-value {
  font-size: 28rpx;
  color: #ef8802;
  font-weight: 700;
}

.stat-unit {
  font-size: 22rpx;
  color: #555562;
}

.task-id-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.id-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.id-label {
  font-size: 24rpx;
  color: #8c8c98;
}

.id-value {
  font-size: 28rpx;
  font-weight: 900;
  color: #222;
}

.copy-btn {
  padding: 12rpx 32rpx;
  border-radius: 999rpx;
  background: #f5f5f7;
  font-size: 24rpx;
  color: #555562;
  font-weight: 900;
}

.detail-card-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.detail-title {
  display: block;
  margin-top: 20rpx;
  font-size: 36rpx;
  font-weight: 900;
  color: #333;
  line-height: 1.35;
}

.reward-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin: 28rpx 0;
}

.reward-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.reward-label {
  font-size: 24rpx;
  color: #8c8c98;
}

.reward-value-row {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
}

.reward-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #ef4444;
}

.reward-value-dark {
  color: #222;
}

.reward-unit {
  font-size: 24rpx;
  color: #8c8c98;
}

.reward-plus {
  font-size: 32rpx;
  color: #c8c8d0;
  margin-top: 18rpx;
}

.tags-row {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.tag-group {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.tag-label {
  font-size: 22rpx;
  color: #8c8c98;
}

.tag-list {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.tag-chip {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #f5f5f7;
}

.tag-chip-text {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
}

.desc-section {
  padding: 24rpx 28rpx;
  background: #eef5ff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.desc-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

.spec-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #ececef;
}

.spec-label {
  font-size: 28rpx;
  color: #555562;
}

.spec-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.restriction-section {
  margin-top: 24rpx;
  padding: 16rpx 20rpx;
  background: rgba(239, 68, 68, 0.08);
  border-radius: 12rpx;
}

.restriction-text {
  font-size: 24rpx;
  color: #ef4444;
  line-height: 1.6;
}

.material-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.material-item {
  width: 210rpx;
  height: 210rpx;
  border-radius: 12rpx;
  overflow: hidden;
  position: relative;
  background: #f5f5f7;
}

.material-thumb {
  width: 100%;
  height: 100%;
}

.material-video-badge {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0, 0, 0, 0.35);
}

.material-video-badge::after {
  content: '';
  position: absolute;
  left: 24rpx;
  top: 18rpx;
  border-top: 14rpx solid transparent;
  border-bottom: 14rpx solid transparent;
  border-left: 22rpx solid #fff;
}

.empty-tip {
  font-size: 24rpx;
  color: #8c8c98;
}

.jimeng-card {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.jimeng-link-row,
.jimeng-edit-row {
  padding: 20rpx;
  border-radius: 12rpx;
  background: #f5f5f7;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.jimeng-link {
  flex: 1;
  font-size: 24rpx;
  color: #2563eb;
  word-break: break-all;
}

.jimeng-count {
  font-size: 22rpx;
  color: #8c8c98;
  flex-shrink: 0;
}

.jimeng-edit-input {
  flex: 1;
  font-size: 24rpx;
  color: #333;
}

.jimeng-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.jimeng-tutorial {
  flex: 1;
  padding: 16rpx 20rpx;
  border-radius: 999rpx;
  background: #eef5ff;
  font-size: 24rpx;
  color: #2563eb;
  text-align: center;
}

.jimeng-btn,
.jimeng-confirm {
  padding: 16rpx 32rpx;
  border-radius: 999rpx;
  background: #ff9f2f;
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  text-align: center;
}

.jimeng-confirm {
  margin-top: 6rpx;
}

.safety-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.safety-icon {
  width: 30rpx;
  height: 30rpx;
}

.safety-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
}

.accent {
  color: #f58a1f;
}

.safety-text {
  display: block;
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

.page {
  min-height: 100vh;
  background: #f5f5f5;
}

.tab-switch {
  position: relative;
  display: flex;
  background: #fff;
  box-shadow: 0 10rpx 26rpx rgba(20, 42, 31, 0.06);
  padding: 0 16rpx;
}

.tab-item {
  position: relative;
  padding: 0 16rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #1d2129;
  box-sizing: border-box;
  border-bottom: 4rpx solid transparent;
}

.tab-item.active {
  color: #ef8802;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  left: 50%;
  bottom: 0rpx;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: #ef8802;
  border-radius: 4rpx 4rpx 4rpx 4rpx;
}

.tab-indicator {
  position: absolute;
  bottom: 0;
  width: 104rpx;
  height: 4rpx;
  background: #ef8802;
  border-radius: 4rpx;
  transition: left 0.3s ease;
}

.tab-indicator-proposals {
  left: 136rpx;
}

.tab-indicator-detail {
  left: 510rpx;
}

.content {
  padding:  34rpx 24rpx;
}

.tab-content {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  box-shadow: 0rpx 20rpx 52rpx 0rpx rgba(20,42,31,0.08);
  border-radius: 16rpx 16rpx 16rpx 16rpx;
}

.merchant-card,
.task-id-card,
.detail-card,
.material-card,
.jimeng-card,
.safety-card,
.review-tip-card,
.stat-card,
.claim-item,
.batch-bar {
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 10rpx 26rpx rgba(20, 42, 31, 0.08);
}

.merchant-card,
.task-id-card,
.detail-card,
.material-card,
.jimeng-card,
.safety-card,
.review-tip-card,
.batch-bar,
.claim-item {
  padding: 32rpx;
}

.compact-card {
  padding-top: 24rpx;
  padding-bottom: 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.header-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.header-hint {
  flex: 1;
  text-align: right;
  font-size: 22rpx;
  color: #8c8c98;
}

.header-link {
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: #f5f5f7;
  font-size: 22rpx;
  color: #555562;
}

.merchant-main {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.merchant-avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 16rpx;
  background: #f5f5f7;
}

.merchant-avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 700;
  color: #ef8802;
}

.merchant-info {
  flex: 1;
}

.merchant-name {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 12rpx;
}

.merchant-badges {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
}

.badge-brand {
  background: #f0f7ff;
}

.badge-trusted {
  background: #e9ffef;
}

.badge-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #ef8802;
}

.badge-text {
  color: #616878;
}

.merchant-stats {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #ececef;
}

.stat-item {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #555562;
}

.stat-value {
  font-size: 28rpx;
  color: #ef8802;
  font-weight: 700;
}

.stat-unit {
  font-size: 22rpx;
  color: #555562;
}

.task-id-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.id-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.id-label {
  font-size: 24rpx;
  color: #8c8c98;
}

.id-value {
  font-size: 25rpx;
  color: #222;
}

.copy-btn {
  padding: 12rpx 32rpx;
  border-radius: 999rpx;
  background: #f5f5f7;
  font-size: 24rpx;
  color: #555562;
  font-weight: 900;
}

.detail-card-title {
  font-family: PingFang SC, PingFang SC;
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  line-height: 48rpx;
}

.detail-title {
  display: block;
  margin-top: 24rpx;
  margin-bottom: 24rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
}

.reward-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 32rpx;
  margin-bottom: 32rpx;
  border-radius: 12rpx;
}

.reward-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.reward-label {
  font-size: 24rpx;
  color: #8c8c98;
}

.reward-value-row {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.reward-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #ef4444;
}

.reward-value-dark {
  color: #222;
}

.reward-unit {
  font-size: 24rpx;
  color: #8c8c98;
}

.reward-value-row-primary .reward-value,
.reward-value-row-primary .reward-unit {
  color: #ef4444;
}

.reward-value-row-secondary .reward-value,
.reward-value-row-secondary .reward-unit {
  color: #333333;
}

.reward-plus {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #ccc;
}

.tags-row {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.tag-group {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.tag-label {
  font-size: 22rpx;
  color: #999;
}

.tag-list {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.tag-chip {
  padding: 2rpx 16rpx;
  background: #f5f5f5;
  border-radius: 8rpx 8rpx 8rpx 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tag-chip-text {
  font-size: 22rpx;
  color: #878fa1;
  font-weight: 400;
}

.desc-section {
  padding: 24rpx 32rpx;
  background: #eef5ff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.desc-text {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
}

.specs-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.spec-item {
  display: flex;
  justify-content: space-between;
  gap: 4rpx;
  border-bottom: 1px solid #ececef;
  padding-bottom: 16rpx;
  padding-top: 16rpx;
}

.spec-label {
  font-size: 28rpx;
  color: #555562;
}

.spec-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.restriction-section {
  padding: 16rpx 20rpx;
  background: rgba(239,68,68,0.08);
  border-radius: 8rpx;
}

.restriction-text {
  font-size: 24rpx;
  color: #EF4444;
  line-height: 1.5;
}

.material-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.material-item {
  width: 210rpx;
  height: 210rpx;
  border-radius: 12rpx;
  overflow: hidden;
  position: relative;
  background: #f5f5f7;
}

.material-thumb {
  width: 100%;
  height: 100%;
  display: block;
}

.material-video-player {
  background: #000;
}

.material-video-badge,
.preview-play-badge {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0, 0, 0, 0.35);
}

.material-video-badge::after,
.preview-play-badge::after {
  content: '';
  position: absolute;
  left: 24rpx;
  top: 18rpx;
  border-top: 14rpx solid transparent;
  border-bottom: 14rpx solid transparent;
  border-left: 22rpx solid #fff;
}

.empty-tip {
  font-size: 24rpx;
  color: #8c8c98;
}

.jimeng-card {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.jimeng-content {
  background: #f5f5f7;
  border-radius: 16rpx;
  padding: 32rpx;
  
}
.jimeng-content-main{
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.jimeng-content .header-hint {
  display: block;
  text-align: left;
}

.jimeng-content .header-hint:first-child {
  font-size: 26rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
}

.jimeng-content .header-hint:nth-child(2) {
  font-size: 24rpx;
  color: #878ba1;
  margin-bottom: 24rpx;
}

.jimeng-link-row,
.jimeng-edit-row {
  padding: 24rpx;
  border-radius: 8rpx;
  background: #fff;
  display: flex;
  flex-direction: column;
  min-height: 206rpx;
  margin-bottom: 24rpx;
}

.jimeng-link {
  flex: 1;
  font-size: 24rpx;
  color: #2563eb;
  word-break: break-all;
}

.jimeng-count {
  font-size: 22rpx;
  color: #8690a4;
  text-align: right;
  width: 100%;
}

.jimeng-edit-input {
  flex: 1;
  width: 100%;
  font-size: 28rpx;
  color: #333;
  line-height: 44rpx;
}

.jimeng-actions {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.jimeng-tutorial text {
  font-size: 24rpx;
  font-weight: 900;
  color: #EF8802;
}

.jimeng-btn,
.jimeng-confirm {
  align-self: flex-end;
  padding: 0 32rpx;
  border-radius: 999rpx;
  background: #ff9f2f;
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
}

.jimeng-confirm {
  margin-top: -8rpx;
}

.safety-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.safety-badge {
  width: 40rpx;
  height: 40rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
}

.safety-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #2f3542;
}

.safety-title-brand {
  color: #ef8802;
}

.safety-text {
  display: block;
  font-size: 24rpx;
  color: #585f6d;
  line-height: 1.6;
}

.safety-highlight {
  color: #ef8802;
}

.stats-cards {
  display: flex;
  gap: 24rpx;
}

.stat-card {
  flex: 1;
  padding: 24rpx;
}

.stat-card-label {
  font-size: 28rpx;
  color: #878FA1;
}

.stat-card-value {
  display: block;
  margin-top: 16rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: #222;
}

.stat-card-number-row {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
}

.stat-card-number-row .stat-card-value {
  margin-top: 0;
}

.stat-card-unit {
  margin-left: 8rpx;
  font-size: 28rpx;
  color: #878fa1;
}

.stat-card-hint {
  display: block;
  margin-top: 22rpx;
  font-size: 28rpx;
  color: #878FA1;
  line-height: 1.5;
}

.filter-scroll {
  width: 100%;
}

.filter-tabs {
  display: inline-flex;
  flex-wrap: nowrap;
  align-items: center;
  gap: 16rpx;
  white-space: nowrap;
}

.filter-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  padding: 16rpx 32rpx;
  border-radius: 999rpx;
  background: #fff;
  color: #8c8c98;
  font-size: 24rpx;
  box-shadow: 0 6rpx 16rpx rgba(20, 42, 31, 0.04);
}

.filter-chip.active {
  background: #ff9f2f;
  color: #fff;
}

.batch-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.batch-info {
  font-size: 24rpx;
  color: #858a92;
}

.batch-actions {
  display: flex;
  gap: 12rpx;
}

.batch-btn {
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.batch-download {
  background: #f5f5f7;
  color: #333;
}

.batch-reject {
  background: #ffebee;
  color: #f44336;
}

.batch-accept {
  background: linear-gradient(135deg, #ff9a1f 0%, #ef6c00 100%);
  color: #fff;
}

.claims-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.batch-toggle {
  display: flex;
  justify-content: flex-end;
}

.batch-toggle-text {
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: #fff4e8;
  color: #ff9f2f;
  font-size: 22rpx;
  font-weight: 700;
}

.claim-item {
  position: relative;
}

.claim-item.selected {
  background: #fff8ef;
}

.claim-checkbox {
  position: absolute;
  right: 32rpx;
  top: 32rpx;
}

.claim-checkbox.disabled {
  opacity: 0.4;
}

.checkbox-icon {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid #d1d5db;
  background: #fff;
  position: relative;
}

.checkbox-icon.checked {
  background: #ff9f2f;
  border-color: #ff9f2f;
}

.checkbox-icon.checked::after {
  content: '';
  position: absolute;
  left: 10rpx;
  top: 6rpx;
  width: 10rpx;
  height: 16rpx;
  border-right: 3rpx solid #fff;
  border-bottom: 3rpx solid #fff;
  transform: rotate(40deg);
}

.claim-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.creator-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
}

.creator-avatar,
.creator-avatar-text {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.creator-avatar-text {
  background: linear-gradient(135deg, #ff9a1f 0%, #ef6c00 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
}

.creator-meta {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.creator-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
}

.submit-time {
  font-size: 22rpx;
  color: #8c8c98;
}

.status-badge {
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
}

.status-badge.pending {
  background: #EEF5FF;
  color: #4D8DFF;
}

.status-badge.passed {
  background: #e8f5e9;
  color: #35b86b;
}

.status-badge.rejected,
.status-badge.cancelled {
  background: #ffebee;
  color: #f44336;
}

.status-badge.reported {
  background: #FFF3EE;
  color: #EF4444;
}

.claim-content {
  margin-top: 20rpx;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  background: #f8fafc;
}

.claim-processing {
  background: #fff8e8;
}

.claim-content.claim-content-reported {
  padding: 16rpx 24rpx;
  background: #fef0f0;
  margin-top: 24rpx;
}

.content-text {
  font-size: 24rpx;
  color: #4b5563;
  line-height: 1.7;
}

.claim-content-reported .content-text {
  font-size: 24rpx;
  color: #ef4444;
  line-height: 1.7;
}

.media-preview {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
}

.media-preview-single .preview-thumb {
  width: 100%;
}

.preview-thumb {
  width: calc((100% - 16rpx) / 2);
  height: 328rpx;
  border-radius: 12rpx;
  overflow: hidden;
  position: relative;
  background: #f3f4f6;
}

.preview-thumb-video {
  background: #000;
}

.preview-thumb-video-player {
  width: 100%;
  height: 100%;
  display: block;
  background: #000;
}

.preview-thumb-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.preview-thumb-video {
  position: relative;
}

.video-link-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-top: 20rpx;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  background: #f5f5f7;
}

.video-link-label {
  font-size: 22rpx;
  color: #8c8c98;
  flex-shrink: 0;
}

.video-link-value {
  font-size: 22rpx;
  color: #2563eb;
  word-break: break-all;
}

.claim-footer {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #ececef;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.claim-title {
  flex: 1;
  font-size: 22rpx;
  color: #8c8c98;
}

.action-btns {
  display: flex;
  gap: 12rpx;
}

.action-btn {
  padding: 16rpx 40rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.action-btn.reject {
  background: #EF4444;
  color: #fff;
}

.action-btn.report {
  background: #fff;
  color: #333;
  border: 1rpx solid #ECECEF;
}

.action-btn.accept {
  background: #35B86B;
  color: #fff;
}

.action-btn.download-original {
  background: #eff6ff;
  color: #2563eb;
  border: 1rpx solid #bfdbfe;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  background: #fff4e8;
  color: #ff9f2f;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 700;
}

.empty-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #333;
  font-weight: 700;
}

.empty-hint {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #8c8c98;
}

/* 采纳二次确认（样式对齐创作者任务详情「创作者须知」弹窗） */
.creator-notice-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 1300;
  background: rgba(0, 0, 0, 0.52);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 48rpx;
}

.creator-notice-modal {
  width: 100%;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.creator-notice-body {
  padding: 48rpx;
}

.creator-notice-title {
  display: block;
  font-size: 34rpx;
  color: #333;
  margin-bottom: 48rpx;
  text-align: center;
}

.creator-notice-text {
  display: block;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  margin-top: 16rpx;
}

.creator-notice-footer {
  display: flex;
  border-top: 1rpx solid #ececef;
}

.creator-notice-btn {
  flex: 1;
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.creator-notice-btn text {
  font-size: 34rpx;
}

.creator-notice-btn-cancel {
  border-right: 1rpx solid #ececef;
}

.creator-notice-btn-cancel text {
  color: #555562;
}

.creator-notice-btn-confirm text {
  color: #7f8eb2;
}

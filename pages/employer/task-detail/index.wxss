/* pages/employer/task-detail/index.wxss */
.page {
  min-height: 100vh;
  background: #fafafa;
  display: flex;
  flex-direction: column;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 32rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.nav-left, .nav-right {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
}

.nav-back {
  width: 40rpx;
  height: 40rpx;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
}

/* 标签切换 */
.tab-switch {
  display: flex;
  position: relative;
  height: 104rpx;
  padding: 0 32rpx;
  background: #fff;
  align-items: flex-end;
}

.tab-item {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-text {
  font-size: 32rpx;
  font-weight: 400;
  color: #1d2129;
}

.tab-text.active {
  font-size: 32rpx;
  font-weight: 500;
  color: #ff8802;
}

.tab-indicator {
  position: absolute;
  bottom: 0;
  width: 48rpx;
  height: 4rpx;
  background: #ff8802;
  border-radius: 4rpx;
  transition: left 0.3s ease;
}

/* 标签内容 */
.tab-content {
  padding: 32rpx 24rpx;
}

/* 视频区域 */
.video-section {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* 视频提案审核卡片 */
.proposal-review-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 10rpx 26rpx rgba(20,42,31,0.08);
}

.proposal-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.proposal-title {
  font-size: 28rpx;
  font-weight: 900;
  color: #333;
}

.proposal-count {
  font-size: 24rpx;
  font-weight: 500;
  color: #8c8c98;
}

.proposal-arrow {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.arrow-text {
  font-size: 28rpx;
  color: #8c8c98;
}

/* 视频容器 */
.video-container {
  border-radius: 16rpx;
  overflow: hidden;
}

.video-player {
  width: 100%;
  height: 420rpx;
}

/* 视频占位 */
.video-placeholder {
  height: 420rpx;
  background: linear-gradient(160deg, #f1f3f8, #dde4ef);
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
}

.play-btn {
  width: 100rpx;
  height: 100rpx;
  background: rgba(255, 159, 47, 0.9);
  border-radius: 50%;
  position: relative;
}

.play-btn::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-40%, -50%);
  border-top: 20rpx solid transparent;
  border-bottom: 20rpx solid transparent;
  border-left: 32rpx solid #fff;
}

.video-hint {
  font-size: 26rpx;
  color: #666;
}

/* 任务ID卡片 */
.task-id-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 10rpx 26rpx rgba(20,42,31,0.08);
}

.id-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.id-label {
  font-size: 24rpx;
  font-weight: 500;
  color: #8c8c98;
}

.id-value {
  font-size: 28rpx;
  font-weight: 900;
  color: #222;
}

.copy-btn {
  padding: 12rpx 32rpx;
  background: #f5f5f7;
  border-radius: 32rpx;
  font-size: 24rpx;
  font-weight: 900;
  color: #555;
}

/* 详情卡片 */
.detail-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 10rpx 26rpx rgba(20,42,31,0.08);
}

.detail-title {
  font-size: 36rpx;
  font-weight: 900;
  color: #333;
  margin-bottom: 24rpx;
}

/* 奖励行 */
.reward-row {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.reward-item {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.reward-label {
  font-size: 24rpx;
  font-weight: 500;
  color: #8c8c98;
}

.reward-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #ef4444;
}

.reward-unit {
  font-size: 24rpx;
  font-weight: 500;
  color: #ef4444;
}

.reward-plus {
  font-size: 24rpx;
  font-weight: 500;
  color: #8c8c98;
}

.reward-value-dark {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
}

/* 标签行 */
.tags-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 24rpx;
}

.tag-group {
  display: flex;
  flex-direction: column;
}

.tag-label {
  font-size: 22rpx;
  font-weight: 500;
  color: #878ba1;
  padding: 4rpx 16rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
}

.tag-content {
  display: flex;
  flex-direction: column;
}

.tag-value {
  font-size: 22rpx;
  font-weight: 500;
  color: #878ba1;
  padding: 4rpx 16rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  margin-top: 8rpx;
}

/* 描述 */
.desc-section {
  background: #eef5ff;
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
  margin-bottom: 24rpx;
}

.desc-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  line-height: 45rpx;
}

/* 规格行 */
.spec-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
  border: 1px solid #ececef;
}

.spec-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #555;
}

.spec-value {
  font-size: 28rpx;
  font-weight: 900;
  color: #333;
}

/* 限制 */
.restriction-section {
  background: rgba(239,68,68,0.08);
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
  margin-top: 24rpx;
}

.restriction-text {
  font-size: 24rpx;
  font-weight: 500;
  color: #ef4444;
  line-height: 36rpx;
}

/* 素材卡片 */
.material-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 10rpx 26rpx rgba(20,42,31,0.08);
}

.card-header {
  margin-bottom: 24rpx;
}

.header-title {
  font-size: 28rpx;
  font-weight: 900;
  color: #333;
}

.material-grid {
  display: flex;
  flex-direction: row;
  gap: 24rpx;
}

.material-item {
  width: 206rpx;
  height: 192rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #f5f5f5;
}

.material-thumb {
  width: 100%;
  height: 100%;
}

/* 即梦卡片 */
.jimeng-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 38rpx;
  box-shadow: 0 10rpx 26rpx rgba(20,42,31,0.08);
}

.jimeng-content {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 32rpx;
  padding: 32rpx;
  background: #f5f5f7;
  border-radius: 16rpx;
}

.jimeng-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.jimeng-name {
  font-size: 28rpx;
  font-weight: 900;
  color: #333;
}

.jimeng-desc {
  font-size: 24rpx;
  font-weight: 500;
  color: #8c8c98;
  line-height: 36rpx;
  margin-top: 8rpx;
}

.jimeng-icon {
  width: 96rpx;
  height: 56rpx;
  margin-top: 16rpx;
}

.jimeng-link-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  border-radius: 8rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.link-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #000;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.link-count {
  font-size: 24rpx;
  font-weight: 500;
  color: #86909c;
  flex-shrink: 0;
  margin-left: 24rpx;
}

.jimeng-tutorial {
  font-size: 24rpx;
  font-weight: 900;
  color: #ff8802;
  text-align: left;
  padding: 24rpx 32rpx;
  margin: 24rpx 0;
}

.update-link-btn {
  text-align: center;
  padding: 16rpx;
  background: #ff9f2f;
  border-radius: 36rpx;
  font-size: 26rpx;
  font-weight: 900;
  color: #fff;
  margin: 24rpx 486rpx 32rpx 0;
}

.jimeng-edit-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  border-radius: 8rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.jimeng-edit-input {
  flex: 1;
  font-size: 28rpx;
  font-weight: 500;
  color: #000;
}

.confirm-update-btn {
  text-align: center;
  padding: 16rpx;
  background: linear-gradient(135deg, #ff9f2f 0%, #ef6c00 100%);
  border-radius: 36rpx;
  font-size: 26rpx;
  font-weight: 900;
  color: #fff;
  margin-top: 24rpx;
}

/* 底部占位 */
.bottom-placeholder {
  height: 50rpx;
}

/* 底部安全区 */
.group_9 {
  width: 750rpx;
  height: 50rpx;
  margin-bottom: 2rpx;
  display: flex;
  flex-direction: column;
}

.block_4 {
  background-color: rgba(17,17,17,0.92);
  border-radius: 1998rpx;
  width: 264rpx;
  height: 10rpx;
  display: flex;
  flex-direction: column;
  margin: 18rpx 0 0 244rpx;
}
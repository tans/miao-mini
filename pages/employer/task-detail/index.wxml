  <!-- 标签切换 -->
  <view class="tab-switch">
    <view class="tab-item {{currentTab === 'video' ? 'active' : ''}}" data-tab="video" bindtap="switchTab">
      <text class="tab-text {{currentTab === 'video' ? 'active' : ''}}">任务视频</text>
    </view>
    <view class="tab-item {{currentTab === 'detail' ? 'active' : ''}}" data-tab="detail" bindtap="switchTab">
      <text class="tab-text {{currentTab === 'detail' ? 'active' : ''}}">任务详情</text>
    </view>
    <view class="tab-indicator" style="left: {{currentTab === 'video' ? '48rpx' : '296rpx'}}"></view>
  </view>

  <!-- 任务视频 -->
  <view class="tab-content" wx:if="{{currentTab === 'video'}}">
    <view class="video-section">
      <!-- 视频提案审核入口 -->
      <view class="proposal-review-card" wx:if="{{proposalCount > 0}}" bindtap="goToProposalReview">
        <view class="proposal-info">
          <text class="proposal-title">视频提案</text>
          <text class="proposal-count">{{proposalCount}}个提案待审核</text>
        </view>
        <view class="proposal-arrow">
          <text class="arrow-text">></text>
        </view>
      </view>

      <!-- 视频播放区域 -->
      <view class="video-container" wx:if="{{task.video_url}}" bindtap="playVideo">
        <video id="taskVideo" class="video-player" src="{{task.video_url}}" controls />
      </view>
      <view class="video-placeholder" wx:else bindtap="playVideo">
        <view class="play-btn"></view>
        <text class="video-hint">点击播放任务视频</text>
      </view>
    </view>
  </view>

  <!-- 任务详情 -->
  <view class="tab-content" wx:if="{{currentTab === 'detail'}}">
    <!-- 任务ID卡片 -->
    <view class="task-id-card">
      <view class="id-info">
        <text class="id-label">任务ID</text>
        <text class="id-value">{{task.id || 'CC-20260418-000126'}}</text>
      </view>
      <view class="copy-btn" bindtap="copyTaskId">
        <text>复制</text>
      </view>
    </view>

    <!-- 任务详情卡片 -->
    <view class="detail-card">
      <text class="detail-title">{{task.title || '高端楼盘春日氛围视频'}}</text>

      <!-- 奖励信息 -->
      <view class="reward-row">
        <view class="reward-item">
          <text class="reward-label">采纳奖励</text>
        </view>
        <text class="reward-value">{{task.unit_price || 100}}</text>
        <text class="reward-unit">元/</text>
        <text class="reward-unit">条</text>
        <text class="reward-plus">+</text>
        <view class="reward-item">
          <text class="reward-label">参与奖励</text>
        </view>
        <text class="reward-value-dark">{{task.award_price || 10}}</text>
        <text class="reward-unit">元/</text>
        <text class="reward-unit">条</text>
      </view>

      <!-- 标签 -->
      <view class="tags-row">
        <view class="tag-group">
          <text class="tag-label">行业标签</text>
        </view>
        <view class="tag-group">
          <text class="tag-label">风格标签</text>
        </view>
        <view class="tag-content">
          <text class="tag-value">{{task.industry || '房产家居'}}</text>
        </view>
        <view class="tag-content">
          <text class="tag-value">{{task.style || '房产家居'}}</text>
        </view>
      </view>

      <!-- 描述 -->
      <view class="desc-section">
        <text class="desc-text">{{task.description || '突出空间通透感与生活方式场景，口语化表达，避免过度摆拍。适合地产、家居类创作者参与。'}}</text>
      </view>

      <!-- 视频规格 -->
      <view class="spec-row">
        <text class="spec-label">视频尺寸</text>
        <text class="spec-value">{{task.video_aspect || '9:16 竖屏'}}</text>
      </view>
      <view class="spec-row">
        <text class="spec-label">分辨率</text>
        <text class="spec-value">{{task.video_resolution || '1080P'}}</text>
      </view>
      <view class="spec-row">
        <text class="spec-label">视频时长</text>
        <text class="spec-value">{{task.video_duration || '30s'}}</text>
      </view>
      <view class="spec-row">
        <text class="spec-label">截稿时间</text>
        <text class="spec-value">{{task.end_at || '2026-04-24 18:00'}}</text>
      </view>

      <!-- 平台禁忌 -->
      <view class="restriction-section">
        <text class="restriction-text">平台禁忌：敏感词、低俗内容、侵权内容、政治敏感、广告夸大。</text>
      </view>
    </view>

    <!-- 商家素材 -->
    <view class="material-card" wx:if="{{materials.length > 0}}">
      <view class="card-header">
        <text class="header-title">商家素材</text>
      </view>
      <view class="material-grid">
        <view class="material-item" wx:for="{{materials}}" wx:key="id" bindtap="previewMaterial" data-url="{{item.file_path}}">
          <image wx:if="{{item.file_type === 'image'}}" class="material-thumb" src="{{item.file_path}}" mode="aspectFill"/>
          <video wx:if="{{item.file_type === 'video'}}" class="material-thumb" src="{{item.file_path}}" controls/>
        </view>
      </view>
    </view>

    <!-- 即梦合拍 -->
    <view class="jimeng-card" wx:if="{{task.jimeng_link || task.jimeng_enabled}}">
      <view class="card-header">
        <text class="header-title">即梦合拍</text>
      </view>
      <view class="jimeng-content">
        <view class="jimeng-info">
          <text class="jimeng-name">即梦合拍设置</text>
          <text class="jimeng-desc">商家提供数字人模型给创作者用于合成视频</text>
        </view>
        <image class="jimeng-icon" src="/assets/icons/jimeng.png" />
      </view>
      <view wx:if="{{!showEditJimeng}}" class="jimeng-link-row">
        <text class="link-text">{{task.jimeng_link || '暂未设置'}}</text>
        <text class="link-count">{{task.jimeng_link ? task.jimeng_link.length : 0}}/50</text>
      </view>
      <view wx:if="{{showEditJimeng}}" class="jimeng-edit-row">
        <input class="jimeng-edit-input" placeholder="请输入新的邀请链接" value="{{editJimengLink}}" bindinput="onJimengLinkInput" maxlength="50"/>
        <text class="link-count">{{editJimengLink.length}}/50</text>
      </view>
      <view class="jimeng-tutorial" bindtap="showJimengTutorial">
        <text>查看即梦合拍教程</text>
      </view>
      <view class="update-link-btn" bindtap="toggleEditJimeng">
        <text>{{showEditJimeng ? '取消' : '更新链接'}}</text>
      </view>
      <view wx:if="{{showEditJimeng}}" class="confirm-update-btn" bindtap="updateJimengLink">
        <text>确认更新</text>
      </view>
    </view>
  </view>

  <!-- 底部占位 -->
  <view class="bottom-placeholder"></view>
</view>

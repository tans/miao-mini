<view class="page">
  <view class="tab-switch">
    <view class="tab-item {{currentTab === 'proposals' ? 'active' : ''}}" data-tab="proposals" bindtap="switchTab">
      <text>任务视频</text>
    </view>
    <view class="tab-item {{currentTab === 'detail' ? 'active' : ''}}" data-tab="detail" bindtap="switchTab">
      <text>任务详情</text>
    </view>
  </view>

  <view class="content">
    <view class="tab-content" wx:if="{{currentTab === 'proposals'}}">

      <view class="stats-cards">
          <view class="stat-card">
            <text class="stat-card-label">总投稿数</text>
            <view class="stat-card-number-row">
              <text class="stat-card-value">{{totalSubmitted}}</text>
              <text class="stat-card-unit">/{{task.totalCount || 0}}</text>
            </view>
            <text class="stat-card-hint">{{proposalCount}} 个待审核</text>
          </view>
        <view class="stat-card">
          <text class="stat-card-label">总采纳数</text>
          <text class="stat-card-value">{{totalAdopted}}</text>
          <text class="stat-card-hint">{{adoptionRate}}% 采纳率</text>
        </view>
        <view class="stat-card">
          <text class="stat-card-label">总支出</text>
          <text class="stat-card-value">¥{{totalSpent}}</text>
          <text class="stat-card-hint">含采纳奖与参与奖</text>
        </view>
      </view>

      <view class="review-tip-card">
        <view class="safety-header">
          <image class="safety-badge" src="../../../images/home/msg-icon.png" />
          <text class="safety-title"><text class="safety-title-brand">创意喵</text>安全提醒</text>
        </view>
        <view class="safety-text">
          请在<text class="safety-highlight">收到投稿后48小时内审核稿件</text>，超时未审核将自动为创作者发放参与奖，后续继续采纳可自动补发采纳奖。
          采纳稿件后自动为创作者发放采纳奖+参与奖；淘汰自动发放参与奖；
          <text class="safety-highlight">如遇恶意低质量水稿件可直接举报</text>，平台介入确认事实后，退还此稿参与奖至商家钱包。
        </view>
      </view>
      <scroll-view class="filter-scroll" scroll-x="true" show-scrollbar="false">
        <view class="filter-tabs">
          <text
            wx:for="{{filters}}"
            wx:key="key"
            class="filter-chip {{activeFilter === item.key ? 'active' : ''}}"
            data-filter="{{item.key}}"
            bindtap="switchFilter"
          >{{item.label}}</text>
        </view>
      </scroll-view>
      <!-- <view class="batch-bar" wx:if="{{batchMode}}">
        <text class="batch-info">已选 {{selectedCount}} 个作品</text>
        <view class="batch-actions">
          <text class="batch-btn batch-download" bindtap="downloadSelected">下载</text>
          <text class="batch-btn batch-reject" data-action="2" bindtap="batchReview">淘汰</text>
          <text class="batch-btn batch-accept" data-action="1" bindtap="batchReview">采纳</text>
        </view>
      </view> -->

      <view class="claims-list" wx:if="{{filteredClaims.length > 0}}">
        <!-- <view class="batch-toggle" bindtap="toggleBatchMode">
          <text class="batch-toggle-text">{{batchMode ? '完成' : '批量操作'}}</text>
        </view> -->

        <view class="claim-item {{selectedClaims[claim.id] ? 'selected' : ''}}" wx:for="{{filteredClaims}}" wx:key="id" wx:for-item="claim">
          <view class="claim-checkbox {{!claim.canReview ? 'disabled' : ''}}" wx:if="{{batchMode}}" bindtap="toggleClaimSelection" data-claim-id="{{claim.id}}">
            <view class="checkbox-icon {{selectedClaims[claim.id] ? 'checked' : ''}}"></view>
          </view>

          <view class="claim-header">
            <view class="creator-info">
              <image class="creator-avatar" wx:if="{{claim.creatorAvatar}}" src="{{claim.creatorAvatar}}" mode="aspectFill" />
              <text class="creator-avatar-text" wx:else>{{claim.creatorInitial}}</text>
              <view class="creator-meta">
                <text class="creator-name">{{claim.creatorName}}</text>
                <text class="submit-time">{{claim.displayDate}}提交</text>
              </view>
            </view>
            <view class="status-badge {{claim.statusClass}}">
              <text>{{claim.statusText}}</text>
            </view>
          </view>

          <!-- <view class="claim-content" wx:if="{{claim.hasContent}}">
            <text class="content-text">{{claim.contentText}}</text>
          </view> -->

          <view class="claim-content claim-processing" wx:if="{{claim.processStatusText}}">
            <text class="content-text">{{claim.processStatusText}}</text>
          </view>

          <view class="media-preview" wx:if="{{claim.hasMaterials}}">
            <image
              wx:for="{{claim.previewImages}}"
              wx:for-item="img"
              wx:key="*this"
              class="preview-thumb"
              src="{{img}}"
              mode="aspectFill"
              data-claim-id="{{claim.id}}"
              data-current="{{img}}"
              bindtap="previewImages"
            />
            <view
              wx:for="{{claim.previewVideos}}"
              wx:for-item="vid"
              wx:key="url"
              class="preview-thumb preview-thumb-video"
              bindtap="previewClaimVideo"
              data-url="{{vid.url}}"
            >
              <image class="preview-thumb-image" src="{{vid.poster || vid.url}}" mode="aspectFill" />
              <view class="preview-play-badge"></view>
            </view>
          </view>

          <view class="video-link-row" wx:if="{{claim.videoLink}}">
            <text class="video-link-label">视频链接</text>
            <text class="video-link-value" data-url="{{claim.videoLink}}" bindtap="copyVideoLink">{{claim.videoLink}}</text>
          </view>

          <view class="claim-footer">
            <!-- <text class="claim-title">{{claim.taskTitle}}</text> -->
            <view class="action-btns" wx:if="{{claim.canReview}}">
              <text class="action-btn accept" data-claim-id="{{claim.id}}" data-result="1" bindtap="reviewClaim">采纳</text>
              <text class="action-btn reject" data-claim-id="{{claim.id}}" data-result="2" bindtap="reviewClaim">淘汰</text>
              <text class="action-btn report" data-claim-id="{{claim.id}}" data-result="3" bindtap="reviewClaim">举报</text>
            </view>
            <view class="action-btns" wx:if="{{claim.canDownloadOriginalVideo}}">
              <text class="action-btn download-original" data-claim-id="{{claim.id}}" bindtap="downloadClaimOriginalVideo">下载原视频</text>
            </view>
          </view>
        </view>
      </view>

      <view class="empty-state" wx:if="{{!loading && filteredClaims.length === 0}}">
        <view class="empty-icon">稿</view>
        <text class="empty-text">{{claimsLoadFailed ? '投稿加载失败' : '暂无投稿'}}</text>
        <text class="empty-hint">{{claimsLoadFailed ? (claimsLoadErrorMessage || '请下拉重试') : '该任务还没有可审核的作品'}}</text>
      </view>
    </view>

    <view class="tab-content" wx:if="{{currentTab === 'detail'}}">
      <!-- <view class="merchant-card">
        <view class="merchant-main">
          <image wx:if="{{task.businessAvatar}}" class="merchant-avatar" src="{{task.businessAvatar}}" mode="aspectFill" />
          <view wx:else class="merchant-avatar merchant-avatar-fallback">商</view>
          <view class="merchant-info">
            <text class="merchant-name">{{task.businessName || '商家'}}</text>
            <view class="merchant-badges">
              <view class="badge badge-brand">
                <text class="badge-dot"></text>
                <text class="badge-text">品牌名企</text>
              </view>
              <view class="badge badge-trusted">
                <text class="badge-dot"></text>
                <text class="badge-text">资金已托管</text>
              </view>
            </view>
          </view>
        </view>

        <view class="merchant-stats">
          <view class="stat-item">
            <text class="stat-label">平均采纳率</text>
            <text class="stat-value">{{adoptionRate || task.adoptionRate || 0}}%</text>
          </view>
          <view class="stat-item">
            <text class="stat-label">累计发布</text>
            <text class="stat-value">{{task.totalPublished || 0}}</text>
            <text class="stat-unit">个任务</text>
          </view>
          <view class="stat-item">
            <text class="stat-label">累计支出</text>
            <text class="stat-value">¥{{totalSpent || task.totalSpent || 0}}</text>
          </view>
        </view>
      </view> -->

      <view class="task-id-card">
        <view class="id-info">
          <text class="id-label">任务ID</text>
          <text class="id-value">{{task.id || '--'}}</text>
        </view>
        <view class="copy-btn" bindtap="copyTaskId">
          <text>复制</text>
        </view>
      </view>

      <view class="detail-card">
        <text class="detail-card-title">任务详情</text>
        <text class="detail-title">{{task.title || ''}}</text>

        <view class="reward-row">
          <view class="reward-item">
            <text class="reward-label">参与奖励</text>
            <view class="reward-value-row">
              <text class="reward-value">{{task.unit_price}}</text>
              <text class="reward-unit">元/条</text>
            </view>
          </view>
          <text class="reward-plus">+</text>
          <view class="reward-item">
            <text class="reward-label">采纳奖励</text>
            <view class="reward-value-row">
              <text class="reward-value reward-value-dark">{{task.award_price}}</text>
              <text class="reward-unit">元/条</text>
            </view>
          </view>
        </view>

        <view class="tags-row">
          <view class="tag-list">
            <view class="tag-chip" wx:for="{{task.industryTags}}" wx:key="index">
              <text class="tag-chip-text">{{item}}</text>
            </view>
            <view class="tag-chip" wx:for="{{task.styleTags}}" wx:key="index">
              <text class="tag-chip-text">{{item}}</text>
            </view>
          </view>
        </view>

        <view class="desc-section">
          <text class="desc-text">{{task.description || '暂无任务描述'}}</text>
        </view>

        <view class="specs-grid">
          <view class="spec-item">
            <text class="spec-label">视频尺寸</text>
            <text class="spec-value">{{task.videoAspect || '未设置'}}</text>
          </view>
          <view class="spec-item">
            <text class="spec-label">分辨率</text>
            <text class="spec-value">{{task.videoResolution || '未设置'}}</text>
          </view>
          <view class="spec-item">
            <text class="spec-label">视频时长</text>
            <text class="spec-value">{{task.videoDuration || '未设置'}}</text>
          </view>
          <view class="spec-item">
            <text class="spec-label">截稿时间</text>
            <text class="spec-value">{{task.endAt || '未设置'}}</text>
          </view>
          <view class="spec-item">
            <text class="spec-label">作品权限</text>
            <text class="spec-value">{{task.visibilityText || '公开投稿'}}</text>
          </view>
        </view>

        <view class="restriction-section">
          <text class="restriction-text">平台禁忌：敏感词、低俗内容、侵权内容、政治敏感、广告夸大。</text>
        </view>
      </view>

      <view class="material-card">
        <view class="section-header">
          <text class="header-title">商家素材</text>
          <view class="header-link" bindtap="downloadAllMaterials">
            <text>下载全部</text>
          </view>
        </view>
        <view class="material-grid" wx:if="{{materials.length > 0}}">
          <view
            class="material-item"
            wx:for="{{materials}}"
            wx:key="file_path"
            bindtap="previewMaterial"
            data-url="{{item.file_path}}"
            data-type="{{item.file_type}}"
          >
            <image
              class="material-thumb"
              src="{{item.file_type === 'video' ? (item.thumbnail_path || item.file_path) : item.file_path}}"
              mode="aspectFill"
            />
            <view class="material-video-badge" wx:if="{{item.file_type === 'video'}}"></view>
          </view>
        </view>
        <view class="empty-tip" wx:else>暂无商家素材</view>
      </view>

      <view class="jimeng-card" wx:if="{{task.jimengEnabled}}">
        <view class="section-header">
          <text class="header-title">即梦合拍</text>
        </view>
        <view class="jimeng-content">
          <view class="jimeng-content-main">
            <view class="jimeng-content-header">
              <text class="header-hint">即梦合拍设置</text>
              <text class="header-hint">商家提供数字人模型给创作者用于合成视频</text>
            </view>
            <switch class="switch-icon" checked="{{task.jimengEnabled}}" color="#FF9F2F" disabled/>
          </view>
          
          <!-- <view wx:if="{{!showEditJimeng}}" class="jimeng-link-row">
          <text class="jimeng-link">{{task.jimengLink || '暂未设置'}}</text>
          <text class="jimeng-count">{{task.jimengLinkLength || 0}}/50</text>
          </view> -->
          
          <view class="jimeng-edit-row">
            <input
              class="jimeng-edit-input"
              placeholder="请输入新的邀请链接"
              value="{{editJimengLink}}"
              bindinput="onJimengLinkInput"
              maxlength="50"
            />
            <text class="jimeng-count">{{editJimengLink.length}}/50</text>
          </view>

          <view class="jimeng-actions">
            <view class="jimeng-tutorial" bindtap="showJimengTutorial">
              <text>查看即梦合拍教程</text>
            </view>
          </view>
        </view>
        

        
        <view class="jimeng-confirm" bindtap="updateJimengLink">
          <text>更新链接</text>
        </view>
      </view>

      <!-- <view class="safety-card">
        <view class="safety-header">
          <view class="safety-badge">安</view>
          <text class="safety-title">安全提醒</text>
        </view>
        <text class="safety-text">如发现违规需求或恶意灌水稿件，可在“全部投稿”中直接处理或举报。</text>
      </view> -->
    </view>
  </view>
</view>

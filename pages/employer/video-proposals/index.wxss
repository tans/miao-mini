/* pages/video-proposals/index.wxss */
.proposals-container {
  min-height: 100vh;
  background: #fafafa;
  padding-bottom: 120rpx;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 32rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.nav-left, .nav-right {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
}

.nav-back {
  width: 40rpx;
  height: 40rpx;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 900;
  color: #333;
}

/* 标签切换 */
.tab-switch {
  display: flex;
  position: relative;
  padding: 0 48rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.tab-item {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #8c8c98;
}

.tab-item.active {
  color: #333;
}

.tab-indicator {
  position: absolute;
  bottom: 0;
  width: 104rpx;
  height: 6rpx;
  background: #ff9f2f;
  border-radius: 3rpx;
  transition: left 0.3s ease;
}

/* 标签内容 */
.tab-content {
  padding: 24rpx;
}

/* 投稿流程 */
.process-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(17, 17, 17, 0.04);
}

.process-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.process-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.step-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  background: #f5f5f5;
}

.step-title {
  font-size: 24rpx;
  color: #333;
}

.process-arrow {
  width: 48rpx;
  height: 24rpx;
  background: #f0f0f0;
  border-radius: 12rpx;
}

/* 任务信息卡片 */
.task-info-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(17, 17, 17, 0.04);
}

/* 商家信息 */
.merchant-section {
  margin-bottom: 24rpx;
}

.merchant-main {
  display: flex;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.merchant-logo {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  background: #f0f0f0;
}

.merchant-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.merchant-name {
  font-size: 30rpx;
  font-weight: 900;
  color: #333;
}

.merchant-badges {
  display: flex;
  gap: 16rpx;
}

.badge {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 12rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
}

.badge-icon {
  width: 24rpx;
  height: 24rpx;
}

.badge text {
  font-size: 22rpx;
  color: #333;
}

.merchant-stats {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  font-size: 24rpx;
}

.stat-label {
  color: #8c8c98;
}

.stat-value {
  color: #333;
  font-weight: 600;
}

.stat-separator {
  color: #8c8c98;
}

/* 任务ID */
.task-id-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
}

.id-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.id-label {
  font-size: 24rpx;
  color: #8c8c98;
}

.id-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.copy-btn {
  padding: 12rpx 32rpx;
  background: #ff9f2f;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 900;
  color: #fff;
}

/* 详情区块 */
.detail-section {
  margin-bottom: 24rpx;
}

.detail-title {
  font-size: 28rpx;
  font-weight: 900;
  color: #333;
  margin-bottom: 16rpx;
}

.task-name {
  font-size: 32rpx;
  font-weight: 900;
  color: #333;
  display: block;
  margin-bottom: 24rpx;
}

/* 奖励 */
.reward-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.reward-item {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.reward-label {
  font-size: 24rpx;
  color: #000;
}

.reward-value {
  font-size: 32rpx;
  font-weight: 900;
  color: #de872c;
}

.reward-unit {
  font-size: 24rpx;
  color: #000;
}

.reward-plus {
  font-size: 32rpx;
  color: #de872c;
}

/* 标签 */
.tags-row {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.tag-group {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.tag-label {
  font-size: 24rpx;
  color: #8c8c98;
}

.tag-content {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 12rpx 16rpx;
}

.tag-value {
  font-size: 24rpx;
  font-weight: 900;
  color: #333;
}

/* 描述 */
.desc-section {
  padding: 24rpx 0;
  border-top: 1rpx solid #f0f0f0;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 24rpx;
}

.desc-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.7;
}

/* 规格 */
.spec-row {
  display: flex;
  margin-bottom: 16rpx;
}

.spec-item {
  display: flex;
  gap: 12rpx;
}

.spec-label {
  font-size: 26rpx;
  color: #8c8c98;
}

.spec-value {
  font-size: 26rpx;
  color: #333;
}

/* 限制 */
.restriction-section {
  padding: 24rpx 0;
}

.restriction-text {
  font-size: 24rpx;
  color: #ef4444;
  line-height: 1.6;
}

/* 素材区块 */
.material-section {
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.header-title {
  font-size: 30rpx;
  font-weight: 900;
  color: #333;
}

.download-all-btn {
  padding: 8rpx 20rpx;
  background: #f5f5f5;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #333;
}

.material-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.material-item {
  aspect-ratio: 1;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f5f5f5;
}

.material-thumb {
  width: 100%;
  height: 100%;
}

/* 即梦区块 */
.jimeng-section {
  background: #fef9e8;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.jimeng-content {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
}

.jimeng-link {
  font-size: 24rpx;
  color: #8c8c98;
}

/* 安全提醒 */
.safety-card {
  background: #fff4e8;
  border-radius: 16rpx;
  padding: 24rpx;
}

.safety-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.safety-icon {
  width: 40rpx;
  height: 40rpx;
  border-radius: 8rpx;
  background: #fff;
}

.safety-title {
  font-size: 28rpx;
  font-weight: 900;
  color: #333;
}

.safety-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

/* Stats Cards */
.stats-cards {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(17, 17, 17, 0.04);
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.stat-card .stat-label {
  font-size: 24rpx;
  color: #878fa1;
}

.stat-card .stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #000;
  font-family: D-DIN-PRO-Bold, sans-serif;
}

.stat-card .stat-hint {
  font-size: 24rpx;
  color: #35b86b;
}

/* Safety Card for Proposals */
.proposals-container .safety-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 10rpx 26rpx rgba(20, 42, 31, 0.08);
}

.proposals-container .safety-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.proposals-container .safety-icon {
  width: 40rpx;
  height: 40rpx;
}

.proposals-container .safety-title {
  font-size: 26rpx;
  font-weight: 900;
  color: #f58a1f;
}

.proposals-container .safety-content {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.proposals-container .safety-text {
  font-size: 24rpx;
  color: #858a92;
  line-height: 36rpx;
}

.proposals-container .safety-highlight {
  font-size: 24rpx;
  color: #f58a1f;
  line-height: 36rpx;
}

/* Filter Tabs */
.filter-tabs {
  display: flex;
  background: #fff;
  padding: 24rpx 32rpx;
  gap: 48rpx;
  border-bottom: 1rpx solid #f0f0f0;
  margin: -24rpx -24rpx 0 -24rpx;
  flex-wrap: wrap;
}

.tab {
  font-size: 28rpx;
  color: #8c8c98;
  padding-bottom: 8rpx;
}

.tab.active {
  color: #ff9f2f;
  font-weight: 600;
  border-bottom: 4rpx solid #ff9f2f;
}

/* Batch Operation Bar */
.batch-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  padding: 24rpx 32rpx;
  margin-bottom: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(17, 17, 17, 0.04);
}

.batch-info {
  font-size: 25rpx;
  color: #858a92;
}

.batch-actions {
  display: flex;
  gap: 16rpx;
}

.batch-btn {
  padding: 16rpx 32rpx;
  border-radius: 19998rpx;
  font-size: 26rpx;
  font-weight: 900;
}

.batch-btn.batch-download {
  border: 1rpx solid #ececef;
  color: #333;
}

.batch-btn.batch-reject {
  background: #ffebee;
  color: #f44336;
}

.batch-btn.batch-accept {
  background: linear-gradient(135deg, #ff9f2f 0%, #ef6c00 100%);
  color: #fff;
}

/* Batch Toggle */
.batch-toggle {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 16rpx;
}

.batch-toggle-text {
  font-size: 24rpx;
  color: #ff9f2f;
  padding: 8rpx 20rpx;
  background: #fff4e8;
  border-radius: 20rpx;
}

.batch-toggle.done .batch-toggle-text {
  color: #52c41a;
  background: #e8f5e9;
}

/* Claims List */
.claims-list {
  margin-top: 24rpx;
}

.claim-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(17, 17, 17, 0.04);
  position: relative;
}

.claim-item.selectable {
  padding-left: 80rpx;
}

.claim-item.selected {
  background: #fff4e8;
}

/* Claim Checkbox */
.claim-checkbox {
  position: absolute;
  left: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 40rpx;
  height: 40rpx;
}

.checkbox-icon {
  width: 40rpx;
  height: 40rpx;
}

/* Claims List */
.claims-list {
  margin-top: 24rpx;
}

.claim-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(17, 17, 17, 0.04);
}

.claim-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.creator-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.creator-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #f0f0f0;
}

.creator-avatar-text {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff9f2f, #ef6c00);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
}

.creator-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.status-badge {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.status-badge.pending {
  background: #fff4e8;
  color: #ff9f2f;
}

.status-badge.passed {
  background: #e8f5e9;
  color: #52c41a;
}

.status-badge.rejected {
  background: #ffebee;
  color: #f44336;
}

.status-badge.reported {
  background: #fff3e0;
  color: #ff9800;
}

/* Media Preview */
.media-preview {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.preview-img {
  width: 100%;
  aspect-ratio: 1;
  border-radius: 12rpx;
  background: #f0f0f0;
}

.preview-video {
  width: 100%;
  aspect-ratio: 1;
  border-radius: 12rpx;
  background: #f0f0f0;
}

/* Video Link */
.video-link-row {
  display: flex;
  gap: 12rpx;
  padding: 16rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.video-link-label {
  font-size: 24rpx;
  color: #8c8c98;
  flex-shrink: 0;
}

.video-link-value {
  font-size: 24rpx;
  color: #2563eb;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* Footer */
.claim-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.submit-time {
  font-size: 24rpx;
  color: #8c8c98;
}

.action-btns {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.action-btn.reject {
  background: #ffebee;
  color: #f44336;
}

.action-btn.report {
  background: #fff3e0;
  color: #ff9800;
}

.action-btn.accept {
  background: #e8f5e9;
  color: #52c41a;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #8c8c98;
}

/* 底部操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.08);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.deadline-info {
  flex: 1;
}

.deadline-text {
  font-size: 24rpx;
  color: #ef4444;
}

.submit-btn {
  padding: 16rpx 48rpx;
  background: linear-gradient(135deg, #ff9f2f 0%, #ef6c00 100%);
  border-radius: 36rpx;
  font-size: 28rpx;
  font-weight: 900;
  color: #fff;
}

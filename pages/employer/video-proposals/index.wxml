<view class="proposals-container">
  <!-- 顶部状态栏 -->
  <view class="status-bar">
    <text class="status-time">9:41</text>
    <view class="status-icons">
      <view class="signal-icon"></view>
      <view class="wifi-icon"></view>
      <view class="battery-icon"></view>
    </view>
  </view>

  <!-- 标题栏 -->
  <view class="page-header">
    <view class="back-btn" bindtap="goBack">
      <image src="/assets/icons/back.png" class="back-icon" />
    </view>
    <text class="page-title">任务详情</text>
    <view class="message-btn">
      <image src="/assets/icons/message.png" class="message-icon" />
    </view>
  </view>

  <!-- 标签切换 -->
  <view class="tab-switch">
    <view class="tab-item {{currentTab === 'detail' ? 'active' : ''}}" data-tab="detail" bindtap="switchTab">
      <text>任务详情</text>
    </view>
    <view class="tab-item {{currentTab === 'proposals' ? 'active' : ''}}" data-tab="proposals" bindtap="switchTab">
      <text>全部投稿</text>
    </view>
    <view class="tab-indicator" style="left: {{currentTab === 'detail' ? '72rpx' : '296rpx'}}"></view>
  </view>

  <!-- 任务详情 -->
  <view class="tab-content" wx:if="{{currentTab === 'detail'}}">
    <!-- 投稿流程 -->
    <view class="process-card">
      <view class="process-header">
        <view class="process-step">
          <image src="/assets/icons/upload-step1.png" class="step-icon" />
          <text class="step-title">报名后按时交稿</text>
        </view>
        <view class="process-arrow"></view>
        <view class="process-step">
          <image src="/assets/icons/review-step2.png" class="step-icon" />
          <text class="step-title">商家审核付款</text>
        </view>
        <view class="process-arrow"></view>
        <view class="process-step">
          <image src="/assets/icons/wallet-step3.png" class="step-icon" />
          <text class="step-title">钱包提现奖励</text>
        </view>
      </view>
    </view>

    <!-- 任务信息卡片 -->
    <view class="task-info-card" wx:if="{{task}}">
      <!-- 商家信息 -->
      <view class="merchant-section">
        <view class="merchant-main">
          <image class="merchant-logo" src="{{task.businessAvatar || '/assets/icons/avatar-default.jpg'}}" mode="aspectFill"/>
          <view class="merchant-info">
            <text class="merchant-name">{{task.business_name || task.businessName || '商家'}}</text>
            <view class="merchant-badges">
              <view class="badge" wx:if="{{task.isBrandVerified}}">
                <image src="/assets/icons/brand-badge.png" class="badge-icon" />
                <text>品牌名企</text>
              </view>
              <view class="badge" wx:if="{{task.isFundEscrow}}">
                <image src="/assets/icons/escrow-badge.png" class="badge-icon" />
                <text>资金已托管</text>
              </view>
            </view>
          </view>
        </view>
        <view class="merchant-stats">
          <text class="stat-label">平均采纳率</text>
          <text class="stat-value">{{task.adoptionRate || '86'}}%</text>
          <text class="stat-separator">累计发布</text>
          <text class="stat-value">{{task.totalPublished || 120}}</text>
          <text class="stat-separator">个任务 累计支出</text>
          <text class="stat-value">¥{{task.totalPaid || 6800}}</text>
        </view>
      </view>

      <!-- 任务ID -->
      <view class="task-id-row">
        <view class="id-info">
          <text class="id-label">任务ID</text>
          <text class="id-value">{{task.id || 'CC-20260418-000126'}}</text>
        </view>
        <view class="copy-btn" bindtap="copyTaskId">
          <text>复制</text>
        </view>
      </view>

      <!-- 任务详情 -->
      <view class="detail-section">
        <text class="detail-title">任务详情</text>
        <text class="task-name">{{task.title || '高端楼盘春日氛围视频'}}</text>

        <!-- 奖励 -->
        <view class="reward-row">
          <view class="reward-item">
            <text class="reward-label">采纳奖励</text>
            <text class="reward-value">{{task.unit_price || 100}}</text>
            <text class="reward-unit">元/</text>
            <text class="reward-unit">条</text>
          </view>
          <text class="reward-plus">+</text>
          <view class="reward-item">
            <text class="reward-label">参与奖励</text>
            <text class="reward-value">{{task.award_price || 10}}</text>
            <text class="reward-unit">元/</text>
            <text class="reward-unit">条</text>
          </view>
        </view>

        <!-- 标签 -->
        <view class="tags-row">
          <view class="tag-group">
            <text class="tag-label">行业标签</text>
            <view class="tag-content">
              <text class="tag-value">{{task.industry || '房产家居'}}</text>
            </view>
          </view>
          <view class="tag-group">
            <text class="tag-label">风格标签</text>
            <view class="tag-content">
              <text class="tag-value">{{task.style || '房产家居'}}</text>
            </view>
          </view>
        </view>

        <!-- 描述 -->
        <view class="desc-section">
          <text class="desc-text">{{task.description || '突出空间通透感与生活方式场景，口语化表达，避免过度摆拍。适合地产、家居类创作者参与。'}}</text>
        </view>

        <!-- 视频规格 -->
        <view class="spec-row">
          <view class="spec-item">
            <text class="spec-label">视频尺寸</text>
            <text class="spec-value">{{task.video_aspect || '9:16 竖屏'}}</text>
          </view>
        </view>
        <view class="spec-row">
          <view class="spec-item">
            <text class="spec-label">分辨率</text>
            <text class="spec-value">{{task.video_resolution || '1080P'}}</text>
          </view>
        </view>
        <view class="spec-row">
          <view class="spec-item">
            <text class="spec-label">视频时长</text>
            <text class="spec-value">{{task.video_duration || '30s'}}</text>
          </view>
        </view>
        <view class="spec-row">
          <view class="spec-item">
            <text class="spec-label">截稿时间</text>
            <text class="spec-value">{{task.end_at || '2026-04-24 18:00'}}</text>
          </view>
        </view>

        <!-- 限制 -->
        <view class="restriction-section">
          <text class="restriction-text">平台禁忌：敏感词、低俗内容、侵权内容、政治敏感、广告夸大。</text>
        </view>
      </view>

      <!-- 商家素材 -->
      <view class="material-section" wx:if="{{materials.length > 0}}">
        <view class="section-header">
          <text class="header-title">商家素材</text>
          <view class="download-all-btn">
            <text>下载全部</text>
          </view>
        </view>
        <view class="material-grid">
          <view class="material-item" wx:for="{{materials}}" wx:key="id" bindtap="previewMaterial" data-url="{{item.file_path}}">
            <image wx:if="{{item.file_type === 'image'}}" class="material-thumb" src="{{item.file_path}}" mode="aspectFill"/>
            <video wx:if="{{item.file_type === 'video'}}" class="material-thumb" src="{{item.file_path}}" controls/>
          </view>
        </view>
      </view>

      <!-- 即梦合拍 -->
      <view class="jimeng-section" wx:if="{{task.jimeng_link}}">
        <view class="section-header">
          <text class="header-title">即梦合拍邀拍链接</text>
        </view>
        <view class="jimeng-content">
          <text class="jimeng-link">{{task.jimeng_link || '报名后可见'}}</text>
        </view>
      </view>

      <!-- 安全提醒 -->
      <view class="safety-card">
        <view class="safety-header">
          <image src="/assets/icons/safety-icon.png" class="safety-icon" />
          <text class="safety-title">创意喵 安全提醒</text>
        </view>
        <text class="safety-text">如发现商家发布违规需求可立即举报。创作者请勿提交无关稿件或违规稿件，被举报超过 5 次将永久封号。</text>
      </view>
    </view>
  </view>

  <!-- 全部投稿 -->
  <view class="tab-content" wx:if="{{currentTab === 'proposals'}}">
    <!-- Filter Tabs -->
    <view class="filter-tabs">
      <text
        wx:for="{{filters}}"
        wx:key="key"
        class="tab {{activeFilter === item.key ? 'active' : ''}}"
        data-filter="{{item.key}}"
        bindtap="switchFilter"
      >{{item.label}}</text>
    </view>

    <!-- Claims List -->
    <view class="claims-list" wx:if="{{filteredClaims.length > 0}}">
      <view class="claim-item" wx:for="{{filteredClaims}}" wx:key="id">
        <!-- Claim Header -->
        <view class="claim-header">
          <view class="creator-info">
            <image class="creator-avatar" wx:if="{{item.creatorAvatar}}" src="{{item.creatorAvatar}}" mode="aspectFill"/>
            <text class="creator-avatar-text" wx:else>{{item.creatorInitial}}</text>
            <text class="creator-name">{{item.creatorName}}</text>
          </view>
          <view class="status-badge status-{{item.statusClass}}">{{item.statusText}}</view>
        </view>

        <!-- Content -->
        <view class="claim-content" wx:if="{{item.hasContent}}">
          <text class="content-text">{{item.contentText}}</text>
        </view>

        <!-- Media Preview -->
        <view class="media-preview" wx:if="{{item.hasMaterials}}">
          <image
            wx:for="{{item.previewImages}}"
            wx:for-item="img"
            wx:key="*this"
            class="preview-img"
            src="{{img}}"
            mode="aspectFill"
            data-claim-index="{{index}}"
            data-current="{{img}}"
            bindtap="previewImages"
          />
          <video
            wx:for="{{item.previewVideos}}"
            wx:for-item="vid"
            wx:key="url"
            class="preview-video"
            src="{{vid.url}}"
            poster="{{vid.poster}}"
            objectFit="cover"
          />
        </view>

        <!-- Video Link -->
        <view class="video-link-row" wx:if="{{item.videoLink}}">
          <text class="video-link-label">视频链接:</text>
          <text class="video-link-value" data-url="{{item.videoLink}}" bindtap="copyVideoLink">{{item.videoLink}}</text>
        </view>

        <!-- Footer -->
        <view class="claim-footer">
          <text class="submit-time">{{item.displayDate}}</text>
          <view class="action-btns" wx:if="{{item.canReview}}">
            <text class="action-btn reject" data-claim-id="{{item.id}}" data-result="2" bindtap="reviewClaim">拒绝</text>
            <text class="action-btn report" data-claim-id="{{item.id}}" data-result="3" bindtap="reviewClaim">举报</text>
            <text class="action-btn accept" data-claim-id="{{item.id}}" data-result="1" bindtap="reviewClaim">采纳</text>
          </view>
        </view>
      </view>
    </view>

    <!-- Empty State -->
    <view class="empty-state" wx:if="{{!loading && filteredClaims.length === 0}}">
      <view class="empty-icon">📋</view>
      <text class="empty-text">暂无提案</text>
      <text class="empty-hint">该任务还没有人提交作品</text>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="action-bar" wx:if="{{currentTab === 'detail'}}">
    <view class="deadline-info">
      <text class="deadline-text">截稿倒计时：{{deadlineText}}</text>
    </view>
    <view class="submit-btn" bindtap="goSubmitWork">
      <text>上传稿件</text>
    </view>
  </view>
</view>

<view class="recharge-container">
    <text class="nav-title">账户充值</text>
    <view class="nav-right"></view>
  </view>

  <!-- 余额显示 -->
  <view class="balance-section">
    <view class="balance-bg">
      <view class="balance-main">
        <text class="balance-label">当前余额(元)</text>
        <view class="balance-amount-row">
          <text class="balance-yuan">¥</text>
          <text class="balance-value">{{balanceDisplay}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 充值金额选择 -->
  <view class="amount-section">
    <view class="section-title">选择充值金额</view>
    <view class="amount-grid">
      <view class="amount-item {{selectedAmount === 100 ? 'active' : ''}}" bindtap="selectAmount" data-amount="100">
        <text class="amount-value">¥100</text>
      </view>
      <view class="amount-item {{selectedAmount === 500 ? 'active' : ''}}" bindtap="selectAmount" data-amount="500">
        <text class="amount-value">¥500</text>
      </view>
      <view class="amount-item {{selectedAmount === 1000 ? 'active' : ''}}" bindtap="selectAmount" data-amount="1000">
        <text class="amount-value">¥1000</text>
      </view>
      <view class="amount-item {{selectedAmount === 2000 ? 'active' : ''}}" bindtap="selectAmount" data-amount="2000">
        <text class="amount-value">¥2000</text>
      </view>
      <view class="amount-item {{selectedAmount === 5000 ? 'active' : ''}}" bindtap="selectAmount" data-amount="5000">
        <text class="amount-value">¥5000</text>
      </view>
      <view class="amount-item {{selectedAmount === 10000 ? 'active' : ''}}" bindtap="selectAmount" data-amount="10000">
        <text class="amount-value">¥10000</text>
      </view>
    </view>

    <!-- 自定义金额 -->
    <view class="custom-amount">
      <text class="custom-label">自定义金额</text>
      <view class="custom-input-row">
        <text class="custom-yuan">¥</text>
        <input type="digit" class="custom-input" placeholder="请输入金额" value="{{customAmount}}" bindinput="onCustomAmountInput"/>
      </view>
    </view>
  </view>

  <!-- 充值说明 -->
  <view class="notice-section">
    <view class="notice-item">
      <text class="notice-icon">•</text>
      <text class="notice-text">充值金额将用于发布任务和支付创作者费用</text>
    </view>
    <view class="notice-item">
      <text class="notice-icon">•</text>
      <text class="notice-text">充值成功后，金额将即时到账</text>
    </view>
  </view>

  <!-- 确认充值按钮 -->
  <view class="submit-section">
    <button class="submit-btn" bindtap="handleRecharge" loading="{{loading}}">确认充值</button>
  </view>
</view>
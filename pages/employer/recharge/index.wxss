.recharge-container {
  min-height: 100vh;
  background: #fafafa;
}

/* 顶部导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 32rpx;
  background: #fff;
}

.nav-left {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
}

.nav-back {
  width: 40rpx;
  height: 40rpx;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
}

.nav-right {
  width: 40rpx;
}

/* 余额显示 */
.balance-section {
  background: #fff;
  padding-bottom: 32rpx;
}

.balance-bg {
  background: linear-gradient(135deg, #ff9a1f 0%, #ef6c00 100%);
  padding: 40rpx 32rpx 32rpx;
}

.balance-main {
  text-align: center;
}

.balance-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.balance-amount-row {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 8rpx;
  margin-top: 12rpx;
}

.balance-yuan {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.balance-value {
  font-size: 64rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1;
}

/* 充值金额选择 */
.amount-section {
  background: #fff;
  padding: 32rpx;
  margin-top: 24rpx;
}

.section-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 32rpx;
}

.amount-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.amount-item {
  width: calc(33.33% - 16rpx);
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
}

.amount-item.active {
  background: #fff7ed;
  border-color: #ef6c00;
}

.amount-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.amount-item.active .amount-value {
  color: #ef6c00;
}

/* 自定义金额 */
.custom-amount {
  margin-top: 32rpx;
  padding-top: 32rpx;
  border-top: 1rpx solid #f0f0f0;
}

.custom-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 24rpx;
  display: block;
}

.custom-input-row {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 24rpx;
}

.custom-yuan {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-right: 16rpx;
}

.custom-input {
  flex: 1;
  font-size: 32rpx;
  color: #333;
}

/* 充值说明 */
.notice-section {
  background: #fff;
  padding: 32rpx;
  margin-top: 24rpx;
}

.notice-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.notice-item:last-child {
  margin-bottom: 0;
}

.notice-icon {
  color: #ef6c00;
  font-size: 28rpx;
  line-height: 1;
}

.notice-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

/* 确认充值按钮 */
.submit-section {
  padding: 32rpx;
  margin-top: 24rpx;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #ff9a1f 0%, #ef6c00 100%);
  border-radius: 44rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  border: none;
}

.submit-btn::after {
  border: none;
}

.submit-btn[loading] {
  opacity: 0.7;
}
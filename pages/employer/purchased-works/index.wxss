.works-container {
  min-height: 100vh;
  background: #f3f3f3;
  padding: 24rpx;
  box-sizing: border-box;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 32rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.nav-left, .nav-right {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
}

.nav-back {
  width: 40rpx;
  height: 40rpx;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 900;
  color: #333;
}

/* 作品网格 */
.works-grid {
  column-count: 2;
  column-gap: 24rpx;
  padding: 0;
}

/* 作品卡片 */
.work-card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(17, 17, 17, 0.04);
  break-inside: avoid;
  margin-bottom: 16rpx;
}

.work-card .work-cover-wrap {
  position: relative;
  width: 100%;
  height: 300rpx;
  background: #eee;
}

.work-card .work-cover {
  width: 100%;
  height: 100%;
}

.work-cover-fallback {
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  gap: 8px;
  padding: 16px 14px;
  color: #fff;
}

.fallback-badge {
  align-self: flex-start;
  padding: 5px 10px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.18);
  font-size: 11px;
  line-height: 1;
}

.fallback-summary {
  font-size: 16px;
  line-height: 1.45;
  font-weight: 600;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
}

.fallback-title {
  font-size: 11px;
  line-height: 1.4;
  opacity: 0.82;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.work-video-preview {
  background: linear-gradient(160deg, #f1f3f8, #dde4ef);
}

.cover-tap-mask {
  position: absolute;
  inset: 0;
  z-index: 2;
  background: transparent;
}

.media-badge {
  position: absolute;
  top: 10px;
  right: 10px;
  width: 28px;
  height: 28px;
  padding: 0;
  border-radius: 50%;
  background: rgba(28, 31, 40, 0.42);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 3;
}

.media-play-icon {
  width: 0;
  height: 0;
  border-top: 6px solid transparent;
  border-bottom: 6px solid transparent;
  border-left: 9px solid #fff;
  margin-left: 3px;
}

.work-info {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
}

.work-title {
  font-size: 28rpx;
  font-weight: 900;
  color: #333;
  display: -webkit-box;
  margin-bottom: 32rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  white-space: normal;
}

.work-meta {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 16rpx;
}

.work-author {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.author-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #eee;
}

.author-name {
  font-size: 24rpx;
  color: #4f5563;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 180rpx;
}

.work-extra {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-top: 16rpx;
}

.work-adopt-time,
.work-material-count {
  font-size: 22rpx;
  color: #8a94a6;
  line-height: 1.4;
}

.work-actions {
  display: flex;
  align-items: center;
  gap: 28rpx;
  margin-top: 32rpx;
}

.action-icon-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
}
.action-icon-wrap image {
  width: 40rpx;
  height: 40rpx;
}

.loading-more {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #8c8c98;
}

/* 主题色 */
.cover-theme-0 {
  background: linear-gradient(145deg, #ff7a59, #ffb347);
}

.cover-theme-1 {
  background: linear-gradient(145deg, #5b86e5, #36d1dc);
}

.cover-theme-2 {
  background: linear-gradient(145deg, #8e54e9, #4776e6);
}

.cover-theme-3 {
  background: linear-gradient(145deg, #11998e, #38ef7d);
}

.cover-theme-4 {
  background: linear-gradient(145deg, #ee0979, #ff6a00);
}

.cover-theme-5 {
  background: linear-gradient(145deg, #4568dc, #b06ab3);
}

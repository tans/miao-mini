.tutorial-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 32rpx;
  background: linear-gradient(66deg, #FF7C09 0%, #FFAF55 32%, #FFCD42 72%, #FFE177 100%);
}

.nav-left, .nav-right {
  width: 80rpx;
}

.nav-back {
  width: 40rpx;
  height: 40rpx;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
}

.intro-section {
  display: flex;
  align-items: center;
  margin: 24rpx;
  padding: 32rpx;
  background: #fff;
  border-radius: 16rpx;
}

.intro-icon {
  width: 80rpx;
  height: 80rpx;
  margin-right: 24rpx;
  background: #f0f0f0;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.intro-icon image {
  width: 60rpx;
  height: 60rpx;
}

.intro-text {
  flex: 1;
}

.intro-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.intro-desc {
  font-size: 24rpx;
  color: #666;
  display: block;
  line-height: 1.5;
}

.steps-section {
  margin: 0 24rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 8rpx 0;
}

.step-item {
  display: flex;
  align-items: flex-start;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.step-item:last-child {
  border-bottom: none;
}

.step-num {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #FF7C09, #FFAF55);
  border-radius: 50%;
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.step-content {
  flex: 1;
}

.step-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.step-desc {
  font-size: 24rpx;
  color: #999;
  display: block;
  line-height: 1.5;
}

.tips-section {
  margin: 0 24rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
}

.tips-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.tips-list {
  display: flex;
  flex-direction: column;
}

.tips-item {
  font-size: 24rpx;
  color: #666;
  line-height: 2;
}

.contact-section {
  padding: 0 32rpx;
}

.contact-btn {
  width: 100%;
  height: 88rpx;
  background: #fff;
  border-radius: 44rpx;
  color: #EF8802;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 88rpx;
  text-align: center;
}

.contact-btn::after {
  border: none;
}
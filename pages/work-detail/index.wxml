<view class="detail-page" wx:if="{{feedItems.length > 0}}">
  <swiper
    class="feed-swiper"
    vertical
    circular="{{false}}"
    current="{{currentIndex}}"
    bindchange="handleSwiperChange"
  >
    <block wx:for="{{feedItems}}" wx:key="id">
      <swiper-item>
        <view class="feed-screen">
          <view class="hero-stage">
            <video
              wx:if="{{item.heroMedia && item.heroMedia.type === 'video'}}"
              id="feed-video-{{item.id}}"
              class="hero-media"
              src="{{item.heroMedia.url}}"
              poster="{{item.posterUrl}}"
              autoplay="{{index === currentIndex && !item.paused}}"
              loop
              muted="{{false}}"
              controls="{{false}}"
              show-center-play-btn="{{false}}"
              show-play-btn="{{false}}"
              show-fullscreen-btn="{{false}}"
              enable-play-gesture="{{false}}"
              objectFit="contain"
            ></video>

            <image
              wx:elif="{{item.heroMedia && item.heroMedia.url}}"
              class="hero-media"
              src="{{item.heroMedia.url}}"
              mode="aspectFit"
              bindtap="previewMaterial"
              data-url="{{item.heroMedia.url}}"
            />

            <view class="tap-layer" wx:if="{{item.heroMedia && item.heroMedia.type === 'video'}}" bindtap="handleMediaTap">
              <view class="play-indicator" wx:if="{{item.paused}}">▶</view>
              <view class="like-burst" wx:if="{{item.showLikeBurst}}">♥</view>
            </view>

            <view class="circle-btn top-back-btn" style="top: {{navTop}}px; left: {{leftActionInset}}px;" bindtap="goBack">‹</view>
            <view class="bottom-panel" style="left: {{pageSideInset}}px; right: {{pageSideInset}}px; bottom: {{overlayBottom}}px;">
              <view class="content-block">
                <text class="detail-title detail-trigger" bindtap="openDetailPanel">{{item.task_title || item.title || '灵感详情'}}</text>
                <text class="detail-content detail-trigger" wx:if="{{item.content}}" bindtap="openDetailPanel">{{item.content}}</text>
                <view class="meta-row" wx:if="{{item.locationText}}">
                  <text class="meta-location">{{item.locationText}}</text>
                </view>
              </view>
            </view>
          </view>

          <view class="comment-bar" style="padding-left: {{pageSideInset}}px; padding-right: {{pageSideInset}}px;">
            <view class="comment-author">
              <image class="comment-author-avatar" src="{{item.creator_avatar || '/assets/icons/avatar-default.jpg'}}" />
              <text class="comment-author-name">{{item.creator_name || '创作者'}}</text>
            </view>
            <view class="comment-actions">
              <view class="comment-action" bindtap="toggleLike">
                <text class="comment-icon comment-like-icon {{item.isLiked ? 'active' : ''}}">♥</text>
                <text class="comment-count">{{item.likeCountText}}</text>
              </view>
              <view class="comment-action comment-view-action">
                <view class="comment-eye-icon">
                  <view class="comment-eye-pupil"></view>
                </view>
                <text class="comment-count">{{item.viewCountText}}</text>
              </view>
              <view class="comment-action comment-share-action">
                <text class="comment-icon comment-share-icon">↗</text>
                <button class="comment-share-hit-btn" open-type="share"></button>
              </view>
            </view>
          </view>
        </view>
      </swiper-item>
    </block>
  </swiper>

  <view class="feed-loading" wx:if="{{loadingMore}}">加载更多灵感...</view>
</view>

<view class="detail-sheet-mask" wx:if="{{detailPanelVisible}}" bindtap="closeDetailPanel"></view>
<view class="detail-sheet {{detailPanelVisible ? 'show' : ''}}" wx:if="{{detailPanelVisible}}" catchtap="noop">
  <view class="detail-sheet-handle"></view>
  <view class="detail-sheet-header">
    <text class="detail-sheet-title">作品详情</text>
    <text class="detail-sheet-close" bindtap="closeDetailPanel">关闭</text>
  </view>
  <scroll-view class="detail-sheet-body" scroll-y>
    <view class="detail-sheet-section">
      <text class="detail-sheet-label">标题</text>
      <text class="detail-sheet-main">{{currentDetailItem.task_title || currentDetailItem.title || '灵感详情'}}</text>
    </view>
    <view class="detail-sheet-section" wx:if="{{currentDetailItem.content}}">
      <text class="detail-sheet-label">创作说明</text>
      <text class="detail-sheet-text">{{currentDetailItem.content}}</text>
    </view>
    <view class="detail-sheet-section" wx:if="{{currentDetailItem.locationText}}">
      <text class="detail-sheet-label">标签</text>
      <text class="detail-sheet-tag">{{currentDetailItem.locationText}}</text>
    </view>
    <view class="detail-sheet-section">
      <text class="detail-sheet-label">创作者</text>
      <view class="detail-sheet-author">
        <image class="detail-sheet-author-avatar" src="{{currentDetailItem.creator_avatar || '/assets/icons/avatar-default.jpg'}}" />
        <text class="detail-sheet-author-name">{{currentDetailItem.creator_name || '创作者'}}</text>
      </view>
    </view>
    <view class="detail-sheet-section" wx:if="{{currentDetailItem.materials && currentDetailItem.materials.length > 0}}">
      <text class="detail-sheet-label">{{entryMode === 'adopted' ? '采纳作品素材' : '作品素材'}}</text>
      <view class="detail-material-list">
        <view class="detail-material-item" wx:for="{{currentDetailItem.materials}}" wx:key="id">
          <view class="detail-material-main">
            <image
              wx:if="{{item.file_type === 'image'}}"
              class="detail-material-thumb"
              src="{{item.thumbnail_path || item.file_path}}"
              mode="aspectFill"
              bindtap="previewMaterial"
              data-url="{{item.file_path}}"
            />
            <view wx:else class="detail-material-thumb detail-material-video-thumb">视频</view>
            <view class="detail-material-meta">
              <text class="detail-material-name">{{item.file_name || '作品素材'}}</text>
              <text class="detail-material-type">{{item.file_type === 'video' ? '视频' : '图片'}}</text>
            </view>
          </view>
          <view class="detail-material-actions">
            <button
              wx:if="{{item.file_type === 'image'}}"
              class="detail-material-btn detail-material-preview-btn"
              bindtap="previewMaterial"
              data-url="{{item.file_path}}"
            >查看</button>
            <button
              class="detail-material-btn detail-material-download-btn"
              bindtap="downloadMaterial"
              data-url="{{item.file_path}}"
              data-type="{{item.file_type}}"
            >下载</button>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>
</view>

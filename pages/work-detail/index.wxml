<view class="work-detail-container">
  <view class="work-media" wx:if="{{materials.length > 0}}">
    <block wx:for="{{materials}}" wx:key="id">
      <image wx:if="{{item.file_type === 'image'}}" class="work-image" src="{{item.file_path}}" mode="widthFix" bindtap="previewMaterial" data-url="{{item.file_path}}"/>
      <video wx:if="{{item.file_type === 'video'}}" class="work-video" src="{{item.file_path}}" controls/>
    </block>
  </view>

  <view class="work-media" wx:elif="{{work.cover_url || work.image}}">
    <image class="work-image" src="{{work.cover_url || work.image}}" mode="widthFix"/>
  </view>

  <mp-cells>
    <mp-cell>
      <view slot="title">
        <text class="work-title">{{work.task_title || work.title || '作品'}}</text>
        <view class="work-author">
          <image class="author-avatar" src="{{work.creator_avatar || '/assets/icons/avatar-default.jpg'}}"/>
          <text class="author-name">{{work.creator_name || '创作者'}}</text>
        </view>
      </view>
    </mp-cell>
  </mp-cells>

  <mp-cells wx:if="{{work}}">
    <mp-cell title="浏览数" value="{{work.views || 0}}"></mp-cell>
    <mp-cell title="点赞数" value="{{work.likes || 0}}"></mp-cell>
  </mp-cells>

  <mp-cells title="创作说明" wx:if="{{work.content}}">
    <mp-cell>
      <text class="work-content">{{work.content}}</text>
    </mp-cell>
  </mp-cells>

  <view class="action-bar">
    <button class="like-btn {{isLiked ? 'active' : ''}}" bindtap="toggleLike" loading="{{liking}}">
      {{isLiked ? '已点赞' : '点赞'}} {{work.likes || 0}}
    </button>
    <button class="share-btn" open-type="share">分享</button>
  </view>
</view>

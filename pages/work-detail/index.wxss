.detail-page {
  height: 100vh;
  background: #0f0f10;
  color: #fff;
}

.feed-swiper {
  width: 100%;
  height: 100vh;
}

.feed-screen {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #0f0f10;
}

.hero-stage {
  position: relative;
  width: 100%;
  height: calc(100vh - 52px - env(safe-area-inset-bottom));
  background: #111;
  overflow: hidden;
}

.hero-media {
  width: 100%;
  height: 100%;
  display: block;
}

.tap-layer {
  position: absolute;
  inset: 0;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.play-indicator {
  width: 72px;
  height: 72px;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.42);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34px;
  backdrop-filter: blur(10px);
}

.top-back-btn,
.top-share-wrap {
  position: absolute;
  z-index: 2;
}

.top-share-wrap {
  width: calc(36px + env(safe-area-inset-right));
  height: 36px;
  padding-right: env(safe-area-inset-right);
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.circle-btn {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.34);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
  line-height: 1;
  backdrop-filter: blur(10px);
}

.share-hit-btn {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  padding: 0;
  margin: 0;
  border: none;
  background: transparent;
  border-radius: 0;
  box-sizing: border-box;
  overflow: hidden;
  line-height: 1;
  opacity: 0;
}

.share-hit-btn::after {
  border: none;
}

.share-visual-btn {
  width: 36px;
  height: 36px;
}

.bottom-panel {
  position: absolute;
  z-index: 2;
  padding: 12px 0 10px;
}

.author-row {
  display: flex;
  align-items: center;
  margin-bottom: 10px;
}

.author-left {
  display: flex;
  align-items: center;
  gap: 10px;
}

.author-avatar {
  width: 42px;
  height: 42px;
  border-radius: 50%;
  border: 1px solid rgba(255, 255, 255, 0.24);
  background: rgba(255, 255, 255, 0.08);
}

.author-meta {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.author-name {
  font-size: 15px;
  font-weight: 600;
}

.author-tip {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.72);
}

.content-block {
  max-width: 100%;
  padding-right: 8px;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 10px;
}

.detail-tag {
  padding: 5px 10px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.16);
  color: rgba(255, 255, 255, 0.96);
  font-size: 11px;
}

.detail-title {
  display: block;
  font-size: 18px;
  font-weight: 600;
  line-height: 1.4;
  margin-bottom: 8px;
}

.detail-content {
  display: block;
  font-size: 13px;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.84);
}

.meta-row {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: 10px;
}

.meta-location {
  display: inline-flex;
  align-items: center;
  padding: 4px 10px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.14);
  color: rgba(255, 255, 255, 0.82);
  font-size: 11px;
}

.comment-bar {
  height: calc(52px + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 8px;
  padding-top: 0;
  padding-bottom: env(safe-area-inset-bottom);
  background: #0f0f10;
}

.comment-input {
  flex: 1;
  height: 38px;
  border-radius: 999px;
  background: rgba(0, 0, 0, 0.45);
  color: rgba(255, 255, 255, 0.68);
  display: flex;
  align-items: center;
  padding: 0 14px;
  font-size: 12px;
  backdrop-filter: blur(10px);
}

.comment-action {
  min-width: 42px;
  display: flex;
  align-items: center;
  gap: 3px;
  justify-content: center;
}

.comment-icon {
  font-size: 18px;
  color: #fff;
}

.comment-icon.active {
  color: #ff7b9c;
}

.comment-count {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.9);
}

.feed-loading {
  position: fixed;
  right: 12px;
  bottom: calc(66px + env(safe-area-inset-bottom));
  z-index: 3;
  padding: 6px 10px;
  border-radius: 999px;
  background: rgba(0, 0, 0, 0.45);
  color: rgba(255, 255, 255, 0.86);
  font-size: 12px;
}

.detail-page {
  height: 100vh;
  background: #0f0f10;
  color: #fff;
}

.feed-swiper {
  width: 100%;
  height: 100vh;
}

.feed-screen {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #0f0f10;
}

.hero-stage {
  position: relative;
  width: 100%;
  height: calc(100vh - 52px - env(safe-area-inset-bottom));
  background: #000;
  overflow: hidden;
}

.hero-media {
  width: 100%;
  height: 100%;
  display: block;
  background: #000;
}

.tap-layer {
  position: absolute;
  inset: 0;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.like-burst {
  position: absolute;
  left: 50%;
  top: 50%;
  z-index: 2;
  transform: translate(-50%, -50%);
  color: rgba(255, 77, 109, 0.98);
  font-size: 72px;
  line-height: 1;
  text-shadow: 0 10px 24px rgba(0, 0, 0, 0.25);
  animation: like-burst-pop 0.52s ease-out forwards;
  pointer-events: none;
}

@keyframes like-burst-pop {
  0% {
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.55);
  }
  20% {
    opacity: 1;
  }
  100% {
    opacity: 0;
    transform: translate(-50%, -50%) scale(1.35);
  }
}

.play-indicator {
  width: 72px;
  height: 72px;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.42);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34px;
  backdrop-filter: blur(10px);
}

.top-back-btn {
  position: absolute;
  z-index: 2;
}

.circle-btn {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.34);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
  line-height: 1;
  backdrop-filter: blur(10px);
}

.bottom-panel {
  position: absolute;
  z-index: 2;
  padding: 8px 0 6px;
}

.content-block {
  max-width: 100%;
  padding-right: 8px;
}

.detail-title {
  display: block;
  font-size: 16px;
  font-weight: 600;
  line-height: 1.35;
  margin-bottom: 6px;
}

.detail-content {
  display: block;
  font-size: 13px;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.84);
}

.detail-trigger {
  position: relative;
}

.detail-trigger:active {
  opacity: 0.72;
}

.meta-row {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: 8px;
}

.meta-location {
  display: inline-flex;
  align-items: center;
  padding: 3px 8px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.14);
  color: rgba(255, 255, 255, 0.82);
  font-size: 10px;
}

.comment-bar {
  height: calc(52px + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 8px;
  justify-content: space-between;
  padding-top: 0;
  padding-bottom: env(safe-area-inset-bottom);
  background: #0f0f10;
}

.comment-author {
  flex: 1;
  min-width: 0;
  height: 38px;
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 0 14px 0 4px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(10px);
}

.comment-author-avatar {
  width: 30px;
  height: 30px;
  flex-shrink: 0;
  border-radius: 50%;
  border: 1px solid rgba(255, 255, 255, 0.24);
  background: rgba(255, 255, 255, 0.08);
}

.comment-author-name {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 13px;
  color: rgba(255, 255, 255, 0.92);
}

.comment-action {
  position: relative;
  min-width: 42px;
  display: flex;
  align-items: center;
  gap: 3px;
  justify-content: center;
}

.comment-actions {
  display: flex;
  align-items: center;
  gap: 12px;
  flex-shrink: 0;
}

.comment-icon {
  font-size: 18px;
  color: rgba(255, 255, 255, 0.9);
}

.comment-icon.active {
  color: #ff4d6d;
}

.comment-count {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.9);
}

.comment-share-action {
  min-width: 56px;
}

.comment-view-action {
  min-width: 62px;
}

.comment-view-label {
  font-size: 12px;
}

.comment-share-hit-btn {
  position: absolute;
  inset: 0;
  padding: 0;
  margin: 0;
  border: none;
  background: transparent;
  border-radius: 0;
  box-sizing: border-box;
  overflow: hidden;
  line-height: 1;
  opacity: 0;
}

.comment-share-hit-btn::after {
  border: none;
}

.feed-loading {
  position: fixed;
  right: 12px;
  bottom: calc(66px + env(safe-area-inset-bottom));
  z-index: 3;
  padding: 6px 10px;
  border-radius: 999px;
  background: rgba(0, 0, 0, 0.45);
  color: rgba(255, 255, 255, 0.86);
  font-size: 12px;
}

.detail-sheet-mask {
  position: fixed;
  inset: 0;
  z-index: 19;
  background: rgba(0, 0, 0, 0.52);
}

.detail-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  height: min(62vh, 520px);
  padding: 10px 18px calc(24px + env(safe-area-inset-bottom));
  border-radius: 22px 22px 0 0;
  background: #17181c;
  box-shadow: 0 -16px 40px rgba(0, 0, 0, 0.28);
  transform: translateY(100%);
  animation: detail-sheet-up 0.22s ease-out forwards;
}

.detail-sheet.show {
  transform: translateY(0);
}

.detail-sheet-handle {
  width: 42px;
  height: 4px;
  margin: 0 auto 14px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.2);
}

.detail-sheet-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 18px;
}

.detail-sheet-title {
  font-size: 17px;
  font-weight: 600;
  color: #fff;
}

.detail-sheet-close {
  font-size: 13px;
  color: rgba(255, 255, 255, 0.68);
}

.detail-sheet-body {
  max-height: 100%;
}

.detail-sheet-section {
  padding: 0 0 18px;
}

.detail-sheet-label {
  display: block;
  margin-bottom: 8px;
  font-size: 11px;
  letter-spacing: 1px;
  color: rgba(255, 255, 255, 0.46);
}

.detail-sheet-main {
  display: block;
  font-size: 18px;
  line-height: 1.45;
  font-weight: 600;
  color: #fff;
}

.detail-sheet-text {
  display: block;
  font-size: 14px;
  line-height: 1.8;
  color: rgba(255, 255, 255, 0.84);
  white-space: pre-wrap;
}

.detail-sheet-tag {
  display: inline-flex;
  align-items: center;
  padding: 5px 10px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.08);
  color: rgba(255, 255, 255, 0.84);
  font-size: 12px;
}

.detail-sheet-author {
  display: flex;
  align-items: center;
  gap: 10px;
}

.detail-sheet-author-avatar {
  width: 34px;
  height: 34px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}

.detail-sheet-author-name {
  font-size: 14px;
  color: rgba(255, 255, 255, 0.92);
}

@keyframes detail-sheet-up {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}





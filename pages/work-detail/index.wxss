.detail-page {
  min-height: 100vh;
  background: #0f0f10;
  color: #fff;
}

.hero-stage {
  position: relative;
  min-height: 100vh;
  background: #111;
  overflow: hidden;
}

.hero-media {
  width: 100%;
  height: 100vh;
  display: block;
}

.hero-mask {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(0, 0, 0, 0.35) 0%, rgba(0, 0, 0, 0.06) 20%, rgba(0, 0, 0, 0.08) 60%, rgba(0, 0, 0, 0.75) 100%);
  pointer-events: none;
}

.top-actions {
  position: absolute;
  top: 56px;
  left: 16px;
  right: 16px;
  z-index: 2;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.top-actions-right {
  display: flex;
  align-items: center;
  gap: 10px;
}

.circle-btn {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.34);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
  line-height: 1;
  backdrop-filter: blur(10px);
}

.share-btn {
  border: none;
  padding: 0;
}

.share-btn::after,
.share-plain::after {
  border: none;
}

.bottom-panel {
  position: absolute;
  left: 0;
  right: 92px;
  bottom: calc(68px + env(safe-area-inset-bottom));
  z-index: 2;
  padding: 20px 16px 18px;
}

.author-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16px;
}

.author-left {
  display: flex;
  align-items: center;
  gap: 10px;
}

.author-avatar {
  width: 42px;
  height: 42px;
  border-radius: 50%;
  border: 1px solid rgba(255, 255, 255, 0.24);
  background: rgba(255, 255, 255, 0.08);
}

.author-meta {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.author-name {
  font-size: 15px;
  font-weight: 600;
}

.author-tip {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.72);
}

.content-block {
  margin-bottom: 18px;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 10px;
}

.detail-tag {
  padding: 5px 10px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.16);
  color: rgba(255, 255, 255, 0.96);
  font-size: 11px;
}

.detail-title {
  display: block;
  font-size: 18px;
  font-weight: 600;
  line-height: 1.4;
  margin-bottom: 8px;
}

.detail-content {
  display: block;
  font-size: 13px;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.84);
}

.meta-row {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: 10px;
}

.meta-location {
  display: inline-flex;
  align-items: center;
  padding: 4px 10px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.14);
  color: rgba(255, 255, 255, 0.82);
  font-size: 11px;
}

.side-actions {
  position: absolute;
  right: 16px;
  bottom: calc(124px + env(safe-area-inset-bottom));
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 18px;
}

.side-action {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  background: transparent;
  padding: 0;
  color: #fff;
}

.side-icon {
  width: 42px;
  height: 42px;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.34);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
  backdrop-filter: blur(10px);
}

.side-icon.active {
  color: #ff7b9c;
}

.side-text {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.9);
}

.side-share {
  border: none;
}

.comment-bar {
  position: absolute;
  left: 12px;
  right: 12px;
  bottom: calc(14px + env(safe-area-inset-bottom));
  z-index: 2;
  display: flex;
  align-items: center;
  gap: 10px;
}

.comment-input {
  flex: 1;
  height: 38px;
  border-radius: 999px;
  background: rgba(0, 0, 0, 0.45);
  color: rgba(255, 255, 255, 0.62);
  display: flex;
  align-items: center;
  padding: 0 14px;
  font-size: 13px;
  backdrop-filter: blur(10px);
}

.comment-action {
  min-width: 42px;
  display: flex;
  align-items: center;
  gap: 4px;
  justify-content: center;
}

.comment-icon {
  font-size: 18px;
  color: #fff;
}

.comment-count {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.9);
}

.materials-panel {
  margin-top: -1px;
  background: #151517;
  padding: 18px 16px 28px;
}

.panel-title {
  font-size: 15px;
  font-weight: 600;
  color: #fff;
  margin-bottom: 12px;
}

.materials-scroll {
  white-space: nowrap;
}

.materials-row {
  display: inline-flex;
  gap: 12px;
}

.material-card {
  width: 120px;
  height: 160px;
  border-radius: 14px;
  overflow: hidden;
  background: #242428;
}

.material-thumb {
  width: 100%;
  height: 100%;
  display: block;
}

.material-video {
  width: 100%;
  height: 100%;
}

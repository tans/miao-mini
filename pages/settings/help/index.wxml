<view class="help-container">
  <view class="hero-card">
    <text class="hero-title">帮助中心</text>
    <text class="hero-desc">围绕任务发布、认领、交付和收益结算，整理了创意喵当前最常用的信息。</text>
  </view>

  <view class="section">
    <view class="section-title">快速开始</view>
    <view class="quick-list">
      <view class="quick-item" wx:for="{{quickLinks}}" wx:key="title">
        <text class="quick-title">{{item.title}}</text>
        <text class="quick-desc">{{item.desc}}</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">创作者等级说明</view>
    <view class="level-table">
      <view class="level-header">
        <text class="col-level">等级</text>
        <text class="col-condition">升级条件</text>
        <text class="col-daily">每日投稿</text>
        <text class="col-commission">佣金</text>
      </view>
      <view class="level-row" wx:for="{{levels}}" wx:key="name">
        <view class="col-level">
          <text class="level-icon">{{item.icon}}</text>
          <text class="level-name">{{item.name}}</text>
        </view>
        <text class="col-condition">{{item.condition}}</text>
        <text class="col-daily">{{item.dailyLimit}}</text>
        <text class="col-commission">{{item.commission}}</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">等级规则</view>
    <view class="rule-list">
      <view class="rule-item" wx:for="{{rules}}" wx:key="*this">
        <text class="rule-bullet">•</text>
        <text class="rule-text">{{item}}</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">常见问题</view>
    <view class="faq-list">
      <view class="faq-item" wx:for="{{faqs}}" wx:key="question">
        <text class="faq-question">{{item.question}}</text>
        <text class="faq-answer">{{item.answer}}</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">联系平台</view>
    <view class="contact-list">
      <view class="contact-item" wx:for="{{contacts}}" wx:key="label">
        <text class="contact-label">{{item.label}}</text>
        <text class="contact-value">{{item.value}}</text>
      </view>
    </view>
  </view>
</view>

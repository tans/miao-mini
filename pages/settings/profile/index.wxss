.profile-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 12px;
  box-sizing: border-box;
}

/* 公共 section */
.section {
  background: #fff;
  border-radius: 12px;
  margin-bottom: 12px;
}

/* 头像区 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28px 16px 20px;
}

.avatar-img {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  background: #eee;
  margin-bottom: 10px;
}

.avatar-hint-text {
  font-size: 13px;
  color: #999;
}

/* 表单区 */
.form-section {
  overflow: hidden;
}

.form-row {
  display: flex;
  align-items: center;
  padding: 0 16px;
  height: 54px;
}

.form-label {
  font-size: 15px;
  color: #333;
  width: 48px;
  flex-shrink: 0;
}

.input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
}

.form-input {
  flex: 1;
  font-size: 15px;
  color: #333;
  border: none;
  outline: none;
  background: transparent;
  text-align: right;
}

.char-count {
  font-size: 12px;
  color: #ccc;
  margin-left: 6px;
  white-space: nowrap;
}

.divider {
  height: 1px;
  background: #f0f0f0;
  margin: 0 16px;
}

/* 保存按钮 */
.save-wrap {
  padding: 20px 0 0;
}

.save-btn {
  width: 100%;
  height: 48px;
  line-height: 48px;
  background: #FF2442;
  color: #fff;
  font-size: 16px;
  font-weight: 600;
  border-radius: 12px;
  border: none;
  text-align: center;
}

.save-btn.disabled,
.save-btn[disabled] {
  background: #ccc;
  color: #fff;
}

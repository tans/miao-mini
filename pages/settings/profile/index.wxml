<view class="profile-container">

  <!-- 头像区域：open-type=chooseAvatar 触发原生头像选择（含微信头像+相册） -->
  <button class="avatar-section section" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
    <image class="avatar-img" src="{{avatar || '/assets/icons/mine.png'}}" mode="aspectFill"/>
    <view class="avatar-hint">
      <text class="avatar-hint-text">{{avatarUploading ? '上传中...' : '点击更换头像'}}</text>
    </view>
  </button>

  <!-- 表单区域 -->
  <view class="section form-section">

    <!-- 名称 -->
    <view class="form-row">
      <text class="form-label">名称</text>
      <view class="input-wrap">
        <input
          class="form-input"
          type="text"
          placeholder="请输入名称"
          maxlength="20"
          value="{{nickname}}"
          bindinput="onNicknameInput"
        />
        <text class="char-count">{{nickname.length}}/20</text>
      </view>
    </view>

    <view class="divider"/>

    <!-- 手机号：type=digit 避免 iOS 吞掉前导零 -->
    <view class="form-row">
      <text class="form-label">手机</text>
      <input
        class="form-input"
        type="digit"
        placeholder="请输入手机号"
        maxlength="11"
        value="{{phone}}"
        bindinput="onPhoneInput"
      />
    </view>

  </view>

  <!-- 保存按钮 -->
  <view class="save-wrap">
    <button
      class="save-btn {{canSave ? '' : 'disabled'}}"
      disabled="{{!canSave || saving}}"
      bindtap="handleSave"
    >{{saving ? '保存中...' : '保存'}}</button>
  </view>

</view>

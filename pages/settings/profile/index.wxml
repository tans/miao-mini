<view class="profile-container">

  <!-- 头像区域：open-type=chooseAvatar 触发原生头像选择（含微信头像+相册） -->
  <button class="avatar-section section" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
    <image class="avatar-img" src="{{avatar || '/assets/icons/mine.png'}}" mode="aspectFill"/>
    <view class="avatar-hint">
      <text class="avatar-hint-text">{{avatarUploading ? '上传中...' : '点击更换头像'}}</text>
    </view>
  </button>

  <!-- 表单区域 -->
  <mp-cells>
    <mp-cell>
      <view slot="title" class="form-label">名称</view>
      <input
        class="weui-input"
        type="text"
        placeholder="请输入名称"
        maxlength="20"
        value="{{nickname}}"
        bindinput="onNicknameInput"
      />
      <text class="char-count" slot="footer">{{nickname.length}}/20</text>
    </mp-cell>
    <mp-cell>
      <view slot="title" class="form-label">手机</view>
      <button
        class="phone-btn {{phone ? 'phone-btn_active' : ''}}"
        open-type="getPhoneNumber"
        bindgetphonenumber="onGetPhoneNumber"
      >{{phone || '点击授权手机号'}}</button>
    </mp-cell>
  </mp-cells>

  <!-- 保存按钮 -->
  <view class="save-wrap">
    <button
      class="weui-btn weui-btn_primary {{canSave ? '' : 'weui-btn_disabled'}}"
      disabled="{{!canSave || saving}}"
      bindtap="handleSave"
    >{{saving ? '保存中...' : '保存'}}</button>
  </view>

</view>

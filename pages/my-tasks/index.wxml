<!--pages/my-tasks/index.wxml-->
<view class="my-tasks-container">
  <!-- 顶部栏 -->
  <view class="top-bar">
    <view class="user-info">
      <image class="avatar" src="{{userInfo.avatar || '/assets/icons/avatar-default.jpg'}}" mode="aspectFill" />
      <text class="username">{{userInfo.nickname || userInfo.username}}</text>
    </view>
    <view class="balance-box">
      <text class="balance-label">余额</text>
      <text class="balance-amount">¥{{balance}}</text>
    </view>
  </view>

  <!-- 我发布的 -->
  <view class="section-header">
    <text class="section-title">我的发布</text>
  </view>

  <!-- 空状态 -->
  <mp-msg type="info" title="您还没有发布任务" wx:if="{{tasks.length === 0}}">
    <view slot="handle">
      <button class="weui-btn weui-btn_primary" bindtap="goCreateTask">发布第一个任务</button>
    </view>
  </mp-msg>

  <mp-cells wx:if="{{tasks.length > 0}}">
    <mp-cell wx:for="{{tasks}}" wx:key="id" link bindtap="goTaskDetail" data-id="{{item.id}}">
      <view slot="title" class="task-cell">
        <text class="task-title">{{item.title}}</text>
        <view class="task-meta">
          <text>📅 {{item.deadline ? item.deadline.substring(0, 10) : '不限'}}</text>
          <text class="task-budget">¥{{item.total_budget || item.unit_price}}</text>
        </view>
      </view>
      <text class="task-status {{getStatusClass(item.status)}}" slot="footer">{{getStatusText(item.status)}}</text>
    </mp-cell>
  </mp-cells>
</view>

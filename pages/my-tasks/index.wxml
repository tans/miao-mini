<view class="my-tasks-container">
  <!-- 顶部栏 -->
  <view class="top-bar">
    <view class="user-info">
      <image class="avatar" src="{{userInfo.avatar || '/assets/icons/avatar-default.jpg'}}" mode="aspectFill" />
      <text class="username">{{userInfo.nickname || userInfo.username}}</text>
    </view>
    <view class="balance-box">
      <text class="balance-label">余额</text>
      <text class="balance-amount">¥{{balance}}</text>
    </view>
  </view>

  <!-- 标题栏 -->
  <view class="section-header">
    <text class="section-title">我发布的任务</text>
    <button class="btn-publish" bindtap="goCreateTask">+ 发布任务</button>
  </view>

  <!-- 任务列表 - 使用 WeUI Panel 风格 -->
  <view class="tasks-list" wx:if="{{tasks.length > 0}}">
    <view class="weui-panel" wx:for="{{tasks}}" wx:key="id">
      <!-- Panel Header -->
      <view class="weui-panel__hd">
        <view class="task-header">
          <text class="task-title" bindtap="goTaskDetail" data-id="{{item.id}}">{{item.title || '任务' + item.id}}</text>
          <view class="status-badge status-{{item.status}}">{{getStatusText(item.status)}}</view>
        </view>
      </view>

      <!-- Panel Body -->
      <view class="weui-panel__bd">
        <view class="weui-media-box weui-media-box_text">
          <!-- 缩略图 -->
          <view class="thumb-row" wx:if="{{item.thumbnail}}">
            <image class="task-thumb" src="{{item.thumbnail}}" mode="aspectFill" bindtap="goTaskDetail" data-id="{{item.id}}"/>
          </view>
          <view class="info-row">
            <view class="info-item">
              <text class="label">截止日期</text>
              <text class="value">{{item.end_at ? formatDate(item.end_at) : '不限'}}</text>
            </view>
            <view class="info-item">
              <text class="label">赏金</text>
              <text class="value price">¥{{item.unit_price || 0}}</text>
            </view>
          </view>
          <view class="info-row">
            <view class="info-item">
              <text class="label">报名数</text>
              <text class="value">{{item.signup_count || 0}}</text>
            </view>
            <view class="info-item">
              <text class="label">已验收</text>
              <text class="value success">{{item.approved_count || 0}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- Panel Footer -->
      <view class="weui-panel__ft">
        <view class="action-group">
          <text class="action-link" bindtap="goTaskDetail" data-id="{{item.id}}">查看详情</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{tasks.length === 0}}">
    <mp-msg type="info" title="您还没有发布任何任务">
      <view slot="desc">快去发布任务吧</view>
    </mp-msg>
  </view>
</view>
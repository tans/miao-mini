<!--pages/my-tasks/index.wxml-->
<view class="my-tasks-container">
  <!-- 顶部栏 -->
  <view class="top-bar">
    <view class="user-info">
      <image class="avatar" src="{{userInfo.avatarUrl || '/assets/icons/home.png'}}" mode="aspectFill" />
      <text class="username">{{userInfo.username}}</text>
    </view>
    <view class="balance-box">
      <text class="balance-label">余额</text>
      <text class="balance-amount">¥{{balance}}</text>
    </view>
  </view>

  <!-- 我发布的 -->
  <view class="section-header">
    <text class="section-title">我的发布</text>
  </view>

  <view wx:if="{{tasks.length === 0}}" class="empty-state">
    <text class="empty-icon">📭</text>
    <text class="empty-desc">您还没有发布任务</text>
    <button class="btn btn-primary" bindtap="goCreateTask" wx:if="{{userInfo.role === 'business'}}">发布第一个任务</button>
    <text wx:else class="empty-tip">只有商家才能发布任务</text>
  </view>

  <view
    wx:for="{{tasks}}"
    wx:key="id"
    class="card task-card"
    bindtap="goTaskDetail"
    data-id="{{item.id}}"
  >
    <view class="task-header">
      <text class="task-title">{{item.title}}</text>
      <text class="task-status {{getStatusClass(item.status)}}">{{getStatusText(item.status)}}</text>
    </view>
    <view class="task-meta">
      <text>📅 {{item.deadline ? item.deadline.substring(0, 10) : '不限'}}</text>
      <text class="task-budget">¥{{item.unit_price}}</text>
    </view>
  </view>
</view>

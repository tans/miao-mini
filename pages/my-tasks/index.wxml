<!--pages/my-tasks/index.wxml-->
<view class="my-tasks-container">
  <!-- 顶部栏 -->
  <view class="top-bar">
    <view class="user-info">
      <image class="avatar" src="{{userInfo.avatar || '/assets/icons/avatar-default.jpg'}}" mode="aspectFill" />
      <text class="username">{{userInfo.nickname || userInfo.username}}</text>
    </view>
    <view class="balance-box">
      <text class="balance-label">余额</text>
      <text class="balance-amount">¥{{balance}}</text>
    </view>
  </view>

  <!-- 我发布的 -->
  <view class="section-header">
    <text class="section-title">我发布的任务</text>
    <button class="btn-publish" bindtap="goCreateTask">+ 发布任务</button>
  </view>

  <!-- 空状态 -->
  <mp-msg type="info" title="您还没有发布任何任务" wx:if="{{tasks.length === 0}}">
  </mp-msg>

  <mp-cells wx:if="{{tasks.length > 0}}">
    <mp-cell wx:for="{{tasks}}" wx:key="id" link bindtap="goTaskDetail" data-id="{{item.id}}">
      <view slot="icon" wx:if="{{item.thumbnail}}">
        <image class="task-thumb" src="{{item.thumbnail}}" mode="aspectFill" />
      </view>
      <view slot="title" class="task-cell">
        <text class="task-title">{{item.title || '任务' + item.id}}</text>
        <view class="task-meta">
          <text>📅 {{item.end_at ? formatDate(item.end_at) : '不限'}}</text>
          <text class="task-budget">¥{{item.unit_price || 0}}</text>
        </view>
      </view>
      <text class="task-status status-{{item.status}}" slot="footer">{{getStatusText(item.status)}}</text>
    </mp-cell>
  </mp-cells>
</view>

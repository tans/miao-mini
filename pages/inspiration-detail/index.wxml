<view class="page">
  <!-- 顶部导航 -->
  <view class="nav-bar">
    <view class="nav-left" bindtap="goBack">
      <image class="nav-back" src="/assets/icons/back.png" />
    </view>
    <text class="nav-title">灵感详情</text>
    <view class="nav-right"></view>
  </view>

  <!-- 视频播放区域 -->
  <view class="video-section">
    <view class="video-container" wx:if="{{inspiration.video_url || inspiration.previewVideoSrc}}" bindtap="playVideo">
      <video
        id="inspirationVideo"
        class="video-player"
        src="{{inspiration.video_url || inspiration.previewVideoSrc}}"
        poster="{{inspiration.displayCover || inspiration.cover}}"
        controls
        show-center-play-btn
        enable-progress-gesture
      ></video>
    </view>
    <view class="video-placeholder" wx:else>
      <image class="cover-image" src="{{inspiration.cover}}" mode="aspectFill"/>
    </view>
  </view>

  <!-- 视频信息 -->
  <view class="spec-section">
    <view class="spec-row">
      <text class="spec-label">视频比例</text>
      <text class="spec-value">{{inspiration.videoAspect || '9:16 竖屏'}}</text>
    </view>
    <view class="spec-row">
      <text class="spec-label">分辨率</text>
      <text class="spec-value">{{inspiration.videoResolution || '1080P'}}</text>
    </view>
    <view class="spec-row">
      <text class="spec-label">时长</text>
      <text class="spec-value">{{inspiration.videoDuration || '30s'}}</text>
    </view>
  </view>

  <!-- 时间与奖金 -->
  <view class="reward-section">
    <view class="reward-row">
      <view class="reward-item">
        <text class="reward-label">采纳奖励</text>
        <text class="reward-value">{{inspiration.reward || 100}}</text>
        <text class="reward-unit">元/条</text>
      </view>
      <view class="reward-plus">+</view>
      <view class="reward-item">
        <text class="reward-label">参与奖励</text>
        <text class="reward-value-dark">{{inspiration.participationReward || 10}}</text>
        <text class="reward-unit">元/条</text>
      </view>
    </view>
    <view class="time-row" wx:if="{{inspiration.deadline}}">
      <text class="time-label">截稿时间</text>
      <text class="time-value">{{inspiration.deadline}}</text>
    </view>
  </view>

  <!-- 灵感信息 -->
  <view class="info-section">
    <view class="info-card">
      <text class="inspiration-title">{{inspiration.title}}</text>
      <view class="author-row">
        <image class="author-avatar" src="{{inspiration.authorAvatar}}" mode="aspectFill"/>
        <text class="author-name">{{inspiration.authorName}}</text>
      </view>
      <view class="stats-row">
        <view class="stat-item">
          <text class="stat-icon">♡</text>
          <text class="stat-value">{{inspiration.likes}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-more" wx:if="{{loading}}">
    <mp-loading type="circle"></mp-loading>
    <text>加载中...</text>
  </view>
</view>
.data-page {
  padding: 16px;
  background: #f5f5f5;
  min-height: 100vh;
}

.page-header {
  background: linear-gradient(135deg, #ef8802, #ffb74d);
  border-radius: 16px;
  padding: 20px 18px;
  margin-bottom: 16px;
  color: #fff;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.page-title {
  font-size: 20px;
  font-weight: 600;
}

.page-subtitle {
  font-size: 13px;
  opacity: 0.92;
}

.stats-row {
  display: flex;
  gap: 12px;
  margin-bottom: 12px;
}

.stat-card {
  flex: 1;
  background: #fff;
  border-radius: 12px;
  padding: 16px 12px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
}

.stat-card.wide {
  flex: 1;
}

.stat-value {
  font-size: 28px;
  font-weight: 700;
  color: #333;
}

.stat-label {
  font-size: 12px;
  color: #999;
}

.stat-content-row {
  display: flex;
  align-items: center;
  width: 100%;
}

.stat-left,
.stat-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
}

.stat-arrow {
  font-size: 18px;
  color: #ccc;
  padding: 0 8px;
}

.stat-value.commission {
  color: #4caf50;
}

.loading-tip {
  text-align: center;
  padding: 20px;
  color: #999;
  font-size: 13px;
}

.stat-card.warning {
  background: linear-gradient(135deg, #fff5f5, #ffe5e5);
  border: 1px solid #ffcccc;
}

.warning-text {
  color: #e53935 !important;
}
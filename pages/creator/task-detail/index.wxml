    <!-- 任务详情内容 -->
    <view class="detail-content" wx:if="{{currentTab === 'detail'}}">
      <!-- 商家信息卡片 -->
      <view class="merchant-card">
        <view class="merchant-info">
          <image class="merchant-avatar" src="{{task.merchantAvatar || '/assets/icons/avatar-default.jpg'}}" mode="aspectFill"/>
          <view class="merchant-detail">
            <text class="merchant-name">{{task.merchantName || '美寓家居旗舰店'}}</text>
            <view class="merchant-badges">
              <view class="badge badge-brand" wx:if="{{task.isBrandEnterprise}}">
                <image src="../../../images/home/badge-brand.png" class="badge-icon" />
                <text class="badge-text">品牌名企</text>
              </view>
              <view class="badge badge-trusted">
                <image src="../../../images/home/badge-trusted.png" class="badge-icon" />
                <text class="badge-text">资金已托管</text>
              </view>
            </view>
          </view>
        </view>
        <view class="merchant-stats">
          <view class="stat-item">
            <text class="stat-label">平均采纳率</text>
            <text class="stat-value">{{task.adoptionRate || 0}}%</text>
          </view>
          <!-- <view class="stat-divider"></view> -->
          <view class="stat-item">
            <text class="stat-label">累计发布</text>
            <text class="stat-value">{{task.totalPublished || 0}}</text>
            <text class="stat-unit">个任务</text>
          </view>
          <!-- <view class="stat-divider"></view> -->
          <view class="stat-item">
            <text class="stat-label">累计支出</text>
            <text class="stat-value">¥{{task.totalSpent || 0}}</text>
          </view>
        </view>
      <!-- 任务ID -->
      <view class="task-id-card">
        <view class="id-info">
          <text class="id-label">任务ID</text>
          <text class="id-value">{{task.id || 'CC-20260418-000126'}}</text>
        </view>
        <view class="copy-btn" bindtap="copyTaskId">
          <text>复制</text>
        </view>
      </view>
      </view>

      

      <!-- 任务详情卡片 -->
      <view class="detail-card">
        <text class="detail-card-title">任务详情</text>
        <text class="detail-title">{{task.title || '高端楼盘春日氛围视频'}}</text>

        <!-- 奖励 -->
        <view class="reward-row">
          <view class="reward-item">
            <text class="reward-label">参与奖励</text>
            <view class="reward-value-row">
              <text class="reward-value">{{task.unit_price}}</text>
              <text class="reward-unit">元/条</text>
            </view>
          </view>
          <text class="reward-plus">+</text>
          <view class="reward-item">
            <text class="reward-label">采纳奖励</text>
            <view class="reward-value-row">
              <text class="reward-value">{{task.award_price}}</text>
              <text class="reward-unit">元/条</text>
            </view>
          </view>
        </view>

        <!-- 标签 -->
        <view class="tags-row">
          <view class="tag-group">
            <!-- <text class="tag-label">行业标签</text> -->
            <view class="tag-value">{{task.industry || '房产家居'}}</view>
          </view>
          <view class="tag-group">
            <!-- <text class="tag-label">风格标签</text> -->
            <view class="tag-value">{{task.style || '房产家居'}}</view>
          </view>
        </view>

        <!-- 描述 -->
        <view class="desc-section">
          <text class="desc-text">{{task.description || '突出空间通透感与生活方式场景，口语化表达，避免过度摆拍。适合地产、家居类创作者参与。'}}</text>
        </view>

        <!-- 视频规格 -->
        <view class="specs-grid">
          <view class="spec-item">
            <text class="spec-label">视频尺寸</text>
            <text class="spec-value">{{task.videoAspect || '9:16 竖屏'}}</text>
          </view>
          <view class="spec-item">
            <text class="spec-label">分辨率</text>
            <text class="spec-value">{{task.videoResolution || '1080P'}}</text>
          </view>
          <view class="spec-item">
            <text class="spec-label">视频时长</text>
            <text class="spec-value">{{task.videoDuration || '30s'}}</text>
          </view>
          <view class="spec-item">
            <text class="spec-label">截稿时间</text>
            <text class="spec-value deadline">{{task.endAt || '2026-04-24 18:00'}}</text>
          </view>
          <view class="spec-item">
            <text class="spec-label">作品权限</text>
            <text class="spec-value">{{task.visibilityText || '公开投稿'}}</text>
          </view>
        </view>

        <!-- 平台禁忌 -->
        <view class="restriction-section">
          <text class="restriction-text">平台禁忌：敏感词、低俗内容、侵权内容、政治敏感、广告夸大。</text>
        </view>
        <!-- <view class="restriction-section" wx:if="{{hasSignedUp}}">
          <text class="restriction-text">当前状态：{{task.claimStatusText || '已报名，待提交'}}</text>
        </view> -->
      </view>

      <!-- 商家素材 -->
      <view class="material-card" wx:if="{{materials.length > 0}}">
        <view class="card-header">
          <text class="header-title">商家素材</text>
          <view class="download-btn">
            <text>下载全部</text>
          </view>
        </view>
        <view class="material-grid">
          <view class="material-item" wx:for="{{materials}}" wx:key="id" bindtap="previewMaterial" data-url="{{item.file_path}}">
            <image class="material-thumb" src="{{item.file_path}}" mode="aspectFill"/>
          </view>
        </view>
        <!-- 即梦合拍 -->
        <view class="jimeng-card" wx:if="{{task.jimengLink}}">
          <view class="card-header">
            <text class="header-title">即梦合拍邀拍链接</text>
          </view>
          <view class="jimeng-content">
            <text class="jimeng-link">{{task.jimengLink}}</text>
          </view>
        </view>
        <view class="jimeng-card" wx:if="{{!task.jimengLink && !hasSignedUp}}">
          <view class="card-header">
            <text class="header-title">即梦合拍邀拍链接</text>
          </view>
          <view class="jimeng-lock">
            <text class="lock-text">报名后可见</text>
          </view>
        </view>
      </view>

      

      <!-- 安全提醒 -->
      <view class="safety-card">
        <view class="safety-header">
          <image style="width:30rpx;height:30rpx;" src="../../../images/home/msg-icon.png" />
          <text style="color:#F58A1F" class="safety-title">创意喵</text>
          <text class="safety-title">安全提醒</text>
        </view>
        <text class="safety-text">如发现商家发布违规需求可立即举报。创作者请勿提交无关稿件或违规稿件，</text>
        <text style="color:#F58A1F" class="safety-text">被效举报超过 5 次将永久封号。</text>
      </view>

      <!-- 热门推荐 -->
      <view class="recommend-section">
        <view class="recommend-header">
          <image style="width:48rpx;height:48rpx;" src="../../../images/home/hot.png" />
          <text class="recommend-title">热门推荐</text>
        </view>
        <view class="recommend-list">
          <view class="recommend-card" wx:for="{{recommendations}}" wx:key="id" bindtap="goTaskDetail" data-id="{{item.id}}">
            <view class="recommend-info">
              <text class="recommend-title">{{item.title}}</text>
              <view class="recommend-reward">
                <text class="reward-amount">{{item.unit_price}}</text>
                <text class="reward-unit">元/条</text>
              </view>
            </view>
            <view class="recommend-tags">
              <text class="recommend-tag">{{item.industry}}</text>
              <text class="recommend-tag">{{item.style}}</text>
              <text class="recommend-tag">{{item.duration}}</text>
            </view>
            <view class="recommend-progress">
              <text class="progress-label">报名进度</text>
              <view class="progress-bar">
                <view class="progress-fill" style="width: {{item.enrolledPercent}}%"></view>
              </view>
              <text class="progress-text">已报名 {{item.enrolled}}/{{item.limit}}人</text>
            </view>
            <view class="recommend-action">
              <text class="countdown-text">{{item.deadlineText}}</text>
              <view class="action-btn">
                <text>立即报名</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 全部投稿内容 -->
    <view class="submissions-content" wx:if="{{currentTab === 'submissions'}}">
      <view class="submission-card" wx:if="{{task.isPublic && submissions.length > 0}}">
        <view class="submission-mock-grid">
          <view class="submission-mock-item" wx:for="{{submissions}}" wx:key="id">
            <view class="submission-mock-cover-wrap">
              <video
                wx:if="{{item.materials.length > 0 && item.materials[0].isVideo && item.materials[0].previewUrl}}"
                class="submission-mock-cover"
                src="{{item.materials[0].previewUrl}}"
                poster="{{item.materials[0].thumbnailPath}}"
                controls
              />

              <image
                wx:elif="{{item.materials.length > 0 && item.materials[0].isImage && item.materials[0].previewUrl}}"
                class="submission-mock-cover"
                src="{{item.materials[0].previewUrl}}"
                mode="aspectFill"
                bindtap="previewMaterial"
                data-url="{{item.materials[0].previewUrl}}"
              />

              <view wx:else class="submission-placeholder">
                <text>素材暂不可预览</text>
              </view>

              <view class="submission-mock-status submission-mock-status-{{item.statusClass}}">
                <text>{{item.statusText}}</text>
              </view>
            </view>
            <view class="submission-mock-footer">
              <view class="submission-mock-user-row">
                <view class="submission-mock-user-left">
                  <image class="submission-mock-avatar" src="{{item.creatorAvatar}}" mode="aspectFill" />
                  <text class="submission-mock-name">{{item.creatorName}}</text>
                </view>
                <text class="submission-mock-level">Lv.{{item.creatorLevel}}</text>
              </view>
              <text class="submission-mock-time">{{item.submitAtText}} 投稿</text>
            </view>
          </view>
        </view>
      </view>

      <view class="submission-card" wx:elif="{{!task.isPublic && task.submissionCount > 0}}">
        <image
          class="submission-image submission-private-cover"
          src="../../../images/home/banner-default.png"
          mode="aspectFill"
        />
      </view>

      <view class="submissions-empty" wx:else>
        <image src="../../../images/home/empty.png" class="clock-icon" />
        <text>暂无投稿记录，先报名再上传稿件</text>
      </view>
    </view>
  </scroll-view>

  <!-- 底部操作栏 -->
  <view class="action-bar">
    <button style="width:100%" class="action-btn {{isMerchantTask ? 'submit-work-btn' : (!hasSignedUp || canSubmit ? 'submit-work-btn' : (task.claimActionClass || 'action-state-pending'))}}" bindtap="handleMainAction">
      <text>{{isMerchantTask ? '编辑审核' : (!hasSignedUp ? '截稿倒计时：'+countdownText+'，立即报名' : canSubmit ? '上传稿件' : (task.claimActionText || '已报名，等待审核'))}}</text>
    </button>
  </view>

  <!-- 创作者须知弹框 -->
  <view class="creator-notice-mask" wx:if="{{showCreatorNoticeModal}}" bindtap="onCloseCreatorNotice">
    <view class="creator-notice-modal" catchtap="stopPropagation">
      <view class="creator-notice-body">
        <text class="creator-notice-title">创作者须知</text>
        <text class="creator-notice-text">上传之前请检查以下内容：</text>
        <text class="creator-notice-text">视频是否已去水印、是否含有违禁词、是否符合商家的视频投稿要求。</text>
        <text class="creator-notice-text">请不要恶意上传与活动无关的注水稿件，此类稿件被商家举报后拿不到任何奖励。创作者被成功举报5次，将永久封号。</text>
        <text class="creator-notice-text">您的稿件上传后，<text class="creator-notice-highlight">如被选中采用所属版权将属于商家</text>，您不可将视频发布到任意平台。</text>
      </view>
      <view class="creator-notice-footer">
        <view class="creator-notice-btn creator-notice-btn-cancel" bindtap="onCloseCreatorNotice">
          <text>取消</text>
        </view>
        <view class="creator-notice-btn creator-notice-btn-confirm" bindtap="onAcknowledgeCreatorNotice">
          <text>我知道了</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 上传进度弹框 -->
  <view class="upload-progress-mask" wx:if="{{showUploadProgressModal}}" bindtap="onCloseUploadProgressModal">
    <view class="upload-progress-modal" catchtap="stopPropagation">
      <view class="upload-progress-close" bindtap="onCloseUploadProgressModal">
        <text>×</text>
      </view>
      <view class="upload-progress-percent">
        <circle-progress progress="{{uploadProgress}}" size="108" lineWidth="10" trackColor="#FFDDCA" progressColor="#EF8802">
          <text class="upload-progress-percent-text">{{uploadProgress}}%</text>
        </circle-progress>
      </view>
      <text class="upload-progress-title">视频正在上传...</text>
      <text class="upload-progress-text">商家会在<text class="upload-progress-highlight">收到投稿后48小时内审核稿件</text>，超时未审核将自动为您发放参与奖，后续商家如果采纳了您的视频也会为自动补发采纳奖给您的钱包。</text>
    </view>
  </view>

  <!-- 提交模态框 -->
  <view class="submit-modal-mask" hidden="{{!showSubmitModal}}" bindtap="onCloseSubmitModal">
    <view class="submit-modal" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">上传稿件</text>
        <view class="modal-close" bindtap="onCloseSubmitModal">
          <text>×</text>
        </view>
      </view>
      <view class="modal-body">
        <!-- 视频预览 -->
        <view class="video-preview" wx:if="{{submitVideoUrl}}">
          <video src="{{submitVideoUrl}}" class="modal-video" />
          <view class="video-cover-overlay">
            <text class="cover-text">视频已选择</text>
          </view>
        </view>
        <!-- 选择视频按钮 -->
        <view class="upload-btn" bindtap="onChooseVideo" wx:if="{{!submitVideoUrl}}">
          <view class="upload-icon">
            <text class="upload-icon-text">+</text>
          </view>
          <text class="upload-text">点击选择视频</text>
          <text class="upload-hint">要求：{{task.videoAspect}} / {{task.videoResolution}} / {{task.videoDuration}}</text>
        </view>
      </view>
      <view class="modal-footer">
        <button class="submit-btn {{submitting || !submitVideoUrl ? 'disabled' : ''}}" bindtap="onSubmitWork" disabled="{{submitting || !submitVideoUrl}}">
          <text>{{submitting ? '提交中...' : '提交作品'}}</text>
        </button>
      </view>
    </view>
  </view>
</view>

<view class="task-detail-container">
  <!-- 流程图 -->
    <view class="flow-section">
      <view class="flow-header">
        <view class="flow-header-left">
          <image class="flow-icon" src="../../../images/home/msg-icon.png" />
          <text class="flow-headline">新手不踩坑</text>
          <text class="flow-headline-highlight">投稿看流程</text>
        </view>
        <text class="flow-hint">详细教程</text>
      </view>
      <view class="flow-body">
        <view class="flow-step">
          <view class="flow-icon-wrapper">
            <image class="flow-step-icon" src="../../../images/home/detail-icon1.png" />
          </view>
          <view class="flow-step-text">
            <text class="flow-step-title">报名后按时交稿</text>
          </view>
        </view>
        <image class="flow-arrow" src="../../../images/home/right.png" />
        <view class="flow-step">
          <view class="flow-icon-wrapper">
            <image class="flow-step-icon" src="../../../images/home/detail-icon2.png" />
          </view>
          <view class="flow-step-text">
            <text class="flow-step-title">商家审核付款</text>
          </view>
        </view>
        <image class="flow-arrow" src="../../../images/home/right.png" />
        <view class="flow-step">
          <view class="flow-icon-wrapper">
            <image class="flow-step-icon" src="../../../images/home/detail-icon3.png" />
          </view>
          <view class="flow-step-text">
            <text class="flow-step-title">钱包提现奖励</text>
          </view>
        </view>
      </view>
    </view>
  <!-- 标签切换 -->
  <view class="tab-switch">
    <view class="tab-item {{currentTab === 'detail' ? 'active' : ''}}" data-tab="detail" bindtap="switchTab">
      <text>任务详情</text>
    </view>
    <view class="tab-item {{currentTab === 'submissions' ? 'active' : ''}}" data-tab="submissions" bindtap="switchTab">
      <text>全部投稿</text>
    </view>
  </view>
    <!-- 任务详情内容 -->
    <view class="detail-content" wx:if="{{currentTab === 'detail'}}">
      <!-- 商家信息卡片 -->
      <view class="merchant-card">
        <view class="merchant-info">
          <image class="merchant-avatar" src="{{task.merchantAvatar || '/assets/icons/avatar-default.jpg'}}" mode="aspectFill"/>
          <view class="merchant-detail">
            <view class="merchant-info-row">
              <text class="merchant-name">{{task.merchantName || ''}}</text>
              <!-- wx:if="{{task.isBrandEnterprise}}" -->
              <view class="badge badge-brand" >
                <image src="../../../images/home/badge-brand.png" class="badge-icon" />
                <text class="badge-text">品牌名企</text>
              </view>
            </view>
            <view class="merchant-stats">
              <view class="stat-item">
                <text class="stat-label">平均采纳率</text>
                <text class="stat-value">{{task.adoptionRate || 0}}%</text>
              </view>
              <view class="stat-item">
                <text class="stat-label">累计发布</text>
                <text class="stat-value">{{task.totalPublished || 0}}</text>
                <text class="stat-unit">个任务</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <!-- 任务详情卡片 -->
      <view class="detail-card">
        <view class="merchant-card">
          <view class="detail-header">
            <text class="detail-title">{{task.title || ''}}</text>
            <view class="badge badge-trusted">
              <image src="../../../images/icon/zijin.png" class="badge-icon" />
              <text class="badge-text">资金已托管</text>
            </view>
          </view>
          <!-- 奖励 -->
          <view class="reward-row">
            <view class="reward-item">
              <text class="reward-label">参与奖励</text>
              <view class="reward-value-row">
                <text class="reward-value">{{task.unit_price}}</text>
                <text class="reward-unit">元/条</text>
              </view>
            </view>
            <text class="reward-plus">+</text>
            <view class="reward-item">
              <text class="reward-label">采纳奖励</text>
              <view class="reward-value-row">
                <text class="reward-value" style="color:#333333;">{{task.award_price}}</text>
                <text class="reward-unit" style="color:#333333;">元/条</text>
              </view>
            </view>
          </view>
          <!-- 进度条 -->
            <view class="task-progress">
              <text class="progress-label">报名进度</text>
              <view class="progress-info">
                <text class="progress-text">已报名</text>
                <text class="progress-num">{{enrolled_count || 0}}</text>
                <text class="progress-text">/{{total_count || 10}}人</text>
              </view>
              
            </view>
            <view class="progress-bar-body">
              <progress class="progress-bar" percent="{{(enrolled_count / (total_count || 10))*100}}" stroke-width="8" activeColor="#F99935" backgroundColor="#F2EEEB" border-radius="16"/>
            </view>
        </view>
        <view class="merchant-card">
          <!-- id -->
          <view class="task-id-card">
            <text class="title-text">任务描述</text>
            <view class="id-info">
              <text class="id-label">任务ID</text>
              <text class="id-value">{{task.id || 'CC-20260418-000126'}}</text>
            </view>
          </view>
           <!-- 描述 -->
          <view class="desc-section">
            <text class="desc-text">{{task.description || ''}}</text>
          </view>
           <!-- 标签 -->
          <view class="tags-row">
            <view class="tag-group">
              <view class="tag-value">{{task.industry || ''}}</view>
            </view>
            <view class="tag-group">
              <view class="tag-value">{{task.style || ''}}</view>
            </view>
          </view>
          <text class="title-text">视频要求</text>
          <!-- 视频规格 -->
          <view class="specs-grid">
            <view class="spec-item">
              <text class="spec-label">视频尺寸</text>
              <text class="spec-value">{{task.videoAspect || ''}}</text>
            </view>
            <view class="spec-item">
              <text class="spec-label">截稿时间</text>
              <text class="spec-value deadline">{{task.endAt || ''}}</text>
            </view>
          </view>
          <!-- 商家素材 -->
          <view class="material-card" wx:if="{{materials.length > 0}}">
            <view class="card-header">
              <text class="header-title">商家素材</text>
              <view class="download-btn">
                <text>下载全部</text>
              </view>
            </view>
            <view class="material-grid">
              <view class="material-item" wx:for="{{materials}}" wx:key="id" bindtap="previewMaterial" data-url="{{item.file_path}}">
                <image class="material-thumb" src="{{item.file_path}}" mode="aspectFill"/>
              </view>
            </view>
          </view>
        </view>
      </view>

      
      <!-- 即梦合拍 -->
        <view class="merchant-card" wx:if="{{task.jimengLink}}">
          <view class="header-content">
            <text class="header-title">即梦合拍</text>
            <text class="header-desc">复制下方邀请链接，使用即梦生成视频</text>
          </view>
          <view class="jimeng-content">
            <text class="jimeng-link" style="color:#333333;">{{task.jimengLink}}</text>
            <view class="jimeng-badge jimeng-copy" bindtap="copyJimengLink">
              <text class="jimeng-badge-text  jimeng-copy-text">复制</text>
            </view>
          </view>
          <view class="jimeng-course">
            <image src="../../../images/icon/start.png" style="width: 24rpx; height: 24rpx;margin-right: 6rpx;" />如何使用即梦合拍？查看教程>
          </view>
        </view>
        <view class="merchant-card" wx:if="{{task.jimengLink && !hasSignedUp}}">
          <view class="header-content">
            <text class="header-title">即梦合拍</text>
            <text class="header-desc">复制下方邀请链接，使用即梦生成视频</text>
          </view>
          <view class="jimeng-content">
            <text class="jimeng-link">https://jm.example.com/invite***</text>
            <view class="jimeng-badge">
              <text class="jimeng-badge-text">报名后可见</text>
            </view>
          </view>
          <view class="jimeng-course">
            如何使用即梦合拍？查看教程>
          </view>
        </view>
        
      <!-- 安全提醒 -->
      <view class="merchant-card">
        <view class="safety-header">
          <image style="width:40rpx;height:40rpx;" src="../../../images/home/msg-icon.png" />
          <text style="color:#F58A1F" class="safety-title">创意喵</text>
          <text class="safety-title">安全提醒</text>
        </view>
        <view class="safety-text">创作者请勿提交无关稿件或违规稿件，<text style="color:#F58A1F" class="safety-text">被举报成功超过 5 次将永久封号。</text> </view>
        <view class="safety-text">平台禁忌：敏感词、低俗内容、侵权内容、政治敏感、广告夸大。</view>
      </view>
    </view>

    <!-- 全部投稿内容 -->
    <view class="submissions-content" wx:if="{{currentTab === 'submissions'}}">
      <view class="submission-card" wx:if="{{task.isPublic && submissions.length > 0}}">
        <view class="submission-mock-grid">
          <view class="submission-mock-item" wx:for="{{submissions}}" wx:key="id">
            <view class="submission-mock-cover-wrap">
              <video
                wx:if="{{item.materials.length > 0 && item.materials[0].isVideo && item.materials[0].previewUrl}}"
                class="submission-mock-cover"
                src="{{item.materials[0].previewUrl}}"
                poster="{{item.materials[0].thumbnailPath}}"
                controls
              />

              <image
                wx:elif="{{item.materials.length > 0 && item.materials[0].isImage && item.materials[0].previewUrl}}"
                class="submission-mock-cover"
                src="{{item.materials[0].previewUrl}}"
                mode="aspectFill"
                bindtap="previewMaterial"
                data-url="{{item.materials[0].previewUrl}}"
              />

              <view wx:else class="submission-placeholder">
                <text>素材暂不可预览</text>
              </view>

              <view class="submission-mock-status submission-mock-status-{{item.statusClass}}">
                <text>{{item.statusText}}</text>
              </view>
            </view>
            <view class="submission-mock-footer">
              <view class="submission-mock-user-row">
                <view class="submission-mock-user-left">
                  <image class="submission-mock-avatar" src="{{item.creatorAvatar}}" mode="aspectFill" />
                  <text class="submission-mock-name">{{item.creatorName}}</text>
                </view>
                <text class="submission-mock-level">Lv.{{item.creatorLevel}}</text>
              </view>
              <text class="submission-mock-time">{{item.submitAtText}} 投稿</text>
            </view>
          </view>
        </view>
      </view>

      <view class="submission-card" wx:elif="{{!task.isPublic && task.submissionCount > 0}}">
        <view class="safety-card">
          <view class="safety-header">
            <image style="width:30rpx;height:30rpx;" src="../../../images/home/msg-icon.png" />
            <text style="color:#F58A1F" class="safety-title">创意喵</text>
            <text class="safety-title">隐私保护</text>
          </view>
          <text class="safety-text">商家已开启了稿件隐私保护，您无权查看。</text>
        </view>
        <!-- <view class="submission-mock-grid">
          <view class="submission-mock-item" wx:for="{{submissions}}" wx:key="id">
            <view class="submission-mock-cover-wrap">
              <video
                wx:if="{{item.materials.length > 0 && item.materials[0].isVideo && item.materials[0].previewUrl}}"
                class="submission-mock-cover"
                src="{{item.materials[0].previewUrl}}"
                poster="{{item.materials[0].thumbnailPath}}"
                controls
              />

              <image
                wx:elif="{{item.materials.length > 0 && item.materials[0].isImage && item.materials[0].previewUrl}}"
                class="submission-mock-cover"

.task-detail-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 160rpx;
  overflow: hidden;
}

/* 流程图 */
.flow-section {
  background: #fff;
  margin: 32rpx 24rpx;
  border-radius: 16rpx;
  box-shadow: 0px 10rpx 26rpx rgba(20,42,31,0.08);
  padding-bottom: 16rpx;
}

.flow-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 24rpx;
}

.flow-header-left {
  display: flex;
  align-items: center;
}

.flow-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 8rpx;
}

.flow-headline {
  font-size: 28rpx;
  font-weight: 900;
  color: #333;
}

.flow-headline-highlight {
  font-size: 28rpx;
  font-weight: 900;
  color: #ef8802;
  margin-left: 8rpx;
}

.flow-hint {
  font-size: 24rpx;
  font-weight: 500;
  color: #ef8802;
  margin-left: 206rpx;
}

.flow-body {
  display: flex;
  align-items: flex-start;
  justify-content: flex-start;
  padding-left: 56rpx;
  margin-bottom: 34rpx;
}

.flow-step {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.flow-icon-wrapper {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.flow-step-icon {
  width: 60rpx;
  height: 60rpx;
}

.flow-step-text {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 24rpx;
}

.flow-step-title {
  font-size: 24rpx;
  color: #333;
  white-space: nowrap;
  text-align: center;
}

.flow-step-sub {
  font-size: 20rpx;
  color: #666;
  white-space: nowrap;
  text-align: center;
}

.flow-arrow {
  width: 90rpx;
  height: 20rpx;
  flex-shrink: 0;
  margin: 20rpx 0 0 -12rpx;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 32rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.nav-left, .nav-right {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
}

.nav-back {
  width: 40rpx;
  height: 40rpx;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 900;
  color: #333;
}

/* 标签切换 */
.tab-switch {
  position: relative;
  display: flex;
  background: #fff;
  padding: 20rpx 32rpx 0 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  border-radius: 24rpx 24rpx 0rpx 0rpx;
}

.tab-item {
  position: relative;
  padding: 16rpx 20rpx;
  text-align: center;
  font-size: 32rpx;
  color: #1D2129;
  font-weight: 500;
}

.tab-item.active {
  color: #EF8802;
  font-weight: 700;
}

.tab-item.active::after {
  content: "";
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  bottom: 0;
  width: 64rpx;
  height: 4rpx;
  background: #ef8802;
  border-radius: 4rpx;
}

/* 内容滚动区 */
.content-scroll {
  height: calc(100vh - 280rpx);
}

/* 商家信息卡片 */
.detail-content{
  padding: 32rpx 24rpx;
}
.merchant-card {
  background: #fff;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0rpx 4rpx 16rpx 0rpx rgba(17,17,17,0.04);
  border-radius: 16rpx 16rpx 16rpx 16rpx;
}

.merchant-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.merchant-avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 16rpx;
}

.merchant-detail {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.merchant-info-row{
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.merchant-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  display: block;
  width: 338rpx;
}

.merchant-badges {
  display: flex;
  gap: 16rpx;
}

.badge {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 12rpx;
  border-radius: 6rpx;
  font-size: 20rpx;
  line-height: 1.4;
}

.badge-icon {
  font-size: 20rpx;
}

.badge-text {
  font-size: 20rpx;
  color: #666;
}
.badge-brand {
  background: #F0F7FF;
  color: #616878;
  border: 2rpx solid #A9D2FF;
}
.badge-brand .badge-text{
  color: #616878;
}

.badge-trusted {
  background: #15B255;
  color: #fff;
}
.badge-trusted .badge-text{
  color: #fff;
}
.badge-icon {
  width: 24rpx;
  height: 24rpx;
}
.merchant-card-content{
  display: flex;
  flex-direction: column;
}
.merchant-stats {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
  gap: 32rpx;
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #555562;
}

.stat-value {
  font-size: 24rpx;
  color: #EF8802;
}

.stat-unit {
  font-size: 24rpx;
  color: #555562
}

.stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: #e0e0e0;
}

/* 任务ID卡片 */
.task-id-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
}
.title-text{
  font-family: PingFang SC, PingFang SC;
  font-weight: 800;
  font-size: 32rpx;
  color: #333333;
  line-height: 48rpx;
}

.id-info {
  display: flex;
  gap: 8rpx;
  
}

.id-label {
  font-size: 24rpx;
  color: #999;
}

.id-value {
  font-size: 24rpx;
  color: #222222;
  font-weight: 500;
}

.copy-btn {
  padding: 8rpx 24rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.copy-btn text {
  font-size: 22rpx;
  color: #666;
}

/* 详情卡片 */
.detail-header{
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #ECECEF;
}
.detail-card-title{
  font-family: PingFang SC, PingFang SC;
  font-weight: bold;
  font-size: 32rpx;
  color: #333333;
  line-height: 48rpx;
}
.detail-card {
  /* background: #fff;
  padding: 32rpx;
  margin-bottom: 24rpx; */
}

.detail-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  /* margin-bottom: 24rpx ; */
  display: block;
  /* margin-top: 24rpx ; */
  width: 456rpx;
  font-family: PingFang SC, PingFang SC;
}

.reward-row {
  display: flex;
  align-items: center;
  gap: 32rpx;
  margin-bottom: 32rpx;
  border-radius: 12rpx;
  justify-content: space-between;
  margin: 24rpx 0;
}

.reward-item {
  display: flex;
  /* flex-direction: column; */
  align-items: center;
  gap: 16rpx;
}

.reward-label {
  font-size: 24rpx;
  color: #333;
}

.reward-value-row {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.reward-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #EF4444;
  font-family: D-DIN-PRO, D-DIN-PRO;
}

.reward-unit {
  font-size: 28rpx;
  color: #EF4444;
}

.reward-plus {
  font-size: 32rpx;

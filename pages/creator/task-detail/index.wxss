.task-detail-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 160rpx;
}

/* 顶部状态栏 */
.status-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 32rpx;
  background: #fff;
}

.status-time {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.status-icons {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.signal-icon, .wifi-icon, .battery-icon {
  width: 32rpx;
  height: 22rpx;
  background: #333;
  border-radius: 4rpx;
}

.battery-icon {
  width: 48rpx;
  height: 24rpx;
}

/* 标题栏 */
.page-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: #fff;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 40rpx;
  color: #333;
  line-height: 1;
}

.page-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
}

.share-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

/* 标签切换 */
.tab-switch {
  position: relative;
  display: flex;
  background: #fff;
  padding: 0 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.tab-item {
  flex: 1;
  padding: 24rpx 0;
  text-align: center;
  font-size: 28rpx;
  color: #999;
  font-weight: 500;
}

.tab-item.active {
  color: #333;
  font-weight: 700;
}

.tab-indicator {
  position: absolute;
  bottom: 0;
  width: 64rpx;
  height: 4rpx;
  background: #ef8802;
  border-radius: 2rpx;
  transition: left 0.3s ease;
}

/* 内容滚动区 */
.content-scroll {
  height: calc(100vh - 280rpx);
}

/* 投稿流程 */
.flow-section {
  background: #fff;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.flow-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.flow-icon-text {
  font-size: 48rpx;
}

.flow-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 700;
}

.flow-subtitle {
  font-size: 24rpx;
  color: #999;
}

.flow-steps {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fafafa;
  border-radius: 16rpx;
  padding: 24rpx;
}

.flow-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.flow-dot {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(145deg, #ff9a1f, #ef6c00);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #fff;
}

.flow-line {
  width: 2rpx;
  height: 24rpx;
  background: #e0e0e0;
}

.flow-text {
  text-align: center;
}

.flow-label {
  font-size: 22rpx;
  color: #666;
  white-space: nowrap;
}

.flow-arrow {
  font-size: 28rpx;
  color: #ccc;
  flex-shrink: 0;
}

/* 商家信息卡片 */
.merchant-card {
  background: #fff;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.merchant-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.merchant-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 48rpx;
}

.merchant-detail {
  flex: 1;
}

.merchant-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
  display: block;
}

.merchant-badges {
  display: flex;
  gap: 16rpx;
}

.badge {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 4rpx 12rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
}

.badge-icon {
  font-size: 20rpx;
}

.badge-text {
  font-size: 20rpx;
  color: #666;
}

.merchant-stats {
  display: flex;
  align-items: center;
  background: #fafafa;
  border-radius: 12rpx;
  padding: 20rpx;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.stat-label {
  font-size: 20rpx;
  color: #999;
}

.stat-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
}

.stat-unit {
  font-size: 20rpx;
  color: #999;
}

.stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: #e0e0e0;
}

/* 任务ID卡片 */
.task-id-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  padding: 24rpx 32rpx;
  margin-bottom: 24rpx;
}

.id-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.id-label {
  font-size: 24rpx;
  color: #999;
}

.id-value {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
}

.copy-btn {
  padding: 8rpx 24rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
}

.copy-btn text {
  font-size: 22rpx;
  color: #666;
}

/* 详情卡片 */
.detail-card {
  background: #fff;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.detail-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 24rpx;
  display: block;
}

.reward-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
  margin-bottom: 32rpx;
  padding: 24rpx;
  background: #fff4e8;
  border-radius: 12rpx;
}

.reward-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.reward-label {
  font-size: 22rpx;
  color: #666;
}

.reward-value-row {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.reward-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #ef8802;
}

.reward-unit {
  font-size: 22rpx;
  color: #999;
}

.reward-plus {
  font-size: 32rpx;
  color: #ccc;
}

/* 标签 */
.tags-row {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.tag-group {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.tag-label {
  font-size: 22rpx;
  color: #999;
}

.tag-value {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
  padding: 8rpx 16rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
}

/* 描述 */
.desc-section {
  padding: 20rpx;
  background: #fafafa;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.desc-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
}

/* 规格 */
.specs-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.spec-item {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.spec-label {
  font-size: 22rpx;
  color: #999;
}

.spec-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.spec-value.deadline {
  color: #ef8802;
}

/* 平台禁忌 */
.restriction-section {
  padding: 16rpx 20rpx;
  background: #fff4e8;
  border-radius: 8rpx;
}

.restriction-text {
  font-size: 22rpx;
  color: #ef8802;
  line-height: 1.5;
}

/* 素材卡片 */
.material-card {
  background: #fff;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.header-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
}

.download-btn {
  padding: 8rpx 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
}

.download-btn text {
  font-size: 22rpx;
  color: #666;
}

.material-grid {
  display: flex;
  gap: 16rpx;
  overflow-x: auto;
}

.material-item {
  flex-shrink: 0;
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.material-thumb {
  width: 100%;
  height: 100%;
}

/* 即梦卡片 */
.jimeng-card {
  background: #fff;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.jimeng-content {
  margin-top: 16rpx;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
}

.jimeng-link {
  font-size: 24rpx;
  color: #2563eb;
  word-break: break-all;
}

.jimeng-lock {
  margin-top: 16rpx;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  text-align: center;
}

.lock-text {
  font-size: 24rpx;
  color: #999;
}

/* 安全提醒 */
.safety-card {
  background: #fff;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.safety-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.safety-icon {
  font-size: 32rpx;
}

.safety-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
}

.safety-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

/* 热门推荐 */
.recommend-section {
  background: #fff;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.recommend-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.recommend-icon {
  font-size: 32rpx;
}

.recommend-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
}

.recommend-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.recommend-card {
  padding: 24rpx;
  background: #fafafa;
  border-radius: 16rpx;
}

.recommend-info {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.recommend-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
  margin-right: 16rpx;
}

.reward-amount {
  font-size: 32rpx;
  font-weight: 700;
  color: #ef8802;
}

.reward-unit {
  font-size: 22rpx;
  color: #999;
}

.recommend-tags {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.recommend-tag {
  font-size: 20rpx;
  color: #666;
  padding: 4rpx 12rpx;
  background: #fff;
  border-radius: 6rpx;
}

.recommend-progress {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.progress-label {
  font-size: 22rpx;
  color: #999;
  flex-shrink: 0;
}

.progress-bar {
  flex: 1;
  height: 8rpx;
  background: #e0e0e0;
  border-radius: 4rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #ff9a1f, #ef6c00);
  border-radius: 4rpx;
}

.progress-text {
  font-size: 22rpx;
  color: #666;
  flex-shrink: 0;
}

.recommend-action {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.countdown-text {
  font-size: 22rpx;
  color: #999;
}

.action-btn {
  padding: 12rpx 32rpx;
  background: linear-gradient(135deg, #ff9a1f, #ef6c00);
  border-radius: 24rpx;
}

.action-btn text {
  font-size: 24rpx;
  color: #fff;
  font-weight: 600;
}

/* 投稿内容 */
.submissions-content {
  padding: 120rpx 0;
  text-align: center;
}

.submissions-empty text {
  font-size: 28rpx;
  color: #999;
}

/* 底部操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
}

.countdown-section {
  display: flex;
  flex-direction: column;
}

.countdown-label {
  font-size: 20rpx;
  color: #999;
}

.countdown-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
}

.signup-btn, .submit-btn {
  padding: 24rpx 64rpx;
  background: linear-gradient(135deg, #ff9a1f, #ef6c00);
  border-radius: 48rpx;
  border: none;
}

.signup-btn text, .submit-btn text {
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
}

.signup-btn::after, .submit-btn::after {
  border: none;
}

.signed-badge {
  padding: 24rpx 48rpx;
  background: #f5f5f5;
  border-radius: 48rpx;
}

.signed-badge text {
  font-size: 28rpx;
  color: #666;
}
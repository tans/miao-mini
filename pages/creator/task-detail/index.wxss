}
.task-progress{
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.progress-info {
  display: flex;
  align-items: center;
  gap: 4rpx;
}
.progress-text {
  font-size: 24rpx;
  color: #999;
}

.progress-num {
  font-size: 24rpx;
  color: #F99935;
  font-weight: 600;
}
.progress-bar-body {
  width: 100%;
  margin-top: 16rpx;
}
.progress-bar {
  width: 100%;
  border-radius: 4px;
  flex: 1;
  height: 16rpx;
  background: #F2EEEB;

}

/* 安全提醒 */
.safety-card {
  background: #fff;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.safety-header {
  display: flex;
  gap: 2rpx;
  margin-bottom: 16rpx;
}

.safety-icon {
  font-size: 32rpx;
}

.safety-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #333;
}

.safety-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

/* 热门推荐 */
.recommend-section {
  /* background: #fff; */
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.recommend-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
  justify-content: center;
}

.recommend-icon {
  font-size: 32rpx;
}

.recommend-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
}

.recommend-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.recommend-card {
  padding: 24rpx;
  background: #fafafa;
  border-radius: 16rpx;
}

.recommend-info {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.recommend-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  /* flex: 1; */
  margin-right: 16rpx;
}

.reward-amount {
  font-size: 32rpx;
  font-weight: 700;
  color: #ef8802;
}

.recommend-tags {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.recommend-tag {
  font-size: 20rpx;
  color: #666;
  padding: 4rpx 12rpx;

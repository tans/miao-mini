}

.progress-label {
  font-size: 22rpx;
  color: #999;
  flex-shrink: 0;
}


.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #ff9a1f, #ef6c00);
  border-radius: 4rpx;
}

.progress-text {
  font-size: 22rpx;
  color: #666;
  flex-shrink: 0;
}

.recommend-action {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.countdown-text {
  font-size: 22rpx;
  color: #999;
}

.action-btn {
  padding: 12rpx 32rpx;
  background: linear-gradient(135deg, #ff9a1f, #ef6c00);
  border-radius: 24rpx;
}

.action-btn text {
  font-size: 24rpx;
  color: #fff;
  font-weight: 600;
}

/* 投稿内容 */
.submissions-content {
  padding: 16rpx 24rpx;
}

.submission-card {
  background: transparent;
  border-radius: 0;
  padding: 0;
  box-shadow: none;
}

.submission-mock-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.submission-mock-item {
  width: calc((100% - 24rpx) / 2);
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0rpx 20rpx 52rpx 0rpx rgba(20,42,31,0.08);
  border-radius: 16rpx 16rpx 16rpx 16rpx;
}

.submission-mock-cover-wrap {
  position: relative;
  height: 320rpx;
  background: #e5e7eb;
}

.submission-mock-cover {
  width: 100%;
  height: 100%;
}

.submission-mock-cover-overlay {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  z-index: 8;
}

.submission-mock-status {
  position: absolute;
  left: 0;
  top: 0;
  padding: 16rpx 24rpx;
  border-radius: 0 0 16rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.submission-mock-status text {
  font-size: 24rpx;
}

.submission-mock-status-approved {
  background: #15B255;
}

.submission-mock-status-approved text {
  color: #fff;
}

.submission-mock-status-rejected {
  background: #ECEEF4;
}

.submission-mock-status-rejected text {
  color: #878FA1;
}

.submission-mock-status-pending {
  background: #FFF3E8;
}

.submission-mock-status-pending text {
  color: #EF8802;
}

.submission-mock-status-reported {
  background: #FDECEC;
}

.submission-mock-status-reported text {
  color: #D63A3A;
}

.submission-mock-play {
  position: absolute;
  right: 16rpx;
  top: 16rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(31, 41, 55, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.submission-mock-play text {
  font-size: 20rpx;
  color: #fff;
}

.submission-mock-footer {
  padding: 32rpx 16rpx;
}

.submission-mock-user-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
}

.submission-mock-user-left {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.submission-mock-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.submission-mock-name {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
  color: #333;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.submission-mock-level {
  font-size: 23rpx;
  color: #8C8C98;
  font-weight: 600;
  flex-shrink: 0;
}

.submission-mock-time {
  display: block;
  margin-top: 24rpx;
  font-size: 24rpx;
  color: #8C8C98;
}

.submission-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 24rpx;
}

.submission-header-main {
  flex: 1;
}

.submission-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
}

.submission-time {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.submission-status {
  flex-shrink: 0;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: #fff4e8;
}

.submission-status text {
  font-size: 24rpx;
  font-weight: 600;
  color: #ef8802;
}

.submission-status.status-approved {
  background: #e8f7eb;
}

.submission-status.status-approved text {
  color: #16a34a;
}

.submission-status.status-cancelled,
.submission-status.status-expired {
  background: #f3f4f6;
}

.submission-status.status-cancelled text,
.submission-status.status-expired text {
  color: #6b7280;
}

.submission-summary {
  margin-top: 24rpx;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  background: #f7fafc;
}

.submission-summary text {
  font-size: 24rpx;
  color: #374151;
  line-height: 1.6;
}

.submission-content {
  margin-top: 20rpx;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  background: #fff7ed;
}

.submission-content text {
  font-size: 24rpx;
  color: #9a3412;
  line-height: 1.6;
}

.submission-material-list {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.submission-material {
  padding-top: 24rpx;
  border-top: 1rpx solid #f1f5f9;
}

.submission-material:first-child {
  padding-top: 0;
  border-top: none;
}

.submission-material-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.submission-material-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
}

.submission-material-status {
  flex-shrink: 0;
  font-size: 22rpx;
  line-height: 1.4;
}

.submission-material-status.status-done {
  color: #16a34a;
}

.submission-material-status.status-processing,
.submission-material-status.status-pending {
  color: #ef8802;
}

.submission-material-status.status-failed {
  color: #dc2626;
}

.submission-video,
.submission-image,
.submission-placeholder {
  width: 100%;
  height: 720rpx;
  border-radius: 20rpx;
  background: #0f172a;
}

.submission-image {
  background: #f3f4f6;
}

.submission-private-cover {
  object-fit: cover;
}

.submission-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
}

.submission-placeholder text {
  font-size: 26rpx;
  color: #cbd5e1;
}

.submission-error {
  display: block;
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #dc2626;
  line-height: 1.5;
}

.submission-empty-tip {
  margin-top: 24rpx;
  padding: 28rpx 24rpx;
  border-radius: 16rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.submission-empty-tip text {
  margin-top: 22rpx;
  font-size: 24rpx;
  color: #878FA1;
  line-height: 1.6;
  text-align: center;
}

.submissions-empty {
  padding: 160rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.submissions-empty image{
  width: 300rpx;
  height: 300rpx;
}

.submissions-empty text {
  margin-top: 22rpx;
  font-size: 24rpx;
  color: #878FA1;
  line-height: 1.6;
  text-align: center;
}

.submissions-empty .clock-icon,.submission-empty-tip .clock-icon {
  width: 300rpx;
  height: 300rpx;
  display: block;
}

/* 底部操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
  flex-direction: column;
}
.action-text{
  font-size: 24rpx;
color: #8C8C98;
margin-bottom: 8rpx;
}

.creator-agreement-link {
  color: #ef8802;
}

.countdown-section {
  display: flex;
  flex-direction: column;
}

.countdown-label {
  font-size: 20rpx;
  color: #999;
}

.countdown-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
}

.signup-btn, .submit-btn {
  padding: 24rpx 64rpx;
  background: #FF9F2F;
  border-radius: 48rpx;
  border: none;
  width: 100%;
}

.signup-btn text, .submit-btn text {
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
}

.signup-btn::after, .submit-btn::after {
  border: none;
}

.signed-badge {
  padding: 24rpx 48rpx;
  background: #f5f5f5;
  border-radius: 48rpx;
}

.signed-badge text {
  font-size: 28rpx;
  color: #666;
}

.submit-work-btn {
  padding: 24rpx 64rpx;
  background: #FF9F2F;
  border-radius: 48rpx;
  border: none;
}

.submit-work-btn-disabled {
  padding: 24rpx 64rpx;
  background: #d9dee7;
  border-radius: 48rpx;
  border: none;
}

.submit-work-btn text {
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
}

.submit-work-btn-disabled text {
  font-size: 30rpx;
  font-weight: 700;
  color: #7b8794;
}

.submit-work-btn::after {
  border: none;
}

.submit-work-btn-disabled::after {
  border: none;
}

.action-state-pending {
  padding: 24rpx 64rpx;
  background: #FFF3E8;
  border-radius: 48rpx;
  border: 1rpx solid #F8D1A3;
}

.action-state-pending text {
  font-size: 30rpx;
  font-weight: 700;
  color: #EF8802;
}

.action-state-pending::after {
  border: none;
}

.action-state-approved {
  padding: 24rpx 64rpx;
  background: #15B255;
  border-radius: 48rpx;
  border: none;
}

.action-state-approved text {
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
}

.action-state-approved::after {
  border: none;
}

.action-state-rejected,
.action-state-timeout {
  padding: 24rpx 64rpx;
  background: #ECEEF4;
  border-radius: 48rpx;
  border: none;
}

.action-state-rejected text,
.action-state-timeout text {
  font-size: 30rpx;
  font-weight: 700;
  color: #878FA1;
}

.action-state-rejected::after,
.action-state-timeout::after {
  border: none;
}

.action-state-reported {
  padding: 24rpx 64rpx;
  background: #FDECEC;
  border-radius: 48rpx;
  border: 1rpx solid #F5C4C4;
}

.action-state-reported text {
  font-size: 30rpx;
  font-weight: 700;
  color: #D63A3A;
}

.action-state-reported::after {
  border: none;
}

/* 提交模态框 */
.submit-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.submit-modal {
  width: 100%;
  max-height: 85vh;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #999;
}

.modal-body {
  flex: 1;
  padding: 32rpx;
  overflow-y: auto;
}

.modal-video {
  width: 100%;
  height: 400rpx;
  border-radius: 16rpx;
  background: #000;
}

.video-preview {
  position: relative;
  margin-bottom: 24rpx;
}

.video-cover-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0,0,0,0.3);
  border-radius: 16rpx;
}

.cover-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
}

.upload-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
  background: #f5f5f5;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.upload-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff9a1f, #ef6c00);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.upload-icon-text {
  font-size: 64rpx;
  color: #fff;
  font-weight: 300;
  line-height: 1;
}

.upload-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.upload-hint {
  font-size: 22rpx;
  color: #999;
}

.ai-disclosure-note {
  margin-top: 8rpx;
  padding: 20rpx 20rpx 18rpx;
  border-radius: 16rpx;
  background: #fff8ef;
  border: 1rpx solid #ffd9ad;
}

.ai-disclosure-title {
  display: block;
  font-size: 26rpx;
  line-height: 1.4;
  font-weight: 700;
  color: #bf6a00;
}

.ai-disclosure-text {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #8b6a3d;
}

.modal-footer {
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f0f0f0;
}

.modal-footer .submit-btn {
  width: 100%;
  padding: 28rpx 0;
  background: linear-gradient(135deg, #ff9a1f, #ef6c00);
  border-radius: 48rpx;
  border: none;
  text-align: center;
}

.modal-footer .submit-btn.disabled {
  background: #ccc;
}

.modal-footer .submit-btn text {
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
}

.modal-footer .submit-btn::after {
  border: none;
}

/* 创作者须知弹框 */
.creator-notice-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 1300;
  background: rgba(0, 0, 0, 0.52);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 48rpx;
}

.creator-notice-modal {
  width: 100%;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.creator-notice-body {
  padding: 38rpx 40rpx 28rpx;
}

.creator-notice-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 24rpx;
}

.creator-notice-text {
  display: block;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  margin-top: 16rpx;
}

.creator-notice-highlight {
  color: #ef8802;
}

.creator-notice-footer {
  display: flex;
  border-top: 1rpx solid #ececef;
}

.creator-notice-btn {
  flex: 1;
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.creator-notice-btn text {
  font-size: 34rpx;
}

.creator-notice-btn-cancel {
  border-right: 1rpx solid #ececef;
}

.creator-notice-btn-cancel text {
  color: #555562;
}

.creator-notice-btn-confirm text {
  color: #7f8eb2;
}

/* 上传进度弹框 */
.upload-progress-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 1400;
  background: rgba(0, 0, 0, 0.52);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 48rpx;
}

.upload-progress-modal {
  width: 100%;
  background: #fff;
  border-radius: 16rpx;
  padding: 34rpx 40rpx 38rpx;
  position: relative;
}

.upload-progress-close {
  position: absolute;
  right: 24rpx;
  top: 20rpx;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-progress-close text {
  font-size: 48rpx;
  color: #2f3138;
  line-height: 1;
}

.upload-progress-percent {
  display: flex;
  margin-top: 44rpx;
  align-items: center;
  justify-content: center;
}

.upload-progress-percent-text {
  font-size: 24rpx;
  font-weight: 700;
  color: #505668;
}

.upload-progress-title {
  display: block;
  margin-top: 26rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #333333;
}

.upload-progress-text {
  display: block;
  margin-top: 30rpx;
  font-size: 28rpx;
  color: #555562;
  line-height: 1.6;
}

.upload-progress-highlight {
  color: #ef8802;
}

/* 报名成功弹窗（对齐 pages/wallet 充值成功弹窗） */
.signup-success-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1350;
  display: flex;
  align-items: center;
  justify-content: center;
}

.signup-success-container {
  position: fixed;
  width: 100vw;
  height: 100vh;
  z-index: 1351;
  display: flex;
  align-items: center;
  justify-content: center;
  left: 0;
  top: 0;
  pointer-events: none;
}

.signup-success-content {
  pointer-events: auto;
  border-radius: 24rpx;
  background: #fff;
  overflow: hidden;
  width: 640rpx;
  padding-top: 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.signup-success-icon {
  width: 117rpx;
  height: 117rpx;
  margin: 58rpx;
}

.signup-success-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.signup-success-desc {
  font-size: 28rpx;
  color: #333;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 48rpx;
  padding: 0 48rpx;
}

.signup-success-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 0 0 24rpx 24rpx;
  color: #576b95;
  font-size: 30rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  border-top: 2rpx solid #e5e5e5;
  box-sizing: border-box;
}

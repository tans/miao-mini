}

/* 即梦卡片 */
.jimeng-card {
  background: #F5F5F7;
  padding: 32rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.header-content{
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.header-desc{
  font-size: 24rpx;
  color: #555562;
  line-height: 36rpx;
}

.jimeng-content {
  margin-top: 24rpx;
  padding: 20rpx 24rpx;
  background: #F6F7FE;
  border-radius: 16rpx;

.task-detail-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 160rpx;
  overflow: hidden;
}

/* 流程图 */
.flow-section {
  background: #fff;
  margin: 32rpx 24rpx;
  border-radius: 16rpx;
  box-shadow: 0px 10rpx 26rpx rgba(20,42,31,0.08);
  padding-bottom: 16rpx;
}

.flow-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 24rpx;
}

.flow-header-left {
  display: flex;
  align-items: center;
}

.flow-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 8rpx;
}

.flow-headline {
  font-size: 28rpx;
  font-weight: 900;
  color: #333;
}

.flow-headline-highlight {
  font-size: 28rpx;
  font-weight: 900;
  color: #ef8802;
  margin-left: 8rpx;
}

.flow-hint {
  font-size: 24rpx;
  font-weight: 500;
  color: #ef8802;
  margin-left: 206rpx;
}

.flow-body {
  display: flex;
  align-items: flex-start;
  justify-content: flex-start;
  padding-left: 56rpx;
  margin-bottom: 34rpx;
}

.flow-step {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.flow-icon-wrapper {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.flow-step-icon {
  width: 60rpx;
  height: 60rpx;
}

.flow-step-text {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.flow-step-title {
  font-size: 24rpx;
  font-weight: 900;
  color: #333;
  white-space: nowrap;
  text-align: center;
}

.flow-step-sub {
  font-size: 20rpx;
  color: #666;
  white-space: nowrap;
  text-align: center;
}

.flow-arrow {
  width: 90rpx;
  height: 20rpx;
  flex-shrink: 0;
  margin: 20rpx 0 0 -12rpx;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 32rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.nav-left, .nav-right {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
}

.nav-back {
  width: 40rpx;
  height: 40rpx;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 900;
  color: #333;
}

/* 标签切换 */
.tab-switch {
  position: relative;
  display: flex;
  background: #fff;
  padding: 20rpx 32rpx 0 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.tab-item {
  padding: 16rpx 20rpx;
  text-align: center;
  font-size: 28rpx;
  color: #999;
  font-weight: 500;
}

.tab-item.active {
  color: #333;
  font-weight: 700;
}

.tab-indicator {
  position: absolute;
  bottom: 0;
  width: 64rpx;
  height: 4rpx;
  background: #ef8802;
  border-radius: 2rpx;
  transition: left 0.3s ease;
}

/* 内容滚动区 */
.content-scroll {
  height: calc(100vh - 280rpx);
}

/* 商家信息卡片 */
.detail-content{
  padding: 40rpx 24rpx;
}
.merchant-card {
  background: #fff;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0rpx 20rpx 52rpx 0rpx rgba(20,42,31,0.08);
}

.merchant-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.merchant-avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 16rpx;
}

.merchant-detail {
  flex: 1;
}

.merchant-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
  display: block;
}

.merchant-badges {
  display: flex;
  gap: 16rpx;
}

.badge {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 4rpx 12rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
}

.badge-icon {
  font-size: 20rpx;
}

.badge-text {
  font-size: 20rpx;
  color: #666;
}
.badge-brand {
  background: #F0F7FF;
  color: #616878;
}

.badge-trusted {
  background: #E9FFEE;
  color: #616878;
}
.badge-icon {
  width: 24rpx;
  height: 24rpx;
}

.merchant-stats {
  display: flex;
  align-items: center;
  border-radius: 12rpx;
  padding: 8rpx 0 40rpx 0;
  justify-content: space-between;
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #555562;
}

.stat-value {
  font-size: 24rpx;
  color: #EF8802;
}

.stat-unit {
  font-size: 24rpx;
  color: #555562
}

.stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: #e0e0e0;
}

/* 任务ID卡片 */
.task-id-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  border-top: 2rpx solid #ECEEF4;
  padding-top: 20rpx;
}

.id-info {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 8rpx;
  
}

.id-label {
  font-size: 24rpx;
  color: #999;
}

.id-value {
  font-size: 24rpx;
  color: #222222;
  font-weight: 500;
}

.copy-btn {
  padding: 8rpx 24rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.copy-btn text {
  font-size: 22rpx;
  color: #666;
}

/* 详情卡片 */
.detail-card-title{
  font-family: PingFang SC, PingFang SC;
  font-weight: bold;
  font-size: 32rpx;
  color: #333333;
  line-height: 48rpx;
}
.detail-card {
  background: #fff;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.detail-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 24rpx;
  display: block;
  margin-top: 24rpx;
}

.reward-row {
  display: flex;
  align-items: center;
  /* justify-content: center ; */
  gap: 32rpx;
  margin-bottom: 32rpx;
  /* padding: 24rpx ; */
  /* background: #fff4e8 ; */
  border-radius: 12rpx;
  justify-content: space-between;
}

.reward-item {
  display: flex;
  /* flex-direction: column; */
  align-items: center;
  gap: 8rpx;
}

.reward-label {
  font-size: 24rpx;
  color: #8C8C98;
}

.reward-value-row {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.reward-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #EF4444;
}

.reward-unit {
  font-size: 24rpx;
  color: #8C8C98;
}

.reward-plus {
  font-size: 32rpx;
  color: #ccc;
}

/* 标签 */
.tags-row {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.tag-group {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.tag-label {
  font-size: 22rpx;
  color: #999;
}

.tag-value {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
  padding: 8rpx 16rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
}

/* 描述 */
.desc-section {
  padding: 24rpx 32rpx;
  background: #EEF5FF;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.desc-text {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
}

/* 规格 */
.specs-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.spec-item {
  display: flex;
  justify-content: space-between;
  gap: 4rpx;
  border-bottom: 1px solid #ECECEF;
  padding-bottom: 16rpx;
  padding-top: 16rpx;
}

.spec-label {
  font-size: 28rpx;
  color: #555562;
}

.spec-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.spec-value.deadline {
  color: #333;
}

/* 平台禁忌 */
.restriction-section {
  padding: 16rpx 20rpx;
  background: rgba(239,68,68,0.08);
  border-radius: 8rpx;
}

.restriction-text {
  font-size: 24rpx;
  color: #EF4444;
  line-height: 1.5;
}

/* 素材卡片 */
.material-card {
  background: #fff;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
}

.download-btn {
  padding: 8rpx 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
}

.download-btn text {
  font-size: 22rpx;
  color: #666;
}

.material-grid {
  display: flex;
  gap: 16rpx;
  overflow-x: auto;
}

.material-item {
  flex-shrink: 0;
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.material-thumb {
  width: 100%;
  height: 100%;
}

/* 即梦卡片 */
.jimeng-card {
  background: #F5F5F7;
  padding: 32rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.jimeng-content {
  margin-top: 16rpx;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
}

.jimeng-link {
  font-size: 24rpx;
  color: #2563eb;
  word-break: break-all;
}

.jimeng-lock {
  padding: 8rpx 16rpx;
  background: #EEF5FF;
  border-radius: 12rpx;
  text-align: center;
}

.lock-text {
  font-size: 24rpx;
  color: #8C8C98;
}

/* 安全提醒 */
.safety-card {
  background: #fff;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.safety-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.safety-icon {
  font-size: 32rpx;
}

.safety-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
}

.safety-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

/* 热门推荐 */
.recommend-section {
  /* background: #fff; */
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.recommend-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
  justify-content: center;
}

.recommend-icon {
  font-size: 32rpx;
}

.recommend-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
}

.recommend-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.recommend-card {
  padding: 24rpx;
  background: #fafafa;
  border-radius: 16rpx;
}

.recommend-info {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.recommend-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  /* flex: 1; */
  margin-right: 16rpx;
}

.reward-amount {
  font-size: 32rpx;
  font-weight: 700;
  color: #ef8802;
}

.reward-unit {
  font-size: 22rpx;
  color: #999;
}

.recommend-tags {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.recommend-tag {
  font-size: 20rpx;
  color: #666;
  padding: 4rpx 12rpx;
  background: #fff;
  border-radius: 6rpx;
}

.recommend-progress {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.progress-label {
  font-size: 22rpx;
  color: #999;
  flex-shrink: 0;
}

.progress-bar {
  flex: 1;
  height: 8rpx;
  background: #e0e0e0;
  border-radius: 4rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #ff9a1f, #ef6c00);
  border-radius: 4rpx;
}

.progress-text {
  font-size: 22rpx;
  color: #666;
  flex-shrink: 0;
}

.recommend-action {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.countdown-text {
  font-size: 22rpx;
  color: #999;
}

.action-btn {
  padding: 12rpx 32rpx;
  background: linear-gradient(135deg, #ff9a1f, #ef6c00);
  border-radius: 24rpx;
}

.action-btn text {
  font-size: 24rpx;
  color: #fff;
  font-weight: 600;
}

/* 投稿内容 */
.submissions-content {
  padding: 16rpx 24rpx;
}

.submission-card {
  background: transparent;
  border-radius: 0;
  padding: 0;
  box-shadow: none;
}

.submission-mock-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.submission-mock-item {
  width: calc((100% - 24rpx) / 2);
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0rpx 20rpx 52rpx 0rpx rgba(20,42,31,0.08);
  border-radius: 16rpx 16rpx 16rpx 16rpx;
}

.submission-mock-cover-wrap {
  position: relative;
  height: 320rpx;
  background: #e5e7eb;
}

.submission-mock-cover {
  width: 100%;
  height: 100%;
}

.submission-mock-status {
  position: absolute;
  left: 0;
  top: 0;
  padding: 16rpx 24rpx;
  border-radius: 0 0 16rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.submission-mock-status text {
  font-size: 24rpx;
}

.submission-mock-status-approved {
  background: #15B255;
}

.submission-mock-status-approved text {
  color: #fff;
}

.submission-mock-status-rejected {
  background: #ECEEF4;
}

.submission-mock-status-rejected text {
  color: #878FA1;
}

.submission-mock-play {
  position: absolute;
  right: 16rpx;
  top: 16rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(31, 41, 55, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.submission-mock-play text {
  font-size: 20rpx;
  color: #fff;
}

.submission-mock-footer {
  padding: 32rpx 16rpx;
}

.submission-mock-user-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
}

.submission-mock-user-left {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.submission-mock-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.submission-mock-name {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
  color: #333;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.submission-mock-level {
  font-size: 23rpx;
  color: #8C8C98;
  font-weight: 600;
  flex-shrink: 0;
}

.submission-mock-time {
  display: block;
  margin-top: 24rpx;
  font-size: 24rpx;
  color: #8C8C98;
}

.submission-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 24rpx;
}

.submission-header-main {
  flex: 1;
}

.submission-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
}

.submission-time {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.submission-status {
  flex-shrink: 0;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: #fff4e8;
}

.submission-status text {
  font-size: 24rpx;
  font-weight: 600;
  color: #ef8802;
}

.submission-status.status-approved {
  background: #e8f7eb;
}

.submission-status.status-approved text {
  color: #16a34a;
}

.submission-status.status-cancelled,
.submission-status.status-expired {
  background: #f3f4f6;
}

.submission-status.status-cancelled text,
.submission-status.status-expired text {
  color: #6b7280;
}

.submission-summary {
  margin-top: 24rpx;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  background: #f7fafc;
}

.submission-summary text {
  font-size: 24rpx;
  color: #374151;
  line-height: 1.6;
}

.submission-content {
  margin-top: 20rpx;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  background: #fff7ed;
}

.submission-content text {
  font-size: 24rpx;
  color: #9a3412;
  line-height: 1.6;
}

.submission-material-list {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.submission-material {
  padding-top: 24rpx;
  border-top: 1rpx solid #f1f5f9;
}

.submission-material:first-child {
  padding-top: 0;
  border-top: none;
}

.submission-material-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.submission-material-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
}

.submission-material-status {
  flex-shrink: 0;
  font-size: 22rpx;
  line-height: 1.4;
}

.submission-material-status.status-done {
  color: #16a34a;
}

.submission-material-status.status-processing,
.submission-material-status.status-pending {
  color: #ef8802;
}

.submission-material-status.status-failed {
  color: #dc2626;
}

.submission-video,
.submission-image,
.submission-placeholder {
  width: 100%;
  height: 720rpx;
  border-radius: 20rpx;
  background: #0f172a;
}

.submission-image {
  background: #f3f4f6;
}

.submission-private-cover {
  object-fit: cover;
}

.submission-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
}

.submission-placeholder text {
  font-size: 26rpx;
  color: #cbd5e1;
}

.submission-error {
  display: block;
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #dc2626;
  line-height: 1.5;
}

.submission-empty-tip {
  margin-top: 24rpx;
  padding: 28rpx 24rpx;
  border-radius: 16rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.submission-empty-tip text {
  margin-top: 22rpx;
  font-size: 24rpx;
  color: #878FA1;
  line-height: 1.6;
  text-align: center;
}

.submissions-empty {
  padding: 160rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.submissions-empty text {
  margin-top: 22rpx;
  font-size: 24rpx;
  color: #878FA1;
  line-height: 1.6;
  text-align: center;
}

.submissions-empty,.submission-empty-tip .clock-icon {
  width: 300rpx;
  height: 300rpx;
  display: block;
}

/* 底部操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
}

.countdown-section {
  display: flex;
  flex-direction: column;
}

.countdown-label {
  font-size: 20rpx;
  color: #999;
}

.countdown-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
}

.signup-btn, .submit-btn {
  padding: 24rpx 64rpx;
  background: linear-gradient(135deg, #ff9a1f, #ef6c00);
  border-radius: 48rpx;
  border: none;
  width: 100%;
}

.signup-btn text, .submit-btn text {
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
}

.signup-btn::after, .submit-btn::after {
  border: none;
}

.signed-badge {
  padding: 24rpx 48rpx;
  background: #f5f5f5;
  border-radius: 48rpx;
}

.signed-badge text {
  font-size: 28rpx;
  color: #666;
}

.submit-work-btn {
  padding: 24rpx 64rpx;
  background: linear-gradient(135deg, #ff9a1f, #ef6c00);
  border-radius: 48rpx;
  border: none;
}

.submit-work-btn text {
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
}

.submit-work-btn::after {
  border: none;
}

/* 提交模态框 */
.submit-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.submit-modal {
  width: 100%;
  max-height: 85vh;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #999;
}

.modal-body {
  flex: 1;
  padding: 32rpx;
  overflow-y: auto;
}

.modal-video {
  width: 100%;
  height: 400rpx;
  border-radius: 16rpx;
  background: #000;
}

.video-preview {
  position: relative;
  margin-bottom: 24rpx;
}

.video-cover-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0,0,0,0.3);
  border-radius: 16rpx;
}

.cover-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
}

.upload-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
  background: #f5f5f5;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.upload-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff9a1f, #ef6c00);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.upload-icon-text {
  font-size: 64rpx;
  color: #fff;
  font-weight: 300;
  line-height: 1;
}

.upload-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.upload-hint {
  font-size: 22rpx;
  color: #999;
}

.modal-footer {
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f0f0f0;
}

.modal-footer .submit-btn {
  width: 100%;
  padding: 28rpx 0;
  background: linear-gradient(135deg, #ff9a1f, #ef6c00);
  border-radius: 48rpx;
  border: none;
  text-align: center;
}

.modal-footer .submit-btn.disabled {
  background: #ccc;
}

.modal-footer .submit-btn text {
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
}

.modal-footer .submit-btn::after {
  border: none;
}

/* 创作者须知弹框 */
.creator-notice-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 1300;
  background: rgba(0, 0, 0, 0.52);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 48rpx;
}

.creator-notice-modal {
  width: 100%;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.creator-notice-body {
  padding: 38rpx 40rpx 28rpx;
}

.creator-notice-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 24rpx;
}

.creator-notice-text {
  display: block;
  font-size: 28rpx;
  color: #555562;
  line-height: 1.6;
  margin-top: 16rpx;
}

.creator-notice-highlight {
  color: #ef8802;
}

.creator-notice-footer {
  display: flex;
  border-top: 1rpx solid #ececef;
}

.creator-notice-btn {
  flex: 1;
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.creator-notice-btn text {
  font-size: 34rpx;
}

.creator-notice-btn-cancel {
  border-right: 1rpx solid #ececef;
}

.creator-notice-btn-cancel text {
  color: #555562;
}

.creator-notice-btn-confirm text {
  color: #7f8eb2;
}

/* 上传进度弹框 */
.upload-progress-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 1400;
  background: rgba(0, 0, 0, 0.52);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 48rpx;
}

.upload-progress-modal {
  width: 100%;
  background: #fff;
  border-radius: 16rpx;
  padding: 34rpx 40rpx 38rpx;
  position: relative;
}

.upload-progress-close {
  position: absolute;
  right: 24rpx;
  top: 20rpx;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-progress-close text {
  font-size: 48rpx;
  color: #2f3138;
  line-height: 1;
}

.upload-progress-percent {
  display: flex;
  margin-top: 44rpx;
  align-items: center;
  justify-content: center;
}

.upload-progress-percent-text {
  font-size: 24rpx;
  font-weight: 700;
  color: #505668;
}

.upload-progress-title {
  display: block;
  margin-top: 26rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #333333;
}

.upload-progress-text {
  display: block;
  margin-top: 30rpx;
  font-size: 28rpx;
  color: #555562;
  line-height: 1.6;
}

.upload-progress-highlight {
  color: #ef8802;
}

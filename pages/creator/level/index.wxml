<view class="level-page">
  <view class="page-header">
    <view class="header-left">
      <text class="page-title">创作者等级</text>
      <text class="page-score">{{currentAdoptedCount}}</text>
    </view>
    <view class="header-deco"></view>
  </view>

  <view class="summary-grid">
    <view class="summary-item">
      <text class="summary-label">累计报名</text>
      <text class="summary-value">{{currentAdoptedCount}}</text>
    </view>
    <view class="summary-item">
      <text class="summary-label">累计提交</text>
      <text class="summary-value">{{currentAdoptedCount}}</text>
    </view>
    <view class="summary-item">
      <text class="summary-label">累计采纳</text>
      <text class="summary-value">{{currentAdoptedCount}}</text>
    </view>
  </view>

  <view class="current-card" wx:if="{{currentLevel < 6}}">
    <view class="current-half">
      <text class="current-title">Lv{{currentLevel}} {{levels[currentLevel].name}}</text>
      <text class="current-sub">当前等级</text>
    </view>
    <view class="current-half">
      <text class="current-title">{{levels[currentLevel].commission}}</text>
      <text class="current-sub">当前佣金</text>
    </view>
  </view>

  <view class="rule-card">
    <view class="rule-title-row">
      <text class="rule-brand">创意喵</text>
      <text class="rule-title">升级规则</text>
    </view>
    <text class="rule-desc">创意喵创作者等级根据累计采纳数（作品被商家录用/入围次数）自动升级，等级越高，权益越好、提现佣金越低。</text>

    <view class="level-table">
      <view class="table-header">
        <text class="col-level">等级</text>
        <text class="col-condition">升级条件（累计采纳数）</text>
        <text class="col-daily">核心权限（每日投稿上限）</text>
        <text class="col-commission">平台佣金</text>
      </view>
      <view class="level-row {{item.level === currentLevel ? 'current' : ''}}" wx:for="{{levels}}" wx:key="level">
        <text class="col-level">Lv{{item.level}}</text>
        <text class="col-condition">{{item.condition}}</text>
        <text class="col-daily">{{item.dailyLimit}}</text>
        <text class="col-commission {{item.commission === '3%' || item.commission === '5%' ? 'low' : ''}}">{{item.commission}}</text>
      </view>
    </view>
  </view>
</view>
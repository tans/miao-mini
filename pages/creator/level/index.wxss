.level-page {
  padding: 16rpx;
  background: #f3f3f3;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 32rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.nav-left, .nav-right {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
}

.nav-back {
  width: 40rpx;
  height: 40rpx;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 900;
  color: #333;
}

.page-header {
  background: linear-gradient(125deg, #5ac2ff 0%, #1aa1f2 52%, #22d3d6 100%);
  border-radius: 12rpx;
  padding: 26rpx 28rpx;
  margin-bottom: 16rpx;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.header-left {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.header-deco {
  width: 132rpx;
  height: 96rpx;
  border-radius: 22rpx;
  background: linear-gradient(145deg, rgba(255,255,255,0.52), rgba(255,255,255,0.08));
  transform: rotate(-8deg);
}

.page-title {
  font-size: 28rpx;
  font-weight: 600;
}

.page-score {
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.1;
}

.summary-grid {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.summary-item {
  flex: 1;
  background: #fff;
  border-radius: 12rpx;
  min-height: 96rpx;
  padding: 16rpx 18rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.summary-label {
  font-size: 24rpx;
  color: #9aa1b1;
}

.summary-value {
  font-size: 40rpx;
  color: #333;
  font-weight: 700;
}

.level-table {
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 0;
}

.table-header {
  display: flex;
  padding: 16rpx 18rpx;
  background: #f8f8f8;
  border-bottom: 1rpx solid #eee;
}

.table-header text {
  font-size: 22rpx;
  color: #666;
  text-align: center;
}

.col-level {
  flex: 1;
}

.col-condition {
  flex: 1.4;
}

.col-daily {
  flex: 1.6;
}

.col-commission {
  flex: 1.1;
}

.level-row {
  display: flex;
  padding: 18rpx;
  border-bottom: 1rpx solid #eee;
  align-items: center;
}

.level-row:last-child {
  border-bottom: none;
}

.level-row.current {
  background: #fff;
}

.level-row view,
.level-row text {
  text-align: center;
  font-size: 30rpx;
  color: #333;
}

.col-commission.low {
  color: #ef8802;
  font-weight: 600;
}

.current-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx 0;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
}

.current-half {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.current-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #ef8802;
}

.current-sub {
  font-size: 24rpx;
  color: #9aa1b1;
}

.rule-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 18rpx;
}

.rule-title-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.rule-brand {
  font-size: 26rpx;
  color: #ef8802;
  font-weight: 700;
}

.rule-title {
  font-size: 26rpx;
  color: #333;
  font-weight: 700;
}

.rule-desc {
  display: block;
  font-size: 22rpx;
  color: #8f96a8;
  line-height: 1.6;
  margin-bottom: 14rpx;
}
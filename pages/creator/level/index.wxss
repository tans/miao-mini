.level-page {
  background: #f3f3f3;
  min-height: 100vh;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 32rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.nav-left, .nav-right {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
}

.nav-back {
  width: 40rpx;
  height: 40rpx;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 900;
  color: #333;
}

.page-header {
  border-radius: 12rpx;
  margin: 32rpx 0;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.header-left {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-left: 56rpx;
}

.header-deco {
  width: 132rpx;
  height: 96rpx;
  border-radius: 22rpx;
  background: linear-gradient(145deg, rgba(255,255,255,0.52), rgba(255,255,255,0.08));
  transform: rotate(-8deg);
}

.page-title {
  font-size: 28rpx;
  font-weight: 600;
}

.page-score {
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.1;
}

.summary-grid {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
  width: 702rpx;
}

.summary-item {
  flex: 1;
  background: #fff;
  border-radius: 12rpx;
  min-height: 96rpx;
  padding: 16rpx 18rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  box-shadow: 0rpx 4rpx 16rpx 0rpx rgba(17,17,17,0.04);
  align-items: center;
}

.summary-label {
  font-size: 24rpx;
  color: #9aa1b1;
}

.summary-value {
  font-size: 40rpx;
  color: #333;
  font-weight: 700;
}

.level-table {
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 0;
  margin-top: 24rpx;
}

.table-header {
  display: flex;
  padding: 16rpx 18rpx;
  background: #fff;
}

.table-header text {
  font-size: 22rpx;
  font-weight: 700;
  text-align: center;
  white-space: pre-line;
  line-height: 1.35;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 10rpx;
}

.table-header .col-level {
  background: #ECEEF4;
  color: #000000;
}

.table-header .col-condition {
  background: #EEF9F1;
  color: #35B86B;
}

.table-header .col-daily {
  background: #ECEEF4;
  color: #000000;
}

.table-header .col-commission {
  background: rgba(239,136,2,0.1);
  color: #EF8802;
}

.col-level {
  flex: 1;
}

.col-condition {
  flex: 1.4;
}

.col-daily {
  flex: 1.6;
}

.col-commission {
  flex: 1.1;
}

.level-row {
  display: flex;
  padding: 18rpx;
  border-bottom: 1rpx solid #eee;
  align-items: center;
  margin: 0 18rpx;
}

.level-row:last-child {
  border-bottom: none;
}

.level-row.current {
  background: #fff;
}

.level-row view,
.level-row text {
  text-align: center;
  font-size: 28rpx;
  font-weight: 700;
}

.level-row .col-level,
.level-row .col-daily {
  color: #000000;
}

.level-row .col-condition {
  color: #35B86B;
}

.level-row .col-commission {
  color: #EF8802;
}

.col-commission.low {
  color: #ef8802;
  font-weight: 600;
}

.current-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx 0;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  width: 702rpx;
  box-shadow: 0rpx 4rpx 16rpx 0rpx rgba(17,17,17,0.04);
}

.current-half {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.current-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #ef8802;
}

.current-sub {
  font-size: 24rpx;
  color: #9aa1b1;
}

.rule-card {
  background: #fff;
  border-radius: 12rpx;
  width: 702rpx;
  padding-bottom: 32rpx;
  margin-bottom: 32rpx;
}

.rule-title-row {
  display: flex;
  align-items: center;
  margin: 32rpx 32rpx 20rpx 32rpx;
}

.rule-brand {
  font-size: 26rpx;
  color: #ef8802;
  font-weight: 700;
}

.rule-title {
  font-size: 26rpx;
  color: #333;
  font-weight: 700;
}

.rule-desc {
  display: block;
  font-size: 22rpx;
  color: #8f96a8;
  line-height: 1.6;
  margin-bottom: 14rpx;
  margin-left: 32rpx;
  border-bottom: 2rpx solid #ECECEF;
  margin-right: 32rpx;
  padding-bottom: 24rpx;
}
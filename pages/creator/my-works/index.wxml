<view class="my-works-container">
  <!-- 顶部导航栏 -->
  <view class="nav-bar">
    <view class="nav-left" bindtap="goBack">
      <image class="nav-back" src="/assets/icons/back.png" />
    </view>
    <text class="nav-title">我的作品</text>
    <view class="nav-right"></view>
  </view>

  <!-- 筛选标签 -->
  <view class="filter-tabs">
    <view class="filter-tab {{currentFilter === 'all' ? 'active' : ''}}" data-filter="all" bindtap="switchFilter">
      <text>全部</text>
    </view>
    <view class="filter-tab {{currentFilter === 'pending' ? 'active' : ''}}" data-filter="pending" bindtap="switchFilter">
      <text>审核中</text>
    </view>
    <view class="filter-tab {{currentFilter === 'adopted' ? 'active' : ''}}" data-filter="adopted" bindtap="switchFilter">
      <text>已采纳</text>
    </view>
    <view class="filter-tab {{currentFilter === 'rejected' ? 'active' : ''}}" data-filter="rejected" bindtap="switchFilter">
      <text>未采纳</text>
    </view>
    <view class="filter-tab {{currentFilter === 'reported' ? 'active' : ''}}" data-filter="reported" bindtap="switchFilter">
      <text>被举报</text>
    </view>
  </view>

  <!-- 安全提醒 -->
  <view class="safety-card">
    <view class="safety-header">
      <image src="/assets/icons/safety-icon.png" class="safety-logo" />
      <text class="safety-brand">创意喵</text>
      <text class="safety-title">安全提醒</text>
    </view>
    <view class="safety-content">
      <text class="safety-text">稿件提交后，如果商家</text>
      <text class="safety-highlight">超过48小时</text>
      <text class="safety-text">未审核您的稿件会自动为您</text>
      <text class="safety-highlight">发放参与奖励</text>
      <text class="safety-text">，之后商家如果采纳了您的稿件，您依然可以获得采纳金。</text>
    </view>
  </view>

  <!-- 作品列表 -->
  <view class="works-list" wx:if="{{filteredWorks.length > 0}}">
    <view class="work-item" wx:for="{{filteredWorks}}" wx:key="id">
      <!-- 封面 -->
      <view class="work-cover">
        <image wx:if="{{item.displayCover}}" class="cover-img" src="{{item.displayCover}}" mode="aspectFill" bindtap="goWorkDetail" data-id="{{item.id}}"/>
        <video wx:elif="{{item.isVideo}}" class="cover-video" src="{{item.previewVideoSrc}}" poster="{{item.thumbnail}}" controls/>
        <view wx:else class="cover-placeholder" bindtap="goWorkDetail" data-id="{{item.id}}">
          <text class="placeholder-title">{{item.task_title}}</text>
        </view>
      </view>

      <!-- 作品信息 -->
      <view class="work-info">
        <view class="info-header">
          <text class="work-title" bindtap="goTaskDetail" data-task-id="{{item.task_id}}">{{item.task_title || item.title}}</text>
          <view class="status-tag status-{{item.statusClass}}">
            <text>{{item.statusText}}</text>
          </view>
        </view>

        <text class="submit-time">投稿时间 {{item.submittedAt}}</text>
        <text class="submit-time" wx:if="{{item.processStatusText}}">{{item.processStatusText}}</text>

        <!-- 收入信息 -->
        <view class="income-row" wx:if="{{item.statusClass !== 'reported'}}">
          <text class="income-label">{{item.incomeLabel}}</text>
          <text class="income-value">{{item.incomeText}}</text>
        </view>

        <!-- 淘汰原因 -->
        <view class="reject-reason" wx:if="{{item.statusClass === 'rejected' && item.rejectReason}}">
          <text class="reason-text">淘汰原因：{{item.rejectReason}}</text>
        </view>

        <!-- 举报原因 -->
        <view class="report-section" wx:if="{{item.statusClass === 'reported'}}">
          <text class="report-text">举报原因：{{item.reportReason}}</text>
          <view class="appeal-btn">
            <text>我要申诉</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && filteredWorks.length === 0}}">
    <view class="empty-icon">🎬</view>
    <text class="empty-text">暂无作品记录</text>
    <text class="empty-hint">快去报名任务并提交作品吧</text>
  </view>
</view>

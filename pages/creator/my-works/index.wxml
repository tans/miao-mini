<view class="my-works-container">
  <!-- Filter Tabs -->
  <view class="filter-tabs">
    <text
      wx:for="{{filters}}"
      wx:key="key"
      class="tab {{activeFilter === item.key ? 'active' : ''}}"
      data-filter="{{item.key}}"
      bindtap="switchFilter"
    >{{item.label}}</text>
  </view>

  <!-- Works List -->
  <view class="works-list" wx:if="{{filteredWorks.length > 0}}">
    <view class="work-item" wx:for="{{filteredWorks}}" wx:key="id">
      <view class="work-header">
        <text class="work-title" bindtap="goTaskDetail" data-task-id="{{item.task_id}}">{{item.task_title}}</text>
        <view class="status-badge status-{{item.statusClass}}">
          <text>{{item.statusText}}</text>
        </view>
      </view>

      <view class="work-content" wx:if="{{item.content}}">
        <text class="content-text">{{item.content}}</text>
      </view>

      <!-- Media Preview -->
      <view class="media-preview" wx:if="{{item.previewImages.length > 0 || item.previewVideos.length > 0}}">
        <image
          wx:for="{{item.previewImages}}"
          wx:for-item="img"
          wx:key="*this"
          class="preview-img"
          src="{{img}}"
          mode="aspectFill"
          data-index="{{index}}"
          bindtap="previewImages"
        />
        <video
          wx:for="{{item.previewVideos}}"
          wx:for-item="vid"
          wx:key="url"
          class="preview-video"
          src="{{vid.url}}"
          poster="{{vid.poster}}"
          objectFit="cover"
        />
      </view>

      <view class="work-footer">
        <text class="submit-time">提交于 {{item.submittedAt}}</text>
        <text class="unit-price">¥{{item.unitPrice}}</text>
      </view>
    </view>
  </view>

  <!-- Empty State -->
  <view class="empty-state" wx:if="{{!loading && filteredWorks.length === 0}}">
    <mp-msg type="info" title="暂无作品记录">
      <view slot="desc">快去报名任务并提交作品吧</view>
    </mp-msg>
  </view>
</view>
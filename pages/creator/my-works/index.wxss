.my-works-container {
  min-height: 100vh;
  background: #fafafa;
  padding-bottom: 120rpx;
}

/* 顶部状态栏 */
.status-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 32rpx;
  background: #fff;
}

.status-time {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.status-icons {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.signal-icon, .wifi-icon, .battery-icon {
  width: 32rpx;
  height: 22rpx;
  background: #333;
  border-radius: 4rpx;
}

.battery-icon {
  width: 48rpx;
  height: 24rpx;
}

/* 标题栏 */
.page-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  width: 40rpx;
  height: 40rpx;
}

.page-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
}

.message-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.message-icon {
  width: 42rpx;
  height: 38rpx;
}

/* 筛选标签 */
.filter-tabs {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  background: #fff;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

.filter-tab {
  padding: 16rpx 32rpx;
  border-radius: 36rpx;
  font-size: 26rpx;
  font-weight: 900;
  color: #8c8c98;
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(17, 17, 17, 0.04);
  white-space: nowrap;
  flex-shrink: 0;
}

.filter-tab.active {
  background: #ff9f2f;
  color: #fff;
}

/* 安全提醒 */
.safety-card {
  margin: 24rpx;
  background: #fff4e8;
  border-radius: 16rpx;
  padding: 24rpx;
}

.safety-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.safety-logo {
  width: 40rpx;
  height: 40rpx;
  border-radius: 8rpx;
  background: #fff;
}

.safety-brand {
  font-size: 28rpx;
  font-weight: 900;
  color: #333;
}

.safety-title {
  font-size: 28rpx;
  font-weight: 900;
  color: #333;
}

.safety-content {
  display: flex;
  flex-wrap: wrap;
  gap: 0;
}

.safety-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

.safety-highlight {
  font-size: 24rpx;
  font-weight: 900;
  color: #ef8802;
}

/* 作品列表 */
.works-list {
  padding: 0 24rpx 24rpx;
}

/* 作品项 */
.work-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(17, 17, 17, 0.04);
  display: flex;
  gap: 24rpx;
}

.work-cover {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f5f5f5;
  flex-shrink: 0;
}

.cover-img {
  width: 100%;
  height: 100%;
}

.cover-video {
  width: 100%;
  height: 100%;
}

.cover-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(145deg, #ff7a59, #ffb347);
}

.placeholder-title {
  font-size: 24rpx;
  color: #fff;
  font-weight: 600;
  padding: 16rpx;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
}

/* 作品信息 */
.work-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  min-width: 0;
}

.info-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.work-title {
  font-size: 28rpx;
  font-weight: 900;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-tag {
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 900;
  white-space: nowrap;
  flex-shrink: 0;
}

.status-tag.status-pending {
  background: #fff4ea;
  color: #ef8802;
}

.status-tag.status-timeout {
  background: #fef3c7;
  color: #d97706;
}

.status-tag.status-adopted {
  background: #e8f5e9;
  color: #52c41a;
}

.status-tag.status-rejected {
  background: #f5f5f5;
  color: #8f96a8;
}

.status-tag.status-reported {
  background: #ffebee;
  color: #ef4444;
}

.submit-time {
  font-size: 22rpx;
  color: #8c8c98;
}

/* 收入信息 */
.income-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: auto;
}

.income-label {
  font-size: 22rpx;
  color: #8c8c98;
}

.income-value {
  font-size: 24rpx;
  font-weight: 900;
  color: #52c41a;
}

/* 淘汰原因 */
.reject-reason {
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 12rpx 16rpx;
}

.reason-text {
  font-size: 22rpx;
  color: #666;
}

/* 举报区块 */
.report-section {
  margin-top: auto;
}

.report-text {
  font-size: 22rpx;
  color: #ef4444;
  margin-bottom: 12rpx;
}

.appeal-btn {
  display: inline-flex;
  padding: 10rpx 24rpx;
  background: #fff;
  border: 1rpx solid #ef4444;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #ef4444;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #8c8c98;
}

.my-works-container {
  min-height: 100vh;
  background: #fafafa;
  padding-bottom: 120rpx;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 32rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.nav-left, .nav-right {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
}

.nav-back {
  width: 40rpx;
  height: 40rpx;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 900;
  color: #333;
}

/* 筛选标签 */
.filter-tabs {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  background: #FAFAFA;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

.filter-tab {
  padding: 16rpx 32rpx;
  border-radius: 36rpx;
  font-size: 26rpx;
  font-weight: 900;
  color: #8c8c98;
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(17, 17, 17, 0.04);
  white-space: nowrap;
  flex-shrink: 0;
}

.filter-tab.active {
  background: #ff9f2f;
  color: #fff;
}

/* 安全提醒 */
.safety-card {
  margin: 24rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
}

.safety-header {
  display: flex;
  align-items: center;
  gap: 4rpx;
  margin-bottom: 16rpx;
}

.safety-logo {
  width: 40rpx;
  height: 40rpx;
  border-radius: 8rpx;
  background: #fff;
}

.safety-brand {
  font-size: 28rpx;
  font-weight: 900;
  color: #F58A1F;
}
.safety-content {
  line-height: 36rpx;
}
.safety-title {
  font-size: 28rpx;
  font-weight: 900;
  color: #333;
}

.safety-text {
  font-size: 24rpx;
  color: #666;
}

.safety-highlight {
  font-size: 24rpx;
  font-weight: 900;
  color: #ef8802;
}

/* 作品列表 */
.works-list {
  padding: 0 24rpx 24rpx;
}

/* 作品项 */
.work-item {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(17, 17, 17, 0.04);
  display: block;
}

.work-cover {
  width: 100%;
  height: 320rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f5f5f5;
  flex-shrink: 0;
  position: relative;
}

.cover-img {
  width: 100%;
  height: 100%;
}

.cover-video {
  width: 100%;
  height: 100%;
}

.cover-play-badge {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.cover-play-badge text {
  font-size: 20rpx;
  color: #fff;
  line-height: 1;
}

.cover-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(145deg, #ff7a59, #ffb347);
}

.placeholder-title {
  font-size: 24rpx;
  color: #fff;
  font-weight: 600;
  padding: 16rpx;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
}

/* 作品信息 */
.work-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  min-width: 0;
  padding: 32rpx;
}

.info-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.work-title {
  font-size: 28rpx;
  font-weight: 900;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-tag {
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 900;
  white-space: nowrap;
  flex-shrink: 0;
}

.status-tag.status-pending {
  background: #EEF5FF;
  color: #4D8DFF;
}

.status-tag.status-timeout {
  background: #EEF5FF;
  color: #4D8DFF;
}

.status-tag.status-adopted {
  background: #EEF9F1;
  color: #35B86B;
}

.status-tag.status-rejected {
  background: #F5F5F5;
  color: #8F96A8;
}

.status-tag.status-reported {
  background: #FFF3EE;
  color: #ef4444;
}

.submit-time {
  font-size: 24rpx;
  color: #8c8c98;
}

/* 收入信息 */
.income-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: auto;
  justify-content: space-between;
}

.income-label {
  font-size: 24rpx;
  color: #555562;
}

.income-value {
  font-size: 40rpx;
  font-weight: 900;
  color: #EF4444;
}

/* 淘汰原因 */
.reject-reason {
  background: #EEF5FF;
  border-radius: 8rpx;
  padding: 16rpx 24rpx;
}

.reason-text {
  font-size: 24rpx;
  color: #878FA1;
}

/* 举报区块 */
.report-section {
  margin-top: auto;
}

.report-text {
  padding: 16rpx 24rpx;
  font-size: 24rpx;
  color: #EF4444;
  background: #FEF0F0;
  border-radius: 8rpx 8rpx 8rpx 8rpx;
}

.appeal-btn {
  display: inline-flex;
  padding: 10rpx 24rpx;
  background: #fff;
  border: 1rpx solid #ef4444;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #ef4444;
}
.appeal-btn-container{
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 32rpx;
  font-weight: 800;
  font-size: 25rpx;
  color: #555562;
}
.appeal-btn{
  padding:20rpx 34rpx;
  background: #fff;
  border-radius: 19998rpx 19998rpx 19998rpx 19998rpx;
  border: 2rpx solid #ECECEF;
  font-weight: 800;
  font-size: 26rpx;
  color: #333333;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #8c8c98;
}

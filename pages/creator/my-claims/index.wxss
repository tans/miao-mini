.claims-container {
  min-height: 100vh;
  background: #fafafa;
  padding-bottom: 120rpx;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 32rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.nav-left, .nav-right {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
}

.nav-back {
  width: 40rpx;
  height: 40rpx;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 900;
  color: #333;
}

/* 筛选标签 */
.filter-tabs {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  background: #fff;
}

.filter-tab {
  padding: 16rpx 32rpx;
  border-radius: 36rpx;
  font-size: 26rpx;
  font-weight: 900;
  color: #8c8c98;
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(17, 17, 17, 0.04);
}

.filter-tab.active {
  background: #ff9f2f;
  color: #fff;
}

/* 报名列表 */
.claims-list {
  padding: 24rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* 报名卡片 */
.claim-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(17, 17, 17, 0.04);
}

.claim-card.card-ended {
  opacity: 0.7;
}

.card-main {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.card-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.task-title {
  font-size: 30rpx;
  font-weight: 900;
  color: #333;
  max-width: 400rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.deadline-text {
  font-size: 24rpx;
  color: #8c8c98;
}

.status-tag {
  padding: 8rpx 20rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 900;
}

.status-tag.tag-active {
  background: #fff4ea;
  color: #ef8802;
}

.status-tag.tag-ended {
  background: #f5f5f5;
  color: #8f96a8;
}

/* 卡片底部 */
/* .card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
} */

.time-remaining {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
  margin-top: 16rpx;
}
.time-remaining-left{
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.time-label {
  font-size: 32rpx;
  color: #ef4444;
}

.time-value {
  font-size: 28rpx;
  font-weight: 800;
  color: #333;
}

.time-value.active {
  color: #EF8802;
}

.time-value.ended {
  color: #EF8802;
}

.action-btn {
  padding: 16rpx 40rpx;
  border-radius: 36rpx;
  font-size: 26rpx;
  font-weight: 900;
  text-align: center;
}

.action-buttons {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}

.action-btn.btn-submit {
  background: #ff9f2f;
  color: #fff;
}

.action-btn.btn-pending {
  background: #eef4ff;
  color: #2f6fed;
}

.action-btn.btn-approved {
  background: #e9ffef;
  color: #169f4f;
}

.action-btn.btn-cancelled,
.action-btn.btn-rejected,
.action-btn.btn-reported,
.action-btn.btn-timeout {
  background: #f5f5f5;
  color: #666;
  border: 1px solid #ececef;
}

.action-btn.btn-ended {
  background: #f5f5f5;
  color: #333;
  border: 1px solid #ececef;
}

.action-btn.btn-cancel {
  background: #fff;
  color: #333333;
  border: 2rpx solid #ECECEF;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #8c8c98;
}

/* 安全提醒 */
.safety-card {
  background: #fff;
  border-radius: 26rpx;
  padding: 32rpx;
  box-shadow: 0rpx 4rpx 16rpx 0rpx rgba(17,17,17,0.04);
  margin: 0 24rpx;
}

.safety-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 14rpx;
}

.safety-logo {
  width: 40rpx;
  height: 40rpx;
  border-radius: 0;
}

.safety-brand {
  font-size: 28rpx;
  font-weight: 900;
  color: #ef8802;
}

.safety-title {
  font-size: 28rpx;
  font-weight: 900;
  color: #2f3542;
}

.safety-content {
  display: block;
}

.safety-text {
  font-size: 24rpx;
  color: #5c6270;
  line-height: 1.6;
}

.safety-highlight {
  font-size: 24rpx;
  font-weight: 900;
  color: #ef8802;
}

/* 提交弹窗 */
.dialog-content {
  padding: 12rpx 0;
}

/* WeUI 按钮调整 */
.weui-btn_mini {
  font-size: 24rpx;
  padding: 0 24rpx;
  height: 56rpx;
  line-height: 56rpx;
  border-radius: 8rpx;
}

.weui-btn_primary {
  background: #EF8802;
}

.weui-btn_primary:active {
  background: #d97b00;
}

.weui-btn_default {
  background: #fff;
  color: #666;
  border: 1rpx solid #e5e5e5;
}

.claims-container {
  min-height: 100vh;
  background: #fafafa;
  padding-bottom: 120rpx;
}

/* 顶部状态栏 */
.status-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 32rpx;
  background: #fff;
}

.status-time {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.status-icons {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.signal-icon, .wifi-icon, .battery-icon {
  width: 32rpx;
  height: 22rpx;
  background: #333;
  border-radius: 4rpx;
}

.battery-icon {
  width: 48rpx;
  height: 24rpx;
}

/* 标题栏 */
.page-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  width: 40rpx;
  height: 40rpx;
}

.page-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
}

.message-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.message-icon {
  width: 42rpx;
  height: 38rpx;
}

/* 筛选标签 */
.filter-tabs {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  background: #fff;
}

.filter-tab {
  padding: 16rpx 32rpx;
  border-radius: 36rpx;
  font-size: 26rpx;
  font-weight: 900;
  color: #8c8c98;
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(17, 17, 17, 0.04);
}

.filter-tab.active {
  background: #ff9f2f;
  color: #fff;
}

/* 报名列表 */
.claims-list {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* 报名卡片 */
.claim-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(17, 17, 17, 0.04);
}

.claim-card.card-ended {
  opacity: 0.7;
}

.card-main {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.card-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.task-title {
  font-size: 30rpx;
  font-weight: 900;
  color: #333;
  max-width: 400rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.deadline-text {
  font-size: 24rpx;
  color: #8c8c98;
}

.status-tag {
  padding: 8rpx 20rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 900;
}

.status-tag.tag-active {
  background: #fff4ea;
  color: #ef8802;
}

.status-tag.tag-ended {
  background: #f5f5f5;
  color: #8f96a8;
}

/* 卡片底部 */
.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.time-remaining {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.time-label {
  font-size: 24rpx;
  color: #8c8c98;
}

.time-value {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
}

.time-value.active {
  color: #ef4444;
}

.time-value.ended {
  color: #8c8c98;
}

.action-btn {
  padding: 16rpx 40rpx;
  border-radius: 36rpx;
  font-size: 26rpx;
  font-weight: 900;
  text-align: center;
}

.action-btn.btn-submit {
  background: #ff9f2f;
  color: #fff;
}

.action-btn.btn-ended {
  background: #f5f5f5;
  color: #333;
  border: 1px solid #ececef;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #8c8c98;
}

/* 安全提醒 */
.safety-card {
  margin: 24rpx;
  background: #fff4e8;
  border-radius: 16rpx;
  padding: 24rpx;
}

.safety-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.safety-logo {
  width: 40rpx;
  height: 40rpx;
  border-radius: 8rpx;
  background: #fff;
}

.safety-brand {
  font-size: 28rpx;
  font-weight: 900;
  color: #333;
}

.safety-title {
  font-size: 28rpx;
  font-weight: 900;
  color: #333;
}

.safety-content {
  display: flex;
  flex-wrap: wrap;
  gap: 0;
}

.safety-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

.safety-highlight {
  font-size: 24rpx;
  font-weight: 900;
  color: #ef8802;
}

/* 提交弹窗 */
.dialog-content {
  padding: 12rpx 0;
}

/* WeUI 按钮调整 */
.weui-btn_mini {
  font-size: 24rpx;
  padding: 0 24rpx;
  height: 56rpx;
  line-height: 56rpx;
  border-radius: 8rpx;
}

.weui-btn_primary {
  background: #EF8802;
}

.weui-btn_primary:active {
  background: #d97b00;
}

.weui-btn_default {
  background: #fff;
  color: #666;
  border: 1rpx solid #e5e5e5;
}

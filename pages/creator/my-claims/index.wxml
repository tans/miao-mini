<view class="claims-container">
  <!-- Tab 标签 -->
  <view class="tabs">
    <text class="tab {{activeTab === 'all' ? 'active' : ''}}" data-tab="all" bindtap="switchTab">全部</text>
    <text class="tab {{activeTab === 'pending' ? 'active' : ''}}" data-tab="pending" bindtap="switchTab">待提交</text>
    <text class="tab {{activeTab === 'submitted' ? 'active' : ''}}" data-tab="submitted" bindtap="switchTab">待验收</text>
    <text class="tab {{activeTab === 'completed' ? 'active' : ''}}" data-tab="completed" bindtap="switchTab">已完成</text>
  </view>

  <!-- 认领列表 - 使用 WeUI Panel 风格 -->
  <view class="claims-list" wx:if="{{filteredClaims.length > 0}}">
    <view class="weui-panel" wx:for="{{filteredClaims}}" wx:key="id">
      <!-- Panel Header -->
      <view class="weui-panel__hd">
        <text class="task-title" bindtap="goTaskDetail" data-id="{{item.task_id}}">{{item.task_title || '任务' + item.task_id}}</text>
        <view class="status-badge status-{{item.status}}">
          <text>{{item.status === 1 ? '待提交' : item.status === 2 ? '待验收' : item.status === 3 ? '已完成' : '已失效'}}</text>
        </view>
      </view>

      <!-- Panel Body -->
      <view class="weui-panel__bd">
        <view class="weui-media-box weui-media-box_text">
          <view class="info-row">
            <view class="info-item">
              <text class="label">任务ID</text>
              <text class="value">{{item.task_id}}</text>
            </view>
            <view class="info-item">
              <text class="label">赏金</text>
              <text class="value price">¥{{item.unit_price || 0}}</text>
            </view>
          </view>
          <view class="info-row">
            <view class="info-item">
              <text class="label">领取时间</text>
              <text class="value">{{formatDateTime(item.created_at)}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- Panel Footer - 操作按钮 -->
      <view class="weui-panel__ft">
        <!-- 待提交状态：显示提交和放弃按钮 -->
        <view wx:if="{{item.status === 1}}" class="action-group">
          <button class="weui-btn weui-btn_mini weui-btn_primary" data-claim-id="{{item.id}}" bindtap="showSubmitModal">提交作品</button>
          <button class="weui-btn weui-btn_mini weui-btn_default" data-claim-id="{{item.id}}" bindtap="cancelClaim">放弃任务</button>
        </view>
        <!-- 待验收状态：显示修改链接 -->
        <view wx:if="{{item.status === 2}}" class="action-group">
          <text class="status-text">等待商家验收中</text>
          <text class="modify-link" bindtap="showSubmitModal" data-claim-id="{{item.id}}">修改作品</text>
        </view>
        <!-- 已完成状态 -->
        <view wx:if="{{item.status === 3}}" class="action-group">
          <text class="status-text success">已完成，赏金已到账</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && filteredClaims.length === 0}}">
    <mp-msg type="info" title="暂无认领记录">
      <view slot="desc">快去首页领取感兴趣的任务吧</view>
    </mp-msg>
  </view>

  <!-- 提交弹窗 - 使用 WeUI Dialog -->
  <mp-dialog title="提交作品" show="{{showSubmitModal}}" bindbuttontap="onDialogTap" buttons="{{dialogButtons}}">
    <view class="dialog-content">
      <mp-cells>
        <mp-cell>
          <input class="weui-input" placeholder="请输入视频链接" value="{{submitUrl}}" bindinput="onSubmitUrlInput"/>
        </mp-cell>
        <mp-cell>
          <input class="weui-input" placeholder="备注（选填）" value="{{submitNote}}" bindinput="onSubmitNoteInput"/>
        </mp-cell>
      </mp-cells>
    </view>
  </mp-dialog>
</view>
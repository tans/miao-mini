<view class="claims-container">
  <!-- 筛选标签 -->
  <view class="filter-tabs">
    <view class="filter-tab {{currentFilter === 'active' ? 'active' : ''}}" data-filter="active" bindtap="switchFilter">
      <text>征稿中</text>
    </view>
    <view class="filter-tab {{currentFilter === 'ended' ? 'active' : ''}}" data-filter="ended" bindtap="switchFilter">
      <text>已截止</text>
    </view>
  </view>

  <!-- 报名列表 -->
  <view class="claims-list" wx:if="{{filteredClaims.length > 0}}">
    <view class="claim-card {{item.isActive ? 'card-active' : 'card-ended'}}" wx:for="{{filteredClaims}}" wx:key="id">
      <view class="card-main">
        <view class="card-info">
          <text class="task-title">{{item.task_title || '任务' + item.task_id}}</text>
          <text class="deadline-text">投稿截止时间 {{item.deadlineText}}</text>
        </view>
        <view class="status-tag {{item.isActive ? 'tag-active' : 'tag-ended'}}">
          <text>{{item.statusLabel}}</text>
        </view>
      </view>

      <view class="card-footer">
        <view class="time-remaining">
          <view class="time-remaining-left">
            <image class="time-icon" src="../../../images/icon/time.png" style="width: 32rpx; height: 32rpx;"/>
            <text class="time-value {{item.remainingTimeClass}}">{{item.remainingTimeDisplay}}</text>
          </view>
          <view class="action-buttons">
            <view class="action-btn btn-cancel" bindtap="cancelClaim" data-claim-id="{{item.id}}" wx:if="{{item.canCancel}}">
              <text>取消</text>
            </view>
            <view wx:if="{{item.reviewResult === 3}}" class="action-btn {{item.claimActionClass || 'btn-reported'}}" bindtap="goAppeal" data-claim-id="{{item.id}}">
              <text>{{item.claimActionText || '去申诉'}}</text>
            </view>
            <view wx:else class="action-btn {{item.claimActionClass || 'btn-submit'}}" bindtap="goTaskDetail" data-claim="{{item.id}}" data-task="{{item.task_id}}">
              <text>{{item.claimActionText || '立即交稿'}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && filteredClaims.length === 0}}">
    <image src="../../../images/home/empty.png" class="clock-icon" style="width:300rpx;height:300rpx;"/>
    <text class="empty-text">暂无报名</text>
    <text class="empty-hint">快去首页领取感兴趣的任务吧</text>
  </view>

  <!-- 安全提醒 -->
  <view class="safety-card" wx:if="{{filteredClaims.length > 0}}">
    <view class="safety-header">
      <image src="../../../images/home/msg-icon.png" class="safety-logo" />
      <text class="safety-brand">创意喵</text>
      <text class="safety-title">安全提醒</text>
    </view>
    <view class="safety-content">
      <text class="safety-text">平台保障内容质量，每个创作者同时最多可报名 3 个任务，您当前的创作者等级为：</text>
      <text class="safety-highlight">{{userLevel || 'Lv3优质创作者'}}，</text>
      <text class="safety-text">每日最多可报名 {{dailyLimit || 8}} 次。请合理安排创作时间。</text>
    </view>
  </view>
</view>

.help-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 32rpx;
  background: linear-gradient(66deg, #FF7C09 0%, #FFAF55 32%, #FFCD42 72%, #FFE177 100%);
}

.nav-left, .nav-right {
  width: 80rpx;
}

.nav-back {
  width: 40rpx;
  height: 40rpx;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
}

.help-list {
  margin: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.help-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.help-item:last-child {
  border-bottom: none;
}

.help-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 20rpx;
}

.help-content {
  flex: 1;
}

.help-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.help-desc {
  font-size: 24rpx;
  color: #999;
}

.help-arrow {
  width: 32rpx;
  height: 32rpx;
}

.contact-section {
  padding: 32rpx;
}

.contact-btn {
  width: 100%;
  height: 88rpx;
  background: #fff;
  border-radius: 44rpx;
  color: #EF8802;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 88rpx;
  text-align: center;
}

.contact-btn::after {
  border: none;
}
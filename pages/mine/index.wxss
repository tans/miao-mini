/* pages/mine/index.wxss */

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 32rpx;
  background: linear-gradient(66deg, #FF7C09 0%, #FFAF55 32%, #FFCD42 72%, #FFE177 100%);
}

.nav-left {
  display: flex;
  align-items: center;
}

.nav-right {
  display: flex;
  align-items: center;
}

.nav-capsule {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255,255,255,0.25);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.nav-icon {
  width: 36rpx;
  height: 36rpx;
}

.nav-dot {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 12rpx;
  height: 12rpx;
  background: #FF3B30;
  border-radius: 50%;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 900;
  color: #fff;
}

.mine-container {
  min-height: 100vh;
  position: relative;
}

.bg-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 750rpx;
  height: 360rpx;
  z-index: 0;
}

/* 自定义导航栏 */
.custom-nav {
  position: relative;
  z-index: 1;
  background: transparent;
}

.status-bar-placeholder {
  height: var(--status-bar-height, 44px);
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
}

.mine-container > view {
  position: relative;
  z-index: 1;
}

/* 状态栏占位 */
.status-bar {
  height: 64rpx;
  background: linear-gradient(66deg, #FF7C09 0%, #FFAF55 32%, #FFCD42 72%, #FFE177 100%);
}

/* 标题栏 */
.title-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 42rpx;
  height: 64rpx;
  background: linear-gradient(66deg, #FF7C09 0%, #FFAF55 32%, #FFCD42 72%, #FFE177 100%);
}

.title-text {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
}

.title-right {
  display: flex;
  align-items: center;
}

.title-icon {
  width: 174rpx;
  height: 64rpx;
}

/* 顶部区域 */
.header-section {
  padding: 0 24rpx 0 24rpx;
  position: relative;
  z-index: 1;
}

/* 用户信息卡片 */
.user-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 32rpx 20rpx 32rpx;
  margin:24rpx 0;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.08);
}

.user-info-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.user-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #f0f0f0;
  margin-right: 24rpx;
  
}

.user-detail {
  flex: 1;
  display: flex;
  flex-direction: column;
  flex-shrink: 0;
}

.user-name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.user-right {
  display: flex;
  align-items: center;
}

.user-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-right: 8rpx;
}

.user-id {
  font-size: 24rpx;
  color: #999;
}

.user-id-row {
  display: flex;
  align-items: center;
  margin-left: auto;
}

.user-arrow {
  width: 32rpx;
  height: 32rpx;
  margin-left: 16rpx;
}

.avatar-debug {
  display: block;
  margin-top: 12rpx;
  font-size: 20rpx;
  color: #ff3b30;
  word-break: break-all;
}

.user-level-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}

.level-badge {
  display: flex;
  align-items: baseline;
  color: #555562;
  font-size: 22rpx; 
  font-weight: 600;
}

.level-num {
  color: #EF8802;
  font-size: 40rpx;
  margin-right: 10rpx;
}

.level-sep {
  color: #999;
  margin: 0 12rpx;
  font-size: 24rpx;
}

.level-info {
  display: flex;
  align-items: baseline;
}

.go-profile-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 60rpx;
  height: 32rpx;
  margin-left: 16rpx;
  justify-content: flex-end;
}
.go-profile-btn image{

}

.level-task-count {
  font-size: 24rpx;
  color: #666;
}

/* 钱包卡片 */
.wallet-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.08);
}

.wallet-left {
  display: flex;
  flex-direction: column;
}

.wallet-header {
  display: flex;
  align-items: center;
}

.wallet-title {
  font-size: 24rpx;
  color: #8C8C98;
}

.wallet-balance {
  font-size: 48rpx;
  font-weight: 700;
  color: #333333;
  font-family: D-DIN-PRO-Bold;
  margin: 16rpx 0;
}

.wallet-right {
  display: flex;
  align-items: center;
}

.wallet-desc {
  font-size: 24rpx;
  color: #8C8C98;
  margin-right: 12rpx;
}

.wallet-arrow {
  width: 32rpx;
  height: 32rpx;
}

/* 主体内容 */
.content-section {
  padding: 24rpx 24rpx;
  background: #f5f5f5;
  position: relative;
  z-index: 1;
}

/* 专区卡片 */
.zone-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.08);
}

.zone-title {
  font-size: 32rpx;
  color: #8C8C98;
  margin-bottom: 32rpx;
}

.zone-items {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.zone-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.zone-item-left {
  display: flex;
  align-items: center;
}

.zone-item-right {
  display: flex;
  align-items: center;
}

.zone-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 20rpx;
}

.zone-item-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.zone-item-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.zone-item-sub {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.zone-item-badge {
  display: flex;
  align-items: center;
}

.badge-num {
  color: #FF6A5C;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 10rpx;
}

.badge-text {
  font-size: 22rpx;
  color: #666;
}

.zone-action {
  display: flex;
  align-items: center;
  margin-left: auto;
}

.action-tag {
  background: #EEF5FF;
  border-radius: 8rpx 8rpx 8rpx 8rpx;
  padding: 8rpx 16rpx;
  display: flex;
  align-items: center;
}

.action-tag-text {
  font-size: 22rpx;
  color: #FF6A5C;
  font-weight: 600;
}

.zone-right {
  display: flex;
  align-items: center;
  margin-left: auto;
}

.zone-badge {
  display: flex;
  align-items: center;
  margin-right: 8rpx;
}

.zone-arrow {
  width: 32rpx;
  height: 32rpx;
}

/* 更新时间 */
.update-time {
  text-align: center;
  font-size: 22rpx;
  color: #999;
  padding: 24rpx 0;
  position: relative;
  z-index: 1;
}

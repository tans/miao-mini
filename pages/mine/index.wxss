/* pages/mine/index.wxss */

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 32rpx;
  background: linear-gradient(66deg, #FF7C09 0%, #FFAF55 32%, #FFCD42 72%, #FFE177 100%);
}

.nav-left {
  display: flex;
  align-items: center;
}

.nav-right {
  display: flex;
  align-items: center;
}

.nav-capsule {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255,255,255,0.25);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.nav-icon {
  width: 36rpx;
  height: 36rpx;
}

.nav-dot {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 12rpx;
  height: 12rpx;
  background: #FF3B30;
  border-radius: 50%;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 900;
  color: #fff;
}

.mine-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 状态栏占位 */
.status-bar {
  height: 64rpx;
  background: linear-gradient(66deg, #FF7C09 0%, #FFAF55 32%, #FFCD42 72%, #FFE177 100%);
}

/* 标题栏 */
.title-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 42rpx;
  height: 64rpx;
  background: linear-gradient(66deg, #FF7C09 0%, #FFAF55 32%, #FFCD42 72%, #FFE177 100%);
}

.title-text {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
}

.title-right {
  display: flex;
  align-items: center;
}

.title-icon {
  width: 174rpx;
  height: 64rpx;
}

/* 顶部区域 */
.header-section {
  background: linear-gradient(66deg, #FF7C09 0%, #FFAF55 32%, #FFCD42 72%, #FFE177 100%);
  padding: 0 24rpx 40rpx;
}

/* 用户信息卡片 */
.user-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.08);
}

.user-info-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.user-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #f0f0f0;
  margin-right: 24rpx;
}

.user-detail {
  flex: 1;
  display: flex;
  flex-direction: column;
  flex-shrink: 0;
}

.user-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.user-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-right: 8rpx;
}

.user-id {
  font-size: 24rpx;
  color: #999;
}

.user-id-row {
  display: flex;
  align-items: center;
  margin-left: auto;
}

.user-arrow {
  width: 32rpx;
  height: 32rpx;
}

.user-level-row {
  display: flex;
  align-items: center;
}

.level-badge {
  background: #FFF0E0;
  color: #EF8802;
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.level-sep {
  color: #999;
  margin: 0 12rpx;
  font-size: 24rpx;
}

.level-task-count {
  font-size: 24rpx;
  color: #666;
}

/* 钱包卡片 */
.wallet-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.08);
}

.wallet-left {
  display: flex;
  flex-direction: column;
}

.wallet-title {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.wallet-balance {
  font-size: 48rpx;
  font-weight: 700;
  color: #EF8802;
  font-family: D-DIN-PRO-Bold;
}

.wallet-right {
  display: flex;
  align-items: center;
}

.wallet-desc {
  font-size: 24rpx;
  color: #999;
  margin-right: 12rpx;
}

.wallet-arrow {
  width: 32rpx;
  height: 32rpx;
}

/* 主体内容 */
.content-section {
  padding: 24rpx 24rpx;
  background: #f5f5f5;
}

/* 专区卡片 */
.zone-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.08);
}

.zone-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 24rpx;
}

.zone-items {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.zone-item {
  display: flex;
  align-items: center;
}

.zone-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 20rpx;
}

.zone-item-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.zone-item-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.zone-item-sub {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.zone-item-badge {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
}

.badge-num {
  background: #EF8802;
  color: #fff;
  font-size: 20rpx;
  font-weight: 600;
  padding: 2rpx 8rpx;
  border-radius: 10rpx;
  margin-right: 6rpx;
}

.badge-text {
  font-size: 22rpx;
  color: #666;
}

.zone-action {
  display: flex;
  align-items: center;
  margin-left: auto;
}

.action-tag {
  background: #EFF5FF;
  border-radius: 8rpx;
  padding: 6rpx 16rpx;
  margin-right: 8rpx;
}

.action-tag-text {
  font-size: 22rpx;
  color: #255FED;
  font-weight: 600;
}

.zone-right {
  display: flex;
  align-items: center;
  margin-left: auto;
}

.zone-badge {
  display: flex;
  align-items: center;
  margin-right: 8rpx;
}

.zone-arrow {
  width: 32rpx;
  height: 32rpx;
  margin-top: 6rpx;
}

/* 更新时间 */
.update-time {
  text-align: center;
  font-size: 22rpx;
  color: #999;
  padding: 24rpx 0;
}

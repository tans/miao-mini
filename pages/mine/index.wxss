.mine-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 12px;
  padding-bottom: 32px;
}

/* 用户信息卡片 */
.user-card {
  background: #fff;
  border-radius: 12px;
  padding: 16px;
  display: flex;
  align-items: center;
  margin-bottom: 12px;
}

.user-card-arrow {
  margin-left: auto;
  color: #ccc;
  font-size: 16px;
}

.avatar {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: #eee;
  margin-right: 12px;
  flex-shrink: 0;
}

.user-info {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.nickname {
  font-size: 16px;
  font-weight: 600;
  color: #333;
  max-width: 200px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 面板区域 */
.panel-section {
  margin-bottom: 12px;
}

.panel-label {
  font-size: 14px;
  font-weight: 600;
  color: #333;
  padding: 0 4px;
  margin-bottom: 8px;
}

.panel-card {
  background: #fff;
  border-radius: 12px;
  padding: 16px 8px;
  display: flex;
  justify-content: space-around;
}

.panel-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.panel-item-icon {
  font-size: 24px;
  margin-bottom: 6px;
}

.panel-item-text {
  font-size: 12px;
  color: #333;
  text-align: center;
}

/* 钱包入口 */
.wallet-row {
  background: #fff;
  border-radius: 12px;
  padding: 14px 16px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.wallet-label {
  font-size: 14px;
  color: #333;
}

.wallet-right {
  display: flex;
  align-items: center;
}

.wallet-balance {
  font-size: 16px;
  font-weight: 600;
  color: #EF8802;
  margin-right: 8px;
}

.wallet-arrow {
  color: #ccc;
  font-size: 14px;
}

/* 帮助中心 */
.help-row {
  background: #fff;
  border-radius: 12px;
  padding: 14px 16px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12px;
}

.help-text {
  font-size: 14px;
  color: #333;
}

.help-arrow {
  color: #ccc;
  font-size: 14px;
}

.version {
  text-align: center;
  color: #ccc;
  font-size: 12px;
  margin-top: 24px;
}
/* pages/mine/index.wxss */

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 32rpx;
  background: linear-gradient(66deg, #FF7C09 0%, #FFAF55 32%, #FFCD42 72%, #FFE177 100%);
}

.nav-left {
  display: flex;
  align-items: center;
}

.nav-right {
  display: flex;
  align-items: center;
}

.nav-capsule {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255,255,255,0.25);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.nav-icon {
  width: 36rpx;
  height: 36rpx;
}

.nav-dot {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 12rpx;
  height: 12rpx;
  background: #FF3B30;
  border-radius: 50%;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 900;
  color: #fff;
}

.mine-container {
  min-height: 100vh;
  position: relative;
}

/* 必须高于 .content-section，否则吸顶导航在组件内 z-index:1000 仍会被整块主体盖住（兄弟层叠后者居上） */
.mine-top-anchor {
  position: relative;
  width: 100%;
  z-index: 10;
}

.nav-slot-placeholder {
  width: 100%;
  flex-shrink: 0;
}

.bg-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 750rpx;
  height: 360rpx;
  z-index: 0;
}

/* 自定义导航栏：背景由组件 elevated 控制 */
.mine-top-anchor > custom-nav {
  position: relative;
  z-index: 9999;
}

.status-bar-placeholder {
  height: var(--status-bar-height, 44px);
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
}

/* 勿对 .content-section 设同级 z-index，否则与 mine-top-anchor 同为 1 时列表会盖住吸顶导航 */
.mine-container > view:not(.content-section) {
  position: relative;
  z-index: 1;
}

/* 状态栏占位 */
.status-bar {
  height: 64rpx;
  background: linear-gradient(66deg, #FF7C09 0%, #FFAF55 32%, #FFCD42 72%, #FFE177 100%);
}

/* 标题栏 */
.title-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 42rpx;
  height: 64rpx;
  background: linear-gradient(66deg, #FF7C09 0%, #FFAF55 32%, #FFCD42 72%, #FFE177 100%);
}

.title-text {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
}

.title-right {
  display: flex;
  align-items: center;
}

.title-icon {
  width: 174rpx;
  height: 64rpx;
}

/* 顶部区域 */
.header-section {
  padding: 0 24rpx 0 24rpx;
  position: relative;
  z-index: 1;
}

/* 用户信息卡片 */
.user-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 32rpx 20rpx 32rpx;
  margin:24rpx 0;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.08);
}

.user-info-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.user-avatar-wrap {
  width: 96rpx;
  height: 96rpx;
  margin-right: 24rpx;
  position: relative;
  flex-shrink: 0;
}

.user-avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: #f0f0f0;
  display: block;
  transition: opacity 0.18s ease;
}

.user-avatar-fallback {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff9f2f 0%, #ffbf5a 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
}

.user-avatar-fallback-text {
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1;
}

.user-detail {
  flex: 1;
  display: flex;
  flex-direction: column;
  flex-shrink: 0;
}

.user-name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.user-right {
  display: flex;
  align-items: center;
}

.user-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-right: 8rpx;
}

.user-id {
  font-size: 24rpx;
  color: #999;
}

.user-id-row {
  display: flex;
  align-items: center;
  margin-left: auto;
}

.user-arrow {
  width: 32rpx;
  height: 32rpx;
  margin-left: 16rpx;
}

.user-level-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}

.level-badge {
  display: flex;
  align-items: baseline;
  color: #555562;
  font-size: 22rpx; 
  font-weight: 600;
}

.level-num {
  color: #EF8802;
  font-size: 40rpx;
  margin-right: 10rpx;
}

.level-sep {
  color: #999;
  margin: 0 12rpx;
  font-size: 24rpx;
}

.level-info {
  display: flex;
  align-items: baseline;
}

.go-profile-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 60rpx;
  height: 32rpx;
  margin-left: 16rpx;
  justify-content: flex-end;
}
.go-profile-btn image{

}

.level-task-count {
  font-size: 24rpx;
  color: #666;
}

/* 钱包卡片 */
.wallet-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.08);
}

.wallet-left {
  display: flex;
  flex-direction: column;
}

.wallet-header {
  display: flex;
  align-items: center;
}

.wallet-title {
  font-size: 24rpx;
  color: #8C8C98;
}

.wallet-balance {
  font-size: 48rpx;
  font-weight: 700;
  color: #333333;
  font-family: 'home-din-pro-700-bold';
  margin: 16rpx 0;
}

.wallet-right {
  display: flex;
  align-items: center;
}
.wallet-right-item {
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(239,136,2,0.1);
  padding:8rpx 32rpx;
  color: #EF8802;
  font-size: 24rpx;
  border-radius: 19998rpx 19998rpx 19998rpx 19998rpx;
}
.wallet-desc {
  font-size: 24rpx;
  color: #8C8C98;
  margin-right: 12rpx;
}

.wallet-arrow {
  width: 32rpx;
  height: 32rpx;
}

/* 主体内容：层叠低于顶部锚区，避免滚动时盖住 fixed 的 custom-nav */
.content-section {
  padding: 24rpx 24rpx;
  background: #f5f5f5;
  position: relative;
  z-index: 0;
}

/* 专区卡片 */
.zone-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.08);
}

.zone-title {
  font-size: 32rpx;
  color: #8C8C98;
  margin-bottom: 32rpx;
}

.zone-items {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.zone-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.zone-item-left {
  display: flex;
  align-items: center;
}

.zone-item-right {
  display: flex;
  align-items: center;
}

.zone-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 20rpx;
}

.zone-item-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.zone-item-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.zone-item-sub {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.zone-item-badge {
  display: flex;
  align-items: center;
}

.badge-num {
  color: #FF6A5C;
  font-size: 28rpx;
}

.badge-text {
  font-size: 28rpx;
  color: #000000;
}

.zone-action {
  display: flex;
  align-items: center;
  margin-left: auto;
}

.action-tag {
  background: #EEF5FF;
  border-radius: 8rpx 8rpx 8rpx 8rpx;
  padding: 8rpx 16rpx;
  display: flex;
  align-items: center;
}

/* .action-tag.is-uncertified {
  background: rgba(239, 136, 2, 0.10);
}

.action-tag.is-pending {
  background: rgba(239, 136, 2, 0.14);
}

.action-tag.is-rejected {
  background: rgba(229, 72, 72, 0.12);
}

.action-tag.is-certified {
  background: rgba(29, 155, 72, 0.12);
} */

.action-tag-text {
  font-size: 22rpx;
  color: #FF6A5C;
  font-weight: 600;
}

.action-tag.is-uncertified .action-tag-text {
  color: #FF6A5C;
}

.action-tag.is-pending .action-tag-text {
  color: #EF8802;
}

.action-tag.is-rejected .action-tag-text {
  color: #E54848;
}

.action-tag.is-certified .action-tag-text {
  color: #1D9B48;
}

.zone-right {
  display: flex;
  align-items: center;
  margin-left: auto;
}

.zone-badge {
  display: flex;
  align-items: center;
  margin-right: 8rpx;
}

.zone-arrow {
  width: 32rpx;
  height: 32rpx;
}

/* 更新时间 */
.update-time {
  text-align: center;
  font-size: 22rpx;
  color: #999;
  padding: 24rpx 0;
  position: relative;
  z-index: 1;
}

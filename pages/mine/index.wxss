.mine-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 12px;
  padding-bottom: 32px;
}

.user-card {
  background: #fff;
  border-radius: 12px;
  padding: 16px;
  display: flex;
  align-items: center;
  margin-bottom: 12px;
}

.user-card-arrow {
  margin-left: auto;
  color: #ccc;
  font-size: 16px;
}

.avatar {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: #eee;
  margin-right: 12px;
  flex-shrink: 0;
}

.user-info {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.nickname {
  font-size: 16px;
  font-weight: 600;
  color: #333;
  max-width: 200px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 创作者等级卡片 */
.level-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 12px;
  color: #fff;
}

.level-header {
  display: flex;
  align-items: center;
  margin-bottom: 12px;
}

.level-icon {
  font-size: 24px;
  margin-right: 8px;
}

.level-name {
  font-size: 18px;
  font-weight: 600;
}

.level-stats {
  display: flex;
  justify-content: space-around;
  background: rgba(255,255,255,0.15);
  border-radius: 8px;
  padding: 12px 0;
  margin-bottom: 8px;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 18px;
  font-weight: 700;
  margin-bottom: 2px;
}

.stat-label {
  font-size: 11px;
  opacity: 0.85;
}

.stat-divider {
  width: 1px;
  background: rgba(255,255,255,0.3);
}

.level-progress {
  text-align: center;
  font-size: 12px;
  opacity: 0.9;
}

/* 钱包卡片 */
.wallet-card {
  background: linear-gradient(135deg, #EF8802, #FFAA33);
  border-radius: 12px;
  padding: 16px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
  color: #fff;
}

.wallet-left {
  display: flex;
  flex-direction: column;
}

.wallet-label {
  font-size: 14px;
  opacity: 0.9;
  margin-bottom: 4px;
}

.wallet-balance {
  font-size: 28px;
  font-weight: 700;
}

.wallet-arrow {
  font-size: 20px;
  opacity: 0.9;
}

/* 功能卡片网格 */
.card-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 0 -6px;
}

.grid-card {
  width: calc(33.333% - 12px);
  background: #fff;
  border-radius: 12px;
  padding: 16px 8px;
  margin: 6px;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

.grid-icon {
  font-size: 24px;
  margin-bottom: 8px;
}

.grid-text {
  font-size: 12px;
  color: #333;
  text-align: center;
}

.version {
  text-align: center;
  color: #ccc;
  font-size: 12px;
  margin-top: 24px;
}

.mine-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 12px;
}

.user-card {
  background: #fff;
  border-radius: 12px;
  padding: 20px;
  display: flex;
  align-items: center;
  margin-bottom: 12px;
}

.user-card-arrow {
  margin-left: auto;
  color: #ccc;
  font-size: 16px;
}

.avatar {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: #eee;
  margin-right: 12px;
  flex-shrink: 0;
}

.user-info {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.nickname {
  font-size: 16px;
  font-weight: 600;
  color: #333;
  margin-bottom: 6px;
  max-width: 160px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.role-tag {
  display: inline-block;
  font-size: 12px;
  color: #EF8802;
  background: rgba(239,136,2,0.1);
  padding: 2px 8px;
  border-radius: 10px;
  width: fit-content;
  margin-top: 2px;
}

.role-tag.creator {
  background: rgba(239,136,2,0.1);
}

.level-badge {
  display: inline-flex;
  align-items: center;
  margin-top: 4px;
  padding: 2px 8px;
  border-radius: 10px;
  background: rgba(0,0,0,0.05);
}

.level-icon {
  font-size: 12px;
  margin-right: 4px;
}

.level-text {
  font-size: 12px;
  color: #666;
}

.wallet-card {
  background: linear-gradient(135deg, #EF8802, #FFAA33);
  border-radius: 12px;
  padding: 20px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
  color: #fff;
}

.wallet-left {
  display: flex;
  flex-direction: column;
}

.wallet-label {
  font-size: 14px;
  opacity: 0.9;
  margin-bottom: 4px;
}

.wallet-balance {
  font-size: 28px;
  font-weight: 700;
}

.wallet-arrow {
  font-size: 20px;
  opacity: 0.9;
}

.menu-list {
  background: #fff;
  border-radius: 12px;
  overflow: hidden;
  margin-bottom: 12px;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 16px;
  border-bottom: 1px solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 18px;
  margin-right: 12px;
}

.menu-text {
  flex: 1;
  font-size: 15px;
  color: #333;
}

.menu-arrow {
  color: #ccc;
  font-size: 16px;
}

.logout-btn {
  background: #fff;
  border-radius: 12px;
  padding: 16px;
  text-align: center;
  color: #999;
  font-size: 15px;
  margin-top: 12px;
}

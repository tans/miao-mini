.auth-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f7f7f7 0%, #efefef 100%);
  padding: 32rpx 24rpx 40rpx 24rpx;
  box-sizing: border-box;
}

.status-section {
  margin-bottom: 24rpx;
}

.status-card {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 702rpx;
  height: 240rpx;
  overflow: hidden;
  background: url('https://public.jisuhudong.com/minapp/商家认证背景.png');
  background-size: 100% 100%;
  background-repeat: no-repeat;
  box-shadow: 0 18rpx 40rpx rgba(255, 151, 63, 0.18);
}

.status-text-wrap {
  position: relative;
  z-index: 2;
  flex: 1;
  padding-left: 58rpx;
}

.status-title {
  display: block;
  margin-bottom: 18rpx;
  font-size: 38rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #ffffff;
}

.status-desc {
  display: block;
  max-width: 388rpx;
  font-size: 27rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.96);
}

.status-visual {
  position: relative;
  width: 220rpx;
  height: 160rpx;
  flex-shrink: 0;
}

.status-shield {
  position: absolute;
  top: 0;
  right: 24rpx;
  width: 124rpx;
  height: 144rpx;
  border-radius: 36rpx;
  background: linear-gradient(180deg, #fff3c7 0%, #ffd47b 100%);
  box-shadow:
    inset 0 6rpx 10rpx rgba(255, 255, 255, 0.58),
    0 14rpx 26rpx rgba(221, 125, 43, 0.26);
  transform: rotate(12deg);
}

.status-shield::before {
  content: '';
  position: absolute;
  inset: 8rpx;
  border-radius: 30rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.45);
}

.status-shield-icon {
  position: absolute;
  top: 30rpx;
  left: 0;
  width: 100%;
  text-align: center;
  font-size: 72rpx;
  line-height: 1;
  color: #ffffff;
  text-shadow: 0 4rpx 10rpx rgba(255, 176, 108, 0.34);
}

.status-orbit {
  position: absolute;
  right: 0;
  bottom: 12rpx;
  width: 176rpx;
  height: 74rpx;
  border: 10rpx solid rgba(255, 231, 176, 0.72);
  border-radius: 50%;
  transform: rotate(-14deg);
  box-shadow: 0 0 0 12rpx rgba(255, 187, 109, 0.14);
}

.result-card {
  margin-bottom: 24rpx;
  padding: 28rpx 30rpx;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 34rpx rgba(24, 29, 36, 0.06);
}

.result-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 112rpx;
  height: 48rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.result-badge-pending {
  background: rgba(239, 136, 2, 0.12);
  color: #ef8802;
}

.result-badge-certified {
  background: rgba(52, 199, 89, 0.12);
  color: #1d9b48;
}

.result-badge-rejected {
  background: rgba(255, 80, 80, 0.12);
  color: #e54848;
}

.result-title {
  display: block;
  margin-top: 20rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #1f1f1f;
}

.result-desc {
  display: block;
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #8a8f99;
}

.form-section {
  padding-bottom: 12rpx;
}

.form-card {
  padding: 32rpx;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 40rpx rgba(24, 29, 36, 0.05);
}

.upload-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 304rpx;
  padding: 24rpx;
  border-radius: 18rpx;
  border: 2rpx dashed #d7dbe3;
  background: linear-gradient(180deg, #fafafa 0%, #f4f5f7 100%);
  overflow: hidden;
  box-sizing: border-box;
}

.upload-area.is-preview {
  justify-content: flex-end;
  padding: 0;
  border-style: solid;
  border-color: #eceef3;
  background: #f8f8f8;
}

.upload-area.is-readonly {
  opacity: 0.94;
}

.upload-icon {
  width: 70rpx;
  height: 70rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.upload-title {
  font-size: 29rpx;
  color: #2c2f36;
  margin-bottom: 18rpx;
}

.upload-text {
  font-size: 25rpx;
  line-height: 1.7;
  color: #959ba6;
  text-align: center;
  padding: 0 16rpx;
}

.upload-preview {
  display: block;
  width: 100%;
  height: 304rpx;
}

.upload-preview-tip {
  width: 100%;
  padding: 18rpx 24rpx;
  box-sizing: border-box;
  background: rgba(20, 24, 31, 0.48);
  font-size: 24rpx;
  color: #ffffff;
  text-align: center;
}

.form-item {
  display: flex;
  align-items: center;
  min-height: 94rpx;
  margin-top: 24rpx;
  padding: 0 24rpx;
  border-radius: 16rpx;
  background: #f5f6f8;
}

.form-label {
  width: 144rpx;
  flex-shrink: 0;
  font-size: 29rpx;
  color: #22262d;
}

.label-wide {
  width: 240rpx;
}

.form-input {
  flex: 1;
  height: 94rpx;
  font-size: 29rpx;
  color: #22262d;
}

.submit-section {
  margin-top: 30rpx;
}

.submit-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 999rpx;
  background: #FF9F2F;
  box-shadow: 0rpx 4rpx 16rpx 0rpx rgba(17,17,17,0.04);
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
}

.submit-btn.is-disabled {
  background: linear-gradient(90deg, #ffd18d 0%, #ffc76f 100%);
  box-shadow: none;
}

.submit-btn.is-secondary {
  margin-top: 18rpx;
  background: #f1f2f5;
  color: #4c5563;
  box-shadow: none;
}

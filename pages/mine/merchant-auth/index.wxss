.auth-container {
  min-height: 100vh;
  background: #f2f2f2;
  padding: 24rpx;
  box-sizing: border-box;
}

.status-section {
  padding: 0;
}

.status-card {
  background: url('https://public.jisuhudong.com/minapp/商家认证背景.png') no-repeat center center; 
  background-size: 100% 100%;
  border-radius: 16rpx;
  width: 702rpx;
  height: 240rpx;
  border-radius: 16rpx 16rpx 16rpx 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.status-text-wrap {
  flex: 1;
  min-width: 0;
}

.status-icon {
  width: 160rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.status-icon-text {
  font-size: 56rpx;
  color: #fff;
}

.status-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 16rpx;
  margin-left: 50rpx;
}

.status-desc {
  display: block;
  max-width: 400rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255);
  line-height: 1.6;
  text-align: left;
  margin-left: 50rpx;
}

.form-section {
  padding: 24rpx 0 0;
}

.form-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0rpx 20rpx 52rpx 0rpx rgba(20,42,31,0.08);
  border-radius: 16rpx 16rpx 16rpx 16rpx;
}

.form-item {
  display: flex;
  align-items: center;
  min-height: 92rpx;
  background: #f5f5f7;
  border-radius: 14rpx;
  padding: 0 24rpx;
  margin-top: 32rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333333;
  width: 168rpx;
}

.form-input {
  flex: 1;
  height: 92rpx;
  font-size: 28rpx;
  color: #333;
}

.upload-area {
  height: 286rpx;
  background: #f6f6f8;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #d8d8de;
}

.upload-icon {
  width: 64rpx;
  height: 64rpx;
  margin-bottom: 24rpx;
}

.upload-title {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
}

.upload-text {
  font-size: 24rpx;
  color: #8C8C98;
  text-align: center;
  padding: 0 24rpx;
}

.upload-preview {
  width: 100%;
  height: 290rpx;
  border-radius: 16rpx;
}

.submit-section {
  margin-top: 32rpx;
  margin-bottom: 50rpx;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: #ffa12a;
  border-radius: 44rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 88rpx;
  text-align: center;
}

.submit-btn::after {
  border: none;
}
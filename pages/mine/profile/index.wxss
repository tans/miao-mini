.profile-container {
  min-height: 100vh;
  box-sizing: border-box;
  background: #f3f4f6;
  padding: 0;
  overflow: hidden;
}

.avatar-card,
.info-card {
  background: #fff;
  box-shadow: 0rpx 20rpx 52rpx 0rpx rgba(20, 42, 31, 0.08);
  border-radius: 16rpx 16rpx 16rpx 16rpx;
  margin: 32rpx 24rpx;
  padding: 28rpx;
}

.avatar-card {
  min-height: 260rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #f1f2f5;
}

.avatar-edit {
  margin-top: 24rpx;
  min-width: 152rpx;
  height: 56rpx;
  padding: 0 20rpx;
  border-radius: 28rpx;
  border: 1rpx solid #e7e7e7;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-edit-text {
  font-size: 24rpx;
  color: #333;
  font-weight: 600;
  line-height: 1;
}

.info-row {
  display: flex;
  align-items: center;
  min-height: 92rpx;
  border-radius: 14rpx;
  background: #f5f5f7;
  padding: 0 24rpx;
}

.info-row + .info-row {
  margin-top: 24rpx;
}

.info-label {
  width: 140rpx;
  font-size: 28rpx;
  color: #4f4f4f;
  font-weight: 500;
}

.info-value,
.info-input {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.info-input {
  height: 92rpx;
}

.info-placeholder {
  color: #a3a3a3;
  font-weight: 400;
}

.save-section {
  margin-top: 28rpx;
}

.save-btn {
  height: 86rpx;
  border-radius: 96rpx;
  background: #FF9F2F;
  color: #fff;
  font-size: 30rpx;
  line-height: 88rpx;
  text-align: center;
  margin: 32rpx 24rpx;
}

.save-btn::after {
  border: none;
}

/* 兼容可能残留的旧类名引用 */
.user-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 0;
}
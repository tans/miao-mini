<view class="profile-container">
  <!-- 头像卡片 -->
  <view class="avatar-card">
    <view class="avatar-section">
      <image class="avatar" src="{{user.avatar || '/assets/icons/avatar-default.jpg'}}" />
      <view class="avatar-edit" bindtap="changeAvatar">
        <text class="avatar-edit-text">更换头像</text>
      </view>
    </view>
  </view>

  <!-- 信息卡片 -->
  <view class="info-card">
    <view class="info-row">
      <text class="info-label">昵称</text>
      <input
        class="info-input"
        value="{{nickname}}"
        bindinput="onNicknameInput"
        placeholder="请输入昵称"
        placeholder-class="info-placeholder"
      />
    </view>
    <view class="info-row">
      <text class="info-label">联系电话</text>
      <input
        class="info-input"
        value="{{phone}}"
        bindinput="onPhoneInput"
        type="number"
        maxlength="11"
        placeholder="请输入手机号"
        placeholder-class="info-placeholder"
      />
    </view>
  </view>

  <!-- 保存按钮 -->
  <view class="save-section">
    <view class="save-btn" bindtap="saveProfile">保存修改</view>
  </view>
</view>

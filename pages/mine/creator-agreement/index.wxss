.agreement-page {
  min-height: 100vh;
  background: #ffffff;
  padding: 24rpx;
  box-sizing: border-box;
  padding-bottom: 48rpx;
}

.doc-main-title {
  display: block;
  font-size: 32rpx;
  color: #000000;
  font-weight: 700;
  text-align: center;
  line-height: 44rpx;
  margin-bottom: 32rpx;
}

.party-block {
  margin-bottom: 24rpx;
}

.party-line {
  display: block;
  font-size: 28rpx;
  color: #333333;
  line-height: 44rpx;
  margin-bottom: 12rpx;
}

.party-label {
  font-weight: 700;
}

.article {
  margin-top: 28rpx;
}

.article-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #000000;
  line-height: 40rpx;
  margin-bottom: 16rpx;
}

.clause {
  display: block;
  font-size: 26rpx;
  color: #333333;
  line-height: 44rpx;
  margin-bottom: 12rpx;
  text-align: justify;
}

.clause-bullet {
  display: block;
  font-size: 26rpx;
  color: #333333;
  line-height: 44rpx;
  margin-bottom: 8rpx;
  padding-left: 8rpx;
  text-align: justify;
}

.sign-block {
  margin-top: 48rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #eeeeee;
}

.sign-line {
  display: block;
  font-size: 26rpx;
  color: #333333;
  line-height: 44rpx;
  margin-bottom: 16rpx;
}

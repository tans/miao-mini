.service-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 32rpx;
  background: linear-gradient(66deg, #FF7C09 0%, #FFAF55 32%, #FFCD42 72%, #FFE177 100%);
}

.nav-left, .nav-right {
  width: 80rpx;
}

.nav-back {
  width: 40rpx;
  height: 40rpx;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
}

.hotline-section {
  padding: 32rpx 24rpx;
}

.hotline-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
}

.hotline-icon {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(66deg, #FF7C09 0%, #FFAF55 32%, #FFCD42 72%, #FFE177 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.hotline-icon-img {
  width: 48rpx;
  height: 48rpx;
}

.hotline-info {
  flex: 1;
}

.hotline-title {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.hotline-number {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
}

.hotline-time {
  font-size: 22rpx;
  color: #999;
}

.online-section {
  padding: 0 24rpx;
}

.online-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
}

.online-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.online-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
}

.online-status {
  display: flex;
  align-items: center;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  background: #34C759;
  border-radius: 50%;
  margin-right: 8rpx;
}

.status-text {
  font-size: 24rpx;
  color: #34C759;
}

.online-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.service-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
}

.service-icon {
  width: 64rpx;
  height: 64rpx;
  margin-right: 20rpx;
}

.service-content {
  flex: 1;
}

.service-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.service-desc {
  font-size: 24rpx;
  color: #999;
}

.service-arrow {
  width: 32rpx;
  height: 32rpx;
}

.faq-section {
  margin-top: 32rpx;
  padding: 0 24rpx;
}

.faq-header {
  margin-bottom: 24rpx;
}

.faq-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
}

.faq-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.faq-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.faq-item:last-child {
  border-bottom: none;
}

.faq-question {
  font-size: 28rpx;
  color: #333;
}

.faq-arrow {
  width: 32rpx;
  height: 32rpx;
}
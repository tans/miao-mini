<view class="mine-container">
  <!-- 用户信息卡片 -->
  <view class="user-card" bindtap="goProfile">
    <image class="avatar" src="{{user.avatar || '/assets/icons/avatar-default.jpg'}}"/>
    <view class="user-info">
      <text class="nickname">{{user.nickname || user.username || '未登录'}}</text>
      <view class="level-badge" wx:if="{{user.level > 0}}">
        <text class="level-icon">{{user.level === 4 ? '💎' : user.level === 3 ? '🥇' : user.level === 2 ? '🥈' : '🪙'}}</text>
        <text class="level-text">{{user.level_name}}</text>
      </view>
    </view>
    <text class="user-card-arrow">></text>
  </view>

  <!-- 钱包卡片 -->
  <view class="wallet-card" bindtap="goWallet">
    <view class="wallet-left">
      <text class="wallet-label">钱包余额</text>
      <text class="wallet-balance">¥{{balance || '0.00'}}</text>
    </view>
    <text class="wallet-arrow">></text>
  </view>

  <!-- 功能列表 -->
  <mp-cells title="我的操作" footer="">
    <mp-cell link bindtap="goMyClaims" value="我领取的任务" hover>
      <text slot="icon" class="menu-icon">📋</text>
    </mp-cell>
    <mp-cell link bindtap="goMyTasks" value="我发布的任务" hover>
      <text slot="icon" class="menu-icon">📝</text>
    </mp-cell>
  </mp-cells>

  <mp-cells title="平台信息" footer="">
    <mp-cell link bindtap="goHelp" value="帮助中心" hover>
      <text slot="icon" class="menu-icon">❓</text>
    </mp-cell>
    <mp-cell link bindtap="goAbout" value="关于我们" hover>
      <text slot="icon" class="menu-icon">🐱</text>
    </mp-cell>
  </mp-cells>

  <view class="version">{{displayText}}</view>
</view>

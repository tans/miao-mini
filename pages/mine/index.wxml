<view class="mine-container">
  <!-- 用户信息卡片 -->
  <view class="user-card" bindtap="goProfile">
    <image class="avatar" src="{{user.avatar || '/assets/icons/avatar-default.jpg'}}"/>
    <view class="user-info">
      <text class="nickname">{{user.nickname || user.username || '未登录'}}</text>
    </view>
    <text class="user-card-arrow">></text>
  </view>

  <!-- 创作者等级卡片 -->
  <view class="level-card" bindtap="goCreatorLevel">
    <view class="level-header">
      <text class="level-icon">{{creatorStats.level === 4 ? '💎' : creatorStats.level === 3 ? '🥇' : creatorStats.level === 2 ? '🥈' : creatorStats.level >= 5 ? '👑' : '🪙'}}</text>
      <text class="level-name">{{creatorStats.level_name}}</text>
    </view>
    <view class="level-stats">
      <view class="stat-item">
        <text class="stat-value">{{creatorStats.adopted_count || 0}}</text>
        <text class="stat-label">累计采纳</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">{{creatorStats.daily_limit || 0}}</text>
        <text class="stat-label">今日投稿</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">{{creatorStats.commission_rate || '10%'}}</text>
        <text class="stat-label">平台佣金</text>
      </view>
    </view>
    <view class="level-progress" wx:if="{{creatorStats.next_level_name}}">
      <text class="progress-text">升级到{{creatorStats.next_level_name}}还需{{creatorStats.need_count}}个采纳</text>
    </view>
  </view>

  <!-- 钱包卡片 -->
  <view class="wallet-card" bindtap="goWallet">
    <view class="wallet-left">
      <text class="wallet-label">钱包余额</text>
      <text class="wallet-balance">¥{{balance || '0.00'}}</text>
    </view>
    <text class="wallet-arrow">></text>
  </view>

  <!-- 功能列表 -->
  <view class="card-grid">
    <view class="grid-card" bindtap="goMyClaims">
      <text class="grid-icon">📋</text>
      <text class="grid-text">我接受的任务</text>
    </view>
    <view class="grid-card" bindtap="goRequirements">
      <text class="grid-icon">📝</text>
      <text class="grid-text">需求</text>
    </view>
    <view class="grid-card" bindtap="goPublishTask">
      <text class="grid-icon">🚀</text>
      <text class="grid-text">发布任务</text>
    </view>
    <view class="grid-card" bindtap="goAdoptedWorks">
      <text class="grid-icon">🏆</text>
      <text class="grid-text">采纳作品库</text>
    </view>
    <view class="grid-card" bindtap="goMyTasks">
      <text class="grid-icon">📤</text>
      <text class="grid-text">我发布的任务</text>
    </view>
    <view class="grid-card" bindtap="goHelp">
      <text class="grid-icon">❓</text>
      <text class="grid-text">帮助中心</text>
    </view>
  </view>

  <view class="version">{{displayText}}</view>
</view>

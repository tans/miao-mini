<!-- pages/mine/index.wxml -->
<view class="mine-container">
  <view class="mine-top-anchor" id="mine-top-anchor">
    <!-- 背景图片 -->
    <image class="bg-image" src="https://public.jisuhudong.com/minapp/mine-bg.png" mode="widthFix" />
    <!-- 自定义导航栏 -->
    <custom-nav title="我的" pinned="{{navPinned}}" elevated="{{navPinned && navElevated}}" />
    <view class="nav-slot-placeholder" wx:if="{{navPinned}}" style="height: {{navSlotPx}}px;"></view>
    <!-- 顶部区域 -->
    <view class="header-section">
    <!-- 用户信息卡片 -->
    <view class="user-card">
      <view class="user-info-row">
        <view class="user-avatar-wrap" bindtap="goProfile">
          <image wx:if="{{avatarSrc}}"
            class="user-avatar"
            src="{{avatarSrc}}"
            mode="aspectFill"
            bindload="onAvatarLoad"
            binderror="onAvatarError"
            style="opacity: {{avatarLoadFailed ? 0 : 1}};"
          />
          <view wx:if="{{avatarLoadFailed || !avatarSrc}}" class="user-avatar-fallback">
            <text class="user-avatar-fallback-text">{{avatarFallbackText}}</text>
          </view>
        </view>
        <view class="user-detail">
          <view class="user-name-row" bindtap="goProfile">
            <view style="display: flex; align-items: center; gap: 10rpx;">
              <text class="user-name">{{user.nickname || user.username || '未登录'}}</text>
              <!-- <image class="wallet-arrow" src="../../images/mine/right.png" /> -->
            </view>
            <!-- <view class="user-right">
              <text class="user-id">ID：{{user.id || '--'}}</text>
              <image class="user-arrow" src="../../images/mine/arrow-right.png" bindtap="copyUserId" />
            </view> -->
          </view>
          <view class="user-level-row"  bindtap="goLevel">
            <view class="level-info">
              <view class="level-badge">
                <text class="level-num">Lv.{{creatorStats.level || 0}}</text>
                <text class="level-name">{{creatorStats.level_name || '创作者'}}</text>
              </view>
              <text class="level-sep">·</text>
              <text class="level-task-count">完成 {{creatorStats.adopted_count || 0}} 个任务</text>
            </view>
            <view class="go-profile-btn">
              <image class="wallet-arrow" src="../../images/mine/right.png" />
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 钱包入口 -->
    <view class="wallet-card" bindtap="goWallet">
      <view class="wallet-left">
        <view class="wallet-header">
          <text class="wallet-title">钱包</text>
          <image class="wallet-arrow" src="../../images/mine/right.png" />
        </view>
        <text class="wallet-balance">¥{{balance || '0.00'}}</text>
        <text class="wallet-desc">可提现余额</text>
      </view>
      <view class="wallet-right">
        <view class="wallet-right-item">
          <text class="wallet-right-text">立即提现</text>
        </view>
      </view>
    </view>
    </view>
  </view>

  <!-- 主体内容 -->
  <view class="content-section">
    <!-- 创作者专区 -->
    <view class="zone-card">
      <view class="zone-title">创作者专区</view>
      <view class="zone-items">
        <view class="zone-item" bindtap="goMyClaims">
          <view class="zone-item-left">
            <image class="zone-icon" src="../../images/icon/renwu.png" />
            <view class="zone-item-content">
              <text class="zone-item-title">我的任务</text>
              
            </view>
          </view>
          <view class="zone-item-right">
            <view class="zone-item-badge" wx:if="{{creatorStats.pending_count > 0}}">
              <text class="badge-num">{{creatorStats.pending_count}}</text>
              <text class="badge-text">个任务待交稿</text>
            </view>
            <image class="zone-arrow" src="../../images/mine/right.png" />
          </view>
        </view>
        <view class="zone-item" bindtap="goWorks">
          <view class="zone-item-left">
            <image class="zone-icon" src="../../images/icon/zuopin.png" />
            <text class="zone-item-title">我的作品</text>
          </view>
          <image class="zone-arrow" src="../../images/mine/right.png" />
        </view>
      </view>
    </view>

    <!-- 商家专区 -->
    <view class="zone-card">
      <view class="zone-title">商家专区</view>
      <view class="zone-items">
        <view class="zone-item" bindtap="goMerchantAuth">
          <view class="zone-item-left">
            <image class="zone-icon" src="../../images/icon/renzheng.png" />
            <text class="zone-item-title">商家认证</text>
          </view>
          <view class="zone-item-right">
            <view class="action-tag {{merchantAuthActionClass}}">
              <text class="action-tag-text">{{merchantAuthActionText}}</text>
            </view>
          </view>
        </view>
        <view class="zone-item" bindtap="goMyTasks">
          <view class="zone-item-left">
            <image class="zone-icon" src="../../images/icon/guanli.png" />
            <view class="zone-item-content">
              <text class="zone-item-title">任务管理</text>
              
            </view>
          </view>
          <view class="zone-item-right">
            <view class="zone-item-badge" wx:if="{{bizStats.pending_count > 0}}">
                <text class="badge-num">{{bizStats.pending_count}}</text>
                <text class="badge-text">个视频待审核</text>
              </view>
            <image class="zone-arrow" src="../../images/mine/right.png" />
          </view>
        </view>
        <view class="zone-item" bindtap="goPurchasedWorks">
          <view class="zone-item-left">
            <image class="zone-icon" src="../../images/icon/pinku.png" />
            <text class="zone-item-title">已购作品库</text>
          </view>
          <image class="zone-arrow" src="../../images/mine/right.png" />
        </view>
      </view>
    </view>

    <!-- 通用功能 -->
    <view class="zone-card">
      <view class="zone-title">通用功能</view>
      <view class="zone-items">
        <view class="zone-item" bindtap="goHelp">
          <view class="zone-item-left">
            <image class="zone-icon" src="../../images/icon/bangzhu.png" />
            <text class="zone-item-title">帮助中心</text>
          </view>
          <image class="zone-arrow" src="../../images/mine/right.png" />
        </view>
        <view class="zone-item" bindtap="goAppeal">
          <view class="zone-item-left">
            <image class="zone-icon" src="../../images/icon/shensu.png" />
            <text class="zone-item-title">申诉与纠纷</text>
          </view>
          <image class="zone-arrow" src="../../images/mine/right.png" />
        </view>
        <view class="zone-item" bindtap="goCustomerService">
          <view class="zone-item-left">
            <image class="zone-icon" src="../../images/icon/lianxi.png" />
            <text class="zone-item-title">联系客服</text>
          </view>
          <image class="zone-arrow" src="../../images/mine/right.png" />
        </view>
      </view>
    </view>


  <view class="update-time" wx:if="{{displayText}}">更新时间：{{displayText}}</view>


</view>
</view>

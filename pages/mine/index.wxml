<view class="mine-container">
  <!-- 用户信息卡片 -->
  <view class="user-card" bindtap="goProfile">
    <image class="avatar" src="{{user.avatar || '/assets/icons/avatar-default.jpg'}}"/>
    <view class="user-info">
      <text class="nickname">{{user.nickname || user.username || '未登录'}}</text>
    </view>
    <text class="user-card-arrow">></text>
  </view>

  <!-- 创作者面板 -->
  <view class="panel-section">
    <view class="panel-label">创作者面板</view>
    <view class="panel-card">
      <view class="panel-item" bindtap="goCreatorLevel">
        <text class="panel-item-icon">📊</text>
        <text class="panel-item-text">创作数据</text>
      </view>
      <view class="panel-item" bindtap="goMyClaims">
        <text class="panel-item-icon">📋</text>
        <text class="panel-item-text">我报名的任务</text>
      </view>
      <view class="panel-item" bindtap="goWorks">
        <text class="panel-item-icon">🎬</text>
        <text class="panel-item-text">我提交的作品</text>
      </view>
    </view>
  </view>

  <!-- 钱包入口 -->
  <view class="wallet-row" bindtap="goWallet">
    <text class="wallet-label">钱包余额</text>
    <view class="wallet-right">
      <text class="wallet-balance">¥{{balance || '0.00'}}</text>
      <text class="wallet-arrow">></text>
    </view>
  </view>

  <!-- 商家面板 -->
  <view class="panel-section">
    <view class="panel-label">商家面板</view>
    <view class="panel-card">
      <view class="panel-item" bindtap="goAdoptedWorks">
        <text class="panel-item-icon">🏆</text>
        <text class="panel-item-text">作品仓库</text>
      </view>
      <view class="panel-item" bindtap="goMyTasks">
        <text class="panel-item-icon">📤</text>
        <text class="panel-item-text">我发布的任务</text>
      </view>
      <view class="panel-item" bindtap="goPublishTask">
        <text class="panel-item-icon">🚀</text>
        <text class="panel-item-text">马上发布</text>
      </view>
    </view>
  </view>

  <!-- 帮助中心 -->
  <view class="help-row" bindtap="goHelp">
    <text class="help-text">帮助中心</text>
    <text class="help-arrow">></text>
  </view>

  <view class="version">{{displayText}}</view>
</view>

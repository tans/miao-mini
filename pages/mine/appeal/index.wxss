.appeal-page {
  min-height: 100vh;
  background: #fafafa;
  box-sizing: border-box;
  padding-bottom: 264rpx;
}

.tabs {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx;
}

.tab {
  padding: 16rpx 32rpx;
  border-radius: 36rpx;
  font-size: 26rpx;
  font-weight: 900;
  color: #333;
  background: #fff;
}

.tab-active {
  background: #ff9f2f;
  color: #fff;
}

.records {
  margin: 0 24rpx;
}

.record-card {
  margin-bottom: 24rpx;
  padding: 32rpx;
  border-radius: 16rpx;
  background: #fff;
  box-shadow: 0 4rpx 16rpx rgba(17, 17, 17, 0.04);
}

.record-title {
  display: block;
  font-size: 28rpx;
  line-height: 1.5;
  font-weight: 700;
  color: #333;
}

.record-subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #555562;
}

.record-panel {
  margin-top: 18rpx;
  padding: 24rpx 16rpx;
  border-radius: 8rpx;
  background: #fef0f0;
}

.record-panel-muted {
  background: #eef5ff;
}

.record-label {
  display: block;
  font-size: 22rpx;
  font-weight: 700;
  color: #8f95a3;
}

.record-text {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #ef4444;
}

.record-panel-muted .record-text {
  color: #333;
}

.record-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 22rpx;
}

.record-time {
  font-size: 22rpx;
  color: #9ca2af;
}

.record-status {
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.record-status-processing {
  background: #fff0e6;
  color: #d66a22;
}

.record-status-resolved {
  background: #ebf8ef;
  color: #278c54;
}

.empty-state {
  margin-top: 44rpx;
  padding: 88rpx 40rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.88);
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.empty-mark {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #fff1e7 0%, #ffe5c8 100%);
  color: #c96f31;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 800;
}

.empty-title {
  margin-top: 28rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #232a35;
}

.empty-desc {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #8f95a3;
}

.service-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10;
  padding: 24rpx 32rpx 40rpx;
  background: linear-gradient(to top, rgba(250, 250, 250, 0.98), rgba(250, 250, 250, 0.72));
}

.service-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.service-btn-solid {
  color: #fff;
  background: linear-gradient(135deg, #ff9f2f 0%, #ff7c09 100%);
}

.composer-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.35);
  z-index: 20;
}

.composer-modal {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: 36rpx;
  z-index: 21;
}

.composer-modal-content {
  border-radius: 28rpx;
  background: #fff;
  padding: 32rpx;
}

.composer-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.composer-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #232a35;
}

.composer-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #f4f4f6;
  color: #666;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
}

.composer-body {
  margin-top: 24rpx;
}

.type-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.type-picker-label {
  font-size: 24rpx;
  color: #666;
}

.type-picker-value {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #fff6de;
  color: #b7780b;
  font-size: 22rpx;
  font-weight: 700;
}

.composer-textarea {
  margin-top: 20rpx;
  width: 100%;
  min-height: 180rpx;
  box-sizing: border-box;
  padding: 20rpx;
  border-radius: 20rpx;
  background: #f7f8fa;
}

.upload-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
}

.upload-item,
.upload-add {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
  background: #f4f4f6;
}

.upload-preview {
  width: 100%;
  height: 100%;
}

.upload-remove {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.55);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-add {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999;
  font-size: 48rpx;
}

.composer-submit {
  margin-top: 24rpx;
  height: 88rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ff9f2f 0%, #ff7c09 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

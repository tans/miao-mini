.tabs {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx;
}

.tab {
  padding: 16rpx 32rpx;
  border-radius: 36rpx;
  font-size: 26rpx;
  font-weight: 900;
  color: #333333;
  background: #fff;
}

.tab-active {
  background: #ff9f2f;
  color: #fff;
}

.records {
  margin: 0 24rpx;
}

.record-card {
  margin-bottom: 24rpx;
  padding: 32rpx;
  border-radius: 16rpx;
  background: #fff;
  box-shadow: 0rpx 4rpx 16rpx 0rpx rgba(17,17,17,0.04);
  display: flex;
}

.record-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.record-image{
  width: 80rpx;
  height: 80rpx;
}
.record-content{
  margin-left: 24rpx;
  flex: 1;
}

.record-badge,
.record-status {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
  border-radius: 12rpx;
}

.record-badge-about {
  background: #fff1e7;
  color: #c96f31;
}

.record-badge-initiated {
  background: #eef3ff;
  color: #4568d4;
}

.record-status-actionable {
  background: #fff6de;
  color: #b7780b;
}

.record-status-processing {
  background: #fff0e6;
  color: #d66a22;
}

.record-status-resolved {
  background: #ebf8ef;
  color: #278c54;
}

/* .record-main {
  margin-top: 22rpx;
} */

.record-title {
  display: block;
  font-size: 28rpx;
  line-height: 1.5;
  font-weight: 700;
  color: #333333;
}

.record-subtitle {
  display: block;
  margin-top: 18rpx;
  font-size: 24rpx;
  color: #555562;
}

.record-panel {
  margin-top: 18rpx;
  padding: 24rpx 16rpx;
  border-radius: 8rpx;
  background: #FEF0F0;
}
.record-primary-panel {
  margin-top: 18rpx;
  padding: 24rpx 16rpx;
  border-radius: 8rpx;
  background: #EEF5FF;
}
.record-primary-text {
  display: block;
  font-size: 24rpx;
  line-height: 1.5;
  color: #333333;
}
.record-success-panel {
  margin-top: 18rpx;
  padding: 24rpx 16rpx;
}
.record-success-text {
  display: block;
  font-size: 24rpx;
  line-height: 1.5;
  color: #EF8802;
}



.record-label {
  display: block;
  font-size: 22rpx;
  font-weight: 700;
  color: #8f95a3;
}

.record-text {
  display: block;
  font-size: 24rpx;
  line-height: 1.5;
  color: #EF4444;
}

.record-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 22rpx;
}

.record-time {
  font-size: 22rpx;
  color: #9ca2af;
}

.record-action {
  padding: 20rpx 34rpx;
  border-radius: 999rpx;
  color: #333;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
  border: 2rpx solid #ECECEF;
}

.empty-state {
  margin-top: 44rpx;
  padding: 88rpx 40rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.88);
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.empty-mark {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #fff1e7 0%, #ffe5c8 100%);
  color: #c96f31;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 800;
}

.empty-title {
  margin-top: 28rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #232a35;
}

.empty-desc {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #8f95a3;
}

.service-bar {
  position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 26rpx 32rpx;
    background: #ffff;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border: 2rpx solid #ECECEF;
}

.service-copy {
  flex: 1;
}

.service-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #fffaf6;
}

.service-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(255, 250, 246, 0.68);
}

.service-actions {
  display: flex;
  gap: 14rpx;
}

.service-btn {
  padding: 24rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
  width: 100%;
}

.service-btn-ghost {
  color: #fff7f1;
  border: 1rpx solid rgba(255, 247, 241, 0.26);
}

.service-btn-solid {
      background: #FF9F2F;
    color: #FFFFFF;
}

.composer-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: center;
}

.composer-modal {
  position: fixed;
  width: 100vw;
  height: 100vh;
  z-index: 21;
  overflow: hidden;
  top: 0;
  left: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.composer-modal-content {
  border-radius: 24rpx;
  background: #fff;
  width: 640rpx;
}

.composer-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 0 32rpx;
  /* border-bottom: 1rpx solid #f0f0f0; */
}

.composer-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.composer-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #999;
  line-height: 1;
}

.composer-body {
  padding: 48rpx;
}

.composer-target {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 22rpx;
  background: #f6f7fb;
}

.composer-target-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2631;
}

.composer-target-subtitle,
.composer-target-reason {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #7b8190;
}

.composer-block {
  margin-top: 28rpx;
}

.composer-label {
  display: block;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #303744;
}

.type-picker {
  margin-bottom: 28rpx;
  padding: 20rpx 24rpx;
  border-radius: 18rpx;
  background: #f7f8fb;
  border: 2rpx solid #eceef4;
}

.type-picker-label {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: #6a7280;
}

.type-picker-value {
  display: block;
  margin-top: 10rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2631;
}

.type-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.type-chip {
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  background: #f3f4f8;
  border: 1rpx solid #ebedf4;
  font-size: 24rpx;
  color: #677082;
}

.type-chip-active {
  background: #fff1e7;
  border-color: #f0b486;
  color: #bf6427;
}

.composer-textarea {
  width: 544rpx;
  height: 170rpx;
  padding: 24rpx;
  border-radius: 8rpx 8rpx 8rpx 8rpx;
  border: 2rpx solid #ECEEF4; 
  box-sizing: border-box;
  font-size: 28rpx;
  line-height: 1.5;
  color: #333;
}

.upload-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 36rpx;
}

.upload-item,
.upload-add {
  width: 112rpx;
  height: 112rpx;
  border-radius: 26rpx;
}

.upload-item {
  position: relative;
}

.upload-preview {
  width: 100%;
  height: 100%;
}

.upload-remove {
  position: absolute;
  top: -18rpx;
  right: -18rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: rgba(23, 28, 40, 0.7);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.upload-add {
  border: 2rpx dashed #d8dce6;
  background: #f8f9fc;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #8f95a3;
}

.upload-add-icon {
  font-size: 40rpx;
  line-height: 1;
}

.upload-add-text {
  margin-top: 10rpx;
  font-size: 22rpx;
}

.composer-submit {
  margin: 0 32rpx 32rpx;
  height: 88rpx;
  border-radius: 999rpx;
  background: #ff9f2f;
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.composer-submit::after {
  border: none;
}

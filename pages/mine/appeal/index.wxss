.appeal-page {
  min-height: 100vh;
  padding: 28rpx 24rpx 220rpx;
  background: linear-gradient(180deg, #fff6ee 0%, #f6f7fb 36%, #f3f4f8 100%);
  box-sizing: border-box;
}

.hero-card {
  position: relative;
  overflow: hidden;
  padding: 36rpx 32rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #2e2521 0%, #53423f 42%, #f08f42 100%);
  box-shadow: 0 18rpx 40rpx rgba(71, 47, 32, 0.16);
}

.hero-copy {
  position: relative;
  z-index: 1;
  width: 470rpx;
}

.hero-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #fff9f2;
}

.hero-desc {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: rgba(255, 249, 242, 0.84);
}

.hero-mark {
  position: absolute;
  right: -10rpx;
  bottom: 4rpx;
  font-size: 58rpx;
  font-weight: 800;
  letter-spacing: 6rpx;
  color: rgba(255, 255, 255, 0.12);
  transform: rotate(-6deg);
}

.tabs {
  display: flex;
  gap: 18rpx;
  margin-top: 28rpx;
}

.tab {
  flex: 1;
  height: 76rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(233, 216, 206, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  color: #8c7163;
}

.tab-active {
  background: #2f2520;
  border-color: #2f2520;
  color: #fff7f1;
  box-shadow: 0 12rpx 24rpx rgba(47, 37, 32, 0.14);
}

.records {
  margin-top: 28rpx;
}

.record-card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 14rpx 30rpx rgba(23, 29, 45, 0.06);
}

.record-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.record-badge,
.record-status {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.record-badge-about {
  background: #fff1e7;
  color: #c96f31;
}

.record-badge-initiated {
  background: #eef3ff;
  color: #4568d4;
}

.record-status-actionable {
  background: #fff6de;
  color: #b7780b;
}

.record-status-processing {
  background: #fff0e6;
  color: #d66a22;
}

.record-status-resolved {
  background: #ebf8ef;
  color: #278c54;
}

.record-main {
  margin-top: 22rpx;
}

.record-title {
  display: block;
  font-size: 32rpx;
  line-height: 1.5;
  font-weight: 700;
  color: #1e232f;
}

.record-subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #8f95a3;
}

.record-panel {
  margin-top: 22rpx;
  padding: 22rpx 24rpx;
  border-radius: 20rpx;
  background: #f6f7fb;
}

.record-label {
  display: block;
  font-size: 22rpx;
  font-weight: 700;
  color: #8f95a3;
}

.record-text {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #2d3440;
}

.record-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 24rpx;
}

.record-time {
  font-size: 22rpx;
  color: #9ca2af;
}

.record-action {
  min-width: 160rpx;
  height: 64rpx;
  padding: 0 26rpx;
  border-radius: 999rpx;
  background: #2f2520;
  color: #fff7f1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
}

.empty-state {
  margin-top: 44rpx;
  padding: 88rpx 40rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.88);
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.empty-mark {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #fff1e7 0%, #ffe5c8 100%);
  color: #c96f31;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 800;
}

.empty-title {
  margin-top: 28rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #232a35;
}

.empty-desc {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #8f95a3;
}

.service-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 28rpx;
  padding: 26rpx 28rpx;
  border-radius: 28rpx;
  background: rgba(33, 27, 24, 0.94);
  box-shadow: 0 18rpx 40rpx rgba(33, 27, 24, 0.2);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.service-copy {
  flex: 1;
}

.service-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #fffaf6;
}

.service-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(255, 250, 246, 0.68);
}

.service-actions {
  display: flex;
  gap: 14rpx;
}

.service-btn {
  height: 68rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
}

.service-btn-ghost {
  color: #fff7f1;
  border: 1rpx solid rgba(255, 247, 241, 0.26);
}

.service-btn-solid {
  background: linear-gradient(135deg, #f8b164 0%, #ec7d38 100%);
  color: #291f1a;
}

.composer-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: rgba(16, 18, 25, 0.52);
  z-index: 20;
}

.composer-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 21;
  padding: 18rpx 24rpx 44rpx;
  border-radius: 36rpx 36rpx 0 0;
  background: #ffffff;
}

.composer-handle {
  width: 88rpx;
  height: 8rpx;
  margin: 0 auto 22rpx;
  border-radius: 999rpx;
  background: #dde1ea;
}

.composer-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.composer-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1e232f;
}

.composer-close {
  font-size: 24rpx;
  color: #8f95a3;
}

.composer-target {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 22rpx;
  background: #f6f7fb;
}

.composer-target-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2631;
}

.composer-target-subtitle,
.composer-target-reason {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #7b8190;
}

.composer-block {
  margin-top: 28rpx;
}

.composer-label {
  display: block;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #303744;
}

.type-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.type-chip {
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  background: #f3f4f8;
  border: 1rpx solid #ebedf4;
  font-size: 24rpx;
  color: #677082;
}

.type-chip-active {
  background: #fff1e7;
  border-color: #f0b486;
  color: #bf6427;
}

.composer-textarea {
  width: 100%;
  min-height: 220rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: #f6f7fb;
  box-sizing: border-box;
  font-size: 26rpx;
  line-height: 1.7;
  color: #222a35;
}

.upload-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.upload-item,
.upload-add {
  width: 180rpx;
  height: 180rpx;
  border-radius: 22rpx;
  overflow: hidden;
}

.upload-item {
  position: relative;
}

.upload-preview {
  width: 100%;
  height: 100%;
}

.upload-remove {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: rgba(23, 28, 40, 0.7);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.upload-add {
  border: 2rpx dashed #d8dce6;
  background: #f8f9fc;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #8f95a3;
}

.upload-add-icon {
  font-size: 40rpx;
  line-height: 1;
}

.upload-add-text {
  margin-top: 10rpx;
  font-size: 22rpx;
}

.composer-submit {
  margin-top: 32rpx;
  height: 92rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #f4a85a 0%, #e76c2f 100%);
  color: #fff9f3;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 92rpx;
}

.composer-submit::after {
  border: none;
}

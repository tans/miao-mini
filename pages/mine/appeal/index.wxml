<view class="appeal-page">
  <view class="tabs">
    <view
      wx:for="{{tabs}}"
      wx:key="key"
      class="tab {{activeTab === item.key ? 'tab-active' : ''}}"
      data-tab="{{item.key}}"
      bindtap="switchTab"
    >
      <text>{{item.label}}</text>
    </view>
  </view>

  <view class="records" wx:if="{{filteredRecords.length > 0}}">
    <view class="record-card" wx:for="{{filteredRecords}}" wx:key="id">
      <view class="record-content">
        <view class="record-main">
          <text class="record-title">{{item.title}}</text>
          <text class="record-subtitle">{{item.subtitle}}</text>
        </view>

        <view class="record-panel">
          <text class="record-label">{{item.reasonLabel}}</text>
          <text class="record-text">{{item.reasonText}}</text>
        </view>

        <view class="record-panel record-panel-muted" wx:if="{{item.resultText}}">
          <text class="record-label">处理结果</text>
          <text class="record-text">{{item.resultText}}</text>
        </view>

        <view class="record-footer">
          <text class="record-time">{{item.timeLabel}} {{item.timeText}}</text>
          <view class="record-status record-status-{{item.statusClass}}">
            <text>{{item.statusText}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:if="{{!loading && filteredRecords.length === 0}}">
    <view class="empty-mark">0</view>
    <text class="empty-title">暂无申诉记录</text>
    <text class="empty-desc">仅显示你提交过的创作者申诉。</text>
  </view>

  <view class="service-bar">
    <view class="service-btn service-btn-solid" bindtap="goCustomerService">
      <text>联系客服</text>
    </view>
  </view>

  <view wx:if="{{showComposer}}" class="composer-mask" bindtap="closeComposer"></view>
  <view wx:if="{{showComposer}}" class="composer-modal">
    <view class="composer-modal-content">
      <view class="composer-header">
        <text class="composer-title">申诉原因</text>
        <view class="composer-close" bindtap="closeComposer">×</view>
      </view>
      <view class="composer-body">
        <view class="type-picker">
          <text class="type-picker-label">申诉类型</text>
          <view class="type-picker-value">{{selectedType.name}}</view>
        </view>
        <textarea
          class="composer-textarea"
          value="{{reason}}"
          bindinput="onReasonInput"
          maxlength="300"
          placeholder="请输入申诉说明"
        />

        <view class="upload-list">
          <view class="upload-item" wx:for="{{uploadImages}}" wx:key="index">
            <image class="upload-preview" src="{{item.previewUrl || item.tempFilePath || item}}" mode="aspectFill" />
            <view class="upload-remove" bindtap="removeImage" data-index="{{index}}">×</view>
          </view>
          <view class="upload-add" wx:if="{{uploadImages.length < 3}}" bindtap="uploadImage">
            <text class="upload-add-icon">+</text>
          </view>
        </view>
      </view>
      <view class="composer-submit" bindtap="submitAppeal">提交</view>
    </view>
  </view>
</view>

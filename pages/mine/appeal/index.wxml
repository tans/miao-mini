<view class="appeal-page">
  <view class="hero-card">
    <view class="hero-top">
      <text class="hero-title">{{pageTitle}}</text>
      <view class="hero-badge">{{records.length}} 条</view>
    </view>
    <text class="hero-desc">{{heroDesc}}</text>
  </view>

  <view class="workflow-list" wx:if="{{records.length > 0}}">
    <view class="workflow-card" wx:for="{{records}}" wx:key="key">
      <view class="workflow-head" bindtap="openTaskDetail" data-task-id="{{item.taskId}}">
        <image wx:if="{{item.taskAvatar}}" class="task-avatar" src="{{item.taskAvatar}}" mode="aspectFill" />
        <view wx:else class="task-avatar task-avatar-fallback">任</view>
        <view class="workflow-head-body">
          <text class="task-title">{{item.taskTitle}}</text>
          <text class="task-subtitle">{{item.taskSubtitle}}</text>
        </view>
        <view class="workflow-state workflow-state-{{item.overallStateClass}}">
          <text>{{item.overallStateText}}</text>
        </view>
      </view>

      <view class="workflow-steps">
        <view class="workflow-step workflow-step-{{item.report.stateClass}}">
          <view class="step-dot"></view>
          <view class="step-body">
            <view class="step-row">
              <text class="step-title">{{item.report.title}}</text>
              <text class="step-label">{{item.report.label}}</text>
            </view>
            <text class="step-desc">{{item.report.reason}}</text>
            <text class="step-time">{{item.report.timeText}}</text>
          </view>
        </view>

        <view class="workflow-connector"></view>

        <view class="workflow-step workflow-step-{{item.appeal.stateClass}}">
          <view class="step-dot"></view>
          <view class="step-body">
            <view class="step-row">
              <text class="step-title">{{item.appeal.title}}</text>
              <text class="step-label">{{item.appeal.label}}</text>
            </view>
            <text class="step-desc">{{item.appeal.reason}}</text>
            <text class="step-time">{{item.appeal.timeText}} · {{item.appeal.detail}}</text>
          </view>
        </view>

        <view class="workflow-connector"></view>

        <view class="workflow-step workflow-step-{{item.platform.stateClass}}">
          <view class="step-dot"></view>
          <view class="step-body">
            <view class="step-row">
              <text class="step-title">{{item.platform.title}}</text>
              <text class="step-label">{{item.platform.label}}</text>
            </view>
            <text class="step-desc">{{item.platform.result}}</text>
            <text class="step-time">{{item.platform.timeText}} · {{item.platform.detail}}</text>
          </view>
        </view>
      </view>

      <view class="workflow-media" wx:if="{{item.creatorMaterials.length > 0}}">
        <view class="media-title">作品显示</view>
        <scroll-view scroll-x class="media-scroll">
          <view class="media-item" wx:for="{{item.creatorMaterials}}" wx:key="file_path" data-claim-id="{{item.claimId}}" data-preview-type="{{media.isVideo ? 'video' : 'image'}}" data-preview-url="{{media.previewUrl}}" bindtap="previewMaterial" wx:for-item="media">
            <image wx:if="{{media.isImage}}" class="media-thumb" src="{{media.previewUrl}}" mode="aspectFill" />
            <image wx:elif="{{media.isVideo && media.posterUrl}}" class="media-thumb" src="{{media.posterUrl}}" mode="aspectFill" />
            <image wx:else class="media-thumb" src="{{media.previewUrl}}" mode="aspectFill" />
          </view>
        </scroll-view>
      </view>

      <view class="workflow-actions" wx:if="{{item.canAppeal}}">
        <view class="workflow-chip workflow-chip-primary" wx:if="{{item.canAppeal}}" bindtap="openComposer" data-claim-id="{{item.claimId}}">
          <text>去申诉</text>
        </view>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:if="{{!loading && records.length === 0}}">
    <view class="empty-mark">流程</view>
    <text class="empty-title">{{emptyTitle}}</text>
    <text class="empty-desc">{{emptyDesc}}</text>
    <view class="empty-action" bindtap="goEntryPage">
      <text>{{emptyActionText}}</text>
    </view>
  </view>

  <view class="service-bar">
    <view class="service-btn service-btn-plain" bindtap="contactService">
      <text>联系客服</text>
    </view>
  </view>

  <view wx:if="{{showComposer}}" class="composer-mask" bindtap="closeComposer"></view>
  <view wx:if="{{showComposer}}" class="composer-modal">
    <view class="composer-modal-content">
      <view class="composer-header">
        <view>
          <text class="composer-title">提交申诉</text>
          <text class="composer-subtitle">{{composerTarget.taskTitle}}</text>
        </view>
        <view class="composer-close" bindtap="closeComposer">×</view>
      </view>
      <view class="composer-body">
        <view class="composer-tip">
          <text class="composer-tip-label">商家举报原因</text>
          <text class="composer-tip-text">{{composerTarget.reportReason}}</text>
        </view>
        <textarea
          class="composer-textarea"
          value="{{reason}}"
          bindinput="onReasonInput"
          maxlength="300"
          placeholder="请输入你的申诉说明"
        />
        <text class="composer-error" wx:if="{{submitError}}">{{submitError}}</text>

        <view class="upload-list">
          <view class="upload-item" wx:for="{{uploadImages}}" wx:key="index">
            <image class="upload-preview" src="{{item.previewUrl || item.tempFilePath || item}}" mode="aspectFill" />
            <view class="upload-remove" bindtap="removeImage" data-index="{{index}}">×</view>
          </view>
          <view class="upload-add" wx:if="{{uploadImages.length < 3}}" bindtap="uploadImage">
            <text class="upload-add-icon">+</text>
          </view>
        </view>
      </view>
      <view class="composer-submit {{submitting ? 'is-disabled' : ''}}" bindtap="submitAppeal">
        <text>{{submitting ? '提交中...' : '提交申诉'}}</text>
      </view>
    </view>
  </view>
</view>

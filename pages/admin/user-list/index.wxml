<view class="container">
  <view class="search-bar">
    <input
      class="search-input"
      placeholder="搜索用户名/手机号/昵称"
      value="{{keyword}}"
      bindconfirm="onSearch"
      bindinput="onSearchInput"
    />
  </view>

  <view class="user-list">
    <block wx:for="{{users}}" wx:key="id">
      <view class="user-item" bindtap="onUserTap" data-id="{{item.id}}">
        <view class="user-info">
          <view class="user-avatar">
            <image wx:if="{{item.avatar}}" src="{{item.avatar}}" mode="aspectFill" />
            <text wx:else>{{item.nickname || item.username}}</text>
          </view>
          <view class="user-detail">
            <view class="user-name">{{item.nickname || item.username}}</view>
            <view class="user-phone">{{item.phone}}</view>
            <view class="user-meta">
              <text class="user-level level-{{item.level}}">{{item.level_name}}</text>
              <text class="user-status status-{{item.status}}">{{item.status === 1 ? '正常' : '禁用'}}</text>
            </view>
          </view>
        </view>
        <view class="user-wallet">
          <view class="wallet-balance">¥{{item.balance}}</view>
          <view class="wallet-frozen">冻结: ¥{{item.frozen_amount}}</view>
        </view>
      </view>
    </block>

    <view class="loading" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>
    <view class="no-more" wx:if="{{!hasMore && users.length > 0}}">
      <text>没有更多了</text>
    </view>
    <view class="empty" wx:if="{{!loading && users.length === 0}}">
      <text>暂无用户</text>
    </view>
  </view>
</view>
<view class="container">
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <block wx:else if="{{user}}">
    <view class="user-card">
      <view class="user-header">
        <view class="user-avatar">
          <image wx:if="{{user.avatar}}" src="{{user.avatar}}" mode="aspectFill" />
          <text wx:else>{{user.nickname || user.username}}</text>
        </view>
        <view class="user-basic">
          <view class="user-name">{{user.nickname || user.username}}</view>
          <view class="user-phone">{{user.phone}}</view>
          <view class="user-status status-{{user.status}}">{{user.status === 1 ? '正常' : '禁用'}}</view>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-title">账户信息</view>
      <view class="info-grid">
        <view class="info-item">
          <view class="info-label">用户ID</view>
          <view class="info-value">{{user.id}}</view>
        </view>
        <view class="info-item">
          <view class="info-label">用户名</view>
          <view class="info-value">{{user.username}}</view>
        </view>
        <view class="info-item">
          <view class="info-label">创建时间</view>
          <view class="info-value">{{user.created_at}}</view>
        </view>
        <view class="info-item">
          <view class="info-label">创作者等级</view>
          <view class="info-value level-{{user.level}}">{{user.level_name}}</view>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-title">钱包信息</view>
      <view class="wallet-card">
        <view class="wallet-row">
          <text class="wallet-label">账户余额</text>
          <text class="wallet-value balance">¥{{user.balance}}</text>
        </view>
        <view class="wallet-row">
          <text class="wallet-label">冻结金额</text>
          <text class="wallet-value">¥{{user.frozen_amount}}</text>
        </view>
        <view class="wallet-row">
          <text class="wallet-label">保证金冻结</text>
          <text class="wallet-value">¥{{user.margin_frozen}}</text>
        </view>
        <view class="wallet-row">
          <text class="wallet-label">行为分</text>
          <text class="wallet-value">{{user.behavior_score}}</text>
        </view>
        <view class="wallet-row">
          <text class="wallet-label">交易分</text>
          <text class="wallet-value">{{user.trade_score}}</text>
        </view>
      </view>
    </view>

    <view class="actions">
      <button class="btn btn-primary" bindtap="onModifyBalance">修改余额</button>
      <button class="btn btn-secondary" bindtap="onViewTransactions">查看流水</button>
      <button
        class="btn {{user.status === 1 ? 'btn-danger' : 'btn-success'}}"
        bindtap="onToggleStatus"
      >
        {{user.status === 1 ? '禁用账户' : '启用账户'}}
      </button>
    </view>
  </block>

  <view class="empty" wx:else>
    <text>用户不存在</text>
  </view>

  <!-- Balance Modal -->
  <view class="modal" wx:if="{{showBalanceModal}}">
    <view class="modal-mask" bindtap="onCancelBalance"></view>
    <view class="modal-content">
      <view class="modal-title">修改余额</view>
      <view class="modal-body">
        <view class="form-item">
          <text class="form-label">变更金额</text>
          <input
            class="form-input"
            type="number"
            placeholder="正数增加，负数减少"
            value="{{balanceChange}}"
            bindinput="onBalanceChangeInput"
          />
        </view>
        <view class="form-item">
          <text class="form-label">操作原因</text>
          <input
            class="form-input"
            placeholder="请输入原因"
            value="{{balanceReason}}"
            bindinput="onBalanceReasonInput"
          />
        </view>
      </view>
      <view class="modal-actions">
        <button class="btn btn-secondary" bindtap="onCancelBalance">取消</button>
        <button class="btn btn-primary" bindtap="onConfirmBalance">确认</button>
      </view>
    </view>
  </view>
</view>
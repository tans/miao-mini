<!--pages/create-task/index.wxml-->
<view class="create-container">
  <form class="card" bindsubmit="handleSubmit">
    <view class="form-group">
      <text class="form-label">任务标题</text>
      <input
        class="form-input"
        type="text"
        placeholder="简洁描述任务需求"
        value="{{title}}"
        bindinput="onTitleInput"
      />
    </view>

    <view class="form-group">
      <text class="form-label">详细描述</text>
      <textarea
        class="form-textarea"
        placeholder="详细说明任务要求、交付标准、注意事项..."
        value="{{description}}"
        bindinput="onDescInput"
      />
    </view>

    <view class="form-row">
      <view class="form-group flex-1">
        <text class="form-label">基础奖励 (元/人)</text>
        <input
          class="form-input"
          type="number"
          placeholder="≥2元"
          value="{{unit_price}}"
          bindinput="onUnitPriceInput"
        />
      </view>
      <view class="form-group flex-1">
        <text class="form-label">报名人数上限</text>
        <input
          class="form-input"
          type="number"
          placeholder="≥10人"
          value="{{total_count}}"
          bindinput="onTotalCountInput"
        />
      </view>
    </view>

    <view class="form-row">
      <view class="form-group flex-1">
        <text class="form-label">入围奖励 (元/人)</text>
        <input
          class="form-input"
          type="number"
          placeholder="≥8元"
          value="{{award_price}}"
          bindinput="onAwardPriceInput"
        />
      </view>
      <view class="form-group flex-1">
        <text class="form-label">入围数量</text>
        <input
          class="form-input"
          type="number"
          placeholder="≥1人"
          value="{{award_count}}"
          bindinput="onAwardCountInput"
        />
      </view>
    </view>

    <view class="form-group">
      <text class="form-label">截止日期</text>
      <picker mode="date" value="{{deadline}}" bindchange="onDeadlineChange">
        <view class="form-input">{{deadline}}</view>
      </picker>
    </view>

    <view class="form-group">
      <text class="form-label">视频时长要求</text>
      <view class="chip-group">
        <text
          wx:for="{{durationOptions}}"
          wx:key="index"
          class="chip {{video_duration === item ? 'active' : ''}}"
          data-value="{{item}}"
          bindtap="selectDuration"
        >{{item}}</text>
      </view>
    </view>

    <view class="form-group">
      <text class="form-label">创作风格</text>
      <view class="chip-group">
        <text
          wx:for="{{styleOptions}}"
          wx:key="index"
          class="chip {{creative_style === item ? 'active' : ''}}"
          data-value="{{item}}"
          bindtap="selectStyle"
        >{{item}}</text>
      </view>
    </view>

    <!-- 任务素材（必填，第一个必须是图片） -->
    <view class="form-group">
      <text class="form-label">任务素材 <text class="label-required">*</text></text>
      <text class="label-hint">第一个必须是图片，可继续添加视频等素材</text>

      <view class="materials-grid">
        <view
          wx:for="{{materials}}" wx:key="index"
          class="material-item"
        >
          <image
            wx:if="{{item.fileType === 'image'}}"
            class="material-thumb"
            src="{{item.url}}"
            mode="aspectFill"
          />
          <view wx:else class="material-video-thumb">
            <text class="material-video-icon">▶</text>
            <text class="material-video-name">{{item.fileName}}</text>
          </view>
          <view class="material-delete" bindtap="deleteMaterial" data-index="{{index}}">✕</view>
        </view>

        <view wx:if="{{materials.length < 9}}" class="material-add" bindtap="addMaterial">
          <text class="material-add-icon">+</text>
          <text class="material-add-label">添加素材</text>
        </view>
      </view>

      <view wx:if="{{uploading}}" class="uploading-tip">
        <text>上传中，请稍候...</text>
      </view>
    </view>

    <button class="btn btn-primary btn-block" form-type="submit">发布任务</button>
  </form>
</view>

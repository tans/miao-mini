/* pages/create-task/index.wxss */
.create-container {
  padding: 12px 0;
}

.card {
  background: #fff;
  border-radius: 12px;
  padding: 16px;
  margin: 0 16px 16px;
}

.form-group {
  margin-bottom: 16px;
}

.form-row {
  display: flex;
  gap: 12px;
}

.flex-1 {
  flex: 1;
}

.form-label {
  display: block;
  font-size: 13px;
  color: #666;
  margin-bottom: 6px;
}

.form-input {
  width: 100%;
  padding: 10px 12px;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  font-size: 14px;
  box-sizing: border-box;
  background: #fff;
}

.form-textarea {
  width: 100%;
  min-height: 100px;
  padding: 10px 12px;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  font-size: 14px;
  box-sizing: border-box;
  resize: vertical;
}

.chip-group {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.chip {
  padding: 6px 14px;
  background: #f0f0f0;
  border-radius: 16px;
  font-size: 13px;
  color: #666;
}

.chip.active {
  background: #FF2442;
  color: #fff;
}

.btn {
  display: inline-block;
  padding: 12px 20px;
  border-radius: 8px;
  font-size: 14px;
  font-weight: 600;
  text-align: center;
  border: none;
}

.btn-primary {
  background: #FF2442;
  color: #fff;
}

.btn-block {
  display: block;
  width: 100%;
  margin-top: 8px;
}

/* 素材上传 */
.label-required {
  color: #FF2442;
}

.label-hint {
  display: block;
  font-size: 12px;
  color: #999;
  margin-bottom: 8px;
}

.materials-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.material-item {
  position: relative;
  width: 96rpx;
  height: 96rpx;
  border-radius: 8rpx;
  overflow: hidden;
  background: #f5f5f5;
}

.material-thumb {
  width: 100%;
  height: 100%;
}

.material-video-thumb {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #222;
}

.material-video-icon {
  color: #fff;
  font-size: 24rpx;
}

.material-video-name {
  color: #ccc;
  font-size: 18rpx;
  margin-top: 4rpx;
  max-width: 80rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.material-delete {
  position: absolute;
  top: 2rpx;
  right: 2rpx;
  width: 32rpx;
  height: 32rpx;
  background: rgba(0,0,0,0.55);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 20rpx;
  line-height: 32rpx;
  text-align: center;
}

.material-add {
  width: 96rpx;
  height: 96rpx;
  border-radius: 8rpx;
  border: 1rpx dashed #ccc;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fafafa;
}

.material-add-icon {
  font-size: 36rpx;
  color: #bbb;
  line-height: 1;
}

.material-add-label {
  font-size: 20rpx;
  color: #bbb;
  margin-top: 4rpx;
}

.uploading-tip {
  margin-top: 8px;
  font-size: 12px;
  color: #FF2442;
}

/* pages/create-task/index.wxss */
.create-container {
  min-height: 100vh;
  background: #f5f5f5;
}

.chip-group {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.chip {
  padding: 6px 14px;
  background: #f0f0f0;
  border-radius: 16px;
  font-size: 13px;
  color: #666;
}

.chip.active {
  background: #07c160;
  color: #fff;
}

/* 素材上传 */
.materials-section {
  background: #fff;
  padding: 16px;
  margin-top: 12px;
}

.section-title {
  font-size: 15px;
  font-weight: 500;
  color: #333;
  margin-bottom: 4px;
}

.required {
  color: #e64340;
}

.section-hint {
  font-size: 12px;
  color: #999;
  margin-bottom: 12px;
}

.materials-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.material-item {
  position: relative;
  width: 96rpx;
  height: 96rpx;
  border-radius: 8rpx;
  overflow: hidden;
  background: #f5f5f5;
}

.material-thumb {
  width: 100%;
  height: 100%;
}

.material-video-thumb {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #222;
}

.material-video-icon {
  color: #fff;
  font-size: 24rpx;
}

.material-video-name {
  color: #ccc;
  font-size: 18rpx;
  margin-top: 4rpx;
  max-width: 80rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.material-delete {
  position: absolute;
  top: 2rpx;
  right: 2rpx;
  width: 32rpx;
  height: 32rpx;
  background: rgba(0,0,0,0.55);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 20rpx;
  line-height: 32rpx;
  text-align: center;
}

.material-add {
  width: 96rpx;
  height: 96rpx;
  border-radius: 8rpx;
  border: 1rpx dashed #ccc;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fafafa;
}

.material-add-icon {
  font-size: 36rpx;
  color: #bbb;
  line-height: 1;
}

.material-add-label {
  font-size: 20rpx;
  color: #bbb;
  margin-top: 4rpx;
}

.uploading-tip {
  margin-top: 8px;
  font-size: 12px;
  color: #999;
  display: flex;
  align-items: center;
  gap: 8px;
}

.submit-section {
  padding: 16px;
}

.weui-btn {
  width: 100%;
}

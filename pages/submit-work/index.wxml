<!--pages/submit-work/index.wxml-->
<view class="submit-container">
  <mp-form-page title="提交作品" subtitle="上传视频或图片并添加说明">
    <mp-form id="submitForm" rules="{{rules}}" models="{{formData}}">
      <!-- 作品描述 -->
      <mp-cells title="作品描述" footer="详细说明你的创作内容、亮点和心得">
        <mp-cell prop="description" show-error>
          <textarea class="weui-textarea" placeholder="详细说明你的创作内容、亮点和心得..." value="{{description}}" bindinput="onDescInput" style="min-height: 150px"/>
        </mp-cell>
      </mp-cells>

      <!-- 视频/图片上传 -->
      <view class="materials-section">
        <view class="section-title">作品素材 <text class="required">*</text></view>
        <view class="section-hint">支持上传视频和图片，第一个必须是图片</view>

        <view class="materials-grid">
          <view wx:for="{{materials}}" wx:key="index" class="material-item">
            <image wx:if="{{item.fileType === 'image'}}" class="material-thumb" src="{{item.url}}" mode="aspectFill" bindtap="previewMaterial" data-url="{{item.url}}"/>
            <video wx:else class="material-thumb" src="{{item.url}}" bindtap="previewMaterial" data-url="{{item.url}}" show-center-play-btn="{{true}}"/>
            <view class="material-delete" bindtap="deleteMaterial" data-index="{{index}}">✕</view>
          </view>

          <view wx:if="{{materials.length < 9}}" class="material-add" bindtap="addMaterial">
            <text class="material-add-icon">+</text>
            <text class="material-add-label">添加素材</text>
          </view>
        </view>

        <view wx:if="{{uploading}}" class="uploading-tip">
          <mp-loading type="circle"></mp-loading>
          <text>上传中，请稍候...</text>
        </view>
      </view>

      <!-- 视频链接（可选） -->
      <mp-cells title="视频链接（选填）" footer="如果作品需要链接到外部平台，可在此填写">
        <mp-cell prop="video_url" show-error>
          <input class="weui-input" placeholder="请输入视频链接" value="{{video_url}}" bindinput="onVideoUrlInput"/>
        </mp-cell>
      </mp-cells>
    </mp-form>

    <!-- 提交按钮 -->
    <view class="submit-section">
      <button class="weui-btn weui-btn_primary" bindtap="handleSubmit" disabled="{{submitting}}">
        <text wx:if="{{submitting}}">提交中...</text>
        <text wx:else>提交作品</text>
      </button>
    </view>
  </mp-form-page>
</view>
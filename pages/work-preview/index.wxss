.preview-container {
  min-height: 100vh;
  background: #f5f5f5;
}

.content-wrap {
  padding-top: 120px;
}

.loading-wrap,
.empty-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 60vh;
  color: #999;
  font-size: 28rpx;
}

.video-player {
  width: 100%;
  height: 500rpx;
  background: #000;
}

.image-list {
  padding: 20rpx;
}

.image-item {
  margin-bottom: 20rpx;
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
}

.preview-image {
  width: 100%;
  display: block;
}
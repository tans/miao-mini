<view
  class="custom-nav {{pinned ? 'custom-nav--pinned' : ''}} {{elevated ? 'custom-nav--solid' : ''}}"
  style="padding-top: {{statusBarHeight}}px;"
>
  <view class="nav-content">
    <!-- 左侧消息图标 -->
    <view class="nav-left" bindtap="onMessageTap">
      <image src="/assets/icons/message.png" class="msg-icon" />
      <view class="msg-badge" wx:if="{{innerMsgCount > 0}}">{{innerMsgCount > 99 ? '99+' : innerMsgCount}}</view>
    </view>

    <!-- 中间标题区域 -->
    <view class="nav-center">
      <view class="title-wrap">
        <text class="title-text">{{title}}</text>
        <text class="subtitle-text" wx:if="{{subtitle}}">{{subtitle}}</text>
      </view>
    </view>

    <!-- 右侧占位，保持居中 -->
    <view class="nav-right"></view>
  </view>
</view>

.nav-content {
  display: flex;
  align-items: center;
  height: 44px;
  padding: 0 16px;
  position: relative;
}

.nav-left {
  position: relative;
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  z-index: 1;
}

.msg-icon {
  width: 24px;
  height: 24px;
  opacity: 0.92;
}

.msg-badge {
  position: absolute;
  top: 0;
  right: 0;
  min-width: 16px;
  height: 16px;
  background: #ef4444;
  color: #fff;
  font-size: 10px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 4px;
}

.nav-center {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  position: absolute;
  left: 60px;
  right: 60px;
}

.title-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  max-width: 100%;
}

.title-text {
  width: 68rpx;
  height: 48rpx;
  font-family: PingFang SC, PingFang SC;
  font-weight: bold;
  font-size: 34rpx;
  color: #333333;
  line-height: 48rpx;
  text-align: center;
  font-style: normal;
  text-transform: none;
}

.subtitle-text {
  font-size: 10px;
  color: #6b7280;
  white-space: nowrap;
  margin-top: 1px;
}

.nav-right {
  width: 40px;
}

.back-btn {
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-btn::before {
  content: '';
  width: 10px;
  height: 10px;
  border-left: 2px solid #111827;
  border-bottom: 2px solid #111827;
  transform: rotate(45deg);
}
